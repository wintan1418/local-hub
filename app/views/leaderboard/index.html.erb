<div class="min-h-screen bg-cream">

  <%# Header section %>
  <section class="bg-cream border-b border-line">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="max-w-3xl">
        <div class="eyebrow mb-4">leaderboard</div>
        <h1 class="display text-ink leading-[0.95] tracking-[-0.035em]" style="font-size: clamp(40px, 7vw, 80px);">
          Top pros, ranked <em class="italic-wonk" style="color: #1f4d3a;">honestly</em>.
        </h1>
        <p class="mt-4 text-[16px] sm:text-[19px] leading-[1.55] text-ink-2 max-w-xl">
          The highest-rated, most-booked, most-reviewed providers in your area.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <%# Filters %>
    <div class="bg-cream-elevated border border-line rounded-xl p-4 sm:p-5 mb-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="flex flex-wrap gap-1.5">
          <% [
            { key: "rating", label: "Top rated" },
            { key: "bookings", label: "Most booked" },
            { key: "revenue", label: "Top earning" },
            { key: "recent", label: "Most active" }
          ].each do |tab| %>
            <%= link_to leaderboard_index_path(filter: tab[:key], category_id: params[:category_id]),
                class: "inline-flex items-center px-4 py-2 rounded-pill text-[13px] font-medium transition-colors #{@filter == tab[:key] ? 'bg-ink text-cream' : 'bg-cream-sunken/50 text-ink-2 hover:bg-cream-sunken'}" do %>
              <%= tab[:label] %>
            <% end %>
          <% end %>
        </div>

        <div class="flex items-center gap-2">
          <%= form_with url: leaderboard_index_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
            <%= form.hidden_field :filter, value: @filter %>
            <%= form.collection_select :category_id, @categories, :id, :name,
                { prompt: "All categories", selected: @category_id },
                { class: "px-4 py-2 rounded-pill border border-line text-[13px] focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated", onchange: "this.form.submit();" } %>
          <% end %>
          <% if @selected_category %>
            <%= link_to leaderboard_index_path(filter: @filter), class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>
              clear
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Provider list %>
    <div class="space-y-2">
      <% @providers.each_with_index do |provider, index| %>
        <%= link_to leaderboard_path(provider), class: "group block bg-cream-elevated rounded-xl border border-line hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200 p-5" do %>
          <div class="flex items-center gap-4 sm:gap-5">
            <%# Rank %>
            <div class="flex-shrink-0 w-12 text-center">
              <% if index < 3 %>
                <% trophy_color = [ "#d96a3a", "#766853", "#b8551c" ][index] %>
                <div class="display text-[28px] sm:text-[36px] leading-none" style="color: <%= trophy_color %>; font-style: italic; font-variation-settings: 'SOFT' 100, 'WONK' 1;"><%= index + 1 %></div>
              <% else %>
                <div class="display text-[24px] text-ink-3 leading-none"><%= index + 1 %></div>
              <% end %>
            </div>

            <%# Avatar %>
            <% if provider.profile_picture.attached? %>
              <%= image_tag provider.profile_picture, class: "h-14 w-14 rounded-full object-cover border border-line flex-shrink-0" %>
            <% else %>
              <img src="https://i.pravatar.cc/120?u=provider<%= provider.id %>" class="h-14 w-14 rounded-full object-cover border border-line flex-shrink-0" alt="<%= provider.display_name %>">
            <% end %>

            <%# Info %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <div class="display text-[18px] sm:text-[20px] text-ink leading-[1.15] tracking-[-0.01em] truncate"><%= provider.business_name.presence || provider.full_name %></div>
                <% badge = provider.provider_badge %>
                <% if badge && badge[:name] != "New" %>
                  <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-cream-sunken text-ink-2">
                    <%= badge[:name] %>
                  </span>
                <% end %>
                <% if provider.verified? %>
                  <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-forest-soft text-forest">
                    <i class="fas fa-check text-[8px] mr-0.5"></i>verified
                  </span>
                <% end %>
              </div>

              <% if provider.bio.present? %>
                <p class="text-[12px] text-ink-3 mb-2 line-clamp-1"><%= provider.bio %></p>
              <% end %>

              <%# Stats row %>
              <div class="flex flex-wrap gap-x-5 gap-y-1 mt-1 font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3">
                <div class="flex items-center gap-1.5"><i class="fas fa-star text-amber-500 text-[10px]"></i><span class="font-semibold text-ink"><%= provider.respond_to?(:avg_rating) ? (provider.avg_rating&.round(1) || 0) : provider.average_rating %></span> rating</div>
                <div class="flex items-center gap-1.5"><i class="fas fa-check-circle text-forest text-[10px]"></i><span class="font-semibold text-ink"><%= provider.respond_to?(:completed_count) ? provider.completed_count : provider.total_completed_bookings %></span> done</div>
                <div class="flex items-center gap-1.5"><i class="fas fa-comment text-ink-3 text-[10px]"></i><span class="font-semibold text-ink"><%= provider.total_reviews %></span> reviews</div>
                <% if @filter == 'revenue' && provider.respond_to?(:total_revenue) %>
                  <div class="flex items-center gap-1.5"><i class="fas fa-dollar-sign text-forest text-[10px]"></i><span class="font-semibold text-ink">$<%= number_with_delimiter(provider.total_revenue.to_i) %></span> earned</div>
                <% else %>
                  <div class="flex items-center gap-1.5"><i class="fas fa-chart-line text-ink-3 text-[10px]"></i><span class="font-semibold text-ink"><%= provider.completion_rate %>%</span> success</div>
                <% end %>
              </div>
            </div>

            <%# Arrow %>
            <div class="flex-shrink-0 hidden sm:block">
              <div class="w-9 h-9 rounded-full border border-line group-hover:bg-ink group-hover:border-ink flex items-center justify-center transition-colors">
                <i class="fas fa-chevron-right text-ink-3 group-hover:text-cream text-[10px] transition-colors"></i>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <% if @providers.empty? %>
        <%= render "shared/empty_state",
            icon: "fa-trophy",
            title: "No providers found",
            message: "Try adjusting your filters or check back later." %>
      <% end %>
    </div>
  </div>
</div>
