<div class="min-h-screen bg-gray-50">
  <%# Provider Header %>
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%# Back button %>
      <div class="mb-6">
        <%= link_to leaderboard_index_path, class: "inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
          <i class="fas fa-arrow-left text-xs"></i>Back to Leaderboard
        <% end %>
      </div>

      <div class="flex flex-col sm:flex-row items-start gap-6">
        <%# Avatar %>
        <div class="flex-shrink-0">
          <% if @provider.profile_picture.attached? %>
            <%= image_tag @provider.profile_picture, class: "h-20 w-20 rounded-2xl object-cover" %>
          <% else %>
            <div class="h-20 w-20 rounded-2xl bg-orange-100 flex items-center justify-center text-2xl font-bold text-orange-600">
              <%= @provider.display_name.first.upcase %>
            </div>
          <% end %>
        </div>

        <%# Info %>
        <div class="flex-grow">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900"><%= @provider.business_name || @provider.full_name %></h1>
            <% badge = @provider.provider_badge %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= badge[:color] %>-50 text-<%= badge[:color] %>-700">
              <i class="<%= badge[:icon] %> mr-1"></i><%= badge[:name] %> Provider
            </span>
            <% if @provider.verified? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                <i class="fas fa-check-circle mr-1"></i>Verified
              </span>
            <% end %>
          </div>

          <% if @provider.bio.present? %>
            <p class="text-gray-500 mb-4 max-w-2xl"><%= @provider.bio %></p>
          <% end %>

          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
            <% if @provider.complete_address.present? %>
              <div class="flex items-center gap-1.5">
                <i class="fas fa-map-marker-alt text-gray-400 text-xs"></i>
                <span><%= @provider.complete_address %></span>
              </div>
            <% end %>
            <% if @provider.years_experience.present? %>
              <div class="flex items-center gap-1.5">
                <i class="fas fa-briefcase text-gray-400 text-xs"></i>
                <span><%= @provider.years_experience %> years experience</span>
              </div>
            <% end %>
            <div class="flex items-center gap-1.5">
              <i class="fas fa-calendar text-gray-400 text-xs"></i>
              <span>Member since <%= @provider.created_at.strftime("%B %Y") %></span>
            </div>
          </div>
        </div>

        <%# Action button %>
        <% if user_signed_in? && current_user.customer? && current_user != @provider %>
          <div class="flex-shrink-0">
            <%= form_with url: conversations_path, method: :post, local: true do |form| %>
              <%= form.hidden_field :user_id, value: @provider.id %>
              <button type="submit" class="inline-flex items-center bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-semibold text-sm transition-colors shadow-sm">
                <i class="fas fa-comments mr-2"></i>Start Conversation
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <%# Main Content %>
      <div class="lg:col-span-2 space-y-8">
        <%# Stats %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-6">Performance</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900 mb-1"><%= @stats[:avg_rating] %></div>
              <div class="flex justify-center mb-2">
                <% 5.times do |i| %>
                  <i class="fas fa-star text-sm <%= i < @stats[:avg_rating].round ? 'text-amber-400' : 'text-gray-200' %>"></i>
                <% end %>
              </div>
              <p class="text-xs text-gray-500">Avg. Rating</p>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900 mb-1"><%= @stats[:completed_bookings] %></div>
              <div class="flex justify-center mb-2"><i class="fas fa-check-circle text-green-500"></i></div>
              <p class="text-xs text-gray-500">Jobs Done</p>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900 mb-1"><%= @stats[:total_reviews] %></div>
              <div class="flex justify-center mb-2"><i class="fas fa-comment text-blue-500"></i></div>
              <p class="text-xs text-gray-500">Reviews</p>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900 mb-1"><%= @stats[:completion_rate] %>%</div>
              <div class="flex justify-center mb-2"><i class="fas fa-chart-line text-orange-500"></i></div>
              <p class="text-xs text-gray-500">Success Rate</p>
            </div>
          </div>
        </div>

        <%# Services %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-6">Services Offered</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% @services.each do |service| %>
              <%= link_to service_path(service), class: "group block rounded-xl border border-gray-100 p-4 hover:shadow-md hover:border-gray-200 transition-all" do %>
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-semibold text-gray-900 group-hover:text-orange-600 transition-colors"><%= service.title %></h3>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700 flex-shrink-0 ml-2">
                    <%= service.category.name %>
                  </span>
                </div>
                <p class="text-sm text-gray-500 mb-3 line-clamp-2"><%= service.description %></p>
                <div class="flex items-center justify-between">
                  <span class="text-lg font-bold text-gray-900">
                    $<%= number_with_precision(service.base_price, precision: 0) %>
                    <span class="text-xs text-gray-500 font-normal">/<%= service.price_type %></span>
                  </span>
                  <span class="text-sm text-orange-500 font-medium opacity-0 group-hover:opacity-100 transition-opacity">
                    View <i class="fas fa-arrow-right ml-1 text-xs"></i>
                  </span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Reviews %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-6">Recent Reviews</h2>
          <% if @recent_reviews.any? %>
            <div class="space-y-6">
              <% @recent_reviews.each do |review| %>
                <div class="border-b border-gray-50 pb-6 last:border-b-0 last:pb-0">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="flex">
                      <% 5.times do |i| %>
                        <i class="fas fa-star text-sm <%= i < review.rating ? 'text-amber-400' : 'text-gray-200' %>"></i>
                      <% end %>
                    </div>
                    <span class="text-sm font-medium text-gray-700"><%= review.booking.customer.first_name %></span>
                    <span class="text-xs text-gray-400"><%= review.created_at.strftime("%b %d, %Y") %></span>
                  </div>
                  <p class="text-gray-700 text-sm leading-relaxed"><%= review.comment %></p>
                  <p class="text-xs text-gray-400 mt-2">
                    <i class="fas fa-tag mr-1"></i><%= review.booking.service.title %>
                  </p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-10">
              <div class="w-12 h-12 mx-auto mb-3 bg-gray-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-comment text-gray-400"></i>
              </div>
              <p class="text-gray-500 text-sm">No reviews yet</p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Sidebar %>
      <div class="space-y-6">
        <%# Portfolio %>
        <% if @provider.portfolio_images.any? %>
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Portfolio</h3>
            <div class="grid grid-cols-2 gap-3">
              <% @provider.portfolio_images.limit(6).each do |image| %>
                <div class="aspect-square rounded-xl overflow-hidden">
                  <%= image_tag image, class: "object-cover w-full h-full hover:scale-105 transition-transform duration-300" %>
                </div>
              <% end %>
            </div>
            <% if @provider.portfolio_images.count > 6 %>
              <p class="text-sm text-gray-400 mt-3 text-center">+<%= @provider.portfolio_images.count - 6 %> more photos</p>
            <% end %>
          </div>
        <% end %>

        <%# Contact %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Contact</h3>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-envelope text-gray-400 text-xs"></i>
              </div>
              <span class="text-sm text-gray-600">Contact via platform</span>
            </div>
            <% if @provider.complete_address.present? %>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-map-marker-alt text-gray-400 text-xs"></i>
                </div>
                <span class="text-sm text-gray-600"><%= @provider.complete_address %></span>
              </div>
            <% end %>
            <% if @provider.verified? %>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-shield-alt text-green-500 text-xs"></i>
                </div>
                <span class="text-sm text-green-600 font-medium">Background verified</span>
              </div>
            <% end %>
          </div>
        </div>

        <%# Quick Stats %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Stats</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-500">Total Revenue</span>
              <span class="text-sm font-semibold text-gray-900">$<%= number_with_delimiter(@stats[:total_revenue].to_i) %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-500">Member Since</span>
              <span class="text-sm font-semibold text-gray-900"><%= @provider.created_at.strftime("%B %Y") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
