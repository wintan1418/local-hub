<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

    <%# Back %>
    <div class="mb-6">
      <%= link_to leaderboard_index_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>Back to leaderboard
      <% end %>
    </div>

    <%# Header %>
    <div class="mb-10">
      <div class="flex flex-col sm:flex-row items-start gap-5">
        <% if @provider.profile_picture.attached? %>
          <%= image_tag @provider.profile_picture, class: "h-20 w-20 rounded-full object-cover border border-line flex-shrink-0" %>
        <% else %>
          <img src="https://i.pravatar.cc/240?u=provider<%= @provider.id %>" class="h-20 w-20 rounded-full object-cover border border-line flex-shrink-0">
        <% end %>

        <div class="flex-grow min-w-0">
          <div class="eyebrow mb-2"><%= @services.first&.category&.name || "leaderboard" %></div>
          <h1 class="display text-ink leading-[1] tracking-[-0.02em]" style="font-size: clamp(28px, 4.5vw, 44px);"><%= @provider.business_name.presence || @provider.full_name %></h1>

          <div class="mt-3 flex flex-wrap items-center gap-2">
            <% badge = @provider.provider_badge %>
            <% if badge && badge[:name] != "New" %>
              <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2.5 py-0.5 rounded-pill bg-cream-sunken text-ink-2"><%= badge[:name] %></span>
            <% end %>
            <% if @provider.verified? %>
              <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2.5 py-0.5 rounded-pill bg-forest-soft text-forest"><i class="fas fa-check text-[8px] mr-0.5"></i>verified</span>
            <% end %>
          </div>

          <% if @provider.bio.present? %>
            <p class="mt-4 text-[15px] text-ink-2 leading-[1.65] max-w-2xl"><%= @provider.bio %></p>
          <% end %>

          <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3">
            <% if @provider.complete_address.present? %>
              <div class="flex items-center gap-1.5"><i class="fas fa-map-marker-alt text-[10px]"></i><%= @provider.complete_address %></div>
            <% end %>
            <% if @provider.years_experience.present? %>
              <div class="flex items-center gap-1.5"><i class="fas fa-briefcase text-[10px]"></i><%= @provider.years_experience %> yrs exp</div>
            <% end %>
            <div class="flex items-center gap-1.5"><i class="fas fa-calendar text-[10px]"></i>since <%= @provider.created_at.strftime("%b %Y") %></div>
          </div>
        </div>

        <% if user_signed_in? && current_user.customer? && current_user != @provider %>
          <%= form_with url: conversations_path, method: :post, local: true, class: "flex-shrink-0" do |form| %>
            <%= form.hidden_field :user_id, value: @provider.id %>
            <button type="submit" class="inline-flex items-center gap-2 bg-ink hover:bg-ink-2 text-cream px-5 py-2.5 rounded-pill text-sm font-semibold transition-colors active:translate-y-px">
              <i class="fas fa-comments text-xs"></i>Message
            </button>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8">

      <%# Main %>
      <div class="space-y-6">

        <%# Performance stats %>
        <div class="bg-cream-elevated border border-line rounded-xl p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">performance</div>
          <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">By the numbers</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-line">
            <% [
              { value: @stats[:avg_rating], label: "Avg rating", suffix: "★" },
              { value: @stats[:completed_bookings], label: "Jobs done" },
              { value: @stats[:total_reviews], label: "Reviews" },
              { value: "#{@stats[:completion_rate]}%", label: "Success" }
            ].each_with_index do |s, i| %>
              <div class="<%= 'md:pl-5' if i > 0 %> <%= 'md:pr-5' if i < 3 %> py-3 md:py-1">
                <div class="display text-[28px] sm:text-[32px] text-ink leading-none">
                  <%= s[:value] %><% if s[:suffix] %><span class="text-amber-500 text-[18px]"><%= s[:suffix] %></span><% end %>
                </div>
                <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= s[:label] %></div>
              </div>
            <% end %>
          </div>
        </div>

        <%# Services %>
        <div class="bg-cream-elevated border border-line rounded-xl p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">services</div>
          <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">What I <em class="italic-wonk" style="color: #1f4d3a;">offer</em></h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <% @services.each do |service| %>
              <%= link_to service_path(service), class: "group block rounded-lg border border-line p-4 hover:bg-cream-sunken/40 transition-colors" do %>
                <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5"><%= service.category.name %></div>
                <div class="display text-[16px] text-ink leading-[1.15] group-hover:underline underline-offset-2"><%= service.title %></div>
                <p class="text-[12px] text-ink-3 mt-1 line-clamp-2"><%= service.description %></p>
                <div class="mt-3 flex items-center justify-between">
                  <div class="display text-[18px] text-ink leading-none">$<%= number_with_precision(service.base_price, precision: 0) %><span class="font-sans text-[10px] text-ink-3 font-normal">/<%= service.price_type %></span></div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Reviews %>
        <div class="bg-cream-elevated border border-line rounded-xl p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recent reviews</div>
          <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">What customers say</h2>
          <% if @recent_reviews.any? %>
            <div class="space-y-1">
              <% @recent_reviews.each do |review| %>
                <div class="border-t border-line py-5 first:border-t-0 first:pt-0">
                  <div class="flex items-center gap-3 mb-2">
                    <div class="flex gap-0.5">
                      <% 5.times do |i| %><i class="fas fa-star text-[11px] <%= i < review.rating ? 'text-amber-500' : 'text-line' %>"></i><% end %>
                    </div>
                    <span class="text-[13px] font-semibold text-ink"><%= review.booking.customer.first_name %></span>
                    <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3"><%= review.created_at.strftime("%b %-d") %></span>
                  </div>
                  <p class="text-[14px] text-ink-2 leading-[1.6]"><%= review.comment %></p>
                  <p class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-2"><i class="fas fa-tag mr-1"></i><%= review.booking.service.title %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-[13px] text-ink-3 text-center py-6">No reviews yet.</p>
          <% end %>
        </div>
      </div>

      <%# Sidebar %>
      <aside class="space-y-4">
        <% if @provider.portfolio_images.any? %>
          <div class="bg-cream-elevated border border-line rounded-xl p-5">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">portfolio</div>
            <div class="grid grid-cols-2 gap-2">
              <% @provider.portfolio_images.limit(6).each do |image| %>
                <div class="aspect-square rounded-lg overflow-hidden border border-line">
                  <%= image_tag image, class: "object-cover w-full h-full hover:scale-105 transition-transform duration-300" %>
                </div>
              <% end %>
            </div>
            <% if @provider.portfolio_images.count > 6 %>
              <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-3 text-center">+<%= @provider.portfolio_images.count - 6 %> more</p>
            <% end %>
          </div>
        <% end %>

        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">contact</div>
          <div class="space-y-3 text-[13px]">
            <div class="flex items-center gap-3">
              <i class="fas fa-envelope text-ink-3 text-[12px] w-4 text-center"></i>
              <span class="text-ink-2">Via platform</span>
            </div>
            <% if @provider.complete_address.present? %>
              <div class="flex items-center gap-3">
                <i class="fas fa-map-marker-alt text-ink-3 text-[12px] w-4 text-center"></i>
                <span class="text-ink-2"><%= @provider.complete_address %></span>
              </div>
            <% end %>
            <% if @provider.verified? %>
              <div class="flex items-center gap-3">
                <i class="fas fa-shield-alt text-forest text-[12px] w-4 text-center"></i>
                <span class="text-forest font-semibold">Background verified</span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">at a glance</div>
          <div class="space-y-2.5">
            <div class="flex justify-between items-center text-[13px]">
              <span class="text-ink-2">Total revenue</span>
              <span class="font-semibold text-ink">$<%= number_with_delimiter(@stats[:total_revenue].to_i) %></span>
            </div>
            <div class="flex justify-between items-center text-[13px]">
              <span class="text-ink-2">Member since</span>
              <span class="font-mono text-[12px] text-ink"><%= @provider.created_at.strftime("%b %Y") %></span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</div>
