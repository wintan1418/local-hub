<% input_class = "w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
<% label_class = "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>

<div class="min-h-screen flex bg-cream">

  <%# ===== LEFT: editorial panel ===== %>
  <div class="hidden lg:flex lg:w-5/12 relative items-center justify-center overflow-hidden border-r border-line" style="background-color: #1d1813;">
    <div class="relative z-10 max-w-sm px-12">
      <span class="brand-mark brand-mark--on-dark mb-8 inline-block"></span>
      <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-4">welcome</div>
      <h2 class="display text-cream leading-[1] tracking-[-0.02em]" style="font-size: clamp(36px, 4vw, 48px);">
        Almost <em class="italic-wonk" style="color: #d96a3a;">there</em>.
      </h2>
      <p class="mt-4 text-[14px] leading-[1.55] text-cream/65">Complete your profile to unlock the full experience.</p>

      <div class="mt-10 space-y-3">
        <% items = [ "Personalized recommendations", "Book services in your area", "Direct messaging with providers" ] %>
        <% items << "List your services & get bookings" if @user.provider? %>
        <% items.each do |item| %>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full border border-cream/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fas fa-check text-cream text-[10px]"></i>
            </div>
            <span class="text-[13px] text-cream/75 leading-[1.5]"><%= item %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== RIGHT: form ===== %>
  <div class="flex-1 flex items-start justify-center px-4 sm:px-6 lg:px-8 py-12 bg-cream overflow-y-auto">
    <div class="w-full max-w-lg">
      <div class="text-center mb-8 lg:hidden">
        <a href="<%= root_path %>" class="inline-flex items-center gap-2.5">
          <span class="brand-mark"></span>
          <span class="font-display text-[22px] font-medium tracking-tight text-ink">radius</span>
        </a>
      </div>

      <div class="bg-cream-elevated border border-line rounded-xl p-7 sm:p-9">
        <div class="mb-6">
          <div class="eyebrow mb-3">step 1 of 1</div>
          <h1 class="display text-[28px] sm:text-[32px] text-ink leading-[1.05] tracking-[-0.02em]">Complete your <em class="italic-wonk" style="color: #1f4d3a;">profile</em>.</h1>
          <p class="mt-2 text-[13px] text-ink-2">
            <%= @user.provider? ? "Set up your business profile to start getting bookings." : "Tell us a bit about yourself to get started." %>
          </p>
        </div>

        <%# Progress bar %>
        <div class="flex items-center gap-3 mb-7 p-3 rounded-xl bg-cream-sunken/40 border border-line">
          <div class="w-7 h-7 rounded-full bg-ink text-cream flex items-center justify-center font-mono text-[11px] font-semibold">1</div>
          <div class="flex-1 h-1.5 rounded-pill bg-line overflow-hidden">
            <div class="h-full rounded-pill bg-ink w-full"></div>
          </div>
          <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">step 1 / 1</span>
        </div>

        <%= form_with(model: @user, url: onboarding_update_profile_path, method: :patch, local: true, class: "space-y-5") do |form| %>
          <% if @user.errors.any? %>
            <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-rose-700 mb-1">please fix:</div>
              <ul class="space-y-0.5 ml-5">
                <% @user.errors.full_messages.each do |message| %><li class="text-[13px] text-rose-700 list-disc"><%= message %></li><% end %>
              </ul>
            </div>
          <% end %>

          <%# Profile Picture %>
          <div>
            <label class="<%= label_class %>">Profile picture <span class="normal-case tracking-normal text-ink-4">(optional)</span></label>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                <i class="fas fa-camera text-ink-3 text-[14px]"></i>
              </div>
              <%= form.file_field :profile_picture, class: "text-[12px] file:mr-3 file:px-4 file:py-2 file:rounded-pill file:border-0 file:bg-cream-sunken file:text-ink-2 file:text-[11px] file:font-semibold hover:file:bg-line cursor-pointer" %>
            </div>
          </div>

          <%# Name %>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="<%= label_class %>">First name</label>
              <%= form.text_field :first_name, required: true, placeholder: "John", class: input_class %>
            </div>
            <div>
              <label class="<%= label_class %>">Last name</label>
              <%= form.text_field :last_name, required: true, placeholder: "Doe", class: input_class %>
            </div>
          </div>

          <%# Phone %>
          <div>
            <label class="<%= label_class %>">Phone</label>
            <%= form.text_field :phone, required: true, placeholder: "1234567890", class: input_class %>
            <p class="text-[11px] text-ink-3 mt-1.5">10–15 digits</p>
          </div>

          <%# Provider-only %>
          <% if @user.provider? %>
            <div class="pt-5 border-t border-line">
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-4">business</div>

              <div class="space-y-4">
                <div>
                  <label class="<%= label_class %>">Business name</label>
                  <%= form.text_field :business_name, required: true, placeholder: "Your Business Name", class: input_class %>
                </div>

                <div>
                  <label class="<%= label_class %>">About your services</label>
                  <%= form.text_area :bio, rows: 3, placeholder: "Tell customers what you offer…",
                      class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
                </div>

                <div>
                  <label class="<%= label_class %>">Business address</label>
                  <%= form.text_field :address, required: true, placeholder: "123 Main Street", class: input_class %>
                </div>

                <div class="grid grid-cols-3 gap-3">
                  <div>
                    <label class="<%= label_class %>">City</label>
                    <%= form.text_field :city, required: true, placeholder: "City", class: input_class %>
                  </div>
                  <div>
                    <label class="<%= label_class %>">State</label>
                    <%= form.text_field :state, required: true, placeholder: "State", class: input_class %>
                  </div>
                  <div>
                    <label class="<%= label_class %>">ZIP</label>
                    <%= form.text_field :zip_code, required: true, placeholder: "12345", class: input_class %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <button type="submit" class="w-full bg-ink hover:bg-ink-2 text-cream py-3.5 rounded-pill font-semibold text-sm transition-colors active:translate-y-px">
            Complete profile
          </button>
        <% end %>
      </div>
    </div>
  </div>
</div>
