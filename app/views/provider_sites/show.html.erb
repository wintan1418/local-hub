<% theme = @provider.site_theme.to_s %>

<%# ============= HERO ============= %>
<% if theme == "bold" %>
  <section class="relative bg-slate-950 text-white overflow-hidden">
    <% if @provider.site_cover_photo.attached? %>
      <div class="absolute inset-0">
        <%= image_tag @provider.site_cover_photo, class: "w-full h-full object-cover opacity-30" %>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/70 to-slate-950/40"></div>
      </div>
    <% end %>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight"><%= @provider.business_name || @provider.display_name %></h1>
      <p class="mt-5 text-lg sm:text-xl text-slate-300 max-w-2xl"><%= @provider.site_tagline.presence || "Trusted local services" %></p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="#services" class="brand-bg hover:opacity-90 text-white px-7 py-3.5 rounded-xl font-bold text-sm transition-all">Book Now</a>
        <a href="#contact" class="text-white border-2 border-white/30 hover:border-white/60 px-7 py-3.5 rounded-xl font-bold text-sm transition-all">Get in Touch</a>
      </div>
    </div>
  </section>
<% elsif theme == "classic" %>
  <section class="bg-white border-b border-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 text-center">
      <h1 class="text-5xl sm:text-6xl font-black text-slate-900 tracking-tight" style="font-family: Georgia, serif;"><%= @provider.business_name || @provider.display_name %></h1>
      <p class="mt-5 text-lg text-slate-500 max-w-2xl mx-auto"><%= @provider.site_tagline.presence || "Trusted local services" %></p>
      <div class="mt-10 flex justify-center gap-3">
        <a href="#services" class="brand-bg hover:opacity-90 text-white px-7 py-3.5 rounded-xl font-bold text-sm transition-all">View Services</a>
      </div>
    </div>
  </section>
<% else # modern %>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 to-white"></div>
    <% if @provider.site_cover_photo.attached? %>
      <div class="absolute inset-0">
        <%= image_tag @provider.site_cover_photo, class: "w-full h-full object-cover" %>
        <div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white"></div>
      </div>
    <% end %>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white shadow-sm border border-slate-100 mb-6">
          <div class="w-2 h-2 rounded-full brand-bg"></div>
          <span class="text-xs font-bold text-slate-700 uppercase tracking-wider">Verified Pro</span>
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-slate-900 tracking-tight leading-[1.05]"><%= @provider.business_name || @provider.display_name %></h1>
        <p class="mt-6 text-lg sm:text-xl text-slate-500 max-w-2xl"><%= @provider.site_tagline.presence || "Trusted local services" %></p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="#services" class="brand-bg hover:opacity-90 text-white px-7 py-3.5 rounded-xl font-bold text-sm transition-all shadow-lg" style="box-shadow: 0 10px 30px -10px <%= @brand_color %>80">Book Now</a>
          <a href="#contact" class="bg-white hover:bg-slate-50 text-slate-900 border border-slate-200 px-7 py-3.5 rounded-xl font-bold text-sm transition-all">Contact</a>
        </div>
      </div>
    </div>
  </section>
<% end %>

<%# ============= STATS BAR ============= %>
<section class="bg-white border-y border-slate-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="text-2xl sm:text-3xl font-black text-slate-900"><%= @provider.average_rating %></div>
        <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Rating</div>
      </div>
      <div class="border-x border-slate-100">
        <div class="text-2xl sm:text-3xl font-black text-slate-900"><%= @provider.total_completed_bookings %>+</div>
        <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Jobs Done</div>
      </div>
      <div>
        <div class="text-2xl sm:text-3xl font-black text-slate-900"><%= @provider.years_experience || 1 %>y</div>
        <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Experience</div>
      </div>
    </div>
  </div>
</section>

<%# ============= SERVICES ============= %>
<% if @services.any? %>
  <section id="services" class="bg-slate-50/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mb-2">Services</h2>
      <p class="text-slate-500 mb-10">Book any service directly. Secure checkout via Radius.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @services.each do |service| %>
          <a href="<%= service_path(service) %>" class="group block bg-white rounded-xl border border-slate-100 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
            <div class="text-xs font-bold brand-text uppercase tracking-wider mb-2"><%= service.category.name %></div>
            <h3 class="text-base font-bold text-slate-900 mb-2"><%= service.title %></h3>
            <p class="text-xs text-slate-500 line-clamp-2 mb-4"><%= service.description %></p>
            <div class="flex items-center justify-between pt-3 border-t border-slate-50">
              <span class="text-lg font-black text-slate-900">$<%= number_with_precision(service.base_price, precision: 0) %></span>
              <span class="text-xs font-semibold brand-text">Book →</span>
            </div>
          </a>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ============= ABOUT ============= %>
<% if @provider.site_about.present? || @provider.bio.present? %>
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-3xl font-black text-slate-900 mb-6">About</h2>
      <p class="text-slate-600 leading-relaxed text-lg"><%= @provider.site_about.presence || @provider.bio %></p>
    </div>
  </section>
<% end %>

<%# ============= REVIEWS ============= %>
<% if @reviews.any? %>
  <section class="bg-slate-50/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-3xl font-black text-slate-900 mb-10">What Customers Say</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @reviews.each do |review| %>
          <div class="bg-white rounded-xl border border-slate-100 p-6">
            <div class="flex gap-0.5 mb-3">
              <% 5.times do |i| %><i class="fas fa-star text-xs <%= i < review.rating ? 'text-amber-400' : 'text-slate-200' %>"></i><% end %>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">"<%= review.comment %>"</p>
            <div class="text-xs font-bold text-slate-900"><%= review.booking.customer.display_name %></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ============= FAQ ============= %>
<% if @faqs.any? %>
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-3xl font-black text-slate-900 mb-8">Common Questions</h2>
      <div class="space-y-3">
        <% @faqs.each do |faq| %>
          <details class="group bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
            <summary class="cursor-pointer flex items-center justify-between px-6 py-5 text-left">
              <span class="text-sm font-bold text-slate-900 pr-4"><%= faq.question %></span>
              <i class="fas fa-chevron-down text-slate-400 text-xs group-open:rotate-180 transition-transform"></i>
            </summary>
            <div class="px-6 pb-5 text-sm text-slate-500 leading-relaxed"><%= faq.answer %></div>
          </details>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ============= CONTACT ============= %>
<section id="contact" class="brand-bg text-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h2 class="text-3xl sm:text-4xl font-black">Ready to book?</h2>
    <p class="mt-3 opacity-90">Pick a service above or get in touch.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <% if @services.any? %>
        <a href="<%= service_path(@services.first) %>" class="bg-white text-slate-900 hover:bg-slate-100 px-7 py-3.5 rounded-xl font-bold text-sm transition-all">Book a Service</a>
      <% end %>
      <% if user_signed_in? && current_user.customer? %>
        <%= form_with url: conversations_path, method: :post, local: true, class: "inline-block" do |f| %>
          <%= f.hidden_field :user_id, value: @provider.id %>
          <button type="submit" class="bg-white/10 border-2 border-white/30 hover:bg-white/20 text-white px-7 py-3.5 rounded-xl font-bold text-sm transition-all cursor-pointer">Message Us</button>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
