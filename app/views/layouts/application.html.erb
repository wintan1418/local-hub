            var wrap = document.getElementById('wintech-wrap');
            var card = document.getElementById('wintech-card');
            if (!wrap || !card || card.classList.contains('hidden')) return;
            if (!wrap.contains(e.target)) card.classList.add('hidden');
          });
          document.addEventListener('keydown', function(e) {
