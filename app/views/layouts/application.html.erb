<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Primary Meta Tags -->
    <title><%= content_for?(:page_title) ? yield(:page_title) : 'Radius - Find Trusted Local Service Providers' %></title>
    <meta name="description" content="<%= content_for?(:page_description) ? yield(:page_description) : 'Connect with trusted local service providers for all your needs. Book appointments, read reviews, and get the best service in your area.' %>">

    <!-- Canonical URL -->
    <link rel="canonical" href="<%= request.original_url %>" />

    <!-- CSRF and CSP -->
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="theme-color" content="#f97316">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Radius">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/service-worker.js').catch(function(err) {
            console.warn('SW registration failed:', err);
          });
        });
      }
    </script>

    <!-- CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            maxWidth: {
              '7xl': '1280px',
            },
            colors: {
              // Champagne/sand — warmer, more distinctive than generic cream
              cream: '#f3ead8',
              'cream-elevated': '#fdf8ed',
              'cream-sunken': '#e6d8bf',
              ink: '#1d1813',
              'ink-2': '#3d3327',
              'ink-3': '#766853',
              'ink-4': '#a89779',
              line: '#ddc9a8',
              'line-strong': '#c4ab85',
              forest: '#1f4d3a',
              'forest-soft': '#dce5d4',
              terracotta: '#d96a3a',
              clay: '#b8551c',
            },
            fontFamily: {
              display: ['Fraunces', 'ui-serif', 'Georgia', 'serif'],
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
              mono: ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
            },
            borderRadius: {
              'pill': '999px',
            },
            boxShadow: {
              'card': '0 1px 2px rgba(26,26,23,0.04), 0 1px 1px rgba(26,26,23,0.03)',
              'card-md': '0 4px 16px rgba(26,26,23,0.06), 0 1px 2px rgba(26,26,23,0.04)',
              'card-lg': '0 12px 40px rgba(26,26,23,0.08), 0 2px 6px rgba(26,26,23,0.04)',
              'card-hover': '0 10px 15px -3px rgb(0 0 0 / 0.08), 0 4px 6px -4px rgb(0 0 0 / 0.04)',
            },
          }
        }
      }
    </script>
    <style>
      /* Editorial display typography — Fraunces with WONK + SOFT axes */
      .display {
        font-family: 'Fraunces', ui-serif, Georgia, serif;
        font-weight: 400;
        letter-spacing: -0.02em;
        line-height: 1.05;
        font-variation-settings: 'SOFT' 30, 'WONK' 0;
      }
      .display em, .italic-wonk {
        font-style: italic;
        font-variation-settings: 'SOFT' 100, 'WONK' 1;
        font-feature-settings: 'ss01';
      }
      .eyebrow {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #6f6a5e;
      }
      /* Brand mark — concentric ring */
      .brand-mark {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #1f4d3a;
        position: relative;
        flex-shrink: 0;
      }
      .brand-mark::after {
        content: '';
        position: absolute;
        inset: 6px;
        border: 1.5px solid #f3ead8;
        border-radius: 50%;
      }
      .brand-mark--on-dark::after { border-color: #1d1813; }
      /* Footer version chip */
      .version-chip {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #766853;
        padding: 4px 10px;
        border: 1px solid #ddc9a8;
        border-radius: 999px;
      }
    </style>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css", rel: "stylesheet" %>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- JavaScript -->
    <%= javascript_importmap_tags %>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,30..100,0..1;1,9..144,300..900,30..100,0..1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%= yield(:head) if content_for?(:head) %>

    <script>
      function toggleMobileMenu(){var m=document.getElementById('mobile-menu'),o=document.getElementById('menu-icon-open'),c=document.getElementById('menu-icon-close');if(!m)return;if(m.classList.contains('hidden')){m.classList.remove('hidden');if(o)o.classList.add('hidden');if(c)c.classList.remove('hidden');document.body.style.overflow='hidden';}else{closeMobileMenu();}}
      function closeMobileMenu(){var m=document.getElementById('mobile-menu'),o=document.getElementById('menu-icon-open'),c=document.getElementById('menu-icon-close');if(m)m.classList.add('hidden');if(o)o.classList.remove('hidden');if(c)c.classList.add('hidden');document.body.style.overflow='';}
    </script>
  </head>

  <body class="min-h-screen font-sans antialiased text-ink bg-cream" style="font-family: 'Inter', system-ui, sans-serif;">

    <%# ========== NAVIGATION ========== %>
    <nav class="sticky top-0 z-50 border-b border-line" style="background: color-mix(in oklab, #f3ead8 88%, transparent); backdrop-filter: saturate(140%) blur(10px);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">

          <%# Left: Logo + Nav Links %>
          <div class="flex items-center gap-7">
            <%# Logo — brand mark + Fraunces wordmark %>
            <%= link_to root_path, class: "flex items-center gap-2.5 group" do %>
              <span class="brand-mark group-hover:scale-105 transition-transform"></span>
              <span class="font-display text-[22px] font-medium tracking-tight text-ink hidden sm:inline">radius</span>
            <% end %>

            <%# Desktop Nav Links %>
            <div class="hidden md:flex items-center gap-1">
              <%
                nav_links = [
                  { name: 'Home', path: root_path, active: request.path == '/' },
                  { name: 'Services', path: services_path, active: request.path.start_with?('/services') },
                  { name: 'How It Works', path: how_it_works_path, active: request.path == '/how-it-works' },
                  { name: 'About', path: about_path, active: request.path.start_with?('/about') },
                  { name: 'Contact', path: contact_path, active: request.path.start_with?('/contact') }
                ]
              %>
              <% nav_links.each do |link| %>
                <%= link_to link[:name], link[:path],
                    class: "px-3.5 py-2 rounded-lg text-sm font-medium transition-colors duration-150 #{link[:active] ? 'bg-cream-sunken text-ink' : 'text-ink-2 hover:text-ink hover:bg-cream-sunken'}" %>
              <% end %>
            </div>
          </div>

          <%# Right: Actions %>
          <div class="flex items-center gap-3">
            <% if user_signed_in? %>
              <%# Messages %>
              <%= link_to conversations_path, class: "relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-50 rounded-lg transition-colors", title: "Messages" do %>
                <i class="fas fa-comment-dots text-lg"></i>
                <% if current_user.total_unread_messages > 0 %>
                  <span class="absolute -top-0.5 -right-0.5 h-4 w-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">
                    <%= current_user.total_unread_messages > 9 ? '9+' : current_user.total_unread_messages %>
                  </span>
                <% end %>
              <% end %>

              <%# Notifications Dropdown %>
              <div class="relative">
                <button type="button" onclick="toggleNotifDropdown(event)" class="relative p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-50 rounded-lg transition-colors" title="Notifications">
                  <i class="fas fa-bell text-lg"></i>
                  <span data-notification-count class="absolute -top-0.5 -right-0.5 h-4 w-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center <%= current_user.unread_notifications_count > 0 ? '' : 'hidden' %>">
                    <%= current_user.unread_notifications_count > 9 ? '9+' : current_user.unread_notifications_count %>
                  </span>
                </button>

                <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-96 max-w-[calc(100vw-2rem)] bg-white rounded-xl shadow-2xl border border-slate-100 z-50 overflow-hidden">
                  <%# Header %>
                  <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
                    <div>
                      <div class="text-sm font-bold text-slate-900">Notifications</div>
                      <% unread = current_user.unread_notifications_count %>
                      <div class="text-xs text-slate-400"><%= unread > 0 ? "#{unread} unread" : "All caught up" %></div>
                    </div>
                    <% if current_user.unread_notifications_count > 0 %>
                      <%= button_to mark_all_as_read_notifications_path, method: :patch, class: "text-xs font-semibold text-orange-600 hover:text-orange-700 cursor-pointer" do %>
                        Mark all read
                      <% end %>
                    <% end %>
                  </div>

                  <%# List %>
                  <% recent_notifs = current_user.notifications.order(created_at: :desc).limit(8) %>
                  <% if recent_notifs.any? %>
                    <div class="max-h-96 overflow-y-auto divide-y divide-slate-50">
                      <% recent_notifs.each do |n| %>
                        <div class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors <%= n.unread? ? 'bg-orange-50/30' : '' %>">
                          <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center flex-shrink-0">
                            <i class="<%= n.icon_class %> text-xs"></i>
                          </div>
                          <div class="flex-1 min-w-0">
                            <div class="text-xs font-bold text-slate-900"><%= n.title %></div>
                            <div class="text-xs text-slate-500 line-clamp-2 mt-0.5"><%= n.message %></div>
                            <div class="text-[10px] text-slate-400 mt-1"><%= time_ago_in_words(n.created_at) %> ago</div>
                          </div>
                          <% if n.unread? %>
                            <span class="w-2 h-2 rounded-full bg-orange-500 flex-shrink-0 mt-1.5"></span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="py-10 text-center">
                      <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center mx-auto mb-2">
                        <i class="fas fa-bell-slash text-slate-300"></i>
                      </div>
                      <p class="text-xs text-slate-400">No notifications yet</p>
                    </div>
                  <% end %>

                  <%# Footer %>
                  <div class="border-t border-slate-100 px-4 py-2.5 bg-slate-50/50">
                    <%= link_to notifications_path, class: "block text-center text-xs font-semibold text-orange-600 hover:text-orange-700" do %>
                      View all notifications →
                    <% end %>
                  </div>
                </div>
              </div>

              <%# Divider %>
              <div class="hidden sm:block w-px h-6 bg-slate-200"></div>

              <%# User Dropdown %>
              <div class="relative">
                <button type="button" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-slate-50 transition-colors" onclick="toggleDropdown()" aria-haspopup="true">
                  <div class="h-8 w-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center text-white font-semibold text-sm shadow-sm">
                    <%= current_user.display_name.first.upcase %>
                  </div>
                  <div class="hidden sm:block text-left">
                    <div class="text-sm font-medium text-slate-900 leading-tight"><%= current_user.display_name %></div>
                    <div class="text-xs text-slate-500 leading-tight capitalize"><%= current_user.user_role %></div>
                  </div>
                  <svg class="hidden sm:block h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>

                <%# Dropdown Menu %>
                <div id="user-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-slate-100 py-1 z-50">
                  <%# User Info Header %>
                  <div class="px-4 py-3 border-b border-slate-100">
                    <p class="text-sm font-semibold text-slate-900"><%= current_user.display_name %></p>
                    <p class="text-xs text-slate-500 truncate"><%= current_user.email %></p>
                  </div>

                  <%# Navigation Links %>
                  <div class="py-1">
                    <% case current_user.user_role %>
                    <% when "customer" %>
                      <%= link_to customer_dashboard_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                        <i class="fas fa-th-large text-slate-400 w-4 text-center"></i>Dashboard
                      <% end %>
                    <% when "provider" %>
                      <%= link_to provider_dashboard_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                        <i class="fas fa-th-large text-slate-400 w-4 text-center"></i>Dashboard
                      <% end %>
                      <%= link_to new_provider_service_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                        <i class="fas fa-plus text-slate-400 w-4 text-center"></i>Add Service
                      <% end %>
                    <% when "admin" %>
                      <%= link_to admin_dashboard_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                        <i class="fas fa-gauge-high text-slate-400 w-4 text-center"></i>Admin Panel
                      <% end %>
                    <% else %>
                      <%= link_to customer_dashboard_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                        <i class="fas fa-th-large text-slate-400 w-4 text-center"></i>Dashboard
                      <% end %>
                    <% end %>

                    <%= link_to conversations_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                      <i class="fas fa-comment-dots text-slate-400 w-4 text-center"></i>
                      Messages
                      <% if current_user.total_unread_messages > 0 %>
                        <span class="ml-auto bg-red-500 text-white text-xs font-medium px-1.5 py-0.5 rounded-full"><%= current_user.total_unread_messages %></span>
                      <% end %>
                    <% end %>

                    <%= link_to notifications_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                      <i class="fas fa-bell text-slate-400 w-4 text-center"></i>
                      Notifications
                      <% if current_user.unread_notifications_count > 0 %>
                        <span class="ml-auto bg-red-500 text-white text-xs font-medium px-1.5 py-0.5 rounded-full"><%= current_user.unread_notifications_count %></span>
                      <% end %>
                    <% end %>
                  </div>

                  <div class="border-t border-slate-100"></div>

                  <div class="py-1">
                    <%= link_to settings_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
                      <i class="fas fa-cog text-slate-400 w-4 text-center"></i>Settings
                    <% end %>
                    <%= link_to destroy_user_session_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors", data: { "turbo-method": :delete } do %>
                      <i class="fas fa-sign-out-alt text-red-400 w-4 text-center"></i>Sign Out
                    <% end %>
                  </div>
                </div>
              </div>

            <% else %>
              <%# Signed-out actions %>
              <%= link_to 'Sign In', new_user_session_path,
                  class: 'hidden sm:inline-flex text-sm font-medium text-slate-600 hover:text-slate-900 px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors' %>
              <%= link_to 'Get Started', new_user_registration_path,
                  class: 'bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm' %>
            <% end %>

            <%# Mobile menu button %>
            <button type="button"
                    id="mobile-menu-btn"
                    class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-slate-500 hover:text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-orange-500 transition-colors"
                    onclick="toggleMobileMenu()">
              <span class="sr-only">Open menu</span>
              <svg id="menu-icon-open" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
              <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <%# ===== MOBILE MENU ===== %>
      <div class="md:hidden hidden" id="mobile-menu">
        <div class="bg-white border-t border-slate-100 shadow-lg">

          <%# Mobile Nav Links %>
          <div class="px-2 pt-3 pb-2 space-y-1">
            <%
              mobile_links = [
                { name: 'Home', path: root_path, icon: 'fa-house', active: request.path == '/' },
                { name: 'Services', path: services_path, icon: 'fa-grid-2', active: request.path.start_with?('/services') },
                { name: 'How It Works', path: how_it_works_path, icon: 'fa-play-circle', active: request.path == '/how-it-works' },
                { name: 'About', path: about_path, icon: 'fa-info-circle', active: request.path.start_with?('/about') },
                { name: 'Contact', path: contact_path, icon: 'fa-envelope', active: request.path.start_with?('/contact') }
              ]
            %>
            <% mobile_links.each do |link| %>
              <%= link_to link[:path],
                  class: "flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium transition-colors #{link[:active] ? 'bg-orange-50 text-orange-600' : 'text-slate-700 hover:bg-slate-50'}",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                <i class="fas <%= link[:icon] %> w-5 text-center text-sm <%= link[:active] ? 'text-orange-500' : 'text-slate-400' %>"></i>
                <%= link[:name] %>
              <% end %>
            <% end %>
          </div>

          <% if user_signed_in? %>
            <div class="border-t border-slate-100 px-2 pt-3 pb-4">
              <%# User Info %>
              <div class="flex items-center gap-3 px-3 py-2 mb-2">
                <div class="h-10 w-10 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center text-white font-semibold shadow-sm">
                  <%= current_user.display_name.first.upcase %>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900"><%= current_user.display_name %></div>
                  <div class="text-xs text-slate-500"><%= current_user.email %></div>
                </div>
              </div>

              <%# Quick Links %>
              <% dashboard_path = case current_user.user_role
                                  when "provider" then provider_dashboard_path
                                  when "admin" then admin_dashboard_path
                                  else customer_dashboard_path
                                  end %>
              <%= link_to dashboard_path,
                  class: "flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                <i class="fas fa-th-large w-5 text-center text-sm text-slate-400"></i>Dashboard
              <% end %>
              <%= link_to conversations_path,
                  class: "flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                <i class="fas fa-comment-dots w-5 text-center text-sm text-slate-400"></i>
                Messages
                <% if current_user.total_unread_messages > 0 %>
                  <span class="ml-auto bg-red-500 text-white text-xs font-medium px-1.5 py-0.5 rounded-full"><%= current_user.total_unread_messages %></span>
                <% end %>
              <% end %>
              <%= link_to settings_path,
                  class: "flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                <i class="fas fa-cog w-5 text-center text-sm text-slate-400"></i>Settings
              <% end %>

              <div class="mt-2 px-3">
                <%= link_to destroy_user_session_path,
                    class: "flex items-center justify-center gap-2 w-full py-2.5 rounded-lg text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 transition-colors",
                    data: { "turbo-method": :delete } do %>
                  <i class="fas fa-sign-out-alt text-sm"></i>Sign Out
                <% end %>
              </div>
            </div>
          <% else %>
            <div class="border-t border-slate-100 px-4 py-4 space-y-2">
              <%= link_to new_user_session_path,
                  class: "block w-full text-center py-2.5 rounded-lg text-sm font-medium text-slate-700 border border-slate-200 hover:bg-slate-50 transition-colors",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                Sign In
              <% end %>
              <%= link_to new_user_registration_path,
                  class: "block w-full text-center py-2.5 rounded-lg text-sm font-semibold text-white bg-orange-500 hover:bg-orange-600 transition-colors",
                  data: { turbo: false }, onclick: 'closeMobileMenu()' do %>
                Get Started
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <%# ========== FLASH MESSAGES ========== %>
    <% if notice %>
      <div class="fixed top-20 right-4 z-[60] max-w-sm" id="notice-flash">
        <div class="bg-white border border-green-200 rounded-xl shadow-2xl p-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
