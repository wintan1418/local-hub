<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <div style="background: linear-gradient(135deg, #f97316, #f43f5e); border-radius: 16px; padding: 32px; text-align: center; color: white;">
    <div style="font-size: 48px; margin-bottom: 8px;">🎁</div>
    <div style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.85;">A Gift From <%= @purchaser.display_name %></div>
    <div style="font-size: 48px; font-weight: 800; margin: 16px 0;">$<%= @amount %></div>
    <div style="font-size: 14px; opacity: 0.85;">Radius Gift Card</div>
  </div>

  <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; margin-top: 16px;">
    <p style="margin: 0 0 12px; font-size: 16px; color: #0f172a;">Hi <%= @recipient_name %>,</p>
    <p style="margin: 0 0 16px; font-size: 14px; line-height: 1.6; color: #475569;"><%= @purchaser.display_name %> has sent you a gift card to spend on local services through Radius — cleaning, handyman, lawn care, and more.</p>

    <% if @message.present? %>
      <div style="background: #fff7ed; border-left: 4px solid #f97316; padding: 12px 16px; margin: 16px 0; border-radius: 8px;">
        <div style="font-size: 12px; font-weight: 700; color: #ea580c; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Personal Message</div>
        <div style="font-size: 14px; color: #0f172a; line-height: 1.5;"><%= @message %></div>
      </div>
    <% end %>

    <div style="background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 12px; padding: 16px; text-align: center; margin: 16px 0;">
      <div style="font-size: 11px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Your Code</div>
      <div style="font-size: 24px; font-weight: 800; color: #0f172a; letter-spacing: 4px; font-family: monospace;"><%= @code %></div>
    </div>

    <a href="<%= @redeem_url %>" style="display: block; background: #f97316; color: #fff; text-decoration: none; text-align: center; padding: 14px; border-radius: 12px; font-weight: 700; font-size: 14px; margin-top: 16px;">Redeem your gift card</a>

    <p style="margin: 24px 0 0; font-size: 12px; color: #94a3b8; text-align: center;">Apply your code at checkout when booking any service.</p>
  </div>
</div>
