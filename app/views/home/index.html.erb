<%
  category_icons = {
    "home-cleaning" => "fa-broom", "plumbing" => "fa-wrench", "electrical" => "fa-bolt",
    "landscaping" => "fa-leaf", "moving" => "fa-truck", "handyman" => "fa-hammer",
    "painting" => "fa-paint-roller", "pet-care" => "fa-paw", "tutoring" => "fa-graduation-cap",
    "personal-training" => "fa-dumbbell"
  }
  category_colors = {
    "home-cleaning" => "sky", "plumbing" => "blue", "electrical" => "amber",
    "landscaping" => "emerald", "moving" => "violet", "handyman" => "orange",
    "painting" => "rose", "pet-care" => "teal", "tutoring" => "indigo",
    "personal-training" => "red"
  }
%>

<%# ================================================================
    HERO — Falling professionals particle rain
    ================================================================ %>
<section class="relative min-h-[100vh] flex items-center overflow-hidden bg-slate-950" id="hero">
  <%# Ambient gradient glow %>
  <div class="absolute inset-0">
    <div class="absolute top-[-20%] left-[20%] w-[500px] h-[500px] bg-orange-500/[0.07] rounded-full blur-[120px] orb-float"></div>
    <div class="absolute bottom-[-10%] right-[15%] w-[600px] h-[600px] bg-violet-500/[0.05] rounded-full blur-[140px] orb-float-reverse"></div>
    <div class="absolute top-[30%] right-[40%] w-[300px] h-[300px] bg-sky-500/[0.04] rounded-full blur-[100px] orb-float-slow"></div>
  </div>

  <%# Dot grid %>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 48px 48px;"></div>

  <%# ===== PARTICLE CANVAS — JS renders falling pro bubbles here ===== %>
  <div class="absolute inset-0 overflow-hidden pointer-events-none" id="particle-canvas"></div>

  <%# ===== CENTER CONTENT ===== %>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-16 lg:py-20">
    <div class="max-w-3xl mx-auto">

      <div class="relative text-center">
        <%# Badge %>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.06] border border-white/[0.08] mb-8 hero-reveal" style="--delay: 0s">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-white/70 text-sm font-medium"><%= number_with_delimiter(@total_providers) %> pros available now</span>
        </div>

        <%# Headline %>
        <h1 class="hero-reveal" style="--delay: 0.1s">
          <span class="block text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[1.05] tracking-tight">
            Find your pro.
          </span>
          <span class="block text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mt-2 hero-gradient-text">
            Book in minutes.
          </span>
        </h1>

        <p class="mt-8 text-lg sm:text-xl text-white/50 max-w-xl mx-auto leading-relaxed hero-reveal" style="--delay: 0.2s">
          Verified local professionals for every project. Search, compare, and book — instantly.
        </p>

        <%# Search bar %>
        <div class="mt-10 max-w-2xl mx-auto hero-reveal" style="--delay: 0.3s">
          <%= form_tag services_path, method: :get do %>
            <div class="search-glow flex flex-col sm:flex-row bg-white rounded-2xl shadow-2xl shadow-black/20 p-2 focus-within:shadow-[0_0_80px_-10px_rgba(249,115,22,0.2)] transition-all duration-500">
              <div class="relative flex-1">
                <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                  <i class="fas fa-search text-slate-300 text-lg"></i>
                </div>
                <%= text_field_tag :query, nil,
                    placeholder: "What do you need help with?",
                    class: "w-full pl-[3.25rem] pr-4 py-4 sm:py-5 bg-transparent text-slate-900 placeholder-slate-400 text-lg focus:outline-none rounded-xl" %>
              </div>
              <button type="submit" class="btn-shine group bg-orange-500 hover:bg-orange-600 text-white px-10 py-4 sm:py-5 rounded-xl font-bold text-base transition-all duration-300 cursor-pointer mt-2 sm:mt-0 whitespace-nowrap hover:shadow-lg hover:shadow-orange-500/30 hover:scale-[1.02] active:scale-[0.98]">
                Search Pros
                <i class="fas fa-arrow-right ml-2 text-sm group-hover:translate-x-1 transition-transform duration-200"></i>
              </button>
            </div>
          <% end %>
        </div>

        <%# Category pills %>
        <div class="mt-8 flex flex-wrap justify-center gap-2 hero-reveal" style="--delay: 0.4s">
          <% @categories.limit(5).each do |cat| %>
            <% color = category_colors[cat.slug] || "gray" %>
            <%= link_to services_path(category_id: cat.id),
                class: "group inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium bg-white/[0.06] border border-white/[0.08] text-white/60 hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all duration-200" do %>
              <i class="fas <%= category_icons[cat.slug] || 'fa-cog' %> text-xs text-<%= color %>-400 opacity-70"></i>
              <%= cat.name %>
            <% end %>
          <% end %>
        </div>

        <%# Social proof %>
        <div class="mt-12 hero-reveal" style="--delay: 0.5s">
          <div class="inline-flex flex-wrap items-center justify-center gap-6 sm:gap-8 px-6 py-3 rounded-2xl bg-white/[0.04] border border-white/[0.06]">
            <div class="flex items-center gap-2.5">
              <div class="flex -space-x-2">
                <img src="https://i.pravatar.cc/32?u=h1" class="w-7 h-7 rounded-full ring-2 ring-slate-950" alt="">
                <img src="https://i.pravatar.cc/32?u=h2" class="w-7 h-7 rounded-full ring-2 ring-slate-950" alt="">
                <img src="https://i.pravatar.cc/32?u=h3" class="w-7 h-7 rounded-full ring-2 ring-slate-950" alt="">
              </div>
              <span class="text-white/60 text-sm font-medium"><%= number_with_delimiter(@total_providers) %>+ pros</span>
            </div>
            <div class="hidden sm:flex items-center gap-1.5">
              <div class="flex gap-0.5"><% 5.times do %><i class="fas fa-star text-amber-400 text-[10px]"></i><% end %></div>
              <span class="text-white/60 text-sm font-medium">4.9 avg</span>
            </div>
            <div class="hidden md:flex items-center gap-1.5">
              <i class="fas fa-shield-alt text-emerald-400 text-[10px]"></i>
              <span class="text-white/60 text-sm font-medium">Verified</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Bottom fade to white %>
  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-white via-white/80 to-transparent z-20"></div>
</section>

<%# ================================================================
    MARQUEE TRUST BAR
    ================================================================ %>
<div class="py-5 bg-slate-900 overflow-hidden">
  <div class="marquee-wrapper">
    <div class="marquee-track">
      <% 2.times do %>
        <% ["Verified Professionals", "Background Checked", "Secure Payments", "Real Reviews", "Instant Booking", "#{number_with_delimiter(@total_bookings)}+ Bookings Completed", "4.9★ Average Rating", "#{number_with_delimiter(@total_providers)}+ Trusted Pros", "Free to Get Started", "24/7 Support"].each do |item| %>
          <span class="inline-flex items-center text-sm text-slate-300 font-medium whitespace-nowrap px-8">
            <span class="w-1.5 h-1.5 rounded-full bg-orange-400 mr-3 flex-shrink-0"></span>
            <%= item %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# ================================================================
    CATEGORIES — Bento-style icon cards
    ================================================================ %>
<section class="py-20 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12" data-aos="fade-up">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">What do you need?</h2>
        <p class="mt-2 text-slate-500 text-lg">Choose a category to find the right pro.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to services_path, class: "group inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-orange-600 transition-colors" do %>
          Browse all <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4" data-aos="fade-up" data-aos-delay="100">
      <% @categories.each_with_index do |category, i| %>
        <% color = category_colors[category.slug] || "gray" %>
        <%= link_to services_path(category_id: category.id),
            class: "cat-card tilt-card group relative flex flex-col items-center justify-center p-6 sm:p-8 rounded-2xl border border-slate-100 bg-white hover:border-#{color}-200 hover:bg-#{color}-50/30 transition-all duration-300 overflow-hidden",
            style: "--glow-color: var(--tw-#{color}-100, rgba(249,115,22,0.06))",
            data: { aos: "fade-up", "aos-delay": i * 40 } do %>
          <%# Glow on hover %>
          <div class="absolute inset-0 bg-gradient-to-br from-<%= color %>-100/0 to-<%= color %>-100/0 group-hover:from-<%= color %>-100/30 group-hover:to-transparent transition-all duration-500 rounded-2xl"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-2xl bg-<%= color %>-50 border border-<%= color %>-100 flex items-center justify-center mb-4 group-hover:scale-110 group-hover:shadow-md group-hover:shadow-<%= color %>-500/10 transition-all duration-300">
              <i class="fas <%= category_icons[category.slug] || 'fa-cog' %> text-xl text-<%= color %>-500"></i>
            </div>
            <span class="text-sm font-bold text-slate-800 group-hover:text-<%= color %>-700 transition-colors"><%= category.name %></span>
            <span class="block text-xs text-slate-400 mt-1"><%= category.services.count %> pros</span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    FEATURED SERVICES
    ================================================================ %>
<% if @featured_services.any? %>
<section class="py-20 bg-gradient-to-b from-slate-50/80 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12" data-aos="fade-up">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">Popular right now</h2>
        <p class="mt-2 text-slate-500 text-lg">Services customers are booking this week.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to services_path, class: "group inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-orange-600 transition-colors" do %>
          See all <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <%= render partial: 'services/service_card', collection: @featured_services, as: :service %>
    </div>
  </div>
</section>
<% end %>

<%# ================================================================
    TRUST — Bold dark section
    ================================================================ %>
<section class="py-24 bg-slate-900 relative overflow-hidden">
  <%# Ambient glow %>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-violet-500/10 rounded-full blur-[100px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">Built for trust</h2>
      <p class="mt-3 text-slate-400 text-lg">Everything you need to hire with confidence.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5" data-aos="fade-up" data-aos-delay="100">
      <% [
        { icon: "fa-shield-alt", title: "Verified Pros", desc: "Background-checked, identity-verified, and reviewed by real customers.", color: "emerald" },
        { icon: "fa-credit-card", title: "Secure Payments", desc: "Stripe-powered. Your money is protected until the job is complete.", color: "sky" },
        { icon: "fa-star", title: "Real Reviews", desc: "Only customers who completed a booking can leave a review. Zero fakes.", color: "amber" },
        { icon: "fa-bolt", title: "Instant Booking", desc: "No back-and-forth. Find a pro, pick a time, get confirmed in minutes.", color: "violet" }
      ].each_with_index do |item, i| %>
        <div class="group p-6 rounded-2xl bg-white/[0.04] border border-white/[0.06] hover:bg-white/[0.08] hover:border-white/[0.12] transition-all duration-300" data-aos="fade-up" data-aos-delay="<%= 100 + i * 80 %>">
          <div class="w-12 h-12 rounded-xl bg-<%= item[:color] %>-500/10 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
            <i class="fas <%= item[:icon] %> text-<%= item[:color] %>-400 text-lg"></i>
          </div>
          <h3 class="text-base font-bold text-white mb-2"><%= item[:title] %></h3>
          <p class="text-sm text-slate-400 leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>

    <%# Stats row %>
    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-8 pt-12 border-t border-white/[0.06]" data-aos="fade-up" data-aos-delay="200">
      <% [
        { value: @total_providers, label: "Providers" },
        { value: @total_services, label: "Services" },
        { value: @total_bookings, label: "Bookings" },
        { value: @total_customers, label: "Customers" }
      ].each do |stat| %>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-black text-white counter" data-target="<%= stat[:value] %>">0</div>
          <div class="text-xs text-slate-500 mt-1 font-medium uppercase tracking-wider"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    TOP PROVIDERS
    ================================================================ %>
<% if @top_providers.present? && @top_providers.any? %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12" data-aos="fade-up">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">Top rated this month</h2>
        <p class="mt-2 text-slate-500 text-lg">Pros with the best track records.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to leaderboard_index_path, class: "group inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-orange-600 transition-colors" do %>
          View all <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @top_providers.each_with_index do |provider, index| %>
        <%= link_to leaderboard_path(provider), class: "group block bg-white rounded-xl border border-slate-100 p-5 hover:shadow-xl hover:shadow-slate-900/[0.05] hover:-translate-y-1 transition-all duration-300", data: { aos: "fade-up", "aos-delay": index * 60 } do %>
          <div class="flex items-center gap-4">
            <div class="relative flex-shrink-0">
              <% if provider.profile_picture.attached? %>
                <%= image_tag provider.profile_picture, class: "w-14 h-14 rounded-xl object-cover ring-2 ring-slate-100" %>
              <% else %>
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-slate-100 to-slate-50 flex items-center justify-center text-lg font-bold text-slate-400">
                  <%= provider.display_name.first.upcase %>
                </div>
              <% end %>
              <% if index == 0 %>
                <div class="absolute -top-1.5 -right-1.5 w-6 h-6 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center shadow-lg shadow-amber-500/30">
                  <i class="fas fa-trophy text-white text-[8px]"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-slate-900 group-hover:text-orange-600 transition-colors text-sm truncate"><%= provider.business_name || provider.full_name %></h3>
              <div class="flex items-center gap-1 mt-1">
                <% 5.times do |i| %><i class="fas fa-star text-[10px] <%= i < provider.average_rating.round ? 'text-amber-400' : 'text-slate-200' %>"></i><% end %>
                <span class="text-xs font-semibold text-slate-700 ml-1"><%= provider.average_rating %></span>
                <span class="text-slate-300 mx-1">&middot;</span>
                <span class="text-xs text-slate-400"><%= provider.total_completed_bookings %> jobs</span>
              </div>
              <% badge = provider.provider_badge %>
              <% if badge && badge[:name] != "New" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-<%= badge[:color] %>-50 text-<%= badge[:color] %>-700 mt-2">
                  <i class="<%= badge[:icon] %> mr-1"></i><%= badge[:name] %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# ================================================================
    TESTIMONIALS
    ================================================================ %>
<section class="py-20 bg-slate-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">Loved by thousands</h2>
      <p class="mt-2 text-slate-500 text-lg">Don't take our word for it.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5" data-aos="fade-up" data-aos-delay="100">
      <% [
        { name: "Sarah J.", role: "Homeowner", review: "Found an amazing plumber within minutes. Fixed my emergency leak the same day. Seamless booking and felt safe the entire time.", rating: 5, avatar: "https://i.pravatar.cc/64?u=sarah1" },
        { name: "Mike C.", role: "Business Owner", review: "We use Radius for all our office maintenance needs. Reliable providers, transparent pricing, great communication.", rating: 5, avatar: "https://i.pravatar.cc/64?u=mike2" },
        { name: "Emily R.", role: "Property Manager", review: "Managing multiple properties is so much easier. All my trusted contractors in one place with scheduling and payment.", rating: 4, avatar: "https://i.pravatar.cc/64?u=emily3" }
      ].each do |t| %>
        <div class="tilt-card group bg-white rounded-2xl border border-slate-100 p-7 transition-all duration-300">
          <div class="flex gap-0.5 mb-4">
            <% t[:rating].times do %><i class="fas fa-star text-amber-400 text-sm"></i><% end %>
            <% (5 - t[:rating]).times do %><i class="fas fa-star text-slate-200 text-sm"></i><% end %>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">"<%= t[:review] %>"</p>
          <div class="flex items-center gap-3">
            <img src="<%= t[:avatar] %>" alt="" class="w-10 h-10 rounded-full ring-2 ring-slate-100">
            <div>
              <div class="text-sm font-bold text-slate-900"><%= t[:name] %></div>
              <div class="text-xs text-slate-400"><%= t[:role] %></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    NEARBY PROVIDERS
    ================================================================ %>
<section class="py-20 bg-white" id="nearby-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10"><h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">Providers near you</h2><p class="mt-2 text-slate-500 text-lg">Within <span class="font-semibold text-slate-700" id="nearby-radius">25</span> miles.</p></div>
    <div id="nearby-prompt"><div class="text-center py-6"><button onclick="nearbyDetect()" class="group inline-flex items-center px-8 py-4 rounded-xl text-sm font-semibold text-white bg-slate-900 hover:bg-slate-800 transition-all cursor-pointer hover:shadow-lg hover:shadow-slate-900/20 hover:scale-[1.02] active:scale-[0.98]"><i class="fas fa-location-arrow mr-2.5 text-xs group-hover:rotate-45 transition-transform duration-300"></i>Detect My Location</button><p class="text-slate-400 text-xs mt-3">We'll find verified pros near you</p></div></div>
    <div id="nearby-loading" class="hidden"><div class="flex flex-col items-center py-10"><div class="w-10 h-10 border-2 border-slate-200 border-t-slate-900 rounded-full animate-spin mb-3"></div><p class="text-slate-500 text-sm">Finding providers...</p></div></div>
    <div id="nearby-error" class="hidden"><div class="text-center py-6"><p class="text-slate-600 text-sm mb-3" id="nearby-error-msg"></p><button onclick="nearbyDetect()" class="text-sm font-semibold text-orange-600 hover:text-orange-700 cursor-pointer">Try again <i class="fas fa-redo text-xs ml-1"></i></button></div></div>
    <div id="nearby-results" class="hidden"><div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4" id="nearby-grid"></div><div class="text-center mt-8"><%= link_to leaderboard_index_path, class: "group text-sm font-semibold text-slate-500 hover:text-orange-600 transition-colors" do %>View all <i class="fas fa-arrow-right text-xs ml-1 group-hover:translate-x-1 transition-transform"></i><% end %></div></div>
  </div>
</section>

<%# ================================================================
    PROVIDER CTA
    ================================================================ %>
<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-orange-500 via-orange-600 to-rose-600"></div>
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-5xl font-black text-white tracking-tight" data-aos="fade-up">Are you a service pro?</h2>
    <p class="mt-2 text-white/40 text-sm font-medium tracking-widest uppercase" data-aos="fade-up" data-aos-delay="50">Join the network</p>
    <p class="mt-4 text-white/80 text-lg" data-aos="fade-up" data-aos-delay="100">Join <%= number_with_delimiter(@total_providers) %>+ professionals growing their business on Radius. Free to start, no commitment.</p>
    <div class="mt-10 flex flex-wrap justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
      <% if user_signed_in? && current_user.provider? %>
        <%= link_to provider_dashboard_path, class: "group bg-white text-slate-900 px-8 py-4 rounded-xl font-bold text-sm hover:shadow-xl hover:shadow-black/10 hover:scale-[1.02] active:scale-[0.98] transition-all" do %>
          Go to Dashboard <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      <% elsif !user_signed_in? %>
        <%= link_to new_user_registration_path(role: 'provider'), class: "group bg-white text-slate-900 px-8 py-4 rounded-xl font-bold text-sm hover:shadow-xl hover:shadow-black/10 hover:scale-[1.02] active:scale-[0.98] transition-all" do %>
          Get Started Free <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
        <% end %>
        <%= link_to about_path, class: "text-white/90 hover:text-white px-8 py-4 rounded-xl font-bold text-sm border-2 border-white/30 hover:border-white/60 transition-all" do %>
          Learn More
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    FINAL CTA
