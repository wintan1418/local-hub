<%
  category_icons = {
    "home-cleaning" => "fa-broom", "plumbing" => "fa-wrench", "electrical" => "fa-bolt",
    "landscaping" => "fa-leaf", "moving" => "fa-truck", "handyman" => "fa-hammer",
    "painting" => "fa-paint-roller", "pet-care" => "fa-paw", "tutoring" => "fa-graduation-cap",
    "personal-training" => "fa-dumbbell"
  }
%>

<%# ================================================================
    1. HERO — 60/40 grid, falling balls inside the image area
    ================================================================ %>
<section class="bg-cream border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-10 lg:gap-16 items-center">
      <%# LEFT: text %>
      <div>
        <div class="eyebrow mb-5 hero-reveal" style="--delay: 0s">find local pros · trusted by <%= number_with_delimiter(@total_customers + @total_providers) %>+</div>

        <h1 class="display text-ink hero-reveal" style="--delay: 0.05s; font-size: clamp(48px, 8vw, 104px); line-height: 0.95; letter-spacing: -0.035em;">
          Local pros,<br>
          <em class="italic-wonk" style="color: #1f4d3a;">actually</em> good.
        </h1>

        <p class="mt-6 max-w-xl text-[17px] sm:text-[19px] leading-[1.5] text-ink-2 hero-reveal" style="--delay: 0.1s">
          Verified plumbers, electricians, cleaners and more. Compare prices,
          read real reviews, book and pay in one place.
        </p>

        <%# Pill search — what / where / submit %>
        <div class="mt-8 max-w-xl hero-reveal" style="--delay: 0.15s">
          <%= form_tag services_path, method: :get, class: "block" do %>
            <div class="flex items-stretch gap-1 bg-cream-elevated border border-line-strong rounded-pill p-1.5 shadow-card">
              <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
                <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">What</label>
                <%= text_field_tag :query, nil, placeholder: "Cleaning, plumbing, lawn…", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
              </div>
              <span class="w-px self-stretch bg-line"></span>
              <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
                <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">Where</label>
                <%= text_field_tag :location, nil, placeholder: "Your zip or city", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
              </div>
              <button type="submit" aria-label="Search" class="flex-shrink-0 w-12 h-12 rounded-full bg-ink hover:bg-ink-2 text-cream flex items-center justify-center transition-colors active:translate-y-px">
                <i class="fas fa-arrow-right text-xs"></i>
              </button>
            </div>
          <% end %>
        </div>

        <%# Trust strip — 3 items separated by top border %>
        <div class="mt-10 pt-6 border-t border-line grid grid-cols-3 gap-4 max-w-xl hero-reveal" style="--delay: 0.2s">
          <% [
            { icon: "fa-shield-alt", label: "Background-checked" },
            { icon: "fa-bolt", label: "Same-day available" },
            { icon: "fa-check", label: "Money-back guarantee" }
          ].each do |item| %>
            <div class="flex items-start gap-2.5">
              <i class="fas <%= item[:icon] %> text-forest text-sm mt-0.5"></i>
              <span class="text-[13px] text-ink-2 leading-[1.35]"><%= item[:label] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# RIGHT: sliding editorial showcase — real pros at work %>
      <%
        # Verified Unsplash photo IDs — all known-good, with safe fallback
        fallback_img = "https://images.unsplash.com/photo-1572981779307-38b8cabb2407?w=900&q=80&auto=format&fit=crop"
        provider_slides = [
          { img: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=900&q=80&auto=format&fit=crop", first: "Maya", last: "Rodriguez", cat: "Cleaning", city: "Brooklyn", rating: "4.96", reviews: 127, response: "8 min", jobs: 312, b_when: "2m", b_meta: "3hr · $147", r_initial: "L", r_quote: "Spotless work", r_when: "just now" },
          { img: "https://images.unsplash.com/photo-1486754735734-325b5831c3ad?w=900&q=80&auto=format&fit=crop", first: "Marcus", last: "Webb", cat: "Auto Repair", city: "Bronx", rating: "4.88", reviews: 156, response: "20 min", jobs: 298, b_when: "4m", b_meta: "2hr · $220", r_initial: "R", r_quote: "Brakes fixed fast", r_when: "1m" },
          { img: "https://images.unsplash.com/photo-1556910103-1c02745aae4d?w=900&q=80&auto=format&fit=crop", first: "Diego", last: "Alvarez", cat: "Catering", city: "Brooklyn", rating: "4.94", reviews: 92, response: "15 min", jobs: 186, b_when: "8m", b_meta: "Event · $420", r_initial: "K", r_quote: "Food was incredible", r_when: "just now" },
          { img: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=900&q=80&auto=format&fit=crop", first: "Sarah", last: "Chen", cat: "Tutoring", city: "Manhattan", rating: "5.00", reviews: 64, response: "5 min", jobs: 142, b_when: "12m", b_meta: "1hr · $65", r_initial: "P", r_quote: "Daughter loved her", r_when: "5m" },
          { img: "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=900&q=80&auto=format&fit=crop", first: "James", last: "Mendoza", cat: "Plumbing", city: "Queens", rating: "4.92", reviews: 89, response: "12 min", jobs: 218, b_when: "1m", b_meta: "Same-day · $189", r_initial: "D", r_quote: "Saved my Sunday", r_when: "just now" },
          { img: "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=900&q=80&auto=format&fit=crop", first: "Aisha", last: "Thompson", cat: "Landscaping", city: "Queens", rating: "4.95", reviews: 78, response: "18 min", jobs: 164, b_when: "6m", b_meta: "Half-day · $310", r_initial: "N", r_quote: "Yard looks new", r_when: "3m" },
          { img: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=900&q=80&auto=format&fit=crop", first: "Carlos", last: "Reyes", cat: "Personal Training", city: "Manhattan", rating: "4.97", reviews: 203, response: "10 min", jobs: 412, b_when: "3m", b_meta: "1hr · $95", r_initial: "J", r_quote: "Great workout", r_when: "just now" },
          { img: "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=900&q=80&auto=format&fit=crop", first: "Olivia", last: "Bennett", cat: "Painting", city: "Brooklyn", rating: "4.91", reviews: 84, response: "14 min", jobs: 156, b_when: "9m", b_meta: "Full-day · $480", r_initial: "T", r_quote: "Clean lines", r_when: "4m" },
          { img: "https://images.unsplash.com/photo-1555963966-b7ae5404b6ed?w=900&q=80&auto=format&fit=crop", first: "Trevor", last: "Singh", cat: "Electrical", city: "Queens", rating: "4.93", reviews: 118, response: "11 min", jobs: 246, b_when: "2m", b_meta: "Service · $175", r_initial: "M", r_quote: "Fast and clean", r_when: "just now" },
          { img: "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=900&q=80&auto=format&fit=crop", first: "Naomi", last: "Park", cat: "Pet Care", city: "Brooklyn", rating: "4.99", reviews: 71, response: "6 min", jobs: 134, b_when: "5m", b_meta: "Daily · $42", r_initial: "S", r_quote: "She loves Naomi", r_when: "2m" }
        ]
      %>

      <div class="relative hero-reveal" style="--delay: 0.1s">

        <%# Main hero card with shattering deck %>
        <div class="provider-deck relative rounded-[20px] overflow-hidden border border-line shadow-card-lg bg-cream-sunken" style="aspect-ratio: 4/5; min-height: 480px;" id="provider-deck">

          <%# Shatter layer — shards rendered here during transitions %>
          <div class="shatter-layer absolute inset-0 z-30 pointer-events-none" id="shatter-layer"></div>

          <%# Flash overlay — bright burst on impact %>
          <div class="shatter-flash absolute inset-0 z-25 pointer-events-none" id="shatter-flash"></div>

          <%# Crack lines — radiate from impact point %>
          <svg class="crack-lines" id="crack-lines" viewBox="0 0 100 100" preserveAspectRatio="none">
            <g stroke="white" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.95">
              <path d="M50,50 L20,8" />
              <path d="M50,50 L75,5" />
              <path d="M50,50 L98,38" />
              <path d="M50,50 L92,85" />
              <path d="M50,50 L48,98" />
              <path d="M50,50 L8,75" />
              <path d="M50,50 L2,40" />
              <path d="M50,50 L25,72" />
              <path d="M50,50 L72,28" />
              <path d="M22,16 L40,30" />
              <path d="M70,12 L60,28" />
              <path d="M88,40 L72,46" />
              <path d="M85,80 L62,68" />
            </g>
          </svg>

          <%# Slides %>
          <% provider_slides.each_with_index do |s, i| %>
            <div class="provider-slide absolute inset-0 <%= i == 0 ? 'is-active is-initial' : '' %>"
                 data-slide="<%= i %>"
                 data-b-when="<%= s[:b_when] %>"
                 data-b-meta="<%= s[:b_meta] %>"
                 data-r-initial="<%= s[:r_initial] %>"
                 data-r-quote="<%= s[:r_quote] %>"
                 data-r-when="<%= s[:r_when] %>">
              <img src="<%= s[:img] %>"
                   data-fallback="<%= fallback_img %>"
                   onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}"
                   class="absolute inset-0 w-full h-full object-cover"
                   alt="<%= s[:first] %> <%= s[:last] %> · <%= s[:cat] %>"
                   loading="<%= i == 0 ? 'eager' : 'lazy' %>">

              <%# Top-right: Rating pill (per-slide) %>
              <div class="absolute top-4 right-4 flex items-center gap-2 px-3 py-1.5 rounded-pill bg-cream-elevated/95 backdrop-blur border border-line shadow-card">
                <i class="fas fa-star text-amber-500 text-[11px]"></i>
                <span class="display text-[15px] text-ink leading-none"><%= s[:rating] %></span>
                <span class="font-mono text-[10px] text-ink-3">(<%= s[:reviews] %>)</span>
              </div>

              <%# Bottom: Editorial overlay %>
              <div class="absolute inset-x-0 bottom-0 p-6 pt-28" style="background: linear-gradient(to top, rgba(29,24,19,0.94), rgba(29,24,19,0.55) 45%, transparent);">
                <div class="font-mono text-[10px] uppercase tracking-[0.16em] text-cream/65 mb-2"><%= s[:cat] %> · <%= s[:city] %>, NY</div>
                <div class="display text-cream leading-[0.95] tracking-[-0.02em]" style="font-size: clamp(28px, 3.5vw, 38px);">
                  <%= s[:first] %> <em class="italic-wonk text-cream"><%= s[:last] %></em>
                </div>
                <div class="mt-3 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.08em] text-cream/65">
                  <span><i class="fas fa-bolt text-amber-400/80 text-[10px] mr-1"></i>responds in <%= s[:response] %></span>
                  <span class="opacity-50">·</span>
                  <span><%= s[:jobs] %> jobs done</span>
                </div>
              </div>
            </div>
          <% end %>

          <%# Static overlays — sit above slides %>
          <%# Top-left: VERIFIED badge with slide number %>
          <div class="absolute top-4 left-4 z-20 flex items-center gap-1.5 px-3 py-1.5 rounded-pill bg-cream-elevated/95 backdrop-blur border border-line shadow-card">
            <i class="fas fa-check text-forest text-[10px]"></i>
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink">verified · no.<span id="deck-no">01</span></span>
          </div>

          <%# Slide indicators (dots) — bottom-center, above gradient %>
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex items-center gap-1.5">
            <% provider_slides.each_with_index do |_, i| %>
              <button type="button" class="deck-dot w-1.5 h-1.5 rounded-full transition-all <%= i == 0 ? 'w-6 bg-cream' : 'bg-cream/40' %>" data-target="<%= i %>" aria-label="Slide <%= i + 1 %>"></button>
            <% end %>
          </div>
        </div>

        <%# Floating chip — top-left, breaks bounds (live booking, swaps per slide) %>
        <div class="absolute top-12 sm:top-16 z-30 hidden sm:block" style="left: -22px;" id="chip-booking">
          <div class="chip-inner bg-cream-elevated border border-line rounded-pill pl-3 pr-4 py-1.5 flex items-center gap-2.5 shadow-card-md">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background-color: #2d6e4e;"></span>
              <span class="relative inline-flex rounded-full h-2 w-2" style="background-color: #2d6e4e;"></span>
            </span>
            <div class="leading-tight">
              <div class="text-[12px] font-semibold text-ink">Just booked · <span data-chip="b_when">2m</span></div>
              <div class="font-mono text-[10px] text-ink-3" data-chip="b_meta">3hr · $147</div>
            </div>
          </div>
        </div>

        <%# Floating chip — bottom-right, breaks bounds (review, swaps per slide) %>
        <div class="absolute bottom-16 sm:bottom-20 z-30 hidden sm:block" style="right: -28px;" id="chip-review">
          <div class="chip-inner bg-cream-elevated border border-line rounded-pill pl-1.5 pr-4 py-1.5 flex items-center gap-2.5 shadow-card-md">
            <div class="w-7 h-7 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[10px] font-bold border border-line" data-chip="r_initial">L</div>
            <div class="leading-tight">
              <div class="text-[12px] font-semibold text-ink">"<span data-chip="r_quote">Spotless work</span>"</div>
              <div class="font-mono text-[10px] text-ink-3 flex items-center gap-1">
                <% 5.times do %><i class="fas fa-star text-amber-500 text-[7px]"></i><% end %><span class="ml-0.5" data-chip="r_when">just now</span>
              </div>
            </div>
          </div>
        </div>

        <%# Live activity strip — below card %>
        <div class="mt-5 flex items-center justify-between gap-2 px-1">
          <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">
            <span class="relative flex h-1.5 w-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background-color: #2d6e4e;"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5" style="background-color: #2d6e4e;"></span>
            </span>
            <span><strong class="text-ink"><%= number_with_delimiter(@total_providers) %></strong> pros active</span>
          </div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">
            <strong class="text-ink"><%= [ ((@total_bookings || 0) / 30).to_i, 12 ].max %></strong> booked today
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ================================================================
    2. CATEGORIES — 4-col grid, swatch + display name + mono count
    ================================================================ %>
<section class="bg-cream py-14 sm:py-20" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4 mb-8 sm:mb-10">
      <div>
        <div class="eyebrow mb-3">browse · 01</div>
        <h2 class="display text-[28px] sm:text-[32px] text-ink" style="line-height: 1.05; letter-spacing: -0.02em;">What do you <em class="italic-wonk" style="color: #1f4d3a;">actually</em> need?</h2>
      </div>
      <%= link_to services_path, class: "hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-ink-2 hover:text-ink transition-colors" do %>
        Browse all <i class="fas fa-arrow-right text-[10px]"></i>
      <% end %>
    </div>

    <% cat_swatches = [ "#1f4d3a", "#d96a3a", "#1d1813", "#766853", "#b8551c", "#1f4d3a", "#d96a3a", "#1d1813", "#766853", "#b8551c" ] %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @categories.limit(8).each_with_index do |category, i| %>
        <%= link_to services_path(category_id: category.id),
            class: "group flex flex-col p-5 sm:p-6 rounded-xl border border-line bg-cream-elevated hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200",
            style: "min-height: 160px;" do %>
          <div class="w-9 h-9 rounded-full flex items-center justify-center mb-auto" style="background-color: <%= cat_swatches[i % cat_swatches.length] %>;">
            <i class="fas <%= category_icons[category.slug] || 'fa-cog' %> text-cream text-[13px]"></i>
          </div>
          <div class="mt-6">
            <div class="display text-[22px] leading-[1.1] tracking-[-0.01em] text-ink"><%= category.name %></div>
            <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= category.services.count %> pros</div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    3. FEATURED PROVIDERS — sunken band, 4-col grid card
    ================================================================ %>
<% if @top_providers.any? %>
<section class="bg-cream-sunken py-14 sm:py-20 border-y border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4 mb-8 sm:mb-10">
      <div>
        <div class="eyebrow mb-3">featured · 02</div>
        <h2 class="display text-[28px] sm:text-[32px] text-ink" style="line-height: 1.05; letter-spacing: -0.02em;">Pros doing it <em class="italic-wonk" style="color: #1f4d3a;">well</em>.</h2>
      </div>
      <%= link_to services_path, class: "hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
        See all <i class="fas fa-arrow-right text-[10px]"></i>
      <% end %>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      <% @top_providers.first(4).each do |provider| %>
        <%= link_to provider_path(provider), class: "group block bg-cream-elevated rounded-xl border border-line overflow-hidden hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200" do %>
          <%# Image area — provider photo (pravatar fallback) %>
          <div class="relative aspect-[4/5] bg-cream-sunken">
            <% if provider.profile_picture.attached? %>
              <%= image_tag provider.profile_picture, class: "absolute inset-0 w-full h-full object-cover" %>
            <% else %>
              <img src="https://i.pravatar.cc/400?u=provider<%= provider.id %>" class="absolute inset-0 w-full h-full object-cover" alt="<%= provider.display_name %>">
            <% end %>
            <%# Top-rated badge overlay %>
            <% if provider.average_rating >= 4.8 %>
              <div class="absolute top-3 left-3 bg-cream-elevated border border-line rounded-pill px-2.5 py-1 flex items-center gap-1.5 shadow-card">
                <i class="fas fa-star text-amber-500 text-[9px]"></i>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink">top-rated</span>
              </div>
            <% end %>
            <%# Favorite icon overlay %>
            <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-cream-elevated/90 backdrop-blur-sm border border-line flex items-center justify-center hover:bg-cream-elevated transition-colors">
              <i class="far fa-heart text-ink-3 text-xs"></i>
            </div>
          </div>

          <div class="p-4">
            <div class="display text-[17px] leading-[1.2] tracking-[-0.01em] text-ink truncate"><%= provider.business_name.presence || provider.display_name %></div>
            <div class="text-[13px] text-ink-3 mt-1 truncate">
              <% primary_service = provider.services.first %>
              <%= primary_service&.title || (primary_service&.category&.name + " pro") || "Local pro" %>
            </div>
            <div class="mt-3 flex items-center justify-between">
              <div class="flex items-center gap-1.5 text-[13px] text-ink-2">
                <i class="fas fa-star text-amber-500 text-[10px]"></i>
                <span class="font-medium"><%= provider.average_rating > 0 ? provider.average_rating : "New" %></span>
                <% if provider.total_reviews > 0 %>
                  <span class="text-ink-3">(<%= provider.total_reviews %>)</span>
                <% end %>
              </div>
              <% if primary_service&.base_price.to_f > 0 %>
                <div class="display text-[17px] text-ink">$<%= number_with_precision(primary_service.base_price, precision: 0) %><span class="font-sans text-[11px] text-ink-3 font-normal">/hr</span></div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# ================================================================
    4. HOW IT WORKS — 3-col, italic display numbers, top+bottom border
    ================================================================ %>
<section class="bg-cream py-14 sm:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 sm:mb-10">
      <div class="eyebrow mb-3">how it works · 03</div>
      <h2 class="display text-[28px] sm:text-[32px] text-ink" style="line-height: 1.05; letter-spacing: -0.02em;">Three steps. <em class="italic-wonk" style="color: #1f4d3a;">Done</em>.</h2>
    </div>

    <div class="grid md:grid-cols-3 border-t border-b border-line">
      <% [
        { num: "1", title: "Tell us what you need", body: "Describe the job in a sentence or pick from a category. Takes 30 seconds." },
        { num: "2", title: "Pick your pro", body: "Compare verified pros, read real reviews, and chat before you commit." },
        { num: "3", title: "Book and relax", body: "Pay securely through Radius. We hold the funds until the job is done right." }
      ].each_with_index do |step, i| %>
        <div class="py-8 sm:py-10 px-2 sm:px-6 <%= 'border-b md:border-b-0 md:border-r' if i < 2 %> <%= 'md:border-r-0' if i == 2 %> border-line">
          <div class="display italic-wonk text-[56px] leading-none" style="color: #1f4d3a; font-style: italic;"><%= step[:num] %></div>
          <h3 class="display text-[24px] mt-4 text-ink" style="line-height: 1.1;"><%= step[:title] %></h3>
          <p class="mt-3 text-[14px] leading-[1.55] text-ink-2 max-w-sm"><%= step[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
