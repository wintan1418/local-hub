<%# ================================================================
    STYLES + ANIMATIONS
    ================================================================ %>
<style>
/* Gradient text */
.hero-gradient-text {
  background: linear-gradient(135deg, #fb923c 0%, #f97316 30%, #e879f9 70%, #a78bfa 100%);
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientText 6s ease-in-out infinite;
}
@keyframes gradientText {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* Falling particle bubbles */
.pro-bubble {
  position: absolute;
  will-change: transform, opacity;
  pointer-events: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  animation: bubbleFall linear infinite, bubbleDrift ease-in-out infinite, bubbleTwinkle ease-in-out infinite;
  box-shadow: 0 0 20px rgba(255,255,255,0.03), inset 0 0 20px rgba(255,255,255,0.02);
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(2px);
}
.pro-bubble img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  opacity: 0.7;
}
/* Trade icon overlay on bubble */
.pro-bubble .bubble-icon {
  position: absolute;
  bottom: -2px;
  right: -2px;
  width: 40%;
  height: 40%;
  border-radius: 50%;
  background: rgba(15,23,42,0.9);
  border: 1px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 45%;
}
/* Star ring around some bubbles */
.pro-bubble .bubble-ring {
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  border: 1px solid rgba(251,191,36,0.2);
  animation: ringPulse 4s ease-in-out infinite;
}
@keyframes bubbleFall {
  0% { transform: translateY(-120px); }
  100% { transform: translateY(calc(100vh + 120px)); }
}
@keyframes bubbleDrift {
  0%, 100% { margin-left: 0; }
  25% { margin-left: 15px; }
  50% { margin-left: -10px; }
  75% { margin-left: 20px; }
}
@keyframes bubbleTwinkle {
  0%, 100% { opacity: var(--base-opacity, 0.4); }
  50% { opacity: calc(var(--base-opacity, 0.4) * 1.6); }
}
@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.15); opacity: 0.6; }
}

/* Floating orbs */
.orb-float {
  animation: orbFloat 8s ease-in-out infinite;
}
.orb-float-reverse {
  animation: orbFloat 10s ease-in-out infinite reverse;
}
.orb-float-slow {
  animation: orbFloat 14s ease-in-out infinite;
}
@keyframes orbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -20px) scale(1.05); }
  66% { transform: translate(-20px, 15px) scale(0.95); }
}

/* Staggered entrance animation */
.hero-reveal {
  opacity: 0;
  transform: translateY(24px) scale(0.98);
  animation: heroReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  animation-delay: var(--delay, 0s);
}
@keyframes heroReveal {
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* Scroll reveal for sections */
.scroll-reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* 3D tilt cards */
.tilt-card {
  transform-style: preserve-3d;
  perspective: 1000px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.tilt-card:hover {
  transform: translateY(-4px) rotateX(2deg) rotateY(-2deg);
  box-shadow: 0 20px 40px -15px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.02);
}

/* Glassmorphism card */
.glass-card {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.8);
}

/* Marquee trust bar */
.marquee-wrapper { overflow: hidden; }
.marquee-track {
  display: flex;
  width: max-content;
  animation: marqueeScroll 40s linear infinite;
}
.marquee-track:hover { animation-play-state: paused; }
@keyframes marqueeScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* Shine effect on buttons */
.btn-shine {
  position: relative;
  overflow: hidden;
}
.btn-shine::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -60%;
  width: 50%;
  height: 200%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  transform: skewX(-20deg);
  transition: left 0.6s ease;
}
.btn-shine:hover::after {
  left: 120%;
}

/* Glow pulse on search focus */
.search-glow:focus-within {
  box-shadow: 0 0 0 4px rgba(249,115,22,0.15), 0 0 80px -10px rgba(249,115,22,0.2);
}


/* Category card inner glow */
.cat-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0;
  transition: opacity 0.3s ease;
  background: radial-gradient(circle at 50% 0%, var(--glow-color, rgba(249,115,22,0.08)), transparent 70%);
}
.cat-card:hover::before { opacity: 1; }
</style>

<%# ================================================================
    SCRIPTS
    ================================================================ %>
<script>
/* Particle rain — falling professional bubbles */
(function() {
  var canvas = document.getElementById('particle-canvas');
  if (!canvas) return;

  var pros = [
    { img: 'https://i.pravatar.cc/96?u=p1', icon: 'fa-wrench', color: '#60a5fa' },
    { img: 'https://i.pravatar.cc/96?u=p2', icon: 'fa-broom', color: '#38bdf8' },
    { img: 'https://i.pravatar.cc/96?u=p3', icon: 'fa-bolt', color: '#fbbf24' },
    { img: 'https://i.pravatar.cc/96?u=p4', icon: 'fa-paint-roller', color: '#fb7185' },
    { img: 'https://i.pravatar.cc/96?u=p5', icon: 'fa-leaf', color: '#34d399' },
    { img: 'https://i.pravatar.cc/96?u=p6', icon: 'fa-dumbbell', color: '#f87171' },
    { img: 'https://i.pravatar.cc/96?u=p7', icon: 'fa-hammer', color: '#fb923c' },
    { img: 'https://i.pravatar.cc/96?u=p8', icon: 'fa-graduation-cap', color: '#818cf8' },
    { img: 'https://i.pravatar.cc/96?u=p9', icon: 'fa-truck', color: '#a78bfa' },
    { img: 'https://i.pravatar.cc/96?u=p10', icon: 'fa-paw', color: '#2dd4bf' },
    { img: 'https://i.pravatar.cc/96?u=p11', icon: 'fa-wrench', color: '#60a5fa' },
    { img: 'https://i.pravatar.cc/96?u=p12', icon: 'fa-broom', color: '#38bdf8' },
    { img: 'https://i.pravatar.cc/96?u=p13', icon: 'fa-bolt', color: '#fbbf24' },
    { img: 'https://i.pravatar.cc/96?u=p14', icon: 'fa-paint-roller', color: '#fb7185' },
    { img: 'https://i.pravatar.cc/96?u=p15', icon: 'fa-hammer', color: '#fb923c' },
    { img: 'https://i.pravatar.cc/96?u=p16', icon: 'fa-leaf', color: '#34d399' },
    { img: 'https://i.pravatar.cc/96?u=p17', icon: 'fa-dumbbell', color: '#f87171' },
    { img: 'https://i.pravatar.cc/96?u=p18', icon: 'fa-graduation-cap', color: '#818cf8' },
    { img: 'https://i.pravatar.cc/96?u=p19', icon: 'fa-truck', color: '#a78bfa' },
    { img: 'https://i.pravatar.cc/96?u=p20', icon: 'fa-paw', color: '#2dd4bf' },
  ];

  var BUBBLE_COUNT = 30;

  function createBubble(initial) {
    var pro = pros[Math.floor(Math.random() * pros.length)];
    var size = 36 + Math.floor(Math.random() * 36); // 36-72px
    var left = Math.random() * 100;
    var fallDuration = 12 + Math.random() * 20; // 12-32s
    var driftDuration = 6 + Math.random() * 8;
    var twinkleDuration = 3 + Math.random() * 5;
    var delay = initial ? -(Math.random() * fallDuration) : 0; // Stagger on first load
    var baseOpacity = 0.15 + Math.random() * 0.35;
    var hasRing = Math.random() > 0.6;
    var hasIcon = Math.random() > 0.3;

    var bubble = document.createElement('div');
    bubble.className = 'pro-bubble';
    bubble.style.cssText = 'width:'+size+'px;height:'+size+'px;left:'+left+'%;'
      + 'animation-duration:'+fallDuration+'s,'+driftDuration+'s,'+twinkleDuration+'s;'
      + 'animation-delay:'+delay+'s,'+(-Math.random()*driftDuration)+'s,'+(-Math.random()*twinkleDuration)+'s;'
      + '--base-opacity:'+baseOpacity+';';

    var img = document.createElement('img');
    img.src = pro.img;
    img.loading = 'lazy';
    img.alt = '';
    bubble.appendChild(img);

    if (hasIcon) {
      var icon = document.createElement('div');
      icon.className = 'bubble-icon';
      icon.innerHTML = '<i class="fas '+pro.icon+'" style="color:'+pro.color+'"></i>';
      bubble.appendChild(icon);
    }

    if (hasRing) {
      var ring = document.createElement('div');
      ring.className = 'bubble-ring';
      ring.style.animationDelay = (-Math.random() * 4) + 's';
      bubble.appendChild(ring);
    }

    canvas.appendChild(bubble);

    // Remove and re-create when animation ends (continuous rain)
    bubble.addEventListener('animationiteration', function handler(e) {
      if (e.animationName === 'bubbleFall') {
        bubble.removeEventListener('animationiteration', handler);
        bubble.remove();
        createBubble(false);
      }
    });
  }

  // Respect reduced motion preference
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    for (var i = 0; i < BUBBLE_COUNT; i++) {
      createBubble(true);
    }
  }
})();

/* Scroll reveal */
document.addEventListener('DOMContentLoaded', function() {
  var reveals = document.querySelectorAll('.scroll-reveal');
  var revealObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  reveals.forEach(function(el) { revealObserver.observe(el); });
});

/* Animated counters */
document.addEventListener('DOMContentLoaded', function() {
  var counters = document.querySelectorAll('.counter');
  var observed = false;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting && !observed) {
        observed = true;
        counters.forEach(function(el) {
          var target = parseInt(el.dataset.target);
          var duration = 2000;
          var start = performance.now();
          function step(now) {
            var progress = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(eased * target).toLocaleString() + '+';
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        });
      }
    });
  }, { threshold: 0.3 });
  counters.forEach(function(el) { observer.observe(el); });
});

/* Nearby providers */
var NEARBY_RADIUS = 25;
function nearbyShow(id) { ['nearby-prompt','nearby-loading','nearby-error','nearby-results'].forEach(function(s){var e=document.getElementById(s);if(e)e.classList.add('hidden');}); var t=document.getElementById(id);if(t)t.classList.remove('hidden'); }
function nearbyDetect() { if(!navigator.geolocation){nearbyShowError('Geolocation not supported.');return;} nearbyShow('nearby-loading'); navigator.geolocation.getCurrentPosition(function(p){nearbyFetch(p.coords.latitude,p.coords.longitude);},function(e){var m={1:'Location access denied.',2:'Could not determine location.',3:'Request timed out.'};nearbyShowError(m[e.code]||'Could not get location.');},{enableHighAccuracy:false,timeout:10000,maximumAge:300000}); }
function nearbyShowError(msg) { nearbyShow('nearby-error'); var e=document.getElementById('nearby-error-msg'); if(e) e.textContent=msg; }
function nearbyFetch(lat,lng) { fetch('/api/nearby_providers?lat='+lat+'&lng='+lng+'&radius='+NEARBY_RADIUS).then(function(r){return r.json();}).then(function(p){if(!p||p.error||p.length===0){nearbyShowError('No providers found nearby.');return;}nearbyRender(p);}).catch(function(){nearbyShowError('Could not load providers.');}); }
function nearbyEsc(s){if(!s)return'';var d=document.createElement('div');d.textContent=s;return d.innerHTML;}
function nearbyRender(providers) {
  nearbyShow('nearby-results'); var g=document.getElementById('nearby-grid'); if(!g) return;
  var bc={purple:{bg:'#faf5ff',text:'#7e22ce',border:'#f3e8ff'},blue:{bg:'#eff6ff',text:'#1d4ed8',border:'#dbeafe'},green:{bg:'#f0fdf4',text:'#15803d',border:'#dcfce7'},yellow:{bg:'#fefce8',text:'#a16207',border:'#fef9c3'},gray:{bg:'#f9fafb',text:'#6b7280',border:'#f3f4f6'}};
  g.innerHTML=providers.map(function(p){
    var i=(p.display_name||'?')[0].toUpperCase();
    var av=p.profile_picture_url?'<img src="'+p.profile_picture_url+'" class="w-12 h-12 rounded-xl object-cover ring-2 ring-slate-100">':'<div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-sm font-bold text-slate-400">'+i+'</div>';
    var st='';for(var j=0;j<5;j++)st+='<i class="fas fa-star text-[10px] '+(j<Math.round(p.average_rating)?'text-amber-400':'text-slate-200')+'"></i>';
    var b=p.badge&&p.badge.name!=='New'?bc[p.badge.color]||bc.gray:null;
    var badge=b?'<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium mt-1.5" style="background:'+b.bg+';color:'+b.text+';border:1px solid '+b.border+'"><i class="'+nearbyEsc(p.badge.icon)+' mr-1"></i>'+nearbyEsc(p.badge.name)+'</span>':'';
    return '<a href="'+p.url+'" class="group block bg-white rounded-xl border border-slate-100 p-4 hover:shadow-xl hover:shadow-slate-900/[0.05] hover:-translate-y-1 transition-all duration-300"><div class="flex items-center gap-3">'+av+'<div class="flex-1 min-w-0"><h4 class="font-bold text-slate-900 group-hover:text-orange-600 text-sm truncate">'+nearbyEsc(p.business_name||p.display_name)+'</h4><div class="flex items-center gap-1 mt-0.5">'+st+'<span class="text-xs text-slate-400 ml-1">'+p.distance+' mi</span></div>'+badge+'</div></div></a>';
  }).join('');
}
</script>
