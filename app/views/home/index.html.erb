<%# ================================================================
    HERO — Full-bleed image slider with bold overlay
    ================================================================ %>
<section class="relative min-h-[92vh] flex items-center overflow-hidden" id="hero">
  <%# Background image slideshow %>
  <div class="absolute inset-0">
    <% hero_images.each_with_index do |img, i| %>
      <div class="hero-slide absolute inset-0 transition-opacity duration-[1.5s] ease-in-out <%= i == 0 ? 'opacity-100' : 'opacity-0' %>" data-slide>
        <img src="<%= img %>" alt="" class="w-full h-full object-cover scale-[1.05]" loading="<%= i == 0 ? 'eager' : 'lazy' %>">
      </div>
    <% end %>
    <%# Overlay: dark bottom-heavy gradient with warm orange tint %>
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/50 to-black/80"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-transparent to-orange-900/20"></div>
  </div>

  <%# Content %>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
    <div class="max-w-2xl">
      <%# Animated pill %>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8 hero-fade-in" style="animation-delay: 0.2s">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-orange-500"></span>
        </span>
        <span class="text-white/90 text-sm font-medium"><%= number_with_delimiter(@total_providers) %>+ verified professionals near you</span>
      </div>

      <%# Headline %>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[1.05] tracking-tight hero-fade-in" style="animation-delay: 0.4s">
        Find the right pro,<br>
        <span class="relative">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 via-amber-300 to-orange-400">right around you.</span>
          <span class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-orange-500 via-amber-400 to-transparent rounded-full opacity-60"></span>
        </span>
      </h1>

      <%# Subtext %>
      <p class="mt-8 text-lg lg:text-xl text-white/70 max-w-lg leading-relaxed hero-fade-in" style="animation-delay: 0.6s">
        Search, compare, and book trusted local professionals — plumbers, electricians, cleaners, and more. All verified, all reviewed.
      </p>

      <%# Search bar — frosted glass %>
      <div class="mt-10 hero-fade-in" style="animation-delay: 0.8s">
        <%= form_tag services_path, method: :get, class: "relative" do %>
          <div class="flex flex-col sm:flex-row bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl p-2 shadow-2xl shadow-black/20 focus-within:border-orange-400/40 focus-within:bg-white/[0.15] transition-all duration-300">
            <div class="relative flex-1">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-search text-white/40"></i>
              </div>
              <%= text_field_tag :query, nil,
                  placeholder: "What service do you need?",
                  class: "w-full pl-11 pr-4 py-4 bg-transparent text-white placeholder-white/40 text-base focus:outline-none" %>
            </div>
            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3.5 rounded-xl font-semibold text-base transition-all hover:shadow-lg hover:shadow-orange-500/25 whitespace-nowrap cursor-pointer mt-2 sm:mt-0">
              <i class="fas fa-search mr-2 sm:hidden"></i>Search
            </button>
          </div>
        <% end %>
      </div>

      <%# Popular tags %>
      <div class="mt-6 flex flex-wrap gap-2 hero-fade-in" style="animation-delay: 1s">
        <span class="text-white/40 text-sm py-1.5">Popular:</span>
        <% @categories.limit(5).each do |category| %>
          <%= link_to category.name, services_path(category_id: category.id),
              class: "px-3.5 py-1.5 rounded-full text-sm font-medium bg-white/[0.08] border border-white/[0.1] text-white/70 hover:bg-white/[0.15] hover:text-white transition-all" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Stats bar at bottom %>
  <div class="absolute bottom-0 inset-x-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/[0.08] backdrop-blur-md rounded-t-2xl overflow-hidden border-t border-x border-white/[0.12]">
        <% [
          { value: @total_providers, label: "Providers", icon: "fa-hard-hat" },
          { value: @total_services, label: "Services", icon: "fa-concierge-bell" },
          { value: @total_bookings, label: "Bookings", icon: "fa-calendar-check" },
          { value: @total_customers, label: "Customers", icon: "fa-users" }
        ].each do |stat| %>
          <div class="px-6 py-5 text-center bg-black/20">
            <div class="text-2xl sm:text-3xl font-bold text-white"><%= number_with_delimiter(stat[:value]) %>+</div>
            <div class="text-xs text-white/50 mt-1 font-medium uppercase tracking-wider"><%= stat[:label] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Slide indicators %>
  <div class="absolute bottom-24 sm:bottom-28 left-1/2 -translate-x-1/2 z-10 flex gap-2">
    <% hero_images.size.times do |i| %>
      <button class="h-1.5 rounded-full transition-all duration-500 cursor-pointer <%= i == 0 ? 'bg-orange-500 w-8' : 'bg-white/30 w-4 hover:bg-white/50' %>"
              data-dot data-index="<%= i %>"></button>
    <% end %>
  </div>
</section>

<%# ================================================================
    CATEGORIES — Clean light section
    ================================================================ %>
<section class="py-24 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-orange-50 text-orange-600 border border-orange-100 uppercase tracking-wider mb-4">Categories</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Browse by Category</h2>
      <p class="mt-4 text-lg text-gray-500">Whatever you need done, we have the right pro.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4" data-aos="fade-up" data-aos-delay="100">
      <% @categories.each do |category| %>
        <%= link_to services_path(category_id: category.id),
            class: "group relative rounded-2xl overflow-hidden aspect-[4/3] shadow-sm hover:shadow-xl transition-shadow duration-300" do %>
          <img src="<%= category_images[category.slug] || 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&q=80' %>"
               alt="<%= category.name %>"
               class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
               loading="lazy">
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/30 to-transparent group-hover:from-gray-900/90 transition-all duration-300"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-4">
            <h3 class="text-white font-bold text-sm sm:text-base drop-shadow-lg"><%= category.name %></h3>
            <span class="text-white/60 text-xs mt-0.5"><%= category.services.count %> services</span>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-12">
      <%= link_to services_path, class: "inline-flex items-center gap-2 text-orange-600 font-semibold hover:text-orange-700 transition-colors group text-sm" do %>
        View all services
        <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    HOW IT WORKS — Subtle gradient background
    ================================================================ %>
<section class="py-24 bg-gradient-to-b from-gray-50 to-white" id="how-it-works">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-orange-50 text-orange-600 border border-orange-100 uppercase tracking-wider mb-4">How It Works</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Three Steps. That's It.</h2>
      <p class="mt-4 text-lg text-gray-500">Getting help has never been easier.</p>
    </div>

    <% steps = [
      { num: 1, title: "Search & Compare", desc: "Browse verified professionals in your area. Compare ratings, prices, and reviews.", icon: "fa-search", color: "orange" },
      { num: 2, title: "Book Instantly", desc: "Pick a time that works. Chat with providers and get instant confirmation.", icon: "fa-calendar-check", color: "blue" },
      { num: 3, title: "Get It Done", desc: "A trusted pro handles the work. Pay securely and leave a review.", icon: "fa-check-double", color: "green" }
    ] %>

    <%# Desktop — horizontal cards %>
    <div class="hidden md:grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <% steps.each_with_index do |step, i| %>
        <%
          step_colors = {
            "orange" => { bg: "bg-orange-50", ring: "ring-orange-100", text: "text-orange-600", icon_bg: "bg-orange-100" },
            "blue"   => { bg: "bg-blue-50", ring: "ring-blue-100", text: "text-blue-600", icon_bg: "bg-blue-100" },
            "green"  => { bg: "bg-green-50", ring: "ring-green-100", text: "text-green-600", icon_bg: "bg-green-100" }
          }
          sc = step_colors[step[:color]]
        %>
        <div class="relative text-center" data-aos="fade-up" data-aos-delay="<%= i * 150 %>">
          <%# Connector line %>
          <% if i < steps.length - 1 %>
            <div class="hidden lg:block absolute top-10 left-[60%] w-[80%] border-t-2 border-dashed border-gray-200"></div>
          <% end %>

          <div class="relative inline-flex items-center justify-center w-20 h-20 rounded-2xl <%= sc[:bg] %> ring-4 <%= sc[:ring] %> mb-6 z-10">
            <i class="fas <%= step[:icon] %> text-2xl <%= sc[:text] %>"></i>
          </div>
          <div class="absolute top-0 right-1/2 translate-x-1/2 -translate-y-2 w-7 h-7 rounded-full bg-gray-900 text-white text-xs font-bold flex items-center justify-center z-20 ring-4 ring-white">
            <%= step[:num] %>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2"><%= step[:title] %></h3>
          <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto"><%= step[:desc] %></p>
        </div>
      <% end %>
    </div>

    <%# Mobile — vertical list %>
    <div class="md:hidden space-y-6">
      <% steps.each_with_index do |step, i| %>
        <div class="flex gap-4" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-500 text-white flex items-center justify-center text-lg font-bold shadow-lg shadow-orange-500/20">
            <%= step[:num] %>
          </div>
          <div>
            <h3 class="text-base font-bold text-gray-900 mb-1"><%= step[:title] %></h3>
            <p class="text-gray-500 text-sm leading-relaxed"><%= step[:desc] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    FEATURED SERVICES — Cards with hover lift
    ================================================================ %>
<% if @featured_services.any? %>
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-14" data-aos="fade-up">
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-orange-50 text-orange-600 border border-orange-100 uppercase tracking-wider mb-4">New Listings</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Recently Added</h2>
        <p class="mt-3 text-gray-500">Fresh services from our newest providers.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to services_path, class: "inline-flex items-center gap-2 text-orange-600 font-semibold hover:text-orange-700 transition-colors group text-sm" do %>
          See all <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-7">
      <% @featured_services.each_with_index do |service, i| %>
        <%= link_to service_path(service), class: "group block rounded-2xl bg-white border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300", data: { aos: "fade-up", "aos-delay": i * 100 } do %>
          <div class="aspect-[16/10] relative overflow-hidden bg-gray-100">
            <% if service.images.attached? %>
              <%= image_tag service.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", loading: "lazy" %>
            <% else %>
              <img src="<%= service_images[service.category&.slug] || 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80' %>"
                   alt="<%= service.title %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                   loading="lazy">
            <% end %>
            <div class="absolute top-3 right-3 bg-white rounded-xl px-3 py-1.5 shadow-lg">
              <span class="text-base font-bold text-gray-900">$<%= number_with_precision(service.base_price, precision: 0) %></span>
              <span class="text-xs text-gray-400"><%= service.hourly? ? "/hr" : "" %></span>
            </div>
          </div>

          <div class="p-5">
            <div class="flex items-center gap-2 mb-2.5">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700 border border-orange-100">
                <%= service.category&.name || "Uncategorized" %>
              </span>
              <% if service.provider&.verified? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100">
                  <i class="fas fa-check-circle mr-1"></i>Verified
                </span>
              <% end %>
            </div>

            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1"><%= service.title %></h3>
            <p class="text-sm text-gray-500 mt-1.5 line-clamp-2 leading-relaxed"><%= service.description %></p>

            <div class="mt-4 flex items-center justify-between pt-4 border-t border-gray-100">
              <div class="flex items-center gap-2.5">
                <div class="w-7 h-7 rounded-full bg-orange-100 flex items-center justify-center text-xs font-bold text-orange-600">
                  <%= service.provider&.display_name&.first&.upcase || "?" %>
                </div>
                <span class="text-sm text-gray-600 font-medium"><%= service.provider&.display_name %></span>
              </div>
              <span class="text-xs text-orange-500 font-semibold opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
                View <i class="fas fa-arrow-right text-[10px]"></i>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-10 sm:hidden">
      <%= link_to services_path, class: "inline-flex items-center gap-2 text-orange-600 font-semibold" do %>
        View all services <i class="fas fa-arrow-right text-xs"></i>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# ================================================================
    TOP PROVIDERS — Soft gray with warm accent
    ================================================================ %>
<% if @top_providers.present? && @top_providers.any? %>
<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-14" data-aos="fade-up">
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-600 border border-amber-100 uppercase tracking-wider mb-4">
          <i class="fas fa-trophy mr-1.5"></i>Top Rated
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Meet Our Best Providers</h2>
        <p class="mt-3 text-gray-500">Highly rated professionals trusted by the community.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to leaderboard_index_path, class: "inline-flex items-center gap-2 text-orange-600 font-semibold hover:text-orange-700 transition-colors group text-sm" do %>
          View leaderboard <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @top_providers.each_with_index do |provider, index| %>
        <%= link_to leaderboard_path(provider), class: "group block bg-white rounded-2xl border #{index == 0 ? 'border-orange-200 ring-1 ring-orange-100' : 'border-gray-100'} p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center", data: { aos: "fade-up", "aos-delay": index * 100 } do %>
          <div class="flex justify-center mb-4">
            <% if index == 0 %>
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 text-white flex items-center justify-center shadow-lg shadow-amber-500/25">
                <i class="fas fa-trophy text-sm"></i>
              </div>
            <% else %>
              <div class="w-10 h-10 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center text-xs font-bold">
                #<%= index + 1 %>
              </div>
            <% end %>
          </div>

          <div class="flex justify-center mb-4">
            <% if provider.profile_picture.attached? %>
              <%= image_tag provider.profile_picture, class: "w-16 h-16 rounded-2xl object-cover ring-2 ring-gray-100" %>
            <% else %>
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-100 to-orange-50 flex items-center justify-center text-xl font-bold text-orange-600 ring-2 ring-orange-100">
                <%= provider.display_name.first.upcase %>
              </div>
            <% end %>
          </div>

          <h3 class="font-semibold text-gray-900 group-hover:text-orange-600 transition-colors mb-2 line-clamp-1">
            <%= provider.business_name || provider.full_name %>
          </h3>

          <% badge = provider.provider_badge %>
          <% if badge %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= badge[:color] %>-50 text-<%= badge[:color] %>-700 border border-<%= badge[:color] %>-100 mb-3">
              <i class="<%= badge[:icon] %> mr-1"></i><%= badge[:name] %>
            </span>
          <% end %>

          <div class="flex items-center justify-center gap-0.5 mb-1">
            <% 5.times do |i| %>
              <i class="fas fa-star text-xs <%= i < provider.average_rating.round ? 'text-amber-400' : 'text-gray-200' %>"></i>
            <% end %>
            <span class="text-sm font-semibold text-gray-900 ml-1.5"><%= provider.average_rating %></span>
          </div>
          <div class="text-xs text-gray-400 mt-1"><%= provider.total_completed_bookings %> jobs completed</div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-10 sm:hidden">
      <%= link_to leaderboard_index_path, class: "inline-flex items-center gap-2 text-orange-600 font-semibold" do %>
        View all providers <i class="fas fa-arrow-right text-xs"></i>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# ================================================================
    PROVIDERS NEAR YOU — Warm background with radar motif
    ================================================================ %>
<section class="py-24 bg-gradient-to-b from-orange-50/50 to-white relative overflow-hidden" id="nearby-section">
  <%# Decorative rings %>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none">
    <div class="w-[400px] h-[400px] rounded-full border border-orange-200/30"></div>
  </div>
