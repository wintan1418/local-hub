<%# ================================================================
    HERO SLIDER (vanilla JS)
    ================================================================ %>
<script>
(function() {
  var slides = document.querySelectorAll('[data-slide]');
  var dots = document.querySelectorAll('[data-dot]');
  if (!slides.length) return;

  var current = 0;
  var interval;

  function goTo(index) {
    slides[current].classList.remove('opacity-100');
    slides[current].classList.add('opacity-0');
    if (dots[current]) {
      dots[current].classList.remove('bg-orange-500', 'w-8');
      dots[current].classList.add('bg-white/30', 'w-4');
    }
    current = index % slides.length;
    slides[current].classList.remove('opacity-0');
    slides[current].classList.add('opacity-100');
    if (dots[current]) {
      dots[current].classList.remove('bg-white/30', 'w-4');
      dots[current].classList.add('bg-orange-500', 'w-8');
    }
  }

  function startAutoplay() {
    interval = setInterval(function() { goTo(current + 1); }, 5000);
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      clearInterval(interval);
      goTo(parseInt(this.dataset.index));
      startAutoplay();
    });
  });

  startAutoplay();
})();
</script>

<%# ================================================================
    NEARBY PROVIDERS (vanilla JS)
    ================================================================ %>
<script>
var NEARBY_RADIUS = 25;

function nearbyShow(id) {
  ['nearby-prompt','nearby-loading','nearby-error','nearby-results'].forEach(function(s) {
    var el = document.getElementById(s);
    if (el) el.classList.add('hidden');
  });
  var target = document.getElementById(id);
  if (target) target.classList.remove('hidden');
}

function nearbyDetect() {
  if (!navigator.geolocation) {
    nearbyShowError('Geolocation is not supported by your browser.');
    return;
  }
  nearbyShow('nearby-loading');
  navigator.geolocation.getCurrentPosition(
    function(pos) { nearbyFetch(pos.coords.latitude, pos.coords.longitude); },
    function(err) {
      var msgs = {
        1: 'Location access was denied. Enable location in your browser settings and try again.',
        2: 'Could not determine your location. Please try again.',
        3: 'Location request timed out. Please try again.'
      };
      nearbyShowError(msgs[err.code] || 'Could not get your location.');
    },
    { enableHighAccuracy: false, timeout: 10000, maximumAge: 300000 }
  );
}

function nearbyShowError(msg) {
  nearbyShow('nearby-error');
  var el = document.getElementById('nearby-error-msg');
  if (el) el.textContent = msg;
}

function nearbyFetch(lat, lng) {
  fetch('/api/nearby_providers?lat=' + lat + '&lng=' + lng + '&radius=' + NEARBY_RADIUS)
    .then(function(r) { return r.json(); })
    .then(function(providers) {
      if (!providers || providers.error || providers.length === 0) {
        nearbyShowError('No providers found within ' + NEARBY_RADIUS + ' miles. Try again later.');
        return;
      }
      nearbyRender(providers);
    })
    .catch(function() {
      nearbyShowError('Could not load nearby providers. Please try again.');
    });
}

function nearbyEscape(str) {
  if (!str) return '';
  var div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

function nearbyRender(providers) {
  nearbyShow('nearby-results');
  var grid = document.getElementById('nearby-grid');
  if (!grid) return;

  var badgeColors = {
    purple: { bg: '#faf5ff', text: '#7e22ce', border: '#f3e8ff' },
    blue:   { bg: '#eff6ff', text: '#1d4ed8', border: '#dbeafe' },
    green:  { bg: '#f0fdf4', text: '#15803d', border: '#dcfce7' },
    yellow: { bg: '#fefce8', text: '#a16207', border: '#fef9c3' },
    gray:   { bg: '#f9fafb', text: '#6b7280', border: '#f3f4f6' }
  };

  grid.innerHTML = providers.map(function(p) {
    var initial = (p.display_name || '?')[0].toUpperCase();
    var avatar = p.profile_picture_url
      ? '<img src="' + p.profile_picture_url + '" alt="' + nearbyEscape(p.display_name) + '" class="w-14 h-14 rounded-2xl object-cover ring-2 ring-gray-100">'
      : '<div class="w-14 h-14 rounded-2xl bg-orange-100 flex items-center justify-center text-lg font-bold text-orange-600">' + initial + '</div>';

    var stars = '';
    for (var i = 0; i < 5; i++) {
      stars += '<i class="fas fa-star text-xs ' + (i < Math.round(p.average_rating) ? 'text-amber-400' : 'text-gray-200') + '"></i>';
    }

    var bc = p.badge ? (badgeColors[p.badge.color] || badgeColors.gray) : null;
    var badge = p.badge
      ? '<div class="mt-2"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium" style="background:' + bc.bg + ';color:' + bc.text + ';border:1px solid ' + bc.border + '"><i class="' + nearbyEscape(p.badge.icon) + ' mr-1"></i>' + nearbyEscape(p.badge.name) + '</span></div>'
      : '';

    var name = nearbyEscape(p.business_name || p.display_name);
    return '<a href="' + p.url + '" class="group block bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">'
      + '<div class="flex items-start gap-4">'
      + '<div class="flex-shrink-0">' + avatar + '</div>'
      + '<div class="flex-1 min-w-0">'
      + '<h4 class="font-semibold text-gray-900 group-hover:text-orange-600 transition-colors truncate text-sm">' + name + '</h4>'
      + '<div class="flex items-center gap-1 mt-1">' + stars + '<span class="text-xs text-gray-400 ml-1">' + p.average_rating + '</span></div>'
      + '<div class="flex items-center gap-3 mt-2 text-xs text-gray-500">'
      + '<span><i class="fas fa-location-dot text-orange-400 mr-1"></i>' + p.distance + ' mi</span>'
      + '<span><i class="fas fa-check-circle text-green-400 mr-1"></i>' + p.total_completed_bookings + ' jobs</span>'
      + '</div>'
      + badge
      + '</div></div></a>';
  }).join('');
}
</script>
