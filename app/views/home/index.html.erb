<%# ================================================================
    HERO BUBBLES STYLES (scoped) + JS
    ================================================================ %>
<style>
  /* Falling pro-bubbles — light-mode tuned for the hero card */
  #particle-canvas .pro-bubble {
    position: absolute;
    will-change: transform, opacity;
    pointer-events: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    animation: bubbleFall linear infinite, bubbleDrift ease-in-out infinite, bubbleTwinkle ease-in-out infinite;
    box-shadow: 0 2px 8px rgba(26, 26, 23, 0.06);
    border: 1px solid #e3ddd0;
    background: #ffffff;
  }
  #particle-canvas .pro-bubble img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    opacity: 0.85;
  }
  #particle-canvas .pro-bubble .bubble-icon {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 42%;
    height: 42%;
    border-radius: 50%;
    background: #1a1a17;
    border: 1.5px solid #f7f4ee;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 45%;
    color: #f7f4ee;
  }
  #particle-canvas .pro-bubble .bubble-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid rgba(31, 77, 58, 0.3);
    animation: ringPulse 4s ease-in-out infinite;
  }
  @keyframes bubbleFall {
    0% { transform: translateY(-120px); }
    100% { transform: translateY(calc(100% + 120px)); }
  }
  @keyframes bubbleDrift {
    0%, 100% { margin-left: 0; }
    25% { margin-left: 12px; }
    50% { margin-left: -8px; }
    75% { margin-left: 16px; }
  }
  @keyframes bubbleTwinkle {
    0%, 100% { opacity: var(--base-opacity, 0.65); }
    50% { opacity: calc(var(--base-opacity, 0.65) * 1.15); }
  }
  @keyframes ringPulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.18); opacity: 0.7; }
  }

  /* Hero entrance */
  .hero-reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: heroReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }
  @keyframes heroReveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
(function() {
  var canvas = document.getElementById('particle-canvas');
  if (!canvas) return;

  var pros = [
    { img: 'https://i.pravatar.cc/96?u=p1', icon: 'fa-wrench' },
    { img: 'https://i.pravatar.cc/96?u=p2', icon: 'fa-broom' },
    { img: 'https://i.pravatar.cc/96?u=p3', icon: 'fa-bolt' },
    { img: 'https://i.pravatar.cc/96?u=p4', icon: 'fa-paint-roller' },
    { img: 'https://i.pravatar.cc/96?u=p5', icon: 'fa-leaf' },
    { img: 'https://i.pravatar.cc/96?u=p6', icon: 'fa-dumbbell' },
    { img: 'https://i.pravatar.cc/96?u=p7', icon: 'fa-hammer' },
    { img: 'https://i.pravatar.cc/96?u=p8', icon: 'fa-graduation-cap' },
    { img: 'https://i.pravatar.cc/96?u=p9', icon: 'fa-truck' },
    { img: 'https://i.pravatar.cc/96?u=p10', icon: 'fa-paw' },
    { img: 'https://i.pravatar.cc/96?u=p11', icon: 'fa-wrench' },
    { img: 'https://i.pravatar.cc/96?u=p12', icon: 'fa-broom' },
    { img: 'https://i.pravatar.cc/96?u=p13', icon: 'fa-bolt' },
    { img: 'https://i.pravatar.cc/96?u=p14', icon: 'fa-paint-roller' },
    { img: 'https://i.pravatar.cc/96?u=p15', icon: 'fa-hammer' }
  ];

  var BUBBLE_COUNT = 16;

  function createBubble(initial) {
    var pro = pros[Math.floor(Math.random() * pros.length)];
    var size = 38 + Math.floor(Math.random() * 30);
    var left = Math.random() * 100;
    var fallDuration = 14 + Math.random() * 18;
    var driftDuration = 6 + Math.random() * 8;
    var twinkleDuration = 3 + Math.random() * 5;
    var delay = initial ? -(Math.random() * fallDuration) : 0;
    var baseOpacity = 0.55 + Math.random() * 0.35;
    var hasRing = Math.random() > 0.55;
    var hasIcon = Math.random() > 0.3;

    var bubble = document.createElement('div');
    bubble.className = 'pro-bubble';
    bubble.style.cssText = 'width:' + size + 'px;height:' + size + 'px;left:' + left + '%;'
      + 'animation-duration:' + fallDuration + 's,' + driftDuration + 's,' + twinkleDuration + 's;'
      + 'animation-delay:' + delay + 's,' + (-Math.random() * driftDuration) + 's,' + (-Math.random() * twinkleDuration) + 's;'
      + '--base-opacity:' + baseOpacity + ';';

    var img = document.createElement('img');
    img.src = pro.img;
    img.loading = 'lazy';
    img.alt = '';
    bubble.appendChild(img);

    if (hasIcon) {
      var icon = document.createElement('div');
      icon.className = 'bubble-icon';
      icon.innerHTML = '<i class="fas ' + pro.icon + '"></i>';
      bubble.appendChild(icon);
    }
    if (hasRing) {
      var ring = document.createElement('div');
      ring.className = 'bubble-ring';
      ring.style.animationDelay = (-Math.random() * 4) + 's';
      bubble.appendChild(ring);
    }

    canvas.appendChild(bubble);

    bubble.addEventListener('animationiteration', function handler(e) {
      if (e.animationName === 'bubbleFall') {
        bubble.removeEventListener('animationiteration', handler);
        bubble.remove();
        createBubble(false);
      }
    });
  }

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    for (var i = 0; i < BUBBLE_COUNT; i++) {
      createBubble(true);
    }
  }
})();
</script>
