<%# ========== HERO WITH IMAGE SLIDER ========== %>
<section class="relative min-h-[600px] lg:min-h-[700px] flex items-center overflow-hidden" id="hero"
         data-controller="hero-slider">
  <%# Sliding background images %>
  <div class="absolute inset-0">
    <% hero_images.each_with_index do |img, i| %>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 <%= i == 0 ? 'opacity-100' : 'opacity-0' %>"
           data-hero-slider-target="slide">
        <img src="<%= img %>" alt="" class="w-full h-full object-cover" loading="<%= i == 0 ? 'eager' : 'lazy' %>">
      </div>
    <% end %>
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 via-gray-900/75 to-gray-900/50"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-orange-500/20 border border-orange-500/30 mb-6">
          <span class="w-2 h-2 bg-orange-400 rounded-full mr-2"></span>
          <span class="text-orange-300 text-sm font-medium">Trusted Local Service Marketplace</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight">
          Find trusted pros<br>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">for any job.</span>
        </h1>

        <p class="mt-6 text-lg text-gray-300 max-w-xl leading-relaxed">
          Connect with verified, reviewed professionals in your area. Book with confidence and get the job done right.
        </p>

        <%# Functional search bar %>
        <div class="mt-8">
          <%= form_tag services_path, method: :get, class: "flex flex-col sm:flex-row gap-3" do %>
            <div class="relative flex-1">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-search text-gray-400"></i>
              </div>
              <%= text_field_tag :query, nil,
                  placeholder: "What service do you need?",
                  class: "w-full pl-11 pr-4 py-4 bg-white rounded-xl text-gray-900 placeholder-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-orange-500 shadow-lg" %>
            </div>
            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-xl font-semibold text-base transition-colors shadow-lg shadow-orange-500/25 whitespace-nowrap">
              Search
            </button>
          <% end %>
        </div>

        <%# Quick category links %>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="text-gray-400 text-sm py-1">Popular:</span>
          <% @categories.limit(5).each do |category| %>
            <%= link_to category.name, services_path(category_id: category.id),
                class: "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-gray-300 hover:bg-white/20 hover:text-white transition-colors" %>
          <% end %>
        </div>
      </div>

      <%# Right side - stats cards (visible on lg+) %>
      <div class="hidden lg:block">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
            <div class="text-3xl font-bold text-white"><%= number_with_delimiter(@total_providers) %>+</div>
            <div class="text-sm text-gray-300 mt-1">Service Providers</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
            <div class="text-3xl font-bold text-white"><%= number_with_delimiter(@total_services) %>+</div>
            <div class="text-sm text-gray-300 mt-1">Services Listed</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
            <div class="text-3xl font-bold text-white"><%= number_with_delimiter(@total_bookings) %>+</div>
            <div class="text-sm text-gray-300 mt-1">Bookings Made</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
            <div class="text-3xl font-bold text-white"><%= number_with_delimiter(@total_customers) %>+</div>
            <div class="text-sm text-gray-300 mt-1">Happy Customers</div>
          </div>
        </div>
      </div>
    </div>

    <%# Mobile stats row %>
    <div class="lg:hidden grid grid-cols-2 sm:grid-cols-4 gap-4 mt-12 border-t border-white/10 pt-8">
      <div>
        <div class="text-2xl font-bold text-white"><%= number_with_delimiter(@total_providers) %>+</div>
        <div class="text-xs text-gray-400 mt-1">Providers</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= number_with_delimiter(@total_services) %>+</div>
        <div class="text-xs text-gray-400 mt-1">Services</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= number_with_delimiter(@total_bookings) %>+</div>
        <div class="text-xs text-gray-400 mt-1">Bookings</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= number_with_delimiter(@total_customers) %>+</div>
        <div class="text-xs text-gray-400 mt-1">Customers</div>
      </div>
    </div>
  </div>

  <%# Slide indicators %>
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex gap-2">
    <% hero_images.size.times do |i| %>
      <button class="w-2 h-2 rounded-full transition-all duration-300 <%= i == 0 ? 'bg-white w-6' : 'bg-white/40' %>"
              data-hero-slider-target="dot"
              data-action="click->hero-slider#goTo"
              data-index="<%= i %>"></button>
    <% end %>
  </div>
</section>

<%# ========== CATEGORIES WITH IMAGES ========== %>
<section class="py-20 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Browse by Category</h2>
      <p class="mt-4 text-lg text-gray-500">Whatever you need done, we have the right professional for the job.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      <% @categories.each do |category| %>
        <%= link_to services_path(category_id: category.id),
            class: "group relative rounded-2xl overflow-hidden aspect-[4/3]" do %>
          <%# Category image %>
          <img src="<%= category_images[category.slug] || 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&q=80' %>"
               alt="<%= category.name %>"
               class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
               loading="lazy">
          <%# Gradient overlay %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <%# Content %>
          <div class="absolute inset-0 flex flex-col justify-end p-4">
            <div class="flex items-center gap-2 mb-1">
              <i class="<%= category.icon.presence || 'fas fa-concierge-bell' %> text-white text-sm"></i>
            </div>
            <h3 class="text-white font-bold text-sm sm:text-base"><%= category.name %></h3>
            <span class="text-gray-300 text-xs"><%= category.services.count %> services</span>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-10">
      <%= link_to services_path, class: "inline-flex items-center text-orange-600 font-semibold hover:text-orange-700 transition-colors" do %>
        View all services
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>
</section>

<%# ========== HOW IT WORKS (fixed layout, no overlapping line) ========== %>
<section class="py-20 bg-gray-50" id="how-it-works">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">How It Works</h2>
      <p class="mt-4 text-lg text-gray-500">Get help in three simple steps. It's that easy.</p>
    </div>

    <div class="max-w-4xl mx-auto">
      <%# Desktop: steps with dashed line connecting the numbers %>
      <div class="hidden md:block relative">
        <%# Connector line - positioned at the center of the step numbers %>
        <div class="absolute top-8 left-[calc(16.67%)] right-[calc(16.67%)] flex items-center" aria-hidden="true">
          <div class="w-full border-t-2 border-dashed border-orange-200"></div>
        </div>

        <div class="relative grid grid-cols-3 gap-12">
          <% [
            { num: 1, title: "Search & Compare", desc: "Browse verified professionals in your area. Compare ratings, prices, and reviews to find the perfect match.", icon: "fa-search" },
            { num: 2, title: "Book Instantly", desc: "Schedule a service at a time that works for you. Chat directly with providers and get instant confirmation.", icon: "fa-calendar-check" },
            { num: 3, title: "Get It Done", desc: "Sit back while a trusted pro handles the work. Pay securely through the platform and leave a review.", icon: "fa-check-double" }
          ].each do |step| %>
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center w-16 h-16 rounded-full bg-orange-500 text-white text-xl font-bold mb-6 ring-4 ring-gray-50 z-10">
                <%= step[:num] %>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3"><%= step[:title] %></h3>
              <p class="text-gray-500 leading-relaxed text-sm"><%= step[:desc] %></p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Mobile: vertical timeline %>
      <div class="md:hidden space-y-8">
        <% [
          { num: 1, title: "Search & Compare", desc: "Browse verified professionals in your area. Compare ratings, prices, and reviews to find the perfect match." },
          { num: 2, title: "Book Instantly", desc: "Schedule a service at a time that works for you. Chat directly with providers and get instant confirmation." },
          { num: 3, title: "Get It Done", desc: "Sit back while a trusted pro handles the work. Pay securely through the platform and leave a review." }
        ].each do |step| %>
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 rounded-full bg-orange-500 text-white flex items-center justify-center text-lg font-bold"><%= step[:num] %></div>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-1"><%= step[:title] %></h3>
              <p class="text-gray-500 leading-relaxed text-sm"><%= step[:desc] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ========== FEATURED SERVICES WITH IMAGES ========== %>
<% if @featured_services.any? %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Recently Added</h2>
        <p class="mt-3 text-lg text-gray-500">Fresh services from our newest providers.</p>
      </div>
      <div class="hidden sm:block">
        <%= link_to services_path, class: "inline-flex items-center text-orange-600 font-semibold hover:text-orange-700 transition-colors" do %>
          See all
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_services.each do |service| %>
        <%= link_to service_path(service), class: "group block rounded-2xl border border-gray-100 bg-white overflow-hidden hover:shadow-lg hover:border-gray-200 transition-all duration-200" do %>
          <%# Service image %>
          <div class="aspect-[16/10] relative overflow-hidden bg-gray-100">
            <% if service.images.attached? %>
              <%= image_tag service.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", loading: "lazy" %>
            <% else %>
              <img src="<%= service_images[service.category&.slug] || 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80' %>"
                   alt="<%= service.title %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                   loading="lazy">
            <% end %>
            <%# Price badge %>
            <div class="absolute top-3 right-3 bg-white/95 backdrop-blur-sm rounded-lg px-3 py-1 shadow-sm">
              <span class="text-base font-bold text-gray-900">$<%= number_with_precision(service.base_price, precision: 0) %></span>
              <span class="text-xs text-gray-500"><%= service.hourly? ? "/hr" : "" %></span>
            </div>
          </div>

          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700">
                <%= service.category&.name || "Uncategorized" %>
              </span>
              <% if service.provider&.verified? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                  <i class="fas fa-check-circle mr-1"></i>Verified
                </span>
              <% end %>
            </div>

            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1"><%= service.title %></h3>
            <p class="text-sm text-gray-500 mt-1 line-clamp-2"><%= service.description %></p>

            <div class="mt-4 flex items-center gap-2 pt-4 border-t border-gray-50">
              <div class="w-7 h-7 rounded-full bg-orange-100 flex items-center justify-center text-xs font-semibold text-orange-600">
                <%= service.provider&.display_name&.first&.upcase || "?" %>
              </div>
              <span class="text-sm text-gray-600 font-medium"><%= service.provider&.display_name %></span>
              <% if service.provider&.verified? %>
                <i class="fas fa-check-circle text-blue-500 text-xs"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center mt-8 sm:hidden">
      <%= link_to services_path, class: "inline-flex items-center text-orange-600 font-semibold hover:text-orange-700 transition-colors" do %>
        View all services
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# ========== WHY CHOOSE US ========== %>
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Why Choose LocalServiceHub</h2>
      <p class="mt-4 text-lg text-gray-500">Built for trust, designed for simplicity.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% [
        { icon: "fa-shield-alt", color_bg: "bg-blue-50", color_text: "text-blue-600", title: "Verified Professionals", desc: "Every provider goes through our verification process including document checks and identity verification." },
        { icon: "fa-lock", color_bg: "bg-green-50", color_text: "text-green-600", title: "Secure Payments", desc: "Pay safely through Stripe-powered payments. Your financial information is always protected." },
        { icon: "fa-star", color_bg: "bg-amber-50", color_text: "text-amber-600", title: "Honest Reviews", desc: "Real reviews from real customers. Only people who booked a service can leave a rating." },
        { icon: "fa-comments", color_bg: "bg-purple-50", color_text: "text-purple-600", title: "Direct Messaging", desc: "Chat directly with providers before booking. Discuss details, ask questions, and build trust." }
      ].each do |item| %>
        <div class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-md transition-shadow duration-200">
          <div class="w-12 h-12 rounded-xl <%= item[:color_bg] %> <%= item[:color_text] %> flex items-center justify-center mb-4">
            <i class="fas <%= item[:icon] %> text-xl"></i>
          </div>
          <h3 class="text-base font-bold text-gray-900 mb-2"><%= item[:title] %></h3>
          <p class="text-sm text-gray-500 leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== TESTIMONIALS ========== %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">What Our Customers Say</h2>
      <p class="mt-4 text-lg text-gray-500">Real stories from people who found the help they needed.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <% [
        { name: "Sarah Johnson", role: "Homeowner", review: "Found an amazing plumber within minutes. Fixed my emergency leak the same day. The booking process was seamless.", rating: 5 },
        { name: "Mike Chen", role: "Business Owner", review: "We use LocalServiceHub for all our office maintenance. Reliable providers, fair prices, and great communication.", rating: 5 },
        { name: "Emily Rodriguez", role: "Property Manager", review: "Managing multiple properties is so much easier now. All my trusted contractors in one place with easy scheduling.", rating: 5 }
      ].each do |testimonial| %>
        <div class="bg-gray-50 rounded-2xl p-8">
          <div class="flex gap-1 mb-4">
            <% testimonial[:rating].times do %>
              <i class="fas fa-star text-amber-400"></i>
            <% end %>
          </div>
          <blockquote class="text-gray-700 leading-relaxed mb-6">"<%= testimonial[:review] %>"</blockquote>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center font-semibold text-sm">
              <%= testimonial[:name].split.map(&:first).join %>
            </div>
            <div>
              <div class="text-sm font-semibold text-gray-900"><%= testimonial[:name] %></div>
              <div class="text-xs text-gray-500"><%= testimonial[:role] %></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== CTA FOR PROVIDERS (with image) ========== %>
<section class="relative overflow-hidden">
  <div class="grid lg:grid-cols-2">
    <%# Image side %>
    <div class="relative hidden lg:block min-h-[500px]">
      <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1200&q=80"
           alt="Service professional at work"
           class="absolute inset-0 w-full h-full object-cover"
           loading="lazy">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent to-gray-900/20"></div>
    </div>

    <%# Content side %>
    <div class="bg-gray-900 py-20 px-8 sm:px-12 lg:px-16">
      <p class="text-orange-400 font-semibold text-sm tracking-wide uppercase mb-4">For Service Providers</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight">Grow your business with LocalServiceHub</h2>
      <p class="mt-4 text-lg text-gray-400 leading-relaxed">Join our network of trusted professionals. Get discovered by new customers, manage bookings, and build your reputation.</p>

      <ul class="mt-8 space-y-4">
        <% [
          "Get found by customers searching in your area",
          "Manage bookings and schedule from one dashboard",
          "Build credibility with verified badges and real reviews",
          "Start free — upgrade only when you're ready"
        ].each do |benefit| %>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-orange-500/20 text-orange-400 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fas fa-check text-xs"></i>
            </div>
            <span class="text-gray-300"><%= benefit %></span>
          </li>
        <% end %>
      </ul>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <% if user_signed_in? %>
          <% if current_user.provider? %>
