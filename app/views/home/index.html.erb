<%# ================================================================
    HERO ANIMATIONS — entrance + provider deck slider
    ================================================================ %>
<style>
  .hero-reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: heroReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }
  @keyframes heroReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Provider deck — glass-shatter showcase */
  .provider-slide {
    opacity: 0;
    pointer-events: none;
  }
  .provider-slide.is-active {
    opacity: 1;
    pointer-events: auto;
    animation: revealZoom 1.1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Initial slide skips the reveal animation */
  .provider-slide.is-active.is-initial {
    animation: none;
  }
  @keyframes revealZoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1); }
  }

  /* Subtle Ken Burns drift on active image */
  .provider-slide.is-active img {
    animation: kenBurns 8s ease-out forwards;
  }
  @keyframes kenBurns {
    from { transform: scale(1.04); }
    to   { transform: scale(1); }
  }

  /* Shatter shards — single bg-image clipped to triangles */
  .shatter-layer .shard {
    position: absolute;
    inset: 0;
    background-size: 100% 100%;
    background-repeat: no-repeat;
    will-change: transform, opacity, filter;
    /* Subtle inner edge to read as glass */
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.18));
  }

  /* Bright flash burst on impact */
  .shatter-flash {
    background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.35) 35%, transparent 65%);
    opacity: 0;
    mix-blend-mode: screen;
  }
  .shatter-flash.flashing {
    animation: shatterFlash 280ms cubic-bezier(0.4, 0, 0.6, 1);
  }
  @keyframes shatterFlash {
    0% { opacity: 0; }
    15% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Crack lines drawn at impact moment */
  .crack-lines {
    position: absolute;
    inset: 0;
    z-index: 28;
    pointer-events: none;
    opacity: 0;
  }
  .crack-lines.cracking {
    animation: crackFlash 180ms ease-out;
  }
  @keyframes crackFlash {
    0% { opacity: 0; }
    20% { opacity: 0.9; }
    100% { opacity: 0; }
  }

  .deck-dot { transition: all 0.4s ease; cursor: pointer; }

  /* Chip swap animation — fires when content updates with each shatter */
  .chip-inner {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s ease-out;
  }
  .chip-inner.is-swapping {
    opacity: 0;
    transform: translateY(10px) scale(0.94);
  }
</style>

<script>
(function() {
  var deck = document.getElementById('provider-deck');
  if (!deck) return;
  var slides = deck.querySelectorAll('.provider-slide');
  var dots = deck.querySelectorAll('.deck-dot');
  var noLabel = document.getElementById('deck-no');
  var shatterLayer = document.getElementById('shatter-layer');
  var flashEl = document.getElementById('shatter-flash');
  var cracksEl = document.getElementById('crack-lines');
  if (slides.length < 2 || !shatterLayer) return;

  var current = 0;
  var interval = 5500;
  var timer;
  var transitioning = false;

  // Build a triangle mesh of clip-paths covering the card.
  // Each cell becomes 2 triangles with a randomly-flipped diagonal so the
  // mesh doesn't look like a uniform grid.
  function buildShards() {
    var ROWS = 4, COLS = 4;
    var shards = [];
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var x1 = (c / COLS) * 100;
        var x2 = ((c + 1) / COLS) * 100;
        var y1 = (r / ROWS) * 100;
        var y2 = ((r + 1) / ROWS) * 100;
        var flip = Math.random() > 0.5;
        var polyA = flip
          ? 'polygon(' + x1 + '% ' + y1 + '%, ' + x2 + '% ' + y1 + '%, ' + x2 + '% ' + y2 + '%)'
          : 'polygon(' + x1 + '% ' + y1 + '%, ' + x2 + '% ' + y1 + '%, ' + x1 + '% ' + y2 + '%)';
        var polyB = flip
          ? 'polygon(' + x1 + '% ' + y1 + '%, ' + x2 + '% ' + y2 + '%, ' + x1 + '% ' + y2 + '%)'
          : 'polygon(' + x2 + '% ' + y1 + '%, ' + x2 + '% ' + y2 + '%, ' + x1 + '% ' + y2 + '%)';
        shards.push({ clip: polyA, cx: (x1 + x2) / 2, cy: (y1 + y2) / 2 });
        shards.push({ clip: polyB, cx: (x1 + x2) / 2, cy: (y1 + y2) / 2 });
      }
    }
    return shards;
  }

  function shatter(leavingSlide, onDone) {
    var img = leavingSlide.querySelector('img');
    if (!img || !img.src) { onDone(); return; }

    shatterLayer.innerHTML = '';
    var shards = buildShards();

    shards.forEach(function(s) {
      var el = document.createElement('div');
      el.className = 'shard';
      el.style.backgroundImage = 'url("' + img.src + '")';
      el.style.clipPath = s.clip;
      el.style.webkitClipPath = s.clip;
      el.style.transform = 'translate(0, 0) rotate(0)';
      el.style.opacity = '1';
      shatterLayer.appendChild(el);

      // Direction outward from card center, with gravity drag and slight randomness
      var dx = (s.cx - 50) * 5 + (Math.random() - 0.5) * 90;
      var dy = (s.cy - 50) * 5 + 90 + (Math.random() - 0.5) * 70;
      var rot = (Math.random() - 0.5) * 90;
      var delay = Math.random() * 70;
      var dur = 850 + Math.random() * 200;

      requestAnimationFrame(function() {
        el.style.transition =
          'transform ' + dur + 'ms cubic-bezier(0.4, 0.05, 0.7, 1) ' + delay + 'ms, ' +
          'opacity 700ms ease-in ' + (delay + 250) + 'ms';
        el.style.transform = 'translate(' + dx + 'px, ' + dy + 'px) rotate(' + rot + 'deg)';
        el.style.opacity = '0';
      });
    });

    // Trigger flash + crack lines simultaneously
    if (flashEl) {
      flashEl.classList.remove('flashing');
      void flashEl.offsetWidth; // restart animation
      flashEl.classList.add('flashing');
    }
    if (cracksEl) {
      cracksEl.classList.remove('cracking');
      void cracksEl.offsetWidth;
      cracksEl.classList.add('cracking');
    }

    setTimeout(function() {
      shatterLayer.innerHTML = '';
      if (flashEl) flashEl.classList.remove('flashing');
      if (cracksEl) cracksEl.classList.remove('cracking');
      onDone();
    }, 1200);
  }

  function updateChrome(idx) {
    dots.forEach(function(d, i) {
      if (i === idx) {
        d.classList.add('w-6', 'bg-cream');
        d.classList.remove('bg-cream/40');
      } else {
        d.classList.remove('w-6', 'bg-cream');
        d.classList.add('bg-cream/40');
      }
    });
    if (noLabel) noLabel.textContent = String(idx + 1).padStart(2, '0');
  }

  // Swap chip content (booking pill + review pill) to match the new slide
  var chipBookingEl = document.getElementById('chip-booking');
  var chipReviewEl = document.getElementById('chip-review');

  function updateChips(idx) {
    var slide = slides[idx];
    if (!slide) return;
    var data = slide.dataset;
    var pairs = [
      [ chipBookingEl, [ [ 'b_when', data.bWhen ], [ 'b_meta', data.bMeta ] ] ],
      [ chipReviewEl,  [ [ 'r_initial', data.rInitial ], [ 'r_quote', data.rQuote ], [ 'r_when', data.rWhen ] ] ]
    ];
    pairs.forEach(function(pair) {
      var chip = pair[0];
      if (!chip) return;
      var inner = chip.querySelector('.chip-inner');
      if (!inner) return;

      // Animate chip out, swap text, animate back in
      inner.classList.add('is-swapping');
      setTimeout(function() {
        pair[1].forEach(function(kv) {
          var node = chip.querySelector('[data-chip="' + kv[0] + '"]');
          if (node && kv[1] != null) node.textContent = kv[1];
        });
        inner.classList.remove('is-swapping');
      }, 350);
    });
  }

  function goTo(idx) {
    if (idx === current || transitioning) return;
    transitioning = true;
    var leaving = slides[current];
    var entering = slides[idx];

    // Reveal incoming slide underneath the shards
    entering.classList.remove('is-initial');
    entering.classList.add('is-active');

    // Kick off chip swap right with the shatter — feels like a single beat
    updateChips(idx);

    shatter(leaving, function() {
      leaving.classList.remove('is-active');
      transitioning = false;
    });

    updateChrome(idx);
    current = idx;
  }

  function next() { goTo((current + 1) % slides.length); }

  function start() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    timer = setInterval(next, interval);
  }
  function stop() { clearInterval(timer); }

  dots.forEach(function(d, i) {
    d.addEventListener('click', function() {
      stop();
      goTo(i);
      start();
    });
  });

  deck.addEventListener('mouseenter', stop);
  deck.addEventListener('mouseleave', start);

  start();
})();
</script>

