<%
  category_icons = {
    "home-cleaning" => "fa-broom", "plumbing" => "fa-wrench", "electrical" => "fa-bolt",
    "landscaping" => "fa-leaf", "moving" => "fa-truck", "handyman" => "fa-hammer",
    "painting" => "fa-paint-roller", "pet-care" => "fa-paw", "tutoring" => "fa-graduation-cap",
    "personal-training" => "fa-dumbbell"
  }
%>

<%# ================================================================
    1. HERO — 60/40 grid, falling balls inside the image area
    ================================================================ %>
<section class="bg-cream border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-10 lg:gap-16 items-center">
      <%# LEFT: text %>
      <div>
        <div class="eyebrow mb-5 hero-reveal" style="--delay: 0s">find local pros · trusted by <%= number_with_delimiter(@total_customers + @total_providers) %>+</div>

        <h1 class="display text-ink hero-reveal" style="--delay: 0.05s; font-size: clamp(48px, 8vw, 104px); line-height: 0.95; letter-spacing: -0.035em;">
          Local pros,<br>
          <em class="italic-wonk" style="color: #1f4d3a;">actually</em> good.
        </h1>

        <p class="mt-6 max-w-xl text-[17px] sm:text-[19px] leading-[1.5] text-ink-2 hero-reveal" style="--delay: 0.1s">
          Verified plumbers, electricians, cleaners and more. Compare prices,
          read real reviews, book and pay in one place.
        </p>

        <%# Pill search — what / where / submit %>
        <div class="mt-8 max-w-xl hero-reveal" style="--delay: 0.15s">
          <%= form_tag services_path, method: :get, class: "block" do %>
            <div class="flex items-stretch gap-1 bg-cream-elevated border border-line-strong rounded-pill p-1.5 shadow-card">
              <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
                <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">What</label>
                <%= text_field_tag :query, nil, placeholder: "Cleaning, plumbing, lawn…", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
              </div>
              <span class="w-px self-stretch bg-line"></span>
              <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
                <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">Where</label>
                <%= text_field_tag :location, nil, placeholder: "Your zip or city", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
              </div>
              <button type="submit" aria-label="Search" class="flex-shrink-0 w-12 h-12 rounded-full bg-ink hover:bg-ink-2 text-cream flex items-center justify-center transition-colors active:translate-y-px">
                <i class="fas fa-arrow-right text-xs"></i>
              </button>
            </div>
          <% end %>
        </div>

        <%# Trust strip — 3 items separated by top border %>
        <div class="mt-10 pt-6 border-t border-line grid grid-cols-3 gap-4 max-w-xl hero-reveal" style="--delay: 0.2s">
          <% [
            { icon: "fa-shield-alt", label: "Background-checked" },
            { icon: "fa-bolt", label: "Same-day available" },
            { icon: "fa-check", label: "Money-back guarantee" }
          ].each do |item| %>
            <div class="flex items-start gap-2.5">
              <i class="fas <%= item[:icon] %> text-forest text-sm mt-0.5"></i>
              <span class="text-[13px] text-ink-2 leading-[1.35]"><%= item[:label] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# RIGHT: image area — falling balls cascade through %>
      <div class="relative hero-reveal" style="--delay: 0.1s">
        <div class="relative rounded-[20px] bg-cream-sunken border border-line overflow-hidden" style="aspect-ratio: 4/5; min-height: 460px;">
          <%# Particle canvas — falling pro bubbles render here %>
          <div class="absolute inset-0 overflow-hidden" id="particle-canvas"></div>

          <%# Subtle inner gradient for depth %>
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-cream-sunken/60 pointer-events-none"></div>

          <%# Image label chip (mono) %>
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 bg-cream/90 border border-line px-2.5 py-1 rounded">
            verified-pros · live
          </div>
        </div>

        <%# Floating chip — top-left, breaks bounds %>
        <div class="absolute top-8 sm:top-12" style="left: -20px;">
          <div class="bg-cream-elevated border border-line rounded-pill pl-1.5 pr-4 py-1.5 flex items-center gap-2.5 shadow-card-md">
            <div class="w-8 h-8 rounded-full bg-forest-soft text-forest flex items-center justify-center text-[11px] font-bold">M</div>
            <div class="leading-tight">
              <div class="text-[12px] font-semibold text-ink">Maya R.</div>
              <div class="text-[10px] text-ink-3 flex items-center gap-1">
                <i class="fas fa-star text-amber-500 text-[8px]"></i>
                <span>4.96 · cleaning</span>
              </div>
            </div>
          </div>
        </div>

        <%# Floating chip — bottom-right, breaks bounds %>
        <div class="absolute bottom-10 sm:bottom-12" style="right: -28px;">
          <div class="bg-cream-elevated border border-line rounded-pill pl-3 pr-4 py-1.5 flex items-center gap-2.5 shadow-card-md">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background-color: #2d6e4e;"></span>
              <span class="relative inline-flex rounded-full h-2 w-2" style="background-color: #2d6e4e;"></span>
            </span>
            <div class="leading-tight">
              <div class="text-[12px] font-semibold text-ink">Booked · Tue 2pm</div>
              <div class="text-[10px] text-ink-3">3hr · $147</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ================================================================
    2. CATEGORIES — 4-col grid, swatch + display name + mono count
    ================================================================ %>
<section class="bg-cream py-14 sm:py-20" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4 mb-8 sm:mb-10">
      <div>
        <div class="eyebrow mb-3">browse · 01</div>
        <h2 class="display text-[28px] sm:text-[32px] text-ink" style="line-height: 1.05; letter-spacing: -0.02em;">What do you <em class="italic-wonk" style="color: #1f4d3a;">actually</em> need?</h2>
      </div>
      <%= link_to services_path, class: "hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-ink-2 hover:text-ink transition-colors" do %>
        Browse all <i class="fas fa-arrow-right text-[10px]"></i>
      <% end %>
    </div>

    <% cat_swatches = [ "#1f4d3a", "#d96a3a", "#3d3a33", "#6f6a5e", "#1f4d3a", "#d96a3a", "#3d3a33", "#6f6a5e", "#1f4d3a", "#d96a3a" ] %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @categories.limit(8).each_with_index do |category, i| %>
        <%= link_to services_path(category_id: category.id),
            class: "group flex flex-col p-5 sm:p-6 rounded-xl border border-line bg-cream-elevated hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200",
            style: "min-height: 160px;" do %>
          <div class="w-9 h-9 rounded-full flex items-center justify-center mb-auto" style="background-color: <%= cat_swatches[i % cat_swatches.length] %>;">
            <i class="fas <%= category_icons[category.slug] || 'fa-cog' %> text-cream text-[13px]"></i>
          </div>
          <div class="mt-6">
            <div class="display text-[22px] leading-[1.1] tracking-[-0.01em] text-ink"><%= category.name %></div>
            <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= category.services.count %> pros</div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ================================================================
    3. FEATURED PROVIDERS — sunken band, 4-col grid card
    ================================================================ %>
<% if @top_providers.any? %>
<section class="bg-cream-sunken py-14 sm:py-20 border-y border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4 mb-8 sm:mb-10">
      <div>
        <div class="eyebrow mb-3">featured · 02</div>
        <h2 class="display text-[28px] sm:text-[32px] text-ink" style="line-height: 1.05; letter-spacing: -0.02em;">Pros doing it <em class="italic-wonk" style="color: #1f4d3a;">well</em>.</h2>
      </div>
      <%= link_to services_path, class: "hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
        See all <i class="fas fa-arrow-right text-[10px]"></i>
      <% end %>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      <% @top_providers.first(4).each do |provider| %>
        <%= link_to provider_path(provider), class: "group block bg-cream-elevated rounded-xl border border-line overflow-hidden hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200" do %>
          <%# Image area — striped placeholder or photo %>
          <div class="relative aspect-[4/5]">
            <% if provider.profile_picture.attached? %>
              <%= image_tag provider.profile_picture, class: "absolute inset-0 w-full h-full object-cover" %>
            <% else %>
              <div class="absolute inset-0" style="background: repeating-linear-gradient(135deg, #d8d2c4 0px, #d8d2c4 1px, #efeae0 1px, #efeae0 9px);"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 bg-cream border border-line px-2 py-1 rounded"><%= provider.display_name.split(" ").first.downcase %>-1.jpg · main</span>
              </div>
            <% end %>
            <%# Top-rated badge overlay %>
            <% if provider.average_rating >= 4.8 %>
              <div class="absolute top-3 left-3 bg-cream-elevated border border-line rounded-pill px-2.5 py-1 flex items-center gap-1.5 shadow-card">
                <i class="fas fa-star text-amber-500 text-[9px]"></i>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink">top-rated</span>
              </div>
            <% end %>
            <%# Favorite icon overlay %>
            <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-cream-elevated/90 backdrop-blur-sm border border-line flex items-center justify-center hover:bg-cream-elevated transition-colors">
              <i class="far fa-heart text-ink-3 text-xs"></i>
            </div>
          </div>

          <div class="p-4">
            <div class="display text-[17px] leading-[1.2] tracking-[-0.01em] text-ink truncate"><%= provider.business_name.presence || provider.display_name %></div>
            <div class="text-[13px] text-ink-3 mt-1 truncate">
              <% primary_service = provider.services.first %>
              <%= primary_service&.title || (primary_service&.category&.name + " pro") || "Local pro" %>
            </div>
            <div class="mt-3 flex items-center justify-between">
              <div class="flex items-center gap-1.5 text-[13px] text-ink-2">
                <i class="fas fa-star text-amber-500 text-[10px]"></i>
                <span class="font-medium"><%= provider.average_rating > 0 ? provider.average_rating : "New" %></span>
                <% if provider.total_reviews > 0 %>
                  <span class="text-ink-3">(<%= provider.total_reviews %>)</span>
                <% end %>
              </div>
              <% if primary_service&.base_price.to_f > 0 %>
                <div class="display text-[17px] text-ink">$<%= number_with_precision(primary_service.base_price, precision: 0) %><span class="font-sans text-[11px] text-ink-3 font-normal">/hr</span></div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

