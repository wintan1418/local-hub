<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Back link %>
    <div class="mb-6">
      <%= link_to (current_user.customer? ? customer_dashboard_path : :back), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>Back
      <% end %>
    </div>

    <%# Header %>
    <div class="mb-6">
      <div class="eyebrow mb-3">quote · #<%= @quote.id %></div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]"><%= @quote.title %></h1>
      <p class="mt-2 text-[15px] text-ink-2">From <%= @quote.provider.business_name.presence || @quote.provider.display_name %></p>
    </div>

    <%# Card %>
    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">

      <%# Details grid %>
      <div class="px-5 sm:px-6 py-5 grid sm:grid-cols-2 gap-x-6 gap-y-4 border-b border-line">
        <% [
          { label: "Service", value: @quote.service.title },
          { label: "Provider", value: @quote.provider.display_name },
          { label: "Issued", value: @quote.created_at.strftime("%B %-d, %Y") },
          { label: "Valid until", value: @quote.valid_until&.strftime("%B %-d, %Y") || "No expiry" }
        ].each do |row| %>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1"><%= row[:label] %></div>
            <div class="text-[14px] font-semibold text-ink"><%= row[:value] %></div>
          </div>
        <% end %>
      </div>

      <% if @quote.description.present? %>
        <div class="px-5 sm:px-6 py-5 border-b border-line">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">scope of work</div>
          <p class="text-[14px] text-ink-2 leading-[1.65] whitespace-pre-line"><%= @quote.description %></p>
        </div>
      <% end %>

      <%# Line items %>
      <% if @quote.line_items.any? %>
        <div class="px-5 sm:px-6 py-5 border-b border-line">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">line items</div>
          <div class="divide-y divide-line">
            <% @quote.line_items.each do |li| %>
              <div class="flex items-center justify-between py-3">
                <span class="text-[14px] text-ink-2"><%= li.description %></span>
                <span class="display text-[16px] text-ink leading-none">$<%= number_with_precision(li.total, precision: 2) %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Total %>
      <div class="px-5 sm:px-6 py-6 bg-cream-sunken/40">
        <div class="flex items-center justify-between">
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3">total</span>
          <span class="display text-[40px] sm:text-[44px] text-ink leading-none">$<%= number_with_precision(@quote.total_price, precision: 2) %></span>
        </div>
      </div>

      <%# Actions / status %>
      <% if @quote.sent? && @quote.customer == current_user %>
        <div class="px-5 sm:px-6 py-5 flex flex-col sm:flex-row gap-2 border-t border-line">
          <%= link_to approve_quote_path(@quote), data: { turbo_method: :patch, turbo_confirm: "Approve this quote and create a booking?" },
              class: "flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-pill text-sm font-semibold bg-ink hover:bg-ink-2 text-cream transition-colors active:translate-y-px" do %>
            <i class="fas fa-check text-[10px]"></i>Approve &amp; book
          <% end %>
          <%= link_to reject_quote_path(@quote), data: { turbo_method: :patch, turbo_confirm: "Decline this quote?" },
              class: "flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors" do %>
            Decline
          <% end %>
        </div>
      <% elsif @quote.approved? || @quote.converted? %>
        <div class="px-5 sm:px-6 py-5 border-t border-line text-center">
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-forest"><i class="fas fa-check-circle mr-1.5"></i>quote approved</span>
        </div>
      <% elsif @quote.rejected? %>
        <div class="px-5 sm:px-6 py-5 border-t border-line text-center">
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-rose-700"><i class="fas fa-times-circle mr-1.5"></i>quote declined</span>
        </div>
      <% end %>
    </div>
  </div>
</div>
