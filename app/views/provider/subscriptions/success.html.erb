<% content_for :page_title, "Payment Successful" %>
<% content_for :page_description, "Your subscription has been activated successfully." %>

<div class="min-h-screen bg-cream flex items-center justify-center p-4">
  <div class="max-w-xl w-full">
    <div class="bg-cream-elevated border border-line rounded-xl p-8 sm:p-12 text-center">

      <%# Success mark %>
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-forest-soft border-2 border-forest/30 mb-6">
        <i class="fas fa-check text-forest text-[24px]"></i>
      </div>

      <div class="eyebrow mb-3">activated</div>
      <h1 class="display text-[40px] sm:text-[56px] text-ink leading-[1] tracking-[-0.02em]">You're <em class="italic-wonk" style="color: #1f4d3a;">in</em>.</h1>
      <p class="mt-4 text-[15px] sm:text-[17px] text-ink-2 leading-[1.55]">Subscription activated. Welcome aboard.</p>

      <%# Plan card %>
      <div class="mt-7 p-5 rounded-xl bg-forest-soft border border-forest/20 text-left">
        <div class="flex items-center justify-between gap-3">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-forest mb-1">your plan</div>
            <div class="display text-[22px] text-ink leading-[1.1]"><%= @subscription.plan.name %></div>
          </div>
          <div class="display text-[26px] text-ink leading-none"><%= @subscription.plan.display_price %></div>
        </div>
        <div class="mt-3 pt-3 border-t border-forest/15 text-[12px] text-ink-2">
          <% if @subscription.status == 'trialing' %>
            <i class="fas fa-gift text-forest text-[10px] mr-1.5"></i>14-day free trial started · first billing <%= @subscription.current_period_end.strftime("%b %-d, %Y") %>
          <% else %>
            <i class="fas fa-credit-card text-forest text-[10px] mr-1.5"></i>Active · next billing <%= @subscription.current_period_end.strftime("%b %-d, %Y") %>
          <% end %>
        </div>
      </div>

      <%# What's next %>
      <div class="mt-6 text-left">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">what's next</div>
        <ul class="space-y-2.5">
          <% [
            "Add your first service from the dashboard",
            "Complete your provider profile and upload verification documents",
            "Customize your branded mini-site",
            "Connect Stripe to start receiving payouts"
          ].each do |item| %>
            <li class="flex items-start gap-2.5 text-[14px] text-ink-2"><i class="fas fa-arrow-right text-forest text-[10px] mt-1.5"></i><%= item %></li>
          <% end %>
        </ul>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-2">
        <%= link_to provider_dashboard_path, class: "flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
          Go to dashboard <i class="fas fa-arrow-right text-[10px]"></i>
        <% end %>
        <%= link_to provider_subscriptions_path, class: "flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors" do %>
          Manage subscription
        <% end %>
      </div>
    </div>
  </div>
</div>
