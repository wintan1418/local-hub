<div class="min-h-screen bg-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <div class="mb-8">
      <div class="eyebrow mb-3">subscription</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Your <em class="italic-wonk" style="color: #1f4d3a;">plan</em>.</h1>
    </div>

    <% if @subscription %>
      <%# Current plan card %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8 mb-6">
        <div class="grid sm:grid-cols-2 gap-6 mb-6">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">current plan</div>
            <div class="mt-2 flex items-baseline gap-3">
              <span class="display text-[32px] text-ink leading-none"><%= @subscription.plan.name %></span>
              <span class="font-mono text-[12px] text-ink-3"><%= @subscription.plan.display_price %></span>
            </div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">status</div>
            <div class="mt-2">
              <% sc = {
                "active" => [ "bg-forest-soft", "text-forest" ],
                "trialing" => [ "bg-amber-100/60", "text-amber-800" ],
                "past_due" => [ "bg-amber-100/60", "text-amber-800" ],
                "canceled" => [ "bg-rose-100/60", "text-rose-700" ]
              } %>
              <% c = sc[@subscription.status] || [ "bg-cream-sunken", "text-ink-3" ] %>
              <span class="inline-flex items-center font-mono text-[11px] uppercase tracking-[0.1em] px-3 py-1 rounded-pill <%= c[0] %> <%= c[1] %>"><%= @subscription.status.humanize %></span>
              <% if @subscription.status == 'trialing' %>
                <span class="ml-2 text-[12px] text-ink-3">(<%= @subscription.days_until_renewal %> days remaining)</span>
              <% end %>
            </div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">billing period</div>
            <div class="mt-2 text-[14px] text-ink"><%= @subscription.current_period_start.strftime("%b %-d, %Y") %> – <%= @subscription.current_period_end.strftime("%b %-d, %Y") %></div>
          </div>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">next renewal</div>
            <div class="mt-2 text-[14px] text-ink">
              <% if @subscription.cancel_at_period_end? %>
                <span class="text-rose-700">Cancels <%= @subscription.current_period_end.strftime("%b %-d, %Y") %></span>
              <% else %>
                <%= @subscription.current_period_end.strftime("%b %-d, %Y") %>
              <% end %>
            </div>
          </div>
        </div>

        <div class="border-t border-line pt-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">included</div>
          <ul class="space-y-2">
            <% (@subscription&.plan&.feature_list || []).each do |feature| %>
              <li class="flex items-start gap-2.5 text-[14px] text-ink-2">
                <i class="fas fa-check text-forest text-[11px] mt-1.5"></i><%= feature %>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="mt-6 pt-5 border-t border-line flex flex-wrap gap-2">
          <% unless @subscription.cancel_at_period_end? || @subscription.plan.price == 0 %>
            <%= link_to "Cancel subscription", cancel_provider_subscriptions_path, method: :post,
                data: { turbo_confirm: "Are you sure you want to cancel?" },
                class: "inline-flex items-center px-5 py-2.5 rounded-pill text-sm font-semibold border border-rose-300 text-rose-700 hover:bg-rose-50 transition-colors" %>
          <% end %>
          <% if @subscription.plan.price > 0 %>
            <button class="inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors">
              <i class="fas fa-credit-card text-[10px]"></i>Update payment method
            </button>
          <% end %>
        </div>
      </div>

      <%# Available plans %>
      <div>
        <div class="mb-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">available plans</div>
          <h2 class="display text-[22px] text-ink leading-[1.1]">Switch plan</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @plans.each do |plan| %>
            <% is_current = @subscription&.plan == plan %>
            <div class="bg-cream-elevated <%= is_current ? 'border-2 border-ink' : 'border border-line' %> rounded-xl p-6">
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2"><%= plan.name %></div>
              <div class="display text-[28px] text-ink leading-none"><%= plan.display_price %></div>
              <ul class="mt-4 space-y-1.5">
                <% plan.feature_list.first(3).each do |feature| %>
                  <li class="flex items-start gap-2 text-[12px] text-ink-2">
                    <i class="fas fa-check text-forest text-[10px] mt-1"></i><%= feature %>
                  </li>
                <% end %>
              </ul>
              <% if is_current %>
                <div class="mt-4 font-mono text-[11px] uppercase tracking-[0.12em] text-ink">current plan</div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-credit-card",
          title: "No active subscription",
          message: "Subscribe to a plan to start offering services.",
          cta_text: "Choose a plan",
          cta_path: new_provider_subscription_path %>
    <% end %>
  </div>
</div>
