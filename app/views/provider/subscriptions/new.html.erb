<div class="min-h-screen bg-cream py-12 sm:py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <div class="eyebrow mb-3">choose a plan</div>
      <h1 class="display text-[40px] sm:text-[56px] text-ink leading-[1] tracking-[-0.02em]">Pick your <em class="italic-wonk" style="color: #1f4d3a;">plan</em>.</h1>
      <p class="mt-3 text-[15px] sm:text-[17px] text-ink-2">Select the right fit for your business. Free trial on paid plans.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 max-w-5xl mx-auto">
      <% @plans.each_with_index do |plan, index| %>
        <% featured = (index == 1) %>
        <div class="bg-cream-elevated <%= featured ? 'border-2 border-forest' : 'border border-line' %> rounded-xl overflow-hidden relative">
          <% if featured %>
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 px-3 py-1 rounded-pill bg-forest text-cream font-mono text-[10px] uppercase tracking-[0.12em]">most popular</div>
          <% end %>
          <div class="p-6 sm:p-7">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2"><%= plan.name %></div>
            <p class="text-[12px] text-ink-2 leading-[1.5] mb-5">
              <%= case plan.name
                  when 'Free' then 'Perfect for trying out the platform'
                  when 'Professional' then 'Great for established service providers'
                  when 'Business' then 'For businesses with multiple services'
                  else 'Everything you need to grow your business'
                  end %>
            </p>
            <div class="display text-ink leading-none">
              <% if plan.price == 0 %>
                <span class="text-[44px]">Free</span>
              <% else %>
                <span class="text-[44px]">$<%= plan.price.to_i %></span><span class="font-sans text-[14px] text-ink-3">/<%= plan.billing_period == 'yearly' ? 'yr' : 'mo' %></span>
              <% end %>
            </div>
            <% if plan.price > 0 %>
              <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-2">14-day free trial</p>
            <% end %>

            <%= form_with(url: provider_subscriptions_path, method: :post, local: true) do |form| %>
              <%= form.hidden_field :plan_id, value: plan.id %>
              <%= form.submit "Get started", class: "mt-6 w-full bg-ink hover:bg-ink-2 text-cream py-2.5 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
            <% end %>
          </div>
          <div class="px-6 sm:px-7 pb-7 pt-2 border-t border-line bg-cream-sunken/30">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-5 mb-3">included</div>
            <ul class="space-y-2">
              <% feats = (plan.feature_list.presence || (defined?(default_features_for) ? default_features_for(plan) : [])) %>
              <% feats.each do |feature| %>
                <li class="flex items-start gap-2 text-[13px] text-ink-2">
                  <i class="fas fa-check text-forest text-[10px] mt-1.5"></i><span><%= feature %></span>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 text-center">
      <p class="text-[13px] text-ink-3">Need help choosing? <%= link_to "Contact us", contact_path, class: "font-semibold text-ink hover:underline underline-offset-2" %></p>
    </div>
  </div>
</div>
