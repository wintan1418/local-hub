<div class="min-h-screen bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= link_to provider_quotes_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Back to Quotes
    <% end %>

    <h1 class="text-2xl font-black text-slate-900 mb-8">Create New Quote</h1>

    <div class="bg-white rounded-xl border border-slate-100 p-6 sm:p-8">
      <%= form_with(model: [:provider, @quote], local: true) do |f| %>
        <% if @quote.errors.any? %>
          <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4">
            <p class="text-sm font-medium text-red-800"><%= pluralize(@quote.errors.count, "error") %>:</p>
            <ul class="mt-1 list-disc list-inside text-sm text-red-700">
              <% @quote.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-6">
          <div>
            <%= f.label :title, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_field :title, placeholder: "e.g. Bathroom Plumbing Repair", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :service_id, "Service", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.select :service_id, options_for_select(@services.map { |s| [s.title, s.id] }, @quote.service_id), { include_blank: "Select a service" }, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
            </div>
            <div>
              <%= f.label :customer_id, "Customer", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.select :customer_id, options_for_select(@customers.map { |c| [c.display_name + " (#{c.email})", c.id] }, @quote.customer_id), { include_blank: "Select a customer" }, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
            </div>
          </div>

          <div>
            <%= f.label :description, "Description / Scope of Work", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_area :description, rows: 3, placeholder: "Describe what's included in this quote...", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 resize-none" %>
          </div>

          <%# Line items %>
          <div>
            <label class="block text-sm font-bold text-slate-900 mb-3">Line Items</label>
            <div id="line-items" class="space-y-3">
              <%= f.fields_for :line_items do |li| %>
                <div class="flex gap-3 items-start line-item-row">
                  <div class="flex-1">
                    <%= li.text_field :description, placeholder: "Item description", class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
                  </div>
                  <div class="w-20">
                    <%= li.number_field :quantity, value: li.object.quantity || 1, min: 1, class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm text-center focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
                  </div>
                  <div class="w-28">
                    <%= li.number_field :unit_price, step: 0.01, min: 0, placeholder: "Price", class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
                  </div>
                </div>
              <% end %>
            </div>
            <p class="text-xs text-slate-400 mt-2">Total will be calculated automatically from line items.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :total_price, "Total Price ($)", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.number_field :total_price, step: 0.01, min: 0, placeholder: "0.00", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
              <p class="text-xs text-slate-400 mt-1">Override if different from line items total.</p>
            </div>
            <div>
              <%= f.label :valid_until, "Valid Until", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.date_field :valid_until, value: @quote.valid_until || 30.days.from_now.to_date, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
            </div>
          </div>

          <div>
            <%= f.label :notes, "Internal Notes (not visible to customer)", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_area :notes, rows: 2, placeholder: "Any internal notes...", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 resize-none" %>
          </div>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <%= link_to "Cancel", provider_quotes_path, class: "text-sm font-semibold text-slate-500 hover:text-slate-700" %>
          <%= f.submit "Create Quote", class: "bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-bold text-sm transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
