<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_quotes_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to quotes
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">new quote</div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]">Build the <em class="italic-wonk" style="color: #1f4d3a;">offer</em>.</h1>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: [ :provider, @quote ], local: true, class: "space-y-5") do |f| %>
        <% if @quote.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-rose-700 mb-1"><%= pluralize(@quote.errors.count, "error") %>:</div>
            <ul class="space-y-0.5 ml-5">
              <% @quote.errors.full_messages.each do |msg| %><li class="text-[13px] text-rose-700 list-disc"><%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :title, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_field :title, placeholder: "e.g. Bathroom Plumbing Repair",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :service_id, "Service", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.select :service_id, options_for_select(@services.map { |s| [ s.title, s.id ] }, @quote.service_id), { include_blank: "Select a service" },
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink text-sm" %>
          </div>
          <div>
            <%= f.label :customer_id, "Customer", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.select :customer_id, options_for_select(@customers.map { |c| [ "#{c.display_name} (#{c.email})", c.id ] }, @quote.customer_id), { include_blank: "Select a customer" },
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :description, "Scope of work", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_area :description, rows: 3, placeholder: "Describe what's included…",
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
        </div>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Line items</label>
          <div id="line-items" class="space-y-2">
            <%= f.fields_for :line_items do |li| %>
              <div class="flex gap-2 items-start">
                <%= li.text_field :description, placeholder: "Item description",
                    class: "flex-1 px-3 py-2.5 rounded-lg border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
                <%= li.number_field :quantity, value: li.object.quantity || 1, min: 1,
                    class: "w-20 px-3 py-2.5 rounded-lg border border-line text-ink text-center focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
                <%= li.number_field :unit_price, step: 0.01, min: 0, placeholder: "Price",
                    class: "w-28 px-3 py-2.5 rounded-lg border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
              </div>
            <% end %>
          </div>
          <p class="text-[11px] text-ink-3 mt-2">Total calculated from line items.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :total_price, "Total ($)", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.number_field :total_price, step: 0.01, min: 0, placeholder: "0.00",
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
            <p class="text-[11px] text-ink-3 mt-1">Override if different from line items total.</p>
          </div>
          <div>
            <%= f.label :valid_until, "Valid until", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.date_field :valid_until, value: @quote.valid_until || 30.days.from_now.to_date,
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :notes, "Internal notes (private)", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_area :notes, rows: 2, placeholder: "Any internal notes…",
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
        </div>

        <div class="flex items-center justify-between pt-5 border-t border-line">
          <%= link_to "Cancel", provider_quotes_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <%= f.submit "Create quote", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
