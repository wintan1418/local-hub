<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_quote_path(@quote), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">edit quote</div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]">Refine the <em class="italic-wonk" style="color: #1f4d3a;">offer</em>.</h1>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: [ :provider, @quote ], local: true, class: "space-y-5") do |f| %>
        <div>
          <%= f.label :title, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_field :title, class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :service_id, "Service", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.select :service_id, options_for_select(@services.map { |s| [ s.title, s.id ] }, @quote.service_id), {},
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink text-sm" %>
          </div>
          <div>
            <%= f.label :customer_id, "Customer", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.select :customer_id, options_for_select(@customers.map { |c| [ c.display_name, c.id ] }, @quote.customer_id), {},
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :description, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_area :description, rows: 3,
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :total_price, "Total ($)", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.number_field :total_price, step: 0.01,
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
          <div>
            <%= f.label :valid_until, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.date_field :valid_until,
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
        </div>

        <div class="flex items-center justify-between pt-5 border-t border-line">
          <%= link_to "Cancel", provider_quote_path(@quote), class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <%= f.submit "Update quote", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
