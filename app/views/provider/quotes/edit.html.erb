<div class="min-h-screen bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= link_to provider_quote_path(@quote), class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Back to Quote
    <% end %>

    <h1 class="text-2xl font-black text-slate-900 mb-8">Edit Quote</h1>

    <div class="bg-white rounded-xl border border-slate-100 p-6 sm:p-8">
      <%= form_with(model: [:provider, @quote], local: true) do |f| %>
        <div class="space-y-6">
          <div>
            <%= f.label :title, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_field :title, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :service_id, "Service", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.select :service_id, options_for_select(@services.map { |s| [s.title, s.id] }, @quote.service_id), {}, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white" %>
            </div>
            <div>
              <%= f.label :customer_id, "Customer", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.select :customer_id, options_for_select(@customers.map { |c| [c.display_name, c.id] }, @quote.customer_id), {}, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white" %>
            </div>
          </div>

          <div>
            <%= f.label :description, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_area :description, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :total_price, "Total Price ($)", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.number_field :total_price, step: 0.01, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
            </div>
            <div>
              <%= f.label :valid_until, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.date_field :valid_until, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <%= link_to "Cancel", provider_quote_path(@quote), class: "text-sm font-semibold text-slate-500" %>
          <%= f.submit "Update Quote", class: "bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-bold text-sm cursor-pointer transition-all" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
