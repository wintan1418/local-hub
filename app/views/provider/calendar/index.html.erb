<div class="min-h-screen bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-black text-slate-900">Calendar</h1>
        <p class="text-sm text-slate-500 mt-1">Your booking schedule at a glance.</p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to provider_calendar_path(month: @month.prev_month.strftime("%Y-%m-%d")), class: "w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-slate-50 transition-colors" do %>
          <i class="fas fa-chevron-left text-xs"></i>
        <% end %>
        <span class="text-sm font-bold text-slate-900 px-3"><%= @month.strftime("%B %Y") %></span>
        <%= link_to provider_calendar_path(month: @month.next_month.strftime("%Y-%m-%d")), class: "w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-slate-50 transition-colors" do %>
          <i class="fas fa-chevron-right text-xs"></i>
        <% end %>
        <%= link_to provider_calendar_path, class: "ml-2 text-xs font-semibold text-orange-600 hover:text-orange-700 px-3 py-1.5 rounded-lg border border-orange-200 bg-orange-50" do %>Today<% end %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-100 overflow-hidden">
      <%# Day headers %>
      <div class="grid grid-cols-7 border-b border-slate-100">
        <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
          <div class="px-3 py-3 text-center text-xs font-bold text-slate-400 uppercase tracking-wider"><%= day %></div>
        <% end %>
      </div>

      <%# Calendar grid %>
      <div class="grid grid-cols-7">
        <% (@start_date..@end_date).each do |date| %>
          <% is_today = date == Date.current %>
          <% is_current_month = date.month == @month.month %>
          <% day_bookings = @bookings_by_date[date] || [] %>
          <div class="min-h-[100px] sm:min-h-[120px] border-b border-r border-slate-50 p-1.5 sm:p-2 <%= is_current_month ? '' : 'bg-slate-50/50' %>">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-bold <%= is_today ? 'w-6 h-6 rounded-full bg-orange-500 text-white flex items-center justify-center' : is_current_month ? 'text-slate-700' : 'text-slate-300' %>">
                <%= date.day %>
              </span>
              <% if day_bookings.any? %>
                <span class="text-[10px] font-bold text-slate-400"><%= day_bookings.size %></span>
              <% end %>
            </div>
            <div class="space-y-0.5">
              <% day_bookings.first(3).each do |booking| %>
                <% status_colors = { "pending" => "bg-amber-100 text-amber-700 border-amber-200", "confirmed" => "bg-emerald-100 text-emerald-700 border-emerald-200", "completed" => "bg-sky-100 text-sky-700 border-sky-200" } %>
                <div class="text-[10px] font-medium px-1.5 py-0.5 rounded border truncate <%= status_colors[booking.status] || 'bg-slate-100 text-slate-600 border-slate-200' %>">
                  <%= booking.scheduled_at.strftime("%-I%p") %> <%= booking.service.title.truncate(15) %>
                </div>
              <% end %>
              <% if day_bookings.size > 3 %>
                <div class="text-[10px] text-slate-400 px-1.5">+<%= day_bookings.size - 3 %> more</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Legend %>
    <div class="mt-4 flex flex-wrap gap-4 text-xs text-slate-500">
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-amber-100 border border-amber-200"></span> Pending</div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-100 border border-emerald-200"></span> Confirmed</div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-sky-100 border border-sky-200"></span> Completed</div>
    </div>
  </div>
</div>
