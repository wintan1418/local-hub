<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

    <div class="flex items-end justify-between gap-4 mb-8 flex-wrap">
      <div>
        <div class="eyebrow mb-3">calendar</div>
        <div class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]"><%= @month.strftime("%B") %> <em class="italic-wonk" style="color: #1f4d3a;"><%= @month.strftime("%Y") %></em>.</div>
        <p class="mt-2 text-[13px] text-ink-2"><i class="fas fa-hand-point-up text-ink-3 mr-1.5"></i>Drag bookings between days to reschedule.</p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to provider_calendar_path(month: @month.prev_month.strftime("%Y-%m-%d")), class: "w-10 h-10 rounded-pill border border-line flex items-center justify-center text-ink-3 hover:bg-cream-elevated transition-colors" do %>
          <i class="fas fa-chevron-left text-[10px]"></i>
        <% end %>
        <%= link_to provider_calendar_path, class: "px-4 py-2 rounded-pill text-[13px] font-medium border border-line text-ink-2 hover:bg-cream-elevated transition-colors" do %>Today<% end %>
        <%= link_to provider_calendar_path(month: @month.next_month.strftime("%Y-%m-%d")), class: "w-10 h-10 rounded-pill border border-line flex items-center justify-center text-ink-3 hover:bg-cream-elevated transition-colors" do %>
          <i class="fas fa-chevron-right text-[10px]"></i>
        <% end %>
      </div>
    </div>

    <%# Toast %>
    <div id="drag-toast" class="fixed top-24 left-1/2 -translate-x-1/2 z-50 hidden text-cream text-sm font-semibold px-5 py-2.5 rounded-pill shadow-card-lg" style="background-color: #1d1813;"></div>

    <div class="bg-cream-elevated rounded-xl border border-line overflow-hidden">
      <%# Day headers %>
      <div class="grid grid-cols-7 border-b border-line">
        <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
          <div class="px-3 py-3 text-center font-mono text-[10px] font-semibold text-ink-3 uppercase tracking-[0.12em]"><%= day %></div>
        <% end %>
      </div>

      <%# Calendar grid %>
      <div class="grid grid-cols-7" id="calendar-grid">
        <% (@start_date..@end_date).each do |date| %>
          <% is_today = date == Date.current %>
          <% is_current_month = date.month == @month.month %>
          <% day_bookings = @bookings_by_date[date] || [] %>
          <div
            class="calendar-day min-h-[120px] sm:min-h-[140px] border-b border-r border-line p-1.5 sm:p-2 transition-colors <%= is_current_month ? '' : 'bg-cream-sunken/30' %>"
            data-date="<%= date.iso8601 %>"
            data-drop-target
          >
            <div class="flex items-center justify-between mb-1.5">
              <span class="<%= is_today ? 'w-6 h-6 rounded-full bg-ink text-cream flex items-center justify-center font-mono text-[11px] font-semibold' : "font-display text-[14px] #{is_current_month ? 'text-ink' : 'text-ink-4'}" %>">
                <%= date.day %>
              </span>
              <% if day_bookings.any? %>
                <span class="font-mono text-[10px] text-ink-3"><%= day_bookings.size %></span>
              <% end %>
            </div>
            <div class="space-y-1" data-bookings-container>
              <% day_bookings.each do |booking| %>
                <% status_styles = {
                  "pending"   => "bg-amber-100/70 text-amber-800 border-amber-200 hover:bg-amber-200/80",
                  "confirmed" => "bg-forest-soft text-forest border-forest/30 hover:bg-forest/15",
                  "completed" => "bg-cream-sunken text-ink-2 border-line hover:bg-line/60"
                } %>
                <div
                  class="booking-card text-[10px] font-medium px-1.5 py-1 rounded border truncate transition-all cursor-move <%= status_styles[booking.status] || 'bg-cream-sunken text-ink-2 border-line' %>"
                  draggable="<%= booking.status.in?([ 'pending', 'confirmed' ]) ? 'true' : 'false' %>"
                  data-booking-id="<%= booking.id %>"
                  data-booking-status="<%= booking.status %>"
                  data-booking-url="<%= booking_path(booking) %>"
                  data-scheduled-time="<%= booking.scheduled_at.strftime("%H:%M") %>"
                  title="<%= booking.scheduled_at.strftime("%-I:%M %p") %> · <%= booking.service.title %> · <%= booking.customer.display_name %>"
                >
                  <i class="fas fa-grip-vertical text-[8px] opacity-40 mr-0.5"></i><span class="font-mono text-[9px] mr-1"><%= booking.scheduled_at.strftime("%-I%P") %></span><%= booking.service.title.truncate(12) %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Legend %>
    <div class="mt-4 flex flex-wrap items-center gap-4 font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3">
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-amber-100/70 border border-amber-200"></span>pending</div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-forest-soft border border-forest/30"></span>confirmed</div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-cream-sunken border border-line"></span>completed</div>
      <span class="ml-auto normal-case lowercase"><i class="fas fa-info-circle mr-1"></i>only pending/confirmed are draggable</span>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const toast = document.getElementById('drag-toast');
  const days = document.querySelectorAll('[data-drop-target]');
  const cards = document.querySelectorAll('.booking-card[draggable="true"]');
  let draggedCard = null;

  function showToast(msg, isError) {
    toast.textContent = msg;
    toast.classList.remove('hidden');
    toast.style.backgroundColor = isError ? '#b8551c' : '#1f4d3a';
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  document.querySelectorAll('.booking-card').forEach(card => {
    let isDragging = false;
    card.addEventListener('dragstart', () => { isDragging = true; });
    card.addEventListener('click', (e) => {
      if (!isDragging) {
        const url = card.dataset.bookingUrl;
        if (url) window.location.href = url;
      }
      setTimeout(() => { isDragging = false; }, 100);
    });
  });

  cards.forEach(card => {
    card.addEventListener('dragstart', (e) => {
      draggedCard = card;
      card.style.opacity = '0.4';
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', card.dataset.bookingId);
    });
    card.addEventListener('dragend', () => {
      card.style.opacity = '1';
      draggedCard = null;
      days.forEach(d => { d.classList.remove('ring-2'); d.style.backgroundColor = ''; });
    });
  });

  days.forEach(day => {
    day.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      day.classList.add('ring-2');
      day.style.boxShadow = 'inset 0 0 0 2px #1f4d3a';
    });
    day.addEventListener('dragleave', () => {
      day.classList.remove('ring-2');
      day.style.boxShadow = '';
    });
    day.addEventListener('drop', async (e) => {
      e.preventDefault();
      day.classList.remove('ring-2');
      day.style.boxShadow = '';
      if (!draggedCard) return;

      const bookingId = draggedCard.dataset.bookingId;
      const newDate = day.dataset.date;
      const time = draggedCard.dataset.scheduledTime || '09:00';
      const newDateTime = `${newDate}T${time}`;

      const container = day.querySelector('[data-bookings-container]');
      container.appendChild(draggedCard);

      try {
        const token = document.querySelector('meta[name="csrf-token"]').content;
        const resp = await fetch(`/bookings/${bookingId}/reschedule.json`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-CSRF-Token': token,
            'Accept': 'application/json'
          },
          body: `scheduled_at=${encodeURIComponent(newDateTime)}`
        });
        const data = await resp.json().catch(() => null);
        if (resp.ok && data?.ok) {
          showToast('✓ Booking rescheduled', false);
        } else {
          showToast((data && data.error) || 'Could not reschedule', true);
        }
      } catch (err) {
        showToast('Network error. Refresh to retry.', true);
      }
    });
  });
});
</script>
