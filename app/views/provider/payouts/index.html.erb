<div class="min-h-screen bg-slate-50">
  <%# Dark header %>
  <div class="bg-slate-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-emerald-500/[0.08] rounded-full blur-[120px]"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center">
          <i class="fas fa-dollar-sign text-white text-sm"></i>
        </div>
        <h1 class="text-2xl font-black text-white">Payouts</h1>
      </div>
      <p class="text-slate-400 text-sm">Manage your Stripe Connect account and view earnings.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="bg-white/[0.06] border border-white/[0.08] rounded-xl p-5">
          <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Total Earned</div>
          <div class="text-2xl font-black text-white mt-1">$<%= number_with_delimiter(@total_earned.to_i) %></div>
          <div class="text-xs text-slate-500 mt-1">After platform fee</div>
        </div>
        <div class="bg-white/[0.06] border border-white/[0.08] rounded-xl p-5">
          <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Pending Payout</div>
          <div class="text-2xl font-black text-amber-400 mt-1">$<%= number_with_delimiter(@pending_payout.to_i) %></div>
          <div class="text-xs text-slate-500 mt-1">Confirmed bookings</div>
        </div>
        <div class="bg-white/[0.06] border border-white/[0.08] rounded-xl p-5">
          <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Platform Fee</div>
          <div class="text-2xl font-black text-white mt-1">$<%= number_with_delimiter(@total_platform_fee.to_i) %></div>
          <div class="text-xs text-slate-500 mt-1">10% commission</div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%# Connect Status Card %>
    <% if current_user.stripe_connect_onboarded? && current_user.stripe_connect_payouts_enabled? %>
      <div class="bg-white rounded-2xl border border-emerald-200 p-6 mb-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center">
            <i class="fas fa-check-circle text-emerald-500 text-xl"></i>
          </div>
          <div>
            <div class="text-sm font-bold text-slate-900">Stripe Connect Active</div>
            <div class="text-xs text-slate-500">You can receive payouts. Bookings are automatically split (90% to you, 10% platform fee).</div>
          </div>
        </div>
      </div>
    <% elsif current_user.stripe_connect_id.present? %>
      <div class="bg-white rounded-2xl border border-amber-200 p-6 mb-6">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center">
              <i class="fas fa-clock text-amber-500 text-xl"></i>
            </div>
            <div>
              <div class="text-sm font-bold text-slate-900">Onboarding Incomplete</div>
              <div class="text-xs text-slate-500">Finish your Stripe Connect setup to start receiving payouts.</div>
            </div>
          </div>
          <%= button_to provider_connect_payouts_path, method: :post, class: "bg-orange-500 hover:bg-orange-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold cursor-pointer whitespace-nowrap" do %>
            Continue Setup <i class="fas fa-arrow-right ml-1 text-xs"></i>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="relative overflow-hidden bg-gradient-to-br from-orange-500 to-rose-500 rounded-2xl p-8 mb-6 text-white">
        <div class="absolute top-0 right-0 opacity-10"><i class="fas fa-university text-[160px]"></i></div>
        <div class="relative">
          <h2 class="text-xl font-black mb-2">Start Receiving Payouts</h2>
          <p class="text-sm opacity-90 mb-5 max-w-md">Connect your bank via Stripe Connect. It's free, secure, and takes 2 minutes. Once verified, payouts are automatic.</p>
          <ul class="text-xs opacity-80 space-y-1 mb-6">
            <li><i class="fas fa-check mr-2"></i>90% of every booking goes directly to your bank</li>
            <li><i class="fas fa-check mr-2"></i>Next-day payouts after job completion</li>
            <li><i class="fas fa-check mr-2"></i>Secure — we never touch your funds</li>
          </ul>
          <%= button_to provider_connect_payouts_path, method: :post, class: "bg-white text-slate-900 hover:bg-slate-100 px-6 py-3 rounded-xl text-sm font-bold cursor-pointer inline-flex items-center gap-2" do %>
            Connect with Stripe <i class="fas fa-arrow-right text-xs"></i>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Recent earnings %>
    <div class="bg-white rounded-2xl border border-slate-100">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <h2 class="text-sm font-bold text-slate-900">Recent Earnings</h2>
        <span class="text-xs text-slate-400">Completed bookings</span>
      </div>
      <% if @recent_bookings.any? %>
        <div class="divide-y divide-slate-50">
          <% @recent_bookings.each do |b| %>
            <div class="flex items-center justify-between px-6 py-4">
              <div class="min-w-0">
                <div class="text-sm font-semibold text-slate-900 truncate"><%= b.service.title %></div>
                <div class="text-xs text-slate-400"><%= b.customer.display_name %> &middot; <%= b.updated_at.strftime("%b %d, %Y") %></div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-black text-emerald-600">+$<%= number_with_precision((b.provider_payout_cents || (b.total_price * 90)).to_f / 100, precision: 2) %></div>
                <div class="text-[10px] text-slate-400">$<%= number_with_precision(b.total_price, precision: 2) %> gross</div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-10 text-center">
          <i class="fas fa-coins text-slate-300 text-2xl mb-2"></i>
          <p class="text-sm text-slate-400">No earnings yet. Complete bookings to see payouts here.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
