<div class="min-h-screen bg-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Header %>
    <div class="mb-8">
      <div class="eyebrow mb-3">payouts</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Get <em class="italic-wonk" style="color: #1f4d3a;">paid</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">Stripe Connect account, earnings, and payouts.</p>
    </div>

    <%# Stats row %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-line">
        <div class="p-5 sm:p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">total earned</div>
          <div class="display text-[36px] text-ink leading-none mt-2">$<%= number_with_delimiter(@total_earned.to_i) %></div>
          <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-1.5">after platform fee</div>
        </div>
        <div class="p-5 sm:p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">pending payout</div>
          <div class="display text-[36px] text-terracotta leading-none mt-2">$<%= number_with_delimiter(@pending_payout.to_i) %></div>
          <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-1.5">confirmed bookings</div>
        </div>
        <div class="p-5 sm:p-6">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">platform fee</div>
          <div class="display text-[36px] text-ink leading-none mt-2">$<%= number_with_delimiter(@total_platform_fee.to_i) %></div>
          <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-1.5">10% commission</div>
        </div>
      </div>
    </div>

    <%# Connect status card %>
    <% if current_user.stripe_connect_onboarded? && current_user.stripe_connect_payouts_enabled? %>
      <div class="bg-forest-soft border border-forest/20 rounded-xl p-5 mb-6">
        <div class="flex items-center gap-3">
          <i class="fas fa-check-circle text-forest text-[20px]"></i>
          <div>
            <div class="display text-[18px] text-ink leading-[1.15]">Stripe Connect active</div>
            <div class="text-[12px] text-ink-2 mt-0.5">You can receive payouts. Bookings split 90/10 (you / platform).</div>
          </div>
        </div>
      </div>
    <% elsif current_user.stripe_connect_id.present? %>
      <div class="bg-amber-100/60 border border-amber-200 rounded-xl p-5 mb-6">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <div class="flex items-center gap-3">
            <i class="fas fa-clock text-amber-700 text-[20px]"></i>
            <div>
              <div class="display text-[18px] text-ink leading-[1.15]">Onboarding incomplete</div>
              <div class="text-[12px] text-ink-2 mt-0.5">Finish your Stripe Connect setup to start receiving payouts.</div>
            </div>
          </div>
          <%= button_to provider_connect_payouts_path, method: :post, class: "inline-flex items-center gap-2 bg-ink text-cream px-5 py-2.5 rounded-pill text-sm font-semibold hover:bg-ink-2 cursor-pointer transition-colors active:translate-y-px" do %>
            Continue setup <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="relative overflow-hidden rounded-[20px] p-8 sm:p-10 mb-6 text-cream" style="background-color: #1f4d3a;">
        <div class="absolute -top-4 -right-4 opacity-15"><i class="fas fa-university text-cream text-[160px]"></i></div>
        <div class="relative max-w-md">
          <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/65 mb-3">connect your bank</div>
          <h2 class="display text-[28px] sm:text-[32px] leading-[1.1] tracking-[-0.02em]">Start receiving <em class="italic-wonk" style="color: #d96a3a;">payouts</em>.</h2>
          <p class="mt-4 text-[14px] leading-[1.55] text-cream/85">Connect your bank via Stripe Connect. Free, secure, takes 2 minutes.</p>
          <ul class="mt-5 space-y-2 text-[13px] text-cream/85">
            <li class="flex items-start gap-2"><i class="fas fa-check text-cream/60 text-[10px] mt-1.5"></i>90% of every booking goes directly to your bank</li>
            <li class="flex items-start gap-2"><i class="fas fa-check text-cream/60 text-[10px] mt-1.5"></i>Next-day payouts after job completion</li>
            <li class="flex items-start gap-2"><i class="fas fa-check text-cream/60 text-[10px] mt-1.5"></i>Secure — we never touch your funds</li>
          </ul>
          <%= button_to provider_connect_payouts_path, method: :post, class: "mt-6 inline-flex items-center gap-2 bg-cream text-ink hover:bg-cream-sunken px-6 py-3 rounded-pill text-sm font-semibold cursor-pointer transition-colors" do %>
            Connect with Stripe <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Recent earnings %>
    <div class="bg-cream-elevated border border-line rounded-xl">
      <div class="px-5 sm:px-6 py-4 border-b border-line flex items-end justify-between">
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recent earnings</div>
          <div class="display text-[18px] text-ink leading-[1.1]">From completed bookings</div>
        </div>
      </div>
      <% if @recent_bookings.any? %>
        <div class="divide-y divide-line">
          <% @recent_bookings.each do |b| %>
            <div class="flex items-center justify-between px-5 sm:px-6 py-4">
              <div class="min-w-0">
                <div class="display text-[15px] text-ink leading-[1.15] truncate"><%= b.service.title %></div>
                <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-0.5"><%= b.customer.display_name %> · <%= b.updated_at.strftime("%b %-d") %></div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="display text-[18px] text-forest leading-none">+$<%= number_with_precision((b.provider_payout_cents || (b.total_price * 90)).to_f / 100, precision: 2) %></div>
                <div class="font-mono text-[10px] text-ink-3 mt-0.5">$<%= number_with_precision(b.total_price, precision: 2) %> gross</div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-10 text-center">
          <i class="fas fa-coins text-ink-3 text-2xl mb-2"></i>
          <p class="text-[13px] text-ink-3">No earnings yet. Complete bookings to see payouts here.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
