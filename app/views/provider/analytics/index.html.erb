<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

    <%# Header %>
    <div class="mb-8 sm:mb-10">
      <div class="eyebrow mb-3">analytics</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Your business, <em class="italic-wonk" style="color: #1f4d3a;">measured</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">Performance overview across services, bookings, and reviews.</p>
    </div>

    <%# KPI row %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-line">
        <% [
          { label: "Revenue", value: "$#{number_with_delimiter(@total_revenue)}" },
          { label: "Bookings", value: @total_bookings.to_s },
          { label: "Rating", value: @avg_rating.to_s, suffix: "★" },
          { label: "Completion", value: "#{@completion_rate}%" }
        ].each do |stat| %>
          <div class="p-5 sm:p-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= stat[:label] %></div>
            <div class="display text-[36px] sm:text-[44px] text-ink leading-none mt-2 truncate">
              <%= stat[:value] %><% if stat[:suffix] %><span class="text-amber-500 text-[20px] ml-1"><%= stat[:suffix] %></span><% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">

      <%# Monthly revenue %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6">
        <div class="flex items-end justify-between mb-6">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">monthly revenue</div>
            <div class="display text-[20px] text-ink leading-[1.1]">Last 6 months</div>
          </div>
        </div>
        <div class="flex items-end gap-3 h-48">
          <% max_rev = @monthly_revenue.map { |m| m[:revenue] }.max %>
          <% max_rev = 1 if max_rev.to_i == 0 %>
          <% @monthly_revenue.each do |m| %>
            <div class="flex-1 flex flex-col items-center gap-2 min-w-0">
              <span class="font-mono text-[10px] text-ink-3 whitespace-nowrap">$<%= number_with_delimiter(m[:revenue].to_i) %></span>
              <div class="w-full bg-cream-sunken rounded-t-lg relative" style="height: <%= [ (m[:revenue].to_f / max_rev * 100), 4 ].max %>%;">
                <div class="absolute inset-0 rounded-t-lg" style="background-color: #1f4d3a;"></div>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= m[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Monthly bookings %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6">
        <div class="flex items-end justify-between mb-6">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">monthly bookings</div>
            <div class="display text-[20px] text-ink leading-[1.1]">Last 6 months</div>
          </div>
        </div>
        <div class="flex items-end gap-3 h-48">
          <% max_book = @monthly_bookings.map { |m| m[:count] }.max %>
          <% max_book = 1 if max_book.to_i == 0 %>
          <% @monthly_bookings.each do |m| %>
            <div class="flex-1 flex flex-col items-center gap-2 min-w-0">
              <span class="font-mono text-[10px] text-ink-3"><%= m[:count] %></span>
              <div class="w-full bg-cream-sunken rounded-t-lg relative" style="height: <%= [ (m[:count].to_f / max_book * 100), 4 ].max %>%;">
                <div class="absolute inset-0 rounded-t-lg" style="background-color: #d96a3a;"></div>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= m[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Top services %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">top services</div>
        <div class="display text-[20px] text-ink leading-[1.1] mb-4">By revenue</div>
        <% if @top_services.any? %>
          <div class="space-y-2">
            <% @top_services.each_with_index do |service, i| %>
              <div class="flex items-center justify-between gap-3 p-3 rounded-lg border border-line">
                <div class="flex items-center gap-3 min-w-0">
                  <span class="font-display text-[18px] text-ink-3 w-7"><%= i + 1 %></span>
                  <div class="min-w-0">
                    <div class="text-[14px] font-semibold text-ink truncate"><%= service.title %></div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= service.try(:booking_count) || 0 %> bookings</div>
                  </div>
                </div>
                <span class="display text-[16px] text-ink leading-none flex-shrink-0">$<%= number_with_delimiter(service.try(:total_rev).to_i) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-[13px] text-ink-3 text-center py-4">No completed bookings yet.</p>
        <% end %>
      </div>

      <%# Recent reviews %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recent reviews</div>
        <div class="display text-[20px] text-ink leading-[1.1] mb-4">From customers</div>
        <% if @recent_reviews.any? %>
          <div class="space-y-2">
            <% @recent_reviews.each do |review| %>
              <div class="p-3 rounded-lg border border-line">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-[13px] font-semibold text-ink"><%= review.booking.customer.display_name %></span>
                  <div class="flex gap-0.5">
                    <% 5.times do |i| %><i class="fas fa-star text-[10px] <%= i < review.rating ? 'text-amber-500' : 'text-line' %>"></i><% end %>
                  </div>
                </div>
                <p class="text-[12px] text-ink-2 leading-[1.5] line-clamp-2"><%= review.comment %></p>
                <p class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-1.5"><%= review.booking.service.title %> · <%= time_ago_in_words(review.created_at) %> ago</p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-[13px] text-ink-3 text-center py-4">No reviews yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
