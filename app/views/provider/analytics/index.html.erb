<div class="min-h-screen bg-slate-50">
  <%# Dark header %>
  <div class="bg-slate-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-orange-500 flex items-center justify-center">
          <i class="fas fa-chart-line text-white text-sm"></i>
        </div>
        <h1 class="text-2xl font-black text-white">Analytics</h1>
      </div>
      <p class="text-slate-400 text-sm">Your business performance overview.</p>

      <%# Key metrics %>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        <% [
          { label: "Revenue", value: "$#{number_with_delimiter(@total_revenue)}", icon: "fa-dollar-sign", color: "emerald" },
          { label: "Bookings", value: @total_bookings, icon: "fa-calendar-check", color: "sky" },
          { label: "Rating", value: @avg_rating, icon: "fa-star", color: "amber" },
          { label: "Completion", value: "#{@completion_rate}%", icon: "fa-check-double", color: "violet" }
        ].each do |stat| %>
          <div class="bg-white/[0.06] border border-white/[0.08] rounded-xl p-5">
            <div class="flex items-center gap-2 mb-2">
              <i class="fas <%= stat[:icon] %> text-<%= stat[:color] %>-400 text-xs"></i>
              <span class="text-xs font-medium text-slate-400 uppercase tracking-wider"><%= stat[:label] %></span>
            </div>
            <div class="text-2xl font-black text-white"><%= stat[:value] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-2 gap-6">
      <%# Revenue chart (CSS bar chart) %>
      <div class="bg-white rounded-xl border border-slate-100 p-6">
        <h2 class="text-sm font-bold text-slate-900 mb-6">Monthly Revenue</h2>
        <div class="flex items-end gap-3 h-48">
          <% max_rev = @monthly_revenue.map { |m| m[:revenue] }.max %>
          <% max_rev = 1 if max_rev.to_i == 0 %>
          <% @monthly_revenue.each do |m| %>
            <div class="flex-1 flex flex-col items-center gap-2">
              <span class="text-[10px] font-bold text-slate-500">$<%= number_with_delimiter(m[:revenue].to_i) %></span>
              <div class="w-full bg-emerald-100 rounded-t-lg relative" style="height: <%= [(m[:revenue].to_f / max_rev * 100), 4].max %>%;">
                <div class="absolute inset-0 bg-gradient-to-t from-emerald-500 to-emerald-400 rounded-t-lg"></div>
              </div>
              <span class="text-[10px] font-medium text-slate-400"><%= m[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Bookings chart %>
      <div class="bg-white rounded-xl border border-slate-100 p-6">
        <h2 class="text-sm font-bold text-slate-900 mb-6">Monthly Bookings</h2>
        <div class="flex items-end gap-3 h-48">
          <% max_book = @monthly_bookings.map { |m| m[:count] }.max %>
          <% max_book = 1 if max_book.to_i == 0 %>
          <% @monthly_bookings.each do |m| %>
            <div class="flex-1 flex flex-col items-center gap-2">
              <span class="text-[10px] font-bold text-slate-500"><%= m[:count] %></span>
              <div class="w-full bg-sky-100 rounded-t-lg relative" style="height: <%= [(m[:count].to_f / max_book * 100), 4].max %>%;">
                <div class="absolute inset-0 bg-gradient-to-t from-sky-500 to-sky-400 rounded-t-lg"></div>
              </div>
              <span class="text-[10px] font-medium text-slate-400"><%= m[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Top services %>
      <div class="bg-white rounded-xl border border-slate-100 p-6">
        <h2 class="text-sm font-bold text-slate-900 mb-4">Top Services by Revenue</h2>
        <% if @top_services.any? %>
          <div class="space-y-3">
            <% @top_services.each_with_index do |service, i| %>
              <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50">
                <div class="flex items-center gap-3">
                  <span class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-500"><%= i + 1 %></span>
                  <div>
                    <div class="text-sm font-semibold text-slate-900"><%= service.title %></div>
                    <div class="text-xs text-slate-400"><%= service.try(:booking_count) || 0 %> bookings</div>
                  </div>
                </div>
                <span class="text-sm font-black text-slate-900">$<%= number_with_delimiter(service.try(:total_rev).to_i) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-400 text-center py-4">No completed bookings yet.</p>
        <% end %>
      </div>

      <%# Recent reviews %>
      <div class="bg-white rounded-xl border border-slate-100 p-6">
        <h2 class="text-sm font-bold text-slate-900 mb-4">Recent Reviews</h2>
        <% if @recent_reviews.any? %>
          <div class="space-y-3">
            <% @recent_reviews.each do |review| %>
              <div class="p-3 rounded-lg bg-slate-50">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-semibold text-slate-900"><%= review.booking.customer.display_name %></span>
                  <div class="flex gap-0.5"><% 5.times do |i| %><i class="fas fa-star text-[9px] <%= i < review.rating ? 'text-amber-400' : 'text-slate-200' %>"></i><% end %></div>
                </div>
                <p class="text-xs text-slate-500 line-clamp-2"><%= review.comment %></p>
                <p class="text-[10px] text-slate-400 mt-1"><%= review.booking.service.title %> &middot; <%= time_ago_in_words(review.created_at) %> ago</p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-400 text-center py-4">No reviews yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
