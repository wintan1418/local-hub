<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">crm campaigns</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">SMS &amp; WhatsApp <em class="italic-wonk" style="color: #1f4d3a;">campaigns</em>.</h1>
      </div>
      <%= link_to new_provider_crm_campaign_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
        <i class="fas fa-plus text-[10px]"></i>New campaign
      <% end %>
    </div>

    <% if @campaigns.any? %>
      <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-cream-sunken/40 border-b border-line">
              <tr>
                <th class="text-left px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Campaign</th>
                <th class="text-left px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Type</th>
                <th class="text-left px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Target</th>
                <th class="text-left px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Status</th>
                <th class="text-left px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Sent / Success</th>
                <th class="text-right px-5 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-line">
              <% @campaigns.each do |campaign| %>
                <tr class="hover:bg-cream-sunken/40 transition-colors">
                  <td class="px-5 py-4">
                    <div class="text-[14px] font-semibold text-ink"><%= campaign.name %></div>
                    <div class="text-[12px] text-ink-3 truncate max-w-xs"><%= campaign.description %></div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= campaign.sms? ? 'bg-cream-sunken text-ink-2' : 'bg-forest-soft text-forest' %>"><%= campaign.campaign_type %></span>
                  </td>
                  <td class="px-5 py-4 text-[13px] text-ink-2"><%= campaign.target_audience.humanize %></td>
                  <td class="px-5 py-4">
                    <% sc = campaign.completed? ? [ "bg-forest-soft", "text-forest" ] : campaign.in_progress? ? [ "bg-amber-100/60", "text-amber-800" ] : [ "bg-cream-sunken", "text-ink-3" ] %>
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= sc[0] %> <%= sc[1] %>"><%= campaign.status %></span>
                  </td>
                  <td class="px-5 py-4 text-[13px] text-ink-2 whitespace-nowrap">
                    <%= campaign.sent_count || 0 %> / <%= campaign.success_count || 0 %>
                    <% if campaign.sent_count.to_i > 0 %>
                      <span class="font-mono text-[10px] text-ink-3">(<%= campaign.success_rate %>%)</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-4 text-right whitespace-nowrap">
                    <%= link_to "view", provider_crm_campaign_path(campaign), class: "font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 hover:text-ink mr-3" %>
                    <% if campaign.can_send? %>
                      <%= link_to "send", send_campaign_provider_crm_campaign_path(campaign), method: :post,
                          data: { turbo_confirm: "Send this campaign?" },
                          class: "font-mono text-[10px] uppercase tracking-[0.1em] text-forest hover:text-forest/80" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-bullhorn",
          title: "No campaigns yet",
          message: "Create your first SMS or WhatsApp campaign to engage with customers.",
          cta_text: "Create campaign",
          cta_path: new_provider_crm_campaign_path,
          cta_icon: "fa-plus" %>
    <% end %>

    <% unless ENV['TWILIO_ACCOUNT_SID'].present? %>
      <div class="mt-6 bg-amber-100/60 border border-amber-200 rounded-xl p-5">
        <div class="flex items-start gap-3">
          <i class="fas fa-exclamation-triangle text-amber-700 mt-0.5"></i>
          <div>
            <div class="display text-[16px] text-ink leading-[1.15]">Twilio configuration required</div>
            <p class="text-[13px] text-ink-2 mt-1">To send SMS and WhatsApp messages, set these environment variables:</p>
            <ul class="font-mono text-[11px] text-ink-2 mt-2 space-y-0.5">
              <li>· TWILIO_ACCOUNT_SID</li>
              <li>· TWILIO_AUTH_TOKEN</li>
              <li>· TWILIO_PHONE_NUMBER</li>
              <li>· TWILIO_WHATSAPP_NUMBER (optional)</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
