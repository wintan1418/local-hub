<div class="min-h-screen bg-slate-50">
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= link_to provider_team_members_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i>Back
    <% end %>

    <h1 class="text-2xl font-black text-slate-900 mb-8">Invite Team Member</h1>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 sm:p-8">
      <%= form_with model: @team_member, url: provider_team_members_path, local: true, class: "space-y-5" do |f| %>
        <% if @team_member.errors.any? %>
          <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700">
            <%= @team_member.errors.full_messages.join(", ") %>
          </div>
        <% end %>

        <div>
          <label class="block text-sm font-bold text-slate-900 mb-2">Email Address</label>
          <%= f.email_field :invite_email, placeholder: "teammate@example.com", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500" %>
          <p class="text-xs text-slate-400 mt-1.5">They'll get an invitation to join your team.</p>
        </div>

        <div>
          <label class="block text-sm font-bold text-slate-900 mb-2">Role</label>
          <%= f.select :role, options_for_select(TeamMember::ROLES.map { |r| [r.titleize, r] }), {}, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white" %>
        </div>

        <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-white px-6 py-3 rounded-xl font-bold text-sm cursor-pointer">Send Invitation</button>
      <% end %>
    </div>
  </div>
</div>
