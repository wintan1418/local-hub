<div class="min-h-screen bg-cream">
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_team_members_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">invite</div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]">Add a <em class="italic-wonk" style="color: #1f4d3a;">teammate</em>.</h1>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with model: @team_member, url: provider_team_members_path, local: true, class: "space-y-5" do |f| %>
        <% if @team_member.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200 text-[13px] text-rose-700"><%= @team_member.errors.full_messages.join(", ") %></div>
        <% end %>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Email</label>
          <%= f.email_field :invite_email, placeholder: "teammate@example.com",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          <p class="text-[11px] text-ink-3 mt-1.5">They'll get an invitation to join your team.</p>
        </div>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Role</label>
          <%= f.select :role, options_for_select(TeamMember::ROLES.map { |r| [ r.titleize, r ] }), {},
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <button type="submit" class="w-full bg-ink hover:bg-ink-2 text-cream py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px">Send invitation</button>
      <% end %>
    </div>
  </div>
</div>
