<div class="min-h-screen bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">team</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Your <em class="italic-wonk" style="color: #1f4d3a;">crew</em>.</h1>
        <p class="mt-2 text-[14px] text-ink-2">Invite people to help run your business.</p>
      </div>
      <%= link_to new_provider_team_member_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
        <i class="fas fa-plus text-[10px]"></i>Invite member
      <% end %>
    </div>

    <% if @team_members.any? %>
      <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
        <div class="divide-y divide-line">
          <% @team_members.each do |tm| %>
            <div class="flex items-center justify-between px-5 sm:px-6 py-4">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[13px] font-semibold border border-line flex-shrink-0">
                  <%= (tm.member&.display_name || tm.invite_email)[0].upcase %>
                </div>
                <div class="min-w-0">
                  <div class="text-[14px] font-semibold text-ink truncate"><%= tm.member&.display_name || tm.invite_email %></div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3"><%= tm.role&.titleize %> · <%= tm.status.titleize %></div>
                </div>
              </div>
              <%= button_to provider_team_member_path(tm), method: :delete, data: { turbo_confirm: "Remove this team member?" }, class: "text-ink-3 hover:text-rose-700 cursor-pointer p-2" do %>
                <i class="fas fa-times text-[12px]"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-users",
          title: "No team members yet",
          message: "Invite staff to assign bookings and help manage your business.",
          cta_text: "Invite first member",
          cta_path: new_provider_team_member_path,
          cta_icon: "fa-plus" %>
    <% end %>
  </div>
</div>
