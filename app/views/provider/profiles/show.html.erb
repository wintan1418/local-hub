<div class="min-h-screen bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Header with avatar %>
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5 mb-8">
      <div class="flex items-center gap-5">
        <% if @user.profile_picture.attached? %>
          <%= image_tag @user.profile_picture, class: "h-20 w-20 rounded-full object-cover border border-line flex-shrink-0" %>
        <% else %>
          <div class="h-20 w-20 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[24px] font-semibold border border-line flex-shrink-0">
            <%= @user.display_name.first.upcase %>
          </div>
        <% end %>
        <div>
          <div class="eyebrow mb-2">profile</div>
          <h1 class="display text-[28px] sm:text-[36px] text-ink leading-[1.05] tracking-[-0.02em]"><%= @user.display_name %></h1>
          <div class="mt-2 flex items-center gap-2 flex-wrap">
            <% if @user.verified? %>
              <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-forest-soft text-forest"><i class="fas fa-check text-[8px] mr-0.5"></i>verified</span>
            <% else %>
              <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-amber-100/60 text-amber-800">pending verification</span>
            <% end %>
            <% if @user.profile_complete? %>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">profile complete</span>
            <% else %>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-rose-700">profile incomplete</span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to edit_provider_profile_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors" do %>
          <i class="fas fa-pen text-[10px]"></i>Edit
        <% end %>
        <%= link_to verification_provider_profile_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors" do %>
          Documents
        <% end %>
        <%= link_to portfolio_provider_profile_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors" do %>
          Portfolio
        <% end %>
      </div>
    </div>

    <%# Info card %>
    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
      <% [
        [ "Full name", @user.full_name.presence || "—" ],
        [ "Email", @user.email ],
        [ "Phone", @user.phone.presence || "—" ],
        [ "Business name", @user.business_name.presence || "—" ],
        [ "Years experience", @user.years_experience.present? ? pluralize(@user.years_experience, "year") : "—" ],
        [ "Business address", @user.complete_address.presence || "—" ],
        [ "Business license", @user.business_license.presence || "—" ],
        [ "Insurance number", @user.insurance_number.presence || "—" ],
        [ "About", @user.bio.presence || "—" ],
        [ "Member since", @user.created_at.strftime("%B %-d, %Y") ],
        [ "Verification status", @user.verification_status ]
      ].each do |label, value| %>
        <div class="px-5 sm:px-6 py-4 grid sm:grid-cols-3 gap-2 sm:gap-4 border-b border-line last:border-0">
          <dt class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= label %></dt>
          <dd class="sm:col-span-2 text-[14px] text-ink leading-[1.5]"><%= value %></dd>
        </div>
      <% end %>
    </div>
  </div>
</div>
