<% input_class = "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
<% label_class = "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>

<div class="min-h-screen bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_profile_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to profile
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">edit profile</div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]">Polish your <em class="italic-wonk" style="color: #1f4d3a;">profile</em>.</h1>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: @user, url: provider_profile_path, method: :patch, local: true, class: "space-y-8") do |form| %>
        <% if @user.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-rose-700 mb-1"><%= pluralize(@user.errors.count, "error") %></div>
            <ul class="space-y-0.5 ml-5">
              <% @user.errors.full_messages.each do |message| %><li class="text-[13px] text-rose-700 list-disc"><%= message %></li><% end %>
            </ul>
          </div>
        <% end %>

        <%# Profile picture %>
        <div>
          <label class="<%= label_class %>">Profile picture</label>
          <div class="flex items-center gap-4">
            <% if @user.profile_picture.attached? %>
              <%= image_tag @user.profile_picture, class: "h-16 w-16 rounded-full object-cover border border-line" %>
            <% else %>
              <div class="h-16 w-16 rounded-full bg-cream-sunken text-ink-3 flex items-center justify-center text-[18px] font-semibold border border-line">
                <%= @user.display_name.first.upcase %>
              </div>
            <% end %>
            <%= form.file_field :profile_picture, class: "text-[12px] file:mr-3 file:px-3 file:py-1.5 file:rounded-pill file:border-0 file:bg-cream-sunken file:text-ink-2 file:text-[11px] file:font-semibold hover:file:bg-line" %>
          </div>
        </div>

        <%# Personal info %>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">personal</div>
          <div class="space-y-4">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <%= form.label :first_name, class: label_class %>
                <%= form.text_field :first_name, class: input_class %>
              </div>
              <div>
                <%= form.label :last_name, class: label_class %>
                <%= form.text_field :last_name, class: input_class %>
              </div>
            </div>
            <div>
              <%= form.label :phone, class: label_class %>
              <%= form.text_field :phone, placeholder: "1234567890", class: input_class %>
              <p class="text-[11px] text-ink-3 mt-1.5">10–15 digits only</p>
            </div>
            <div>
              <%= form.label :bio, "About you", class: label_class %>
              <%= form.text_area :bio, rows: 4, class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
              <p class="text-[11px] text-ink-3 mt-1.5">Brief description about your services and experience.</p>
            </div>
          </div>
        </div>

        <%# Business %>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">business</div>
          <div class="space-y-4">
            <div>
              <%= form.label :business_name, class: label_class %>
              <%= form.text_field :business_name, class: input_class %>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <%= form.label :business_license, "Business license", class: label_class %>
                <%= form.text_field :business_license, class: input_class %>
              </div>
              <div>
                <%= form.label :insurance_number, class: label_class %>
                <%= form.text_field :insurance_number, class: input_class %>
              </div>
              <div>
                <%= form.label :years_experience, class: label_class %>
                <%= form.number_field :years_experience, min: 0, max: 50, class: input_class %>
              </div>
            </div>
          </div>
        </div>

        <%# Address %>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">business address</div>
          <div class="space-y-4">
            <div>
              <%= form.label :address, "Street", class: label_class %>
              <%= form.text_field :address, class: input_class %>
            </div>
            <div class="grid sm:grid-cols-3 gap-4">
              <div>
                <%= form.label :city, class: label_class %>
                <%= form.text_field :city, class: input_class %>
              </div>
              <div>
                <%= form.label :state, class: label_class %>
                <%= form.text_field :state, class: input_class %>
              </div>
              <div>
                <%= form.label :zip_code, "ZIP", class: label_class %>
                <%= form.text_field :zip_code, placeholder: "12345", class: input_class %>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between pt-5 border-t border-line">
          <%= link_to "Cancel", provider_profile_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <%= form.submit "Save profile", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
