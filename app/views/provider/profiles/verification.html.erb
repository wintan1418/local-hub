<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_profile_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to profile
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">verification</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Get the <em class="italic-wonk" style="color: #1f4d3a;">badge</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">Upload documents to verify your business and increase customer trust.</p>
    </div>

    <%# Status callout %>
    <% status_class = @user.verified? ? "bg-forest-soft border-forest/20" : (@user.verification_documents_uploaded? ? "bg-forest-soft border-forest/20" : "bg-amber-100/60 border-amber-200") %>
    <% status_color = @user.verified? ? "text-forest" : (@user.verification_documents_uploaded? ? "text-forest" : "text-amber-800") %>
    <div class="<%= status_class %> border rounded-xl p-5 mb-6">
      <div class="flex items-start gap-3">
        <i class="fas <%= @user.verified? ? 'fa-check-circle' : (@user.verification_documents_uploaded? ? 'fa-clock' : 'fa-exclamation-triangle') %> <%= status_color %> mt-1"></i>
        <div class="flex-1">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] <%= status_color %> mb-1">status</div>
          <div class="display text-[18px] text-ink leading-[1.15]"><%= @user.verification_status %></div>
          <p class="mt-2 text-[13px] text-ink-2 leading-[1.5]">
            <% if @user.verified? %>
              Your account is verified. Customers see your verified badge.
            <% elsif @user.verification_documents_uploaded? %>
              All documents uploaded — under review. We'll notify you when verification completes.
            <% else %>
              Upload the required documents below to start verification.
            <% end %>
          </p>
          <% unless @user.verified? %>
            <div class="mt-4">
              <div class="flex justify-between font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mb-1.5">
                <span>progress</span>
                <span><%= @user.verification_progress %>%</span>
              </div>
              <div class="w-full bg-cream-sunken rounded-pill h-1.5 overflow-hidden">
                <div class="h-full rounded-pill" style="width: <%= @user.verification_progress %>%; background-color: <%= @user.verification_progress == 100 ? '#1f4d3a' : '#d96a3a' %>;"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%= form_with(url: upload_documents_provider_profile_path, method: :post, local: true, multipart: true, class: "space-y-3") do |form| %>
      <% [
        { field: :business_license_file, doc_check: :business_license_document?, title: "Business license", note: "A clear photo or scan of your business license" },
        { field: :insurance_certificate_file, doc_check: :insurance_certificate_document?, title: "Insurance certificate", note: "Your current liability insurance certificate" },
        { field: :professional_certifications_file, doc_check: :professional_certifications_document?, title: "Professional certifications", note: "Any relevant certifications or trade licenses" },
        { field: :government_id_file, doc_check: :government_id_document?, title: "Government ID", note: "A valid government-issued photo ID (driver's license or passport)" }
      ].each do |doc| %>
        <% uploaded = @user.send(doc[:doc_check]) %>
        <div class="rounded-xl p-5 border <%= uploaded ? 'bg-forest-soft border-forest/20' : 'bg-cream-elevated border-line' %>">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <h5 class="display text-[18px] text-ink leading-[1.15]"><%= doc[:title] %></h5>
                <% if uploaded %>
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-forest"><i class="fas fa-check text-[8px] mr-0.5"></i>uploaded</span>
                <% end %>
              </div>
              <p class="text-[12px] text-ink-3"><%= doc[:note] %></p>
            </div>
          </div>

          <% file_attachment = @user.send(doc[:field].to_s.sub("_file", "_file")) %>
          <% if file_attachment.attached? %>
            <div class="mb-3 flex items-center gap-3 p-3 bg-cream-elevated border border-line rounded-lg">
              <i class="fas fa-file-alt text-ink-3 text-[14px]"></i>
              <span class="text-[13px] text-ink truncate flex-1"><%= file_attachment.filename %></span>
              <span class="font-mono text-[10px] text-ink-3 whitespace-nowrap"><%= number_to_human_size(file_attachment.byte_size) %></span>
            </div>
          <% end %>

          <%= form.file_field doc[:field], accept: "image/*,application/pdf",
              class: "block w-full text-[12px] file:mr-3 file:px-4 file:py-2 file:rounded-pill file:border-0 file:bg-cream-sunken file:text-ink-2 file:text-[11px] file:font-semibold hover:file:bg-line" %>
        </div>
      <% end %>

      <div class="pt-2 text-center">
        <%= form.submit "Upload all documents", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
      </div>
    <% end %>

    <div class="mt-8 bg-cream-sunken/40 border border-line rounded-xl p-5">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">notes</div>
      <ul class="text-[13px] text-ink-2 space-y-1.5">
        <li class="flex items-start gap-2"><i class="fas fa-circle text-ink-3 text-[5px] mt-2"></i>All documents must be clear and legible</li>
        <li class="flex items-start gap-2"><i class="fas fa-circle text-ink-3 text-[5px] mt-2"></i>Accepted formats: JPG, PNG, PDF · max 10MB per file</li>
        <li class="flex items-start gap-2"><i class="fas fa-circle text-ink-3 text-[5px] mt-2"></i>Reviewed within 1–2 business days</li>
        <li class="flex items-start gap-2"><i class="fas fa-circle text-ink-3 text-[5px] mt-2"></i>You'll get an email when verification completes</li>
        <% unless @user.missing_documents.empty? %>
          <li class="flex items-start gap-2 text-rose-700 font-semibold"><i class="fas fa-circle text-rose-700 text-[5px] mt-2"></i>Missing: <%= @user.missing_documents.join(", ") %></li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
