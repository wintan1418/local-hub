<div class="min-h-screen bg-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to provider_profile_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to profile
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">portfolio</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Show your <em class="italic-wonk" style="color: #1f4d3a;">work</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">Showcase previous work to attract more customers.</p>
    </div>

    <%# Upload form %>
    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8 mb-6">
      <%= form_with(url: upload_portfolio_provider_profile_path, method: :post, local: true, class: "space-y-4") do |form| %>
        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Add images</label>
          <%= form.file_field :portfolio_images, multiple: true, accept: "image/*",
              class: "block w-full text-[13px] file:mr-3 file:px-4 file:py-2 file:rounded-pill file:border-0 file:bg-cream-sunken file:text-ink-2 file:text-[12px] file:font-semibold hover:file:bg-line" %>
          <p class="text-[11px] text-ink-3 mt-1.5">JPG, PNG, GIF · max 5MB per image</p>
        </div>
        <%= form.submit "Upload images", class: "bg-ink hover:bg-ink-2 text-cream px-5 py-2.5 rounded-pill text-sm font-semibold cursor-pointer transition-colors active:translate-y-px" %>
      <% end %>
    </div>

    <%# Gallery %>
    <% if @portfolio_images.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4">
        <% @portfolio_images.each do |image| %>
          <div class="relative group">
            <div class="aspect-square rounded-xl overflow-hidden border border-line bg-cream-sunken">
              <%= image_tag image, class: "object-cover w-full h-full group-hover:opacity-75 transition-opacity" %>
            </div>
            <%= link_to destroy_portfolio_image_provider_profile_path(image_id: image.id),
                method: :delete, data: { turbo_confirm: "Remove this image?" },
                class: "absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity w-8 h-8 rounded-full bg-rose-700 hover:bg-rose-800 text-cream flex items-center justify-center" do %>
              <i class="fas fa-times text-[12px]"></i>
            <% end %>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-2">uploaded <%= image.created_at.strftime("%b %-d") %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-image",
          title: "No portfolio images",
          message: "Upload photos of your work to start your portfolio." %>
    <% end %>

    <%# Tips %>
    <div class="mt-8 bg-forest-soft border border-forest/20 rounded-xl p-5">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-forest mb-2">tips</div>
      <h4 class="display text-[18px] text-ink leading-[1.15] mb-3">For a great portfolio</h4>
      <ul class="space-y-1.5 text-[13px] text-ink-2">
        <li class="flex items-start gap-2"><i class="fas fa-check text-forest text-[10px] mt-1.5"></i>Include before and after photos when possible</li>
        <li class="flex items-start gap-2"><i class="fas fa-check text-forest text-[10px] mt-1.5"></i>Show a variety of your work to demonstrate range</li>
        <li class="flex items-start gap-2"><i class="fas fa-check text-forest text-[10px] mt-1.5"></i>Use high-quality, well-lit photos</li>
        <li class="flex items-start gap-2"><i class="fas fa-check text-forest text-[10px] mt-1.5"></i>Showcase attention to detail</li>
        <li class="flex items-start gap-2"><i class="fas fa-check text-forest text-[10px] mt-1.5"></i>Keep your portfolio updated with recent work</li>
      </ul>
    </div>
  </div>
</div>
