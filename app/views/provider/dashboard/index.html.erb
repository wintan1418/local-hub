<div class="min-h-screen bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-xl sm:text-3xl font-bold text-slate-900">Provider Dashboard</h1>
          <p class="mt-1 text-xs sm:text-sm text-slate-600">Welcome back, <%= current_user.display_name %>!</p>
        </div>
        <div class="flex gap-2">
          <%= link_to new_provider_service_path, class: "flex-1 sm:flex-none bg-orange-500 hover:bg-orange-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors flex items-center justify-center" do %>
            <i class="fas fa-plus mr-2 text-xs"></i>Add Service
          <% end %>
        </div>
      </div>
    </div>

    <!-- Stats Cards — 2-col on mobile, compact -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6 sm:mb-8">
      <div class="bg-white rounded-xl border border-slate-100 p-4 sm:p-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-orange-50 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-dollar-sign text-orange-600 text-sm sm:text-base"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] sm:text-xs font-medium text-slate-500 uppercase tracking-wider">Revenue</p>
            <p class="text-base sm:text-2xl font-black text-slate-900 truncate">$<%= number_with_delimiter(@total_revenue) %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-100 p-4 sm:p-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-calendar-check text-blue-600 text-sm sm:text-base"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] sm:text-xs font-medium text-slate-500 uppercase tracking-wider">Bookings</p>
            <p class="text-base sm:text-2xl font-black text-slate-900"><%= @total_bookings %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-100 p-4 sm:p-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-green-50 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-star text-green-600 text-sm sm:text-base"></i>
          </div>
          <div class="ml-4">
            <p class="text-[10px] sm:text-xs font-medium text-slate-500 uppercase tracking-wider">Rating</p>
            <p class="text-base sm:text-2xl font-black text-slate-900"><%= @avg_rating %><span class="text-xs text-amber-400 ml-0.5">★</span></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-100 p-4 sm:p-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-purple-50 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-cog text-purple-600 text-sm sm:text-base"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] sm:text-xs font-medium text-slate-500 uppercase tracking-wider">Services</p>
            <p class="text-base sm:text-2xl font-black text-slate-900"><%= @total_services %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Recent Bookings -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-slate-100">
          <div class="p-6 border-b border-slate-200">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-slate-900">Recent Bookings</h2>
              <div class="flex space-x-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  <i class="fas fa-clock mr-1"></i><%= @pending_count %> Pending
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <i class="fas fa-calendar-alt mr-1"></i><%= @this_month_bookings %> This Month
                </span>
              </div>
            </div>
          </div>
          <div class="p-6">
            <% if @recent_bookings.any? %>
              <div class="space-y-4">
                <% @recent_bookings.each do |booking| %>
                  <div class="border border-slate-200 rounded-lg hover:border-slate-300 transition-colors overflow-hidden">
                    <%= link_to booking_path(booking), class: "flex items-start gap-3 p-3 sm:p-4 hover:bg-slate-50 transition-colors" do %>
                      <div class="h-9 w-9 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-user text-orange-600 text-xs"></i>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <h3 class="font-semibold text-slate-900 text-sm truncate"><%= booking.service.title %></h3>
                          <% status_colors = { 'pending' => 'bg-yellow-100 text-yellow-800', 'confirmed' => 'bg-green-100 text-green-800', 'completed' => 'bg-blue-100 text-blue-800', 'cancelled' => 'bg-red-100 text-red-800' } %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold flex-shrink-0 <%= status_colors[booking.status] %>"><%= booking.status.titleize %></span>
                        </div>
                        <p class="text-xs text-slate-500 truncate"><%= booking.customer.display_name %></p>
                        <div class="flex items-center gap-2 mt-1 text-xs text-slate-400">
                          <span class="truncate"><i class="fas fa-clock mr-1 text-[10px]"></i><%= booking.scheduled_at.strftime("%b %d, %-I:%M %p") %></span>
                          <span class="flex-shrink-0 font-bold text-slate-900">$<%= booking.total_price %></span>
                        </div>
                      </div>
                    <% end %>
                    <% if booking.pending? || booking.confirmed? %>
                      <div class="flex gap-2 px-3 pb-3 sm:px-4 sm:pb-4 border-t border-slate-100 pt-3">
                        <% if booking.pending? %>
                          <%= button_to confirm_provider_booking_path(booking), method: :patch, class: "flex-1 inline-flex items-center justify-center px-3 py-2 rounded-lg text-xs font-semibold bg-emerald-50 text-emerald-700 hover:bg-emerald-100 transition-colors cursor-pointer" do %>
                            <i class="fas fa-check mr-1"></i>Accept
                          <% end %>
                          <%= button_to cancel_provider_booking_path(booking), method: :patch, data: { turbo_confirm: "Reject this booking?" }, class: "flex-1 inline-flex items-center justify-center px-3 py-2 rounded-lg text-xs font-semibold bg-red-50 text-red-600 hover:bg-red-100 transition-colors cursor-pointer" do %>
                            <i class="fas fa-times mr-1"></i>Reject
                          <% end %>
                        <% elsif booking.confirmed? %>
                          <%= button_to complete_provider_booking_path(booking), method: :patch, data: { turbo_confirm: "Mark this booking as completed?" }, class: "flex-1 inline-flex items-center justify-center px-3 py-2 rounded-lg text-xs font-semibold bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors cursor-pointer" do %>
                            <i class="fas fa-check-double mr-1"></i>Mark Complete
                          <% end %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="mt-6 text-center">
                <button class="text-orange-600 hover:text-orange-700 font-medium text-sm">
                  View All Bookings <i class="fas fa-arrow-right ml-1"></i>
                </button>
              </div>
            <% else %>
              <div class="text-center py-12">
                <i class="fas fa-calendar-alt text-4xl text-slate-400 mb-4"></i>
                <h3 class="text-lg font-medium text-slate-900 mb-2">No bookings yet</h3>
                <p class="text-slate-500">Start by adding some services to attract customers!</p>
                <%= link_to new_provider_service_path, class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-orange-500 hover:bg-orange-600" do %>
                  <i class="fas fa-plus mr-2"></i>Add Your First Service
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4 sm:space-y-6">
        <!-- Quick Actions — icon grid (more compact, scales with screen) -->
        <div class="bg-white rounded-xl border border-slate-100 p-4 sm:p-5">
          <h2 class="text-sm font-bold text-slate-900 mb-3">Quick Actions</h2>
          <div class="grid grid-cols-4 sm:grid-cols-3 gap-2">
            <% [
              { path: new_provider_service_path, icon: "fa-plus", label: "Add", color: "orange", primary: true },
              { path: provider_quotes_path, icon: "fa-file-invoice-dollar", label: "Quotes", color: "slate" },
              { path: provider_calendar_path, icon: "fa-calendar-alt", label: "Calendar", color: "slate" },
              { path: provider_analytics_path, icon: "fa-chart-line", label: "Analytics", color: "slate" },
              { path: provider_payouts_path, icon: "fa-dollar-sign", label: "Payouts", color: "emerald" },
              { path: edit_provider_site_path, icon: "fa-globe", label: "Website", color: "violet" },
              { path: provider_team_members_path, icon: "fa-users", label: "Team", color: "slate" },
              { path: job_requests_path, icon: "fa-briefcase", label: "Jobs", color: "slate" },
              { path: conversations_path, icon: "fa-comments", label: "Messages", color: "slate" },
              { path: provider_profile_path, icon: "fa-user", label: "Profile", color: "slate" },
              { path: provider_subscriptions_path, icon: "fa-credit-card", label: "Plan", color: "slate" },
              { path: provider_export_bookings_path, icon: "fa-file-export", label: "Export", color: "slate" }
            ].each do |action| %>
              <%= link_to action[:path], class: "group flex flex-col items-center gap-1.5 p-2.5 rounded-lg #{action[:primary] ? 'bg-orange-500 hover:bg-orange-600 text-white' : action[:color] != 'slate' ? "bg-#{action[:color]}-50 hover:bg-#{action[:color]}-100 text-#{action[:color]}-700" : 'bg-slate-50 hover:bg-slate-100 text-slate-700'} transition-colors" do %>
                <i class="fas <%= action[:icon] %> text-sm"></i>
                <span class="text-[10px] font-semibold text-center leading-tight"><%= action[:label] %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Vacation Mode -->
        <div class="bg-white rounded-xl border border-slate-100 p-6">
          <h2 class="text-sm font-bold text-slate-900 mb-3"><i class="fas fa-umbrella-beach mr-1.5 text-amber-500"></i>Vacation Mode</h2>
          <% if current_user.on_vacation? %>
            <div class="text-sm text-amber-700 bg-amber-50 rounded-lg p-3 border border-amber-100 mb-3">
              Away until <%= current_user.vacation_until.strftime("%b %d, %Y") %>. New customers can't book you.
            </div>
            <%= button_to provider_profile_path, method: :patch, params: { user: { vacation_until: nil } }, class: "w-full text-sm font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200 px-4 py-2 rounded-lg cursor-pointer" do %>
              Resume Bookings
            <% end %>
          <% else %>
            <p class="text-xs text-slate-500 mb-3">Pause new bookings when you're away.</p>
            <%= form_with url: provider_profile_path, method: :patch, local: true do |f| %>
              <%= f.date_field "user[vacation_until]", min: Date.current.to_s, class: "w-full px-3 py-2 mb-2 rounded-lg border border-slate-200 text-sm" %>
              <button type="submit" class="w-full text-sm font-semibold text-white bg-amber-500 hover:bg-amber-600 px-4 py-2 rounded-lg">Set Away Date</button>
            <% end %>
          <% end %>
        </div>

        <!-- Profile Status -->
        <div class="bg-white rounded-xl border border-slate-100 p-6">
          <h2 class="text-lg font-semibold mb-4 text-slate-900">Profile Status</h2>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-600">Profile Complete</span>
              <% if current_user.profile_complete? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <i class="fas fa-check mr-1"></i>Complete
                </span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  <i class="fas fa-exclamation mr-1"></i>Incomplete
                </span>
              <% end %>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-600">Verification</span>
              <% if current_user.verified? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <i class="fas fa-check-circle mr-1"></i>Verified
                </span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  <i class="fas fa-clock mr-1"></i>Pending
                </span>
              <% end %>
            </div>
            <% unless current_user.profile_complete? %>
              <%= link_to edit_provider_profile_path, class: "block w-full text-center text-sm text-blue-600 hover:text-blue-700 mt-3" do %>
                Complete Your Profile <i class="fas fa-arrow-right ml-1"></i>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Your Services -->
        <div class="bg-white rounded-xl border border-slate-100 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-slate-900">Your Services</h2>
            <span class="text-sm text-slate-500"><%= @total_services %> services</span>
          </div>
          <% if @services.any? %>
            <div class="space-y-3">
              <% @services.limit(4).each do |service| %>
                <div class="flex items-center justify-between p-3 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                  <div class="flex items-center space-x-3">
                    <% if service.images.any? %>
                      <%= image_tag service.images.first, class: "h-8 w-8 rounded object-cover" %>
                    <% else %>
                      <div class="h-8 w-8 rounded bg-slate-200 flex items-center justify-center">
                        <i class="fas fa-image text-slate-400 text-sm"></i>
                      </div>
                    <% end %>
                    <div>
                      <h3 class="font-medium text-sm text-slate-900"><%= service.title %></h3>
                      <p class="text-xs text-slate-600"><%= service.category.name %></p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-slate-900">$<%= service.base_price %></p>
                    <p class="text-xs text-slate-500"><%= service.price_type.titleize %></p>
                  </div>
                </div>
              <% end %>
            </div>
            <% if @services.count > 4 %>
              <div class="mt-4 text-center">
                <button class="text-orange-600 hover:text-orange-700 font-medium text-sm">
                  View All Services <i class="fas fa-arrow-right ml-1"></i>
                </button>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-6">
              <i class="fas fa-plus-circle text-3xl text-slate-400 mb-3"></i>
              <p class="text-slate-500 text-sm mb-3">No services added yet.</p>
              <%= link_to new_provider_service_path, class: "text-orange-600 hover:text-orange-700 font-medium text-sm" do %>
                Add Your First Service <i class="fas fa-arrow-right ml-1"></i>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Performance Overview -->
        <div class="bg-white rounded-xl border border-slate-100 p-6">
          <h2 class="text-lg font-semibold mb-4 text-slate-900">Performance Overview</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-600">Total Reviews</span>
              <span class="text-sm font-medium text-slate-900"><%= @total_reviews %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-600">Completion Rate</span>
              <span class="text-sm font-medium text-slate-900">
                <%= @total_bookings > 0 ? ((@completed_bookings.count.to_f / @total_bookings) * 100).round(1) : 0 %>%
              </span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-600">Response Time</span>
              <span class="text-sm font-medium text-slate-900">< 2 hours</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>