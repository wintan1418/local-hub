<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

    <%# ===== HEADER ===== %>
    <div class="mb-8 sm:mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <div class="eyebrow mb-3">provider dashboard</div>
          <h1 class="display text-[36px] sm:text-[48px] text-ink leading-[1] tracking-[-0.02em]">Welcome back, <em class="italic-wonk" style="color: #1f4d3a;"><%= current_user.display_name %></em>.</h1>
        </div>
        <div class="flex gap-2">
          <%= link_to new_provider_service_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
            <i class="fas fa-plus text-[10px]"></i>Add service
          <% end %>
        </div>
      </div>
    </div>

    <%# ===== KPI ROW ===== %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-8 sm:mb-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-line">
        <% [
          { label: "Revenue", value: "$#{number_with_delimiter(@total_revenue)}", color: "ink" },
          { label: "Bookings", value: @total_bookings.to_s, color: "ink" },
          { label: "Rating", value: @avg_rating.to_s, suffix: "★", color: "amber" },
          { label: "Services", value: @total_services.to_s, color: "ink" }
        ].each do |stat| %>
          <div class="p-5 sm:p-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= stat[:label] %></div>
            <div class="display text-[36px] sm:text-[44px] text-ink leading-none mt-2 truncate">
              <%= stat[:value] %><% if stat[:suffix] %><span class="text-amber-500 text-[20px] ml-1"><%= stat[:suffix] %></span><% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ===== MAIN GRID ===== %>
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-6 lg:gap-8">

      <%# LEFT — recent bookings %>
      <div>
        <div class="bg-cream-elevated border border-line rounded-xl">
          <div class="px-5 sm:px-6 py-4 border-b border-line flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
            <div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recent bookings</div>
              <div class="display text-[20px] text-ink leading-[1.1]"><%= @recent_bookings.count %> recent · <%= @this_month_bookings %> this month</div>
            </div>
            <div class="flex gap-1.5 flex-wrap">
              <% if @pending_count > 0 %>
                <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2.5 py-0.5 rounded-pill bg-amber-100/60 text-amber-800 border border-amber-200">
                  <%= @pending_count %> pending
                </span>
              <% end %>
              <%= link_to bookings_path, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink ml-1 self-center" do %>see all →<% end %>
            </div>
          </div>

          <div class="p-3 sm:p-4">
            <% if @recent_bookings.any? %>
              <div class="space-y-2">
                <% @recent_bookings.each do |booking| %>
                  <div class="rounded-lg border border-line overflow-hidden">
                    <%= link_to booking_path(booking), class: "flex items-start gap-3 p-3 sm:p-4 hover:bg-cream-sunken/40 transition-colors" do %>
                      <div class="h-10 w-10 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-user text-ink-3 text-xs"></i>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <div class="display text-[16px] text-ink leading-[1.15] truncate"><%= booking.service.title %></div>
                          <% status_colors = {
                            "pending" => [ "bg-amber-100/60", "text-amber-800" ],
                            "confirmed" => [ "bg-forest-soft", "text-forest" ],
                            "completed" => [ "bg-cream-sunken", "text-ink-2" ],
                            "cancelled" => [ "bg-rose-100/60", "text-rose-700" ]
                          } %>
                          <% c = status_colors[booking.status] || [ "bg-cream-sunken", "text-ink-2" ] %>
                          <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %> flex-shrink-0"><%= booking.status %></span>
                        </div>
                        <div class="font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3 mt-0.5 truncate"><%= booking.customer.display_name %></div>
                        <div class="flex items-center justify-between gap-2 mt-1.5">
                          <div class="text-[12px] text-ink-3"><%= booking.scheduled_at.strftime("%b %-d · %-I:%M %p") %></div>
                          <div class="display text-[15px] text-ink leading-none">$<%= number_with_precision(booking.total_price, precision: 0) %></div>
                        </div>
                      </div>
                    <% end %>
                    <% if booking.pending? || booking.confirmed? %>
                      <div class="flex gap-2 px-3 sm:px-4 py-3 border-t border-line bg-cream-sunken/30">
                        <% if booking.pending? %>
                          <%= button_to confirm_provider_booking_path(booking), method: :patch, class: "flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-pill text-[12px] font-semibold bg-forest hover:opacity-90 text-cream transition-opacity cursor-pointer" do %>
                            <i class="fas fa-check text-[10px]"></i>Accept
                          <% end %>
                          <%= button_to cancel_provider_booking_path(booking), method: :patch, data: { turbo_confirm: "Reject this booking?" }, class: "flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-pill text-[12px] font-semibold border border-rose-300 text-rose-700 hover:bg-rose-50 transition-colors cursor-pointer" do %>
                            <i class="fas fa-times text-[10px]"></i>Reject
                          <% end %>
                        <% elsif booking.confirmed? %>
                          <%= button_to complete_provider_booking_path(booking), method: :patch, data: { turbo_confirm: "Mark as completed?" }, class: "flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 rounded-pill text-[12px] font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors cursor-pointer" do %>
                            <i class="fas fa-check-double text-[10px]"></i>Mark complete
                          <% end %>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <%= render "shared/empty_state",
                  icon: "fa-calendar-alt",
                  title: "No bookings yet",
                  message: "Add some services to start getting booked.",
                  cta_text: "Add your first service",
                  cta_path: new_provider_service_path,
                  cta_icon: "fa-plus" %>
            <% end %>
          </div>
        </div>
      </div>

      <%# RIGHT — sidebar %>
      <aside class="space-y-4">

        <%# Quick actions — icon grid %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">quick actions</div>
          <div class="grid grid-cols-4 sm:grid-cols-3 gap-1.5">
            <% [
              { path: new_provider_service_path, icon: "fa-plus", label: "Add", primary: true },
              { path: provider_quotes_path, icon: "fa-file-invoice-dollar", label: "Quotes" },
              { path: provider_calendar_path, icon: "fa-calendar-alt", label: "Calendar" },
              { path: provider_analytics_path, icon: "fa-chart-line", label: "Analytics" },
              { path: provider_payouts_path, icon: "fa-dollar-sign", label: "Payouts" },
              { path: edit_provider_site_path, icon: "fa-globe", label: "Website" },
              { path: provider_team_members_path, icon: "fa-users", label: "Team" },
              { path: job_requests_path, icon: "fa-briefcase", label: "Jobs" },
              { path: conversations_path, icon: "fa-comments", label: "Messages" },
              { path: provider_profile_path, icon: "fa-user", label: "Profile" },
              { path: provider_subscriptions_path, icon: "fa-credit-card", label: "Plan" },
              { path: provider_export_bookings_path, icon: "fa-file-export", label: "Export" }
            ].each do |action| %>
              <% cls = action[:primary] ? "bg-ink text-cream hover:bg-ink-2" : "bg-cream-sunken/40 text-ink-2 hover:bg-cream-sunken" %>
              <%= link_to action[:path], class: "#{cls} flex flex-col items-center gap-1 p-2.5 rounded-lg transition-colors" do %>
                <i class="fas <%= action[:icon] %> text-[13px]"></i>
                <span class="text-[10px] font-medium leading-tight text-center"><%= action[:label] %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Vacation Mode %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2"><i class="fas fa-umbrella-beach text-amber-500 mr-1.5 text-[11px]"></i>vacation mode</div>
          <% if current_user.on_vacation? %>
            <div class="text-[13px] text-amber-800 bg-amber-100/60 rounded-lg p-3 border border-amber-200 mb-3">
              Away until <strong><%= current_user.vacation_until.strftime("%b %-d, %Y") %></strong>. New bookings paused.
            </div>
            <%= button_to provider_profile_path, method: :patch, params: { user: { vacation_until: nil } }, class: "w-full px-5 py-2.5 rounded-pill text-sm font-semibold bg-cream-sunken hover:bg-line text-ink transition-colors cursor-pointer" do %>
              Resume bookings
            <% end %>
          <% else %>
            <p class="text-[12px] text-ink-3 mb-3">Pause new bookings when you're away.</p>
            <%= form_with url: provider_profile_path, method: :patch, local: true, class: "space-y-2" do |f| %>
              <%= f.date_field "user[vacation_until]", min: Date.current.to_s, class: "w-full px-3 py-2 rounded-pill border border-line text-sm bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink" %>
              <button type="submit" class="w-full px-5 py-2.5 rounded-pill text-sm font-semibold bg-amber-500 hover:bg-amber-600 text-cream transition-colors cursor-pointer">Set away date</button>
            <% end %>
          <% end %>
        </div>

        <%# Profile status %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">profile status</div>
          <div class="space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-[13px] text-ink-2">Profile</span>
              <% if current_user.profile_complete? %>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-forest"><i class="fas fa-check mr-1"></i>complete</span>
              <% else %>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-amber-700"><i class="fas fa-exclamation mr-1"></i>incomplete</span>
              <% end %>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[13px] text-ink-2">Verification</span>
              <% if current_user.verified? %>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-forest"><i class="fas fa-check-circle mr-1"></i>verified</span>
              <% else %>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-amber-700"><i class="fas fa-clock mr-1"></i>pending</span>
              <% end %>
            </div>
            <% unless current_user.profile_complete? %>
              <%= link_to edit_provider_profile_path, class: "block w-full mt-3 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors text-center" do %>
                Complete profile
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Your services %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="flex items-end justify-between mb-3">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">your services</div>
            <span class="font-mono text-[11px] text-ink-3"><%= @total_services %></span>
          </div>
          <% if @services.any? %>
            <div class="space-y-1.5">
              <% @services.limit(4).each do |service| %>
                <div class="flex items-center justify-between gap-3 p-3 rounded-lg border border-line">
                  <div class="flex items-center gap-3 min-w-0">
                    <% if service.images.any? %>
                      <%= image_tag service.images.first, class: "w-9 h-9 rounded-lg object-cover border border-line flex-shrink-0" %>
                    <% else %>
                      <div class="w-9 h-9 rounded-lg bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-image text-ink-3 text-xs"></i>
                      </div>
                    <% end %>
                    <div class="min-w-0">
                      <div class="text-[13px] font-semibold text-ink truncate"><%= service.title %></div>
                      <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 truncate"><%= service.category.name %></div>
                    </div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="display text-[14px] text-ink leading-none">$<%= service.base_price %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-[13px] text-ink-3 text-center py-3">No services yet.</p>
            <%= link_to new_provider_service_path, class: "block w-full mt-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors text-center" do %>
              Add first service
            <% end %>
          <% end %>
        </div>

        <%# Performance %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">performance</div>
          <div class="space-y-2.5">
            <div class="flex items-center justify-between text-[13px]">
              <span class="text-ink-2">Reviews</span>
              <span class="font-semibold text-ink"><%= @total_reviews %></span>
            </div>
            <div class="flex items-center justify-between text-[13px]">
              <span class="text-ink-2">Completion</span>
              <span class="font-semibold text-ink"><%= @total_bookings > 0 ? ((@completed_bookings.count.to_f / @total_bookings) * 100).round(1) : 0 %>%</span>
            </div>
            <div class="flex items-center justify-between text-[13px]">
              <span class="text-ink-2">Response</span>
              <span class="font-semibold text-ink">&lt; 2h</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</div>
