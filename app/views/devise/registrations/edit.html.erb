<div class="min-h-screen bg-cream">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="mb-8">
      <div class="eyebrow mb-3">account</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Edit your <em class="italic-wonk" style="color: #1f4d3a;">account</em>.</h1>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p class="mt-1 text-[12px] text-ink-3">Awaiting confirmation for: <%= resource.unconfirmed_email %></p>
          <% end %>
        </div>

        <div class="border-t border-line pt-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">change password</div>
          <p class="text-[12px] text-ink-3 mb-3">Leave blank to keep your current password.</p>

          <div class="space-y-4">
            <div>
              <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">
                New password<% if @minimum_password_length %><span class="text-ink-4 normal-case ml-1">(<%= @minimum_password_length %>+ chars)</span><% end %>
              </label>
              <%= f.password_field :password, autocomplete: "new-password",
                  class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
            </div>
            <div>
              <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Confirm password</label>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
            </div>
          </div>
        </div>

        <div class="border-t border-line pt-5">
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Current password</label>
          <p class="text-[12px] text-ink-3 mb-2">Required to confirm any changes.</p>
          <%= f.password_field :current_password, autocomplete: "current-password",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Update account", class: "w-full bg-ink hover:bg-ink-2 text-cream py-3.5 rounded-pill font-semibold text-sm transition-colors cursor-pointer active:translate-y-px" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 bg-rose-50 border border-rose-200 rounded-xl p-5">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-rose-700 mb-2">danger zone</div>
      <h3 class="display text-[18px] text-ink leading-[1.1]">Cancel your account</h3>
      <p class="mt-1 text-[13px] text-ink-2">This is permanent — all your data will be removed.</p>
      <div class="mt-4">
        <%= button_to "Delete my account", registration_path(resource_name), data: { turbo_confirm: "Are you sure? This cannot be undone." }, method: :delete, class: "px-5 py-2.5 rounded-pill text-sm font-semibold border border-rose-300 text-rose-700 hover:bg-rose-100 transition-colors cursor-pointer" %>
      </div>
    </div>

    <div class="mt-6 text-center">
      <%= link_to :back, class: "inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>back
      <% end %>
    </div>
  </div>
</div>
