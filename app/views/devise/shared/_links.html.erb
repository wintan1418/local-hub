<div class="mt-6 pt-6 border-t border-slate-100 space-y-3 text-center">
  <%- if controller_name != 'sessions' %>
    <a href="<%= new_session_path(resource_name) %>" class="block text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <i class="fas fa-sign-in-alt mr-1.5 text-xs"></i>Already have an account? Sign in
    </a>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <a href="<%= new_registration_path(resource_name) %>" class="block text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <i class="fas fa-user-plus mr-1.5 text-xs"></i>Don't have an account? Sign up
    </a>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <a href="<%= new_password_path(resource_name) %>" class="block text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <i class="fas fa-key mr-1.5 text-xs"></i>Forgot your password?
    </a>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <a href="<%= new_confirmation_path(resource_name) %>" class="block text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <i class="fas fa-envelope mr-1.5 text-xs"></i>Didn't receive confirmation instructions?
    </a>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <a href="<%= new_unlock_path(resource_name) %>" class="block text-sm text-slate-500 hover:text-orange-500 transition-colors">
      <i class="fas fa-unlock mr-1.5 text-xs"></i>Didn't receive unlock instructions?
    </a>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <div>
        <%= button_to omniauth_authorize_path(resource_name, provider), data: { turbo: false },
            class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-orange-500 transition-colors" do %>
          <i class="fab fa-<%= provider %> text-xs"></i>Sign in with <%= OmniAuth::Utils.camelize(provider) %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
