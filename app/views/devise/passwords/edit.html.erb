<div class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12 bg-slate-50">
  <div class="w-full max-w-md">
    <%# Logo %>
    <div class="text-center mb-10">
      <a href="<%= root_path %>" class="inline-flex items-center gap-2.5 group">
        <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center shadow-sm">
          <i class="fas fa-map-marker-alt text-white text-sm"></i>
        </div>
        <span class="text-xl font-bold text-slate-900">Local<span class="text-orange-500">ServiceHub</span></span>
      </a>
    </div>

    <%# Card %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 sm:p-10">
      <div class="text-center mb-8">
        <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-shield-alt text-green-500 text-xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">Set a new password</h1>
        <p class="mt-2 text-sm text-slate-500">Choose a strong password to keep your account secure.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <%# Error messages %>
        <% if resource.errors.any? %>
          <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100">
            <div class="flex items-center gap-2 mb-2">
              <i class="fas fa-exclamation-circle text-red-400"></i>
              <h3 class="text-sm font-semibold text-red-700">Please fix the following:</h3>
            </div>
            <ul class="space-y-1 ml-6">
              <% resource.errors.full_messages.each do |msg| %>
                <li class="text-sm text-red-600 list-disc"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-5">
          <%# New Password %>
          <div>
            <label for="user_password" class="block text-sm font-medium text-slate-700 mb-1.5">
              New password
              <% if @minimum_password_length %>
                <span class="font-normal text-slate-400">(<%= @minimum_password_length %> characters min)</span>
              <% end %>
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-lock text-slate-400 text-sm"></i>
              </div>
              <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
                  placeholder: "Enter new password",
                  class: "w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm" %>
            </div>
          </div>

          <%# Confirm Password %>
          <div>
            <label for="user_password_confirmation" class="block text-sm font-medium text-slate-700 mb-1.5">Confirm new password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-lock text-slate-400 text-sm"></i>
              </div>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  placeholder: "Confirm new password",
                  class: "w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm" %>
            </div>
          </div>

          <%# Submit %>
          <button type="submit"
                  class="w-full bg-orange-500 hover:bg-orange-600 text-white py-3.5 rounded-xl font-semibold text-sm transition-all shadow-sm hover:shadow-md flex items-center justify-center gap-2">
            <i class="fas fa-check-circle"></i>
            Update Password
          </button>
        </div>
      <% end %>

      <%# Back to sign in %>
      <div class="mt-6 text-center">
        <a href="<%= new_session_path(resource_name) %>" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 transition-colors">
          <i class="fas fa-arrow-left text-xs"></i>
          Back to sign in
        </a>
      </div>
    </div>
  </div>
</div>
