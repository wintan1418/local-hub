<div class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12 bg-cream">
  <div class="w-full max-w-md">
    <div class="text-center mb-10">
      <a href="<%= root_path %>" class="inline-flex items-center gap-2.5">
        <span class="brand-mark"></span>
        <span class="font-display text-[22px] font-medium tracking-tight text-ink">radius</span>
      </a>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-8 sm:p-10">
      <div class="mb-7">
        <div class="eyebrow mb-3">forgot password</div>
        <h1 class="display text-[28px] sm:text-[32px] text-ink leading-[1.05] tracking-[-0.02em]">No worries, <em class="italic-wonk" style="color: #1f4d3a;">happens</em>.</h1>
        <p class="mt-2 text-[14px] text-ink-2 leading-[1.5]">Enter your email and we'll send reset instructions.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <ul class="space-y-0.5 ml-5">
              <% resource.errors.full_messages.each do |msg| %>
                <li class="text-[13px] text-rose-700 list-disc"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label for="user_email" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <button type="submit" class="w-full bg-ink hover:bg-ink-2 text-cream py-3.5 rounded-pill font-semibold text-sm transition-colors active:translate-y-px">
          Send reset instructions
        </button>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to new_session_path(resource_name), class: "inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>
          <i class="fas fa-arrow-left text-[10px]"></i>back to sign in
        <% end %>
      </div>
    </div>
  </div>
</div>
