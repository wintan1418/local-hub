<div class="min-h-screen flex">
  <%# ===== LEFT: Image Panel (hidden on mobile) ===== %>
  <div class="hidden lg:flex lg:w-1/2 relative bg-gray-900 items-center justify-center overflow-hidden">
    <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1200&q=80"
         alt="People working together"
         class="absolute inset-0 w-full h-full object-cover opacity-30">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-600/40 to-gray-900/80"></div>
    <div class="relative z-10 max-w-md px-12 text-center">
      <div class="w-16 h-16 bg-white/10 backdrop-blur-sm rounded-2xl flex items-center justify-center mx-auto mb-8">
        <i class="fas fa-map-marker-alt text-2xl text-orange-400"></i>
      </div>
      <h2 class="text-3xl font-bold text-white mb-4">Welcome back to<br>LocalServiceHub</h2>
      <p class="text-gray-300 text-base leading-relaxed">Connect with trusted local service providers or manage your business — all in one place.</p>
      <div class="mt-10 flex items-center justify-center gap-8 text-sm text-gray-400">
        <div class="text-center">
          <div class="text-2xl font-bold text-white"><%= User.provider.count %>+</div>
          <div>Providers</div>
        </div>
        <div class="w-px h-10 bg-white/20"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white"><%= Service.count %>+</div>
          <div>Services</div>
        </div>
        <div class="w-px h-10 bg-white/20"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white"><%= Review.count %>+</div>
          <div>Reviews</div>
        </div>
      </div>
    </div>
  </div>

  <%# ===== RIGHT: Sign In Form ===== %>
  <div class="flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12 bg-gray-50">
    <div class="w-full max-w-md">
      <%# Logo %>
      <div class="text-center mb-10">
        <a href="<%= root_path %>" class="inline-flex items-center gap-2.5 group">
          <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center shadow-sm">
            <i class="fas fa-map-marker-alt text-white text-sm"></i>
          </div>
          <span class="text-xl font-bold text-gray-900">Local<span class="text-orange-500">ServiceHub</span></span>
        </a>
      </div>

      <%# Card %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 sm:p-10">
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-gray-900">Sign in to your account</h1>
          <p class="mt-2 text-sm text-gray-500">
            Don't have an account?
            <a href="<%= new_registration_path(resource_name) %>" class="font-semibold text-orange-500 hover:text-orange-600 transition-colors">Sign up free</a>
          </p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <%# Error messages %>
          <% if flash[:alert] && flash[:alert] != "You need to sign in or sign up before continuing." %>
            <div class="mb-6 flex items-start gap-3 p-4 rounded-xl bg-red-50 border border-red-100">
              <i class="fas fa-exclamation-circle text-red-400 mt-0.5"></i>
              <p class="text-sm text-red-600"><%= flash[:alert] %></p>
            </div>
          <% end %>

          <div class="space-y-5">
            <%# Email %>
            <div>
              <label for="user_email" class="block text-sm font-medium text-gray-700 mb-1.5">Email address</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <i class="fas fa-envelope text-gray-400 text-sm"></i>
                </div>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                    placeholder: "you@example.com",
                    class: "w-full pl-11 pr-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm" %>
              </div>
            </div>

            <%# Password %>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="user_password" class="block text-sm font-medium text-gray-700">Password</label>
                <a href="<%= new_password_path(resource_name) %>" class="text-xs font-semibold text-orange-500 hover:text-orange-600 transition-colors">Forgot password?</a>
              </div>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <i class="fas fa-lock text-gray-400 text-sm"></i>
                </div>
                <%= f.password_field :password, autocomplete: "current-password", required: true,
                    placeholder: "Enter your password",
                    class: "w-full pl-11 pr-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm" %>
              </div>
            </div>

            <%# Remember me %>
            <div class="flex items-center justify-between">
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-gray-300 text-orange-500 focus:ring-orange-500 focus:ring-offset-0 cursor-pointer" %>
                <span class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">Remember me</span>
              </label>
            </div>

            <%# Submit %>
            <button type="submit"
                    class="w-full bg-orange-500 hover:bg-orange-600 text-white py-3.5 rounded-xl font-semibold text-sm transition-all shadow-sm hover:shadow-md flex items-center justify-center gap-2">
              <i class="fas fa-sign-in-alt"></i>
              Sign In
            </button>
          </div>
        <% end %>
      </div>

      <%# Footer %>
      <p class="mt-8 text-center text-xs text-gray-400">
        By signing in, you agree to our
        <a href="#" class="text-gray-500 hover:text-gray-700 underline">Terms of Service</a>
        and
        <a href="#" class="text-gray-500 hover:text-gray-700 underline">Privacy Policy</a>.
      </p>
    </div>
  </div>
</div>
