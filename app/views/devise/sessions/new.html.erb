<div class="min-h-screen flex bg-cream">

  <%# ===== LEFT: editorial panel (hidden on mobile) ===== %>
  <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center overflow-hidden border-r border-line" style="background-color: #1d1813;">
    <div class="relative z-10 max-w-md px-12">
      <span class="brand-mark brand-mark--on-dark mb-8 inline-block"></span>
      <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-4">welcome back</div>
      <h2 class="display text-cream leading-[1] tracking-[-0.02em]" style="font-size: clamp(40px, 4.5vw, 64px);">
        Find local pros, <em class="italic-wonk" style="color: #d96a3a;">actually</em> good.
      </h2>
      <p class="mt-5 text-[15px] leading-[1.55] text-cream/65 max-w-sm">Connect with verified local providers or run your business — all in one place.</p>

      <div class="mt-12 grid grid-cols-3 divide-x divide-cream/10">
        <% [
          { num: "#{User.provider.count}+", label: "providers" },
          { num: "#{Service.count}+", label: "services" },
          { num: "#{Review.count}+", label: "reviews" }
        ].each_with_index do |stat, i| %>
          <div class="<%= 'pl-6' if i > 0 %> <%= 'pr-6' if i < 2 %>">
            <div class="display text-cream text-[28px] leading-none"><%= stat[:num] %></div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-cream/55 mt-1.5"><%= stat[:label] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== RIGHT: form ===== %>
  <div class="flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12 bg-cream">
    <div class="w-full max-w-md">
      <%# Logo %>
      <div class="text-center mb-10 lg:hidden">
        <a href="<%= root_path %>" class="inline-flex items-center gap-2.5 group">
          <span class="brand-mark"></span>
          <span class="font-display text-[22px] font-medium tracking-tight text-ink">radius</span>
        </a>
      </div>

      <div class="bg-cream-elevated border border-line rounded-xl p-8 sm:p-10">
        <div class="mb-7">
          <div class="eyebrow mb-3">sign in</div>
          <h1 class="display text-[32px] text-ink leading-[1.05] tracking-[-0.02em]">Welcome <em class="italic-wonk" style="color: #1f4d3a;">back</em>.</h1>
          <p class="mt-2 text-[14px] text-ink-2">
            New here?
            <%= link_to "Sign up free", new_registration_path(resource_name), class: "font-semibold text-ink hover:underline underline-offset-2" %>
          </p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false }, class: "space-y-5" }) do |f| %>
          <% if flash[:alert] && flash[:alert] != "You need to sign in or sign up before continuing." %>
            <div class="flex items-start gap-2.5 p-3 rounded-lg bg-rose-50 border border-rose-200">
              <i class="fas fa-exclamation-circle text-rose-500 mt-0.5 text-[12px]"></i>
              <p class="text-[13px] text-rose-700"><%= flash[:alert] %></p>
            </div>
          <% end %>

          <%# Email %>
          <div>
            <label for="user_email" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                placeholder: "you@example.com",
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>

          <%# Password %>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label for="user_password" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Password</label>
              <%= link_to "Forgot?", new_password_path(resource_name), class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", required: true,
                placeholder: "Your password",
                class: "w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>

          <label class="flex items-center gap-2.5 cursor-pointer">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-line accent-ink cursor-pointer" %>
            <span class="text-[13px] text-ink-2">Remember me</span>
          </label>

          <button type="submit" class="w-full bg-ink hover:bg-ink-2 text-cream py-3.5 rounded-pill font-semibold text-sm transition-colors active:translate-y-px">
            Sign in
          </button>
        <% end %>

        <div class="relative my-7">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-line"></div></div>
          <div class="relative flex justify-center"><span class="bg-cream-elevated px-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">or</span></div>
        </div>

        <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "w-full inline-flex items-center justify-center gap-3 py-3 px-4 rounded-pill border border-line bg-cream-elevated hover:bg-cream-sunken transition-colors text-sm font-medium text-ink" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        <% end %>
      </div>

      <p class="mt-6 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">By signing in you agree to our terms & privacy</p>
    </div>
  </div>
</div>
