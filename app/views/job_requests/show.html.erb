<div class="min-h-screen bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= link_to job_requests_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Back
    <% end %>

    <div class="bg-white rounded-xl border border-slate-100 p-6 sm:p-8 mb-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full"><%= @job_request.category.name %></span>
            <% status_colors = { "open" => "emerald", "awarded" => "violet", "closed" => "slate", "cancelled" => "red" } %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-<%= status_colors[@job_request.status] %>-50 text-<%= status_colors[@job_request.status] %>-700"><%= @job_request.status.titleize %></span>
          </div>
          <h1 class="text-xl font-black text-slate-900"><%= @job_request.title %></h1>
          <p class="text-xs text-slate-400 mt-1">Posted by <%= @job_request.customer.display_name %> &middot; <%= time_ago_in_words(@job_request.created_at) %> ago</p>
        </div>
      </div>

      <p class="text-sm text-slate-600 leading-relaxed mb-5"><%= @job_request.description %></p>

      <div class="grid sm:grid-cols-3 gap-3 text-xs">
        <% if @job_request.budget_min.present? %>
          <div class="p-3 rounded-lg bg-slate-50">
            <div class="text-slate-400">Budget</div>
            <div class="font-bold text-slate-900 mt-0.5">$<%= @job_request.budget_min.to_i %><% if @job_request.budget_max.present? && @job_request.budget_max != @job_request.budget_min %>-$<%= @job_request.budget_max.to_i %><% end %></div>
          </div>
        <% end %>
        <% if @job_request.needed_by.present? %>
          <div class="p-3 rounded-lg bg-slate-50">
            <div class="text-slate-400">Needed by</div>
            <div class="font-bold text-slate-900 mt-0.5"><%= @job_request.needed_by.strftime("%b %d, %Y") %></div>
          </div>
        <% end %>
        <% if @job_request.city.present? %>
          <div class="p-3 rounded-lg bg-slate-50">
            <div class="text-slate-400">Location</div>
            <div class="font-bold text-slate-900 mt-0.5"><%= [@job_request.city, @job_request.state].compact.join(', ') %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Submit quote (providers only, open only) %>
    <% if current_user.provider? && @job_request.open? && !@my_quote %>
      <div class="bg-white rounded-xl border border-slate-100 p-6 sm:p-8 mb-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Submit Your Quote</h2>
        <%= form_with url: job_request_quotes_path(@job_request), local: true do |f| %>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-bold text-slate-900 mb-1.5">Your price ($)</label>
              <%= f.number_field :price, step: 0.01, placeholder: "0.00", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm", name: "job_request_quote[price]" %>
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-900 mb-1.5">Message</label>
              <%= f.text_area :message, rows: 3, placeholder: "Explain your approach, timeline, what's included...", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm resize-none", name: "job_request_quote[message]" %>
            </div>
            <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-bold text-sm cursor-pointer">Submit Quote</button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Quotes list %>
    <div>
      <h2 class="text-sm font-bold text-slate-900 mb-4"><%= pluralize(@quotes.count, 'Quote') %></h2>
      <% if @quotes.any? %>
        <div class="space-y-3">
          <% @quotes.each do |quote| %>
            <div class="bg-white rounded-xl border border-slate-100 p-5 <%= quote.accepted? ? 'ring-2 ring-emerald-200' : '' %>">
              <div class="flex items-start justify-between mb-2">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center text-sm font-bold text-slate-400">
                    <%= quote.provider.display_name.first.upcase %>
                  </div>
                  <div>
                    <div class="text-sm font-bold text-slate-900"><%= quote.provider.business_name || quote.provider.display_name %></div>
                    <div class="flex items-center gap-1">
                      <% 5.times do |i| %><i class="fas fa-star text-[9px] <%= i < quote.provider.average_rating.round ? 'text-amber-400' : 'text-slate-200' %>"></i><% end %>
                      <span class="text-xs text-slate-400 ml-1"><%= quote.provider.average_rating %></span>
                    </div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-xl font-black text-slate-900">$<%= number_with_precision(quote.price, precision: 0) %></div>
                  <% status_styles = { "pending" => "slate", "accepted" => "emerald", "declined" => "red" } %>
                  <span class="text-[10px] font-bold text-<%= status_styles[quote.status] %>-600"><%= quote.status.titleize %></span>
                </div>
              </div>
              <p class="text-sm text-slate-600 leading-relaxed mt-3"><%= quote.message %></p>

              <% if @job_request.customer == current_user && @job_request.open? && quote.pending? %>
                <div class="mt-4 pt-4 border-t border-slate-100 flex justify-end">
                  <%= button_to accept_job_request_quote_path(@job_request, quote), method: :patch, data: { turbo_confirm: "Accept this quote from #{quote.provider.display_name}?" }, class: "bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer" do %>
                    <i class="fas fa-check mr-1"></i>Accept Quote
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-xl border border-slate-100 p-8 text-center">
          <p class="text-sm text-slate-400">No quotes yet. Check back soon!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
