<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%= link_to job_requests_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back
    <% end %>

    <%# Job header %>
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= @job_request.category.name %></span>
        <% status_colors = {
          "open" => [ "bg-forest-soft", "text-forest" ],
          "awarded" => [ "bg-cream-sunken", "text-ink-2" ],
          "closed" => [ "bg-cream-sunken", "text-ink-3" ],
          "cancelled" => [ "bg-rose-100/60", "text-rose-700" ]
        } %>
        <% c = status_colors[@job_request.status] || [ "bg-cream-sunken", "text-ink-3" ] %>
        <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= @job_request.status %></span>
      </div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]"><%= @job_request.title %></h1>
      <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">Posted by <%= @job_request.customer.display_name %> · <%= time_ago_in_words(@job_request.created_at) %> ago</p>
    </div>

    <%# Description card %>
    <div class="bg-cream-elevated border border-line rounded-xl p-6 mb-5">
      <p class="text-[15px] text-ink-2 leading-[1.65] whitespace-pre-line"><%= @job_request.description %></p>

      <div class="grid sm:grid-cols-3 gap-3 mt-6 pt-5 border-t border-line">
        <% if @job_request.budget_min.present? %>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">budget</div>
            <div class="display text-[20px] text-ink leading-none mt-1">$<%= @job_request.budget_min.to_i %><% if @job_request.budget_max.present? && @job_request.budget_max != @job_request.budget_min %><span class="text-ink-3">–</span>$<%= @job_request.budget_max.to_i %><% end %></div>
          </div>
        <% end %>
        <% if @job_request.needed_by.present? %>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">needed by</div>
            <div class="display text-[18px] text-ink leading-[1.1] mt-1"><%= @job_request.needed_by.strftime("%b %-d, %Y") %></div>
          </div>
        <% end %>
        <% if @job_request.city.present? %>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">location</div>
            <div class="display text-[18px] text-ink leading-[1.1] mt-1"><%= [ @job_request.city, @job_request.state ].compact.join(", ") %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Submit quote — providers only, open only %>
    <% if current_user.provider? && @job_request.open? && !@my_quote %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6 mb-5">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">submit a quote</div>
        <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">Make your <em class="italic-wonk" style="color: #1f4d3a;">offer</em></h2>

        <%= form_with url: job_request_quotes_path(@job_request), local: true, class: "space-y-4" do |f| %>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Your price</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ink-3 text-sm">$</span>
              <%= f.number_field :price, step: 0.01, placeholder: "0.00",
                  class: "w-full pl-8 pr-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm",
                  name: "job_request_quote[price]" %>
            </div>
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Message</label>
            <%= f.text_area :message, rows: 3, placeholder: "Explain your approach, timeline, what's included…",
                class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none",
                name: "job_request_quote[message]" %>
          </div>
          <button type="submit" class="w-full bg-ink hover:bg-ink-2 text-cream py-3 rounded-pill font-semibold text-sm transition-colors cursor-pointer active:translate-y-px">Submit quote</button>
        <% end %>
      </div>
    <% end %>

    <%# Quotes list %>
    <div>
      <div class="flex items-end justify-between gap-2 mb-4">
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">quotes</div>
          <div class="display text-[20px] text-ink leading-[1.1]"><%= pluralize(@quotes.count, "quote") %></div>
        </div>
      </div>

      <% if @quotes.any? %>
        <div class="space-y-3">
          <% @quotes.each do |quote| %>
            <div class="bg-cream-elevated rounded-xl p-5 <%= quote.accepted? ? 'border-2 border-forest' : 'border border-line' %>">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-11 h-11 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[14px] font-semibold border border-line flex-shrink-0">
                    <%= quote.provider.display_name.first.upcase %>
                  </div>
                  <div class="min-w-0">
                    <div class="display text-[16px] text-ink leading-[1.15] truncate"><%= quote.provider.business_name.presence || quote.provider.display_name %></div>
                    <div class="flex items-center gap-1 mt-0.5">
                      <% 5.times do |i| %><i class="fas fa-star text-[9px] <%= i < quote.provider.average_rating.round ? 'text-amber-500' : 'text-line' %>"></i><% end %>
                      <span class="font-mono text-[10px] text-ink-3 ml-1"><%= quote.provider.average_rating %></span>
                    </div>
                  </div>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="display text-[24px] text-ink leading-none">$<%= number_with_precision(quote.price, precision: 0) %></div>
                  <% sc = { "pending" => "text-ink-3", "accepted" => "text-forest", "declined" => "text-rose-700" } %>
                  <div class="font-mono text-[10px] uppercase tracking-[0.08em] mt-1 <%= sc[quote.status] || 'text-ink-3' %>"><%= quote.status %></div>
                </div>
              </div>
              <p class="text-[14px] text-ink-2 leading-[1.6] mt-3"><%= quote.message %></p>

              <% if @job_request.customer == current_user && @job_request.open? && quote.pending? %>
                <div class="mt-4 pt-4 border-t border-line flex justify-end">
                  <%= button_to accept_job_request_quote_path(@job_request, quote), method: :patch, data: { turbo_confirm: "Accept this quote from #{quote.provider.display_name}?" },
                      class: "inline-flex items-center gap-2 bg-ink hover:bg-ink-2 text-cream px-5 py-2.5 rounded-pill text-sm font-semibold cursor-pointer transition-colors" do %>
                    <i class="fas fa-check text-[10px]"></i>Accept quote
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-cream-elevated rounded-xl border border-line p-8 text-center">
          <p class="text-[14px] text-ink-3">No quotes yet. Check back soon.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
