<div class="min-h-screen bg-slate-50 relative overflow-hidden">
  <%# Ambient background %>
  <div class="absolute top-0 right-0 w-96 h-96 bg-orange-100/40 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-sky-100/40 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= link_to job_requests_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 mb-8 group" do %>
      <i class="fas fa-arrow-left text-xs group-hover:-translate-x-1 transition-transform"></i>
      <span>Back to Job Requests</span>
    <% end %>

    <%# Page header with icon %>
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange-50 border border-orange-100 text-orange-600 text-xs font-bold uppercase tracking-wider mb-4">
        <i class="fas fa-bullhorn text-[10px]"></i>
        Reverse Marketplace
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight">Post a Job</h1>
      <p class="mt-2 text-slate-500">Describe what you need. Verified providers will send you quotes within hours.</p>
    </div>

    <%# Steps indicator %>
    <div class="flex items-center gap-2 mb-8">
      <div class="flex-1 h-1.5 rounded-full bg-gradient-to-r from-orange-500 to-rose-500"></div>
      <div class="flex-1 h-1.5 rounded-full bg-slate-200"></div>
      <div class="flex-1 h-1.5 rounded-full bg-slate-200"></div>
    </div>
    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-6">Step 1 of 3 · Tell us about your job</p>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-xl shadow-slate-900/[0.04] p-6 sm:p-10">
      <%= form_with(model: @job_request, local: true, class: "space-y-8") do |f| %>
        <% if @job_request.errors.any? %>
          <div class="flex items-start gap-3 p-4 rounded-xl bg-red-50 border border-red-200">
            <i class="fas fa-exclamation-circle text-red-500 mt-0.5"></i>
            <div>
              <p class="text-sm font-bold text-red-800">Please fix the following:</p>
              <ul class="mt-1 text-sm text-red-700 space-y-0.5">
                <% @job_request.errors.full_messages.each do |msg| %><li>• <%= msg %></li><% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <%# Title %>
        <div>
          <%= f.label :title, class: "block text-sm font-bold text-slate-900 mb-2" do %>
            What do you need? <span class="text-red-500">*</span>
          <% end %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <i class="fas fa-lightbulb text-slate-300"></i>
            </div>
            <%= f.text_field :title, placeholder: "e.g. Fix leaking kitchen faucet",
                class: "w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
          </div>
          <p class="mt-1.5 text-xs text-slate-400 flex items-center gap-1">
            <i class="fas fa-info-circle"></i>
            Be specific — "Fix leaking kitchen faucet" is better than "Plumbing help"
          </p>
        </div>

        <%# Category — custom pill-style selector %>
        <div>
          <label class="block text-sm font-bold text-slate-900 mb-2">Category <span class="text-red-500">*</span></label>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            <% @categories.each do |cat| %>
              <label class="relative cursor-pointer group">
                <input type="radio" name="job_request[category_id]" value="<%= cat.id %>" class="peer absolute opacity-0" required>
                <div class="flex items-center gap-2.5 px-3 py-3 rounded-xl border-2 border-slate-100 hover:border-slate-200 peer-checked:border-orange-500 peer-checked:bg-orange-50 transition-all">
                  <% if cat.icon.present? %>
                    <i class="<%= cat.icon %> text-slate-400 peer-checked:group-has-[:checked]:text-orange-500 text-sm"></i>
                  <% end %>
                  <span class="text-sm font-semibold text-slate-700 group-has-[:checked]:text-orange-700"><%= cat.name %></span>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# Description %>
        <div>
          <%= f.label :description, class: "block text-sm font-bold text-slate-900 mb-2" do %>
            Describe the job <span class="text-red-500">*</span>
          <% end %>
          <%= f.text_area :description, rows: 5, placeholder: "What's the problem? When did it start? Any special requirements? The more detail you give, the better quotes you'll get.",
              class: "w-full px-4 py-3.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all resize-none" %>
          <div class="mt-1.5 flex items-center justify-between">
            <p class="text-xs text-slate-400"><i class="fas fa-camera mr-1"></i>Photos help too — add them after posting</p>
            <span class="text-xs text-slate-400" id="desc-count">0 characters</span>
          </div>
        </div>

        <%# Budget — two fields with visual range %>
        <div>
          <label class="block text-sm font-bold text-slate-900 mb-2">Budget range</label>
          <div class="grid grid-cols-2 gap-3">
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-sm font-medium">$</span>
              </div>
              <%= f.number_field :budget_min, step: 1, placeholder: "50",
                  class: "w-full pl-8 pr-16 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
              <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <span class="text-xs text-slate-400">min</span>
              </div>
            </div>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-sm font-medium">$</span>
              </div>
              <%= f.number_field :budget_max, step: 1, placeholder: "200",
                  class: "w-full pl-8 pr-16 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
              <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <span class="text-xs text-slate-400">max</span>
              </div>
            </div>
          </div>
          <p class="mt-1.5 text-xs text-slate-400">Optional — leaving blank lets providers price freely</p>
        </div>

        <%# Needed by + Location %>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :needed_by, "When do you need this?", class: "block text-sm font-bold text-slate-900 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-calendar-alt text-slate-300"></i>
              </div>
              <%= f.datetime_field :needed_by, class: "w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-900 mb-2">ZIP code</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i class="fas fa-map-marker-alt text-slate-300"></i>
              </div>
              <%= f.text_field :zip, placeholder: "12345", maxlength: 5, class: "w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
            </div>
          </div>
        </div>

        <%# City + state %>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-900 mb-2">City</label>
            <%= f.text_field :city, placeholder: "e.g. New York", class: "w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-900 mb-2">State</label>
            <%= f.text_field :state, placeholder: "e.g. NY", maxlength: 2, class: "w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all" %>
          </div>
        </div>

        <%# Submit %>
        <div class="flex items-center justify-between pt-6 border-t border-slate-100">
          <%= link_to job_requests_path, class: "text-sm font-semibold text-slate-500 hover:text-slate-700" do %>
            Cancel
          <% end %>
          <button type="submit" class="btn-shine group inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-rose-500 hover:from-orange-600 hover:to-rose-600 text-white px-8 py-3.5 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-orange-500/30 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">
            Post Job
            <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
          </button>
        </div>
      <% end %>
    </div>

    <%# Trust signals under form %>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-slate-500">
      <div class="flex items-center gap-1.5"><i class="fas fa-shield-alt text-emerald-500"></i>Free to post</div>
      <div class="flex items-center gap-1.5"><i class="fas fa-bolt text-amber-500"></i>Quotes within hours</div>
      <div class="flex items-center gap-1.5"><i class="fas fa-user-check text-sky-500"></i>All providers verified</div>
    </div>
  </div>
</div>

<script>
// Character counter
document.addEventListener('DOMContentLoaded', function() {
  var desc = document.querySelector('textarea[name="job_request[description]"]');
  var count = document.getElementById('desc-count');
  if (desc && count) {
    var updateCount = function() { count.textContent = desc.value.length + ' characters'; };
    desc.addEventListener('input', updateCount);
    updateCount();
  }
});
</script>
