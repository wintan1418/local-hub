<div class="min-h-screen bg-slate-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= link_to job_requests_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Back
    <% end %>

    <h1 class="text-2xl font-black text-slate-900 mb-2">Post a Job</h1>
    <p class="text-sm text-slate-500 mb-8">Describe what you need and providers will send you quotes.</p>

    <div class="bg-white rounded-xl border border-slate-100 p-6 sm:p-8">
      <%= form_with(model: @job_request, local: true) do |f| %>
        <% if @job_request.errors.any? %>
          <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4">
            <ul class="list-disc list-inside text-sm text-red-700">
              <% @job_request.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-5">
          <div>
            <%= f.label :title, "What do you need?", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_field :title, placeholder: "e.g. Fix leaking kitchen faucet", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
          </div>

          <div>
            <%= f.label :category_id, "Category", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.select :category_id, options_for_select(@categories.map { |c| [c.name, c.id] }), { include_blank: "Select category" }, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
          </div>

          <div>
            <%= f.label :description, "Details", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.text_area :description, rows: 4, placeholder: "Describe the job, materials needed, any special requirements...", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 resize-none" %>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :budget_min, "Budget (min $)", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.number_field :budget_min, step: 1, placeholder: "50", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
            </div>
            <div>
              <%= f.label :budget_max, "Budget (max $)", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.number_field :budget_max, step: 1, placeholder: "200", class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
            </div>
          </div>

          <div>
            <%= f.label :needed_by, "Needed by", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
            <%= f.datetime_field :needed_by, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
          </div>

          <div class="grid sm:grid-cols-3 gap-4">
            <div>
              <%= f.label :city, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.text_field :city, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
            </div>
            <div>
              <%= f.label :state, class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.text_field :state, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
            </div>
            <div>
              <%= f.label :zip, "ZIP", class: "block text-sm font-bold text-slate-900 mb-1.5" %>
              <%= f.text_field :zip, class: "w-full px-4 py-3 rounded-xl border border-slate-200 text-sm" %>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <%= link_to "Cancel", job_requests_path, class: "text-sm font-semibold text-slate-500" %>
          <%= f.submit "Post Job", class: "bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-bold text-sm cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
