<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%= link_to job_requests_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to job requests
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">post a job</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Tell us what you <em class="italic-wonk" style="color: #1f4d3a;">need</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">Verified providers will send you quotes within hours. Free to post.</p>
    </div>

    <%# Step indicator %>
    <div class="flex items-center gap-1.5 mb-2">
      <div class="flex-1 h-1 rounded-pill bg-ink"></div>
      <div class="flex-1 h-1 rounded-pill bg-line"></div>
      <div class="flex-1 h-1 rounded-pill bg-line"></div>
    </div>
    <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-6">step 1 of 3 · about your job</p>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: @job_request, local: true, class: "space-y-6") do |f| %>
        <% if @job_request.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-rose-700 mb-1">please fix:</div>
            <ul class="space-y-0.5 ml-5">
              <% @job_request.errors.full_messages.each do |msg| %>
                <li class="text-[13px] text-rose-700 list-disc"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Title %>
        <div>
          <%= f.label :title, "What do you need?", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_field :title, placeholder: "e.g. Fix leaking kitchen faucet",
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          <p class="mt-1.5 text-[11px] text-ink-3">Be specific — "Fix leaking kitchen faucet" beats "Plumbing help"</p>
        </div>

        <%# Category — pill-style chips %>
        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Category</label>
          <div class="flex flex-wrap gap-1.5">
            <% @categories.each do |cat| %>
              <label class="cursor-pointer">
                <input type="radio" name="job_request[category_id]" value="<%= cat.id %>" class="peer sr-only" required>
                <div class="px-4 py-2 rounded-pill border border-line bg-cream-elevated text-[13px] font-medium text-ink-2 hover:border-line-strong peer-checked:bg-ink peer-checked:text-cream peer-checked:border-ink transition-colors">
                  <%= cat.name %>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <%# Description %>
        <div>
          <%= f.label :description, "Describe the job", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_area :description, rows: 5, placeholder: "What's the problem? When did it start? Any special requirements? More detail = better quotes.",
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
          <div class="mt-1.5 flex items-center justify-between">
            <p class="text-[11px] text-ink-3"><i class="fas fa-camera mr-1"></i>Add photos after posting</p>
            <span class="font-mono text-[10px] text-ink-3" id="desc-count">0 chars</span>
          </div>
        </div>

        <%# Budget %>
        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Budget range (optional)</label>
          <div class="grid grid-cols-2 gap-3">
            <div class="relative">
              <span class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ink-3 text-sm">$</span>
              <%= f.number_field :budget_min, step: 1, placeholder: "Min",
                  class: "w-full pl-8 pr-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
            </div>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ink-3 text-sm">$</span>
              <%= f.number_field :budget_max, step: 1, placeholder: "Max",
                  class: "w-full pl-8 pr-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
            </div>
          </div>
        </div>

        <%# Needed by + ZIP %>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :needed_by, "When do you need this?", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
            <%= f.datetime_field :needed_by, class: "w-full px-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">ZIP</label>
            <%= f.text_field :zip, placeholder: "12345", maxlength: 5,
                class: "w-full px-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
        </div>

        <%# City + state %>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">City</label>
            <%= f.text_field :city, placeholder: "e.g. New York",
                class: "w-full px-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">State</label>
            <%= f.text_field :state, placeholder: "NY", maxlength: 2,
                class: "w-full px-4 py-3 rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
          </div>
        </div>

        <%# Submit %>
        <div class="flex items-center justify-between pt-5 border-t border-line">
          <%= link_to "Cancel", job_requests_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <button type="submit" class="inline-flex items-center gap-2 bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm transition-colors active:translate-y-px">
            Post job <i class="fas fa-arrow-right text-[10px]"></i>
          </button>
        </div>
      <% end %>
    </div>

    <%# Trust signals %>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-6 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">
      <div class="flex items-center gap-1.5"><i class="fas fa-shield-alt text-forest"></i>free to post</div>
      <div class="flex items-center gap-1.5"><i class="fas fa-bolt text-amber-600"></i>quotes within hours</div>
      <div class="flex items-center gap-1.5"><i class="fas fa-user-check text-forest"></i>verified providers</div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var desc = document.querySelector('textarea[name="job_request[description]"]');
  var count = document.getElementById('desc-count');
  if (desc && count) {
    var update = function() { count.textContent = desc.value.length + ' chars'; };
    desc.addEventListener('input', update);
    update();
  }
});
</script>
