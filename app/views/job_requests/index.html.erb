<div class="min-h-screen bg-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">job requests</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">
          <% if current_user.customer? %>
            Pros come to <em class="italic-wonk" style="color: #1f4d3a;">you</em>.
          <% else %>
            Open <em class="italic-wonk" style="color: #1f4d3a;">opportunities</em>.
          <% end %>
        </h1>
        <p class="mt-2 text-[14px] text-ink-2"><%= current_user.customer? ? "Post a job and get quotes from verified pros." : "Customers looking for pros — submit a quote." %></p>
      </div>
      <% if current_user.customer? %>
        <%= link_to new_job_request_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
          <i class="fas fa-plus text-[10px]"></i>Post a job
        <% end %>
      <% end %>
    </div>

    <% if @job_requests.any? %>
      <div class="space-y-2">
        <% @job_requests.each do |jr| %>
          <%= link_to job_request_path(jr), class: "block bg-cream-elevated rounded-xl border border-line p-5 hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200" do %>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= jr.category.name %></span>
                  <% status_colors = {
                    "open" => [ "bg-forest-soft", "text-forest" ],
                    "awarded" => [ "bg-cream-sunken", "text-ink-2" ],
                    "closed" => [ "bg-cream-sunken", "text-ink-3" ],
                    "cancelled" => [ "bg-rose-100/60", "text-rose-700" ]
                  } %>
                  <% c = status_colors[jr.status] || [ "bg-cream-sunken", "text-ink-3" ] %>
                  <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= jr.status %></span>
                </div>
                <div class="display text-[18px] sm:text-[20px] text-ink leading-[1.15] tracking-[-0.01em] truncate"><%= jr.title %></div>
                <p class="text-[13px] text-ink-3 line-clamp-1 mt-1"><%= jr.description %></p>
                <div class="flex items-center gap-4 mt-3 font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">
                  <% if jr.city.present? %><span><i class="fas fa-map-marker-alt mr-1"></i><%= [ jr.city, jr.state ].compact.join(", ") %></span><% end %>
                  <% if jr.needed_by.present? %><span><i class="fas fa-clock mr-1"></i>by <%= jr.needed_by.strftime("%b %-d") %></span><% end %>
                  <span><i class="fas fa-comment-dollar mr-1"></i><%= jr.quotes.count %> quote<%= jr.quotes.count == 1 ? '' : 's' %></span>
                </div>
              </div>
              <% if jr.budget_min.present? || jr.budget_max.present? %>
                <div class="text-right flex-shrink-0">
                  <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">budget</div>
                  <div class="display text-[18px] text-ink leading-none mt-1">
                    $<%= jr.budget_min.to_i %><% if jr.budget_max.present? && jr.budget_max != jr.budget_min %><span class="text-ink-3">–</span>$<%= jr.budget_max.to_i %><% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-briefcase",
          title: current_user.customer? ? "No job requests yet" : "No open requests",
          message: current_user.customer? ? "Post what you need and let providers come to you." : "Check back later — customers post new jobs daily.",
          cta_text: current_user.customer? ? "Post your first job" : nil,
          cta_path: current_user.customer? ? new_job_request_path : nil,
          cta_icon: "fa-plus" %>
    <% end %>
  </div>
</div>
