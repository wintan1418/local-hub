<div class="min-h-screen bg-cream">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <%= link_to job_request_path(@job_request), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to job request
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">edit quote</div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]">Refine your <em class="italic-wonk" style="color: #1f4d3a;">offer</em>.</h1>
      <p class="mt-2 text-[14px] text-ink-2">For: <strong><%= @job_request.title %></strong></p>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with model: @quote, url: job_request_quote_path(@job_request, @quote), method: :patch, local: true, class: "space-y-5" do |f| %>
        <% if @quote.errors.any? %>
          <div class="bg-rose-50 border border-rose-200 rounded-lg p-3 text-[13px] text-rose-700">
            <%= @quote.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div>
          <%= f.label :price, "Price ($)", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.number_field :price, step: 0.01, min: 0,
              class: "w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>

        <div>
          <%= f.label :message, "Message to customer", class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block" %>
          <%= f.text_area :message, rows: 5,
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-line">
          <%= link_to "Cancel", job_request_path(@job_request), class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <%= f.submit "Update quote", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill text-sm font-semibold cursor-pointer transition-colors active:translate-y-px" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
