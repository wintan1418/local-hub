<div class="min-h-screen bg-slate-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
    <div class="mb-6">
      <%= link_to job_request_path(@job_request), class: "inline-flex items-center text-sm text-slate-500 hover:text-slate-700" do %>
        <i class="fas fa-arrow-left mr-2 text-xs"></i>Back to job request
      <% end %>
      <h1 class="mt-3 text-2xl font-black text-slate-900">Edit your quote</h1>
      <p class="mt-1 text-sm text-slate-500">For: <strong><%= @job_request.title %></strong></p>
    </div>

    <div class="bg-white rounded-xl border border-slate-100 p-5 sm:p-6">
      <%= form_with model: @quote, url: job_request_quote_path(@job_request, @quote), method: :patch, local: true, class: "space-y-4" do |f| %>
        <% if @quote.errors.any? %>
          <div class="bg-rose-50 border border-rose-200 rounded-lg p-3 text-sm text-rose-700">
            <%= @quote.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div>
          <%= f.label :price, "Quote amount ($)", class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <%= f.number_field :price, step: 0.01, min: 0, class: "w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
        </div>

        <div>
          <%= f.label :message, "Message to customer", class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <%= f.text_area :message, rows: 5, class: "w-full px-3 py-2 text-sm rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
        </div>

        <div class="flex items-center justify-between gap-3 pt-2">
          <%= link_to "Cancel", job_request_path(@job_request), class: "px-4 py-2 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-50" %>
          <%= f.submit "Update quote", class: "bg-orange-500 hover:bg-orange-600 text-white px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
