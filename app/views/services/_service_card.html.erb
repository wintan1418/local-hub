<%
  fallback_images = {
    "home-cleaning"     => "https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?w=800&q=80",
    "plumbing"          => "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=800&q=80",
    "electrical"        => "https://images.unsplash.com/photo-1555963966-b7ae5404b6ed?w=800&q=80",
    "landscaping"       => "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80",
    "moving"            => "https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=80",
    "handyman"          => "https://images.unsplash.com/photo-1572981779307-38b8cabb2407?w=800&q=80",
    "painting"          => "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=800&q=80",
    "pet-care"          => "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=800&q=80",
    "tutoring"          => "https://images.unsplash.com/photo-1523050854058-8df90110c476?w=800&q=80",
    "personal-training" => "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80"
  }
  image_url = fallback_images[service.category&.slug] || "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80"
%>

<%= link_to service_path(service), class: "group block rounded-2xl border border-gray-100 bg-white overflow-hidden hover:shadow-lg hover:border-gray-200 transition-all duration-200" do %>
  <%# Image with price badge %>
  <div class="aspect-[16/10] relative overflow-hidden bg-gray-100">
    <% if service.images.attached? %>
      <%= image_tag service.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", loading: "lazy", alt: service.title %>
    <% else %>
      <img src="<%= image_url %>" alt="<%= service.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
    <% end %>
    <div class="absolute top-3 right-3 bg-white/95 backdrop-blur-sm rounded-lg px-3 py-1 shadow-sm">
      <span class="text-base font-bold text-gray-900">$<%= number_with_precision(service.base_price, precision: 0) %></span>
      <% if service.hourly? %><span class="text-xs text-gray-500">/hr</span><% end %>
    </div>
  </div>

  <%# Card body %>
  <div class="p-5">
    <div class="flex items-center gap-2 mb-2">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700">
        <%= service.category&.name || "Uncategorized" %>
      </span>
      <% if service.provider&.verified? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
          <i class="fas fa-check-circle mr-1"></i>Verified
        </span>
      <% end %>
    </div>

    <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1"><%= service.title %></h3>
    <p class="text-sm text-gray-500 mt-1 line-clamp-2"><%= service.description %></p>

    <div class="mt-4 flex items-center gap-2 pt-4 border-t border-gray-50">
      <div class="w-7 h-7 rounded-full bg-orange-100 flex items-center justify-center text-xs font-semibold text-orange-600">
        <%= service.provider&.display_name&.first&.upcase || "?" %>
      </div>
      <span class="text-sm text-gray-600 font-medium"><%= service.provider&.display_name %></span>
    </div>
  </div>
<% end %>
