<%
  fallback_images = {
    "home-cleaning"     => "https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?w=800&q=80",
    "plumbing"          => "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=800&q=80",
    "electrical"        => "https://images.unsplash.com/photo-1555963966-b7ae5404b6ed?w=800&q=80",
    "landscaping"       => "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80",
    "moving"            => "https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800&q=80",
    "handyman"          => "https://images.unsplash.com/photo-1572981779307-38b8cabb2407?w=800&q=80",
    "painting"          => "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=800&q=80",
    "pet-care"          => "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=800&q=80",
    "tutoring"          => "https://images.unsplash.com/photo-1523050854058-8df90110c476?w=800&q=80",
    "personal-training" => "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80"
  }
  image_url = fallback_images[service.category&.slug] || "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80"
  rating = service.provider&.average_rating || 0
  review_count = service.provider&.total_reviews || 0
%>

<%= link_to service_path(service), class: "group block rounded-xl border border-line bg-cream-elevated overflow-hidden hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200" do %>
  <%# Image — 4:5 ratio per design spec %>
  <div class="aspect-[4/5] relative overflow-hidden bg-cream-sunken">
    <% if service.images.attached? %>
      <%= image_tag service.images.first, class: "w-full h-full object-cover", loading: "lazy", alt: service.title %>
    <% else %>
      <img src="<%= image_url %>" alt="<%= service.title %>" class="w-full h-full object-cover" loading="lazy">
    <% end %>

    <%# Top-rated badge — overlay top-left if rating high %>
    <% if rating >= 4.8 && review_count > 0 %>
      <div class="absolute top-3 left-3 bg-cream-elevated border border-line rounded-pill px-2.5 py-1 flex items-center gap-1.5 shadow-card">
        <i class="fas fa-star text-amber-500 text-[9px]"></i>
        <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink">top-rated</span>
      </div>
    <% elsif service.provider&.verified? %>
      <div class="absolute top-3 left-3 bg-forest-soft border border-forest/20 rounded-pill px-2.5 py-1 flex items-center gap-1.5">
        <i class="fas fa-check text-forest text-[9px]"></i>
        <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-forest">verified</span>
      </div>
    <% end %>

    <%# Favorite icon — top-right %>
    <button type="button" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-cream-elevated/90 backdrop-blur-sm border border-line flex items-center justify-center hover:bg-cream-elevated transition-colors" onclick="event.preventDefault(); event.stopPropagation();" aria-label="Favorite">
      <i class="far fa-heart text-ink-3 text-xs"></i>
    </button>
  </div>

  <%# Card body %>
  <div class="p-4">
    <%# Category eyebrow %>
    <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5"><%= service.category&.name || "service" %></div>

    <%# Title — Fraunces display %>
    <h3 class="display text-[17px] sm:text-[18px] leading-[1.15] tracking-[-0.01em] text-ink line-clamp-2"><%= service.title %></h3>

    <%# Provider name %>
    <div class="text-[13px] text-ink-3 mt-1.5 truncate"><%= service.provider&.display_name %></div>

    <%# Rating + price row %>
    <div class="mt-3 flex items-center justify-between">
      <% if review_count > 0 %>
        <div class="flex items-center gap-1.5 text-[13px] text-ink-2">
          <i class="fas fa-star text-amber-500 text-[10px]"></i>
          <span class="font-medium"><%= rating %></span>
          <span class="text-ink-3">(<%= review_count %>)</span>
        </div>
      <% else %>
        <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">new pro</span>
      <% end %>
      <div class="display text-[17px] text-ink leading-none">
        $<%= number_with_precision(service.base_price, precision: 0) %><span class="font-sans text-[11px] text-ink-3 font-normal"><%= service.hourly? ? "/hr" : "" %></span>
      </div>
    </div>
  </div>
<% end %>
