<%# ===== HERO SEARCH ===== %>
<section class="bg-slate-50 border-b border-slate-100 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Find Local Services</h1>
      <p class="mt-3 text-lg text-slate-500">Browse verified professionals ready to help in your area.</p>
    </div>

    <%= form_with url: services_path, method: :get, local: true, class: "flex flex-col sm:flex-row gap-3 max-w-3xl mx-auto" do |f| %>
      <div class="relative flex-1">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <i class="fas fa-search text-slate-400 text-sm"></i>
        </div>
        <%= f.text_field :query, value: @query,
            placeholder: "What service do you need?",
            class: "w-full pl-11 pr-4 py-3 rounded-lg border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-shadow text-sm" %>
      </div>

      <div class="relative flex-1 sm:max-w-[200px]">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <i class="fas fa-map-marker-alt text-slate-400 text-sm"></i>
        </div>
        <%= f.text_field :location, value: @location,
            placeholder: "City or ZIP",
            class: "w-full pl-11 pr-4 py-3 rounded-lg border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-shadow text-sm" %>
      </div>

      <%= f.select :category_id,
          options_for_select([['All Categories', '']] + @categories.map { |c| [c.name, c.id] }, @category_id),
          {}, class: "px-4 py-3 rounded-lg border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 text-sm bg-white" %>

      <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold text-sm transition-colors shadow-sm whitespace-nowrap">
        <i class="fas fa-search mr-2"></i>Search
      </button>
    <% end %>

    <%# Active filter chips %>
    <% if @query.present? || @category_id.present? || @location.present? %>
      <div class="flex flex-wrap items-center gap-2 mt-4 max-w-3xl mx-auto">
        <span class="text-sm text-slate-500">Filters:</span>
        <% if @query.present? %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-orange-50 text-orange-700">
            "<%= @query %>"
            <%= link_to services_path(category_id: @category_id, sort: @sort, location: @location), class: "ml-1 text-orange-400 hover:text-orange-600" do %>
              <i class="fas fa-times text-xs"></i>
            <% end %>
          </span>
        <% end %>
        <% if @location.present? %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-sky-50 text-sky-700">
            <i class="fas fa-map-marker-alt text-xs"></i>
            <%= @location %>
            <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort), class: "ml-1 text-sky-400 hover:text-sky-600" do %>
              <i class="fas fa-times text-xs"></i>
            <% end %>
          </span>
        <% end %>
        <% if @category_id.present? %>
          <% active_cat = @categories.find { |c| c.id.to_s == @category_id.to_s } %>
          <% if active_cat %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-orange-50 text-orange-700">
              <i class="fas fa-tag text-xs"></i>
              <%= active_cat.name %>
              <%= link_to services_path(query: @query, sort: @sort, location: @location), class: "ml-1 text-orange-400 hover:text-orange-600" do %>
                <i class="fas fa-times text-xs"></i>
              <% end %>
            </span>
          <% end %>
        <% end %>
        <%= link_to "Clear all", services_path, class: "text-sm text-slate-500 hover:text-slate-700 underline" %>
      </div>
    <% end %>
  </div>
</section>

<%# ===== RESULTS ===== %>
<section class="py-12 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @services.any? %>
      <%# Sort bar + count %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <p class="text-sm text-slate-500">
          Showing <%= @services.total_count %> service<%= @services.total_count == 1 ? '' : 's' %>
          <% if @query.present? || @category_id.present? %> matching your search<% end %>
        </p>
        <div class="flex items-center gap-1 bg-slate-100 rounded-lg p-1">
          <% sort_options = [
            ["Newest", "newest", "fas fa-clock"],
            ["Price: Low", "price_low", "fas fa-arrow-down"],
            ["Price: High", "price_high", "fas fa-arrow-up"],
            ["Top Rated", "top_rated", "fas fa-star"]
          ] %>
          <% sort_options.each do |label, value, icon| %>
            <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: value),
                class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium transition-colors #{@sort == value ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>
              <i class="<%= icon %> text-[10px]"></i><%= label %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# View toggle %>
      <div class="flex items-center justify-end mb-4">
        <div class="inline-flex bg-slate-100 rounded-lg p-1">
          <button onclick="toggleView('list')" id="list-btn" class="px-4 py-1.5 rounded-md text-xs font-semibold bg-white text-slate-900 shadow-sm transition-all">
            <i class="fas fa-list mr-1"></i>List
          </button>
          <button onclick="toggleView('map')" id="map-btn" class="px-4 py-1.5 rounded-md text-xs font-semibold text-slate-500 hover:text-slate-700 transition-all">
            <i class="fas fa-map-location-dot mr-1"></i>Map
          </button>
        </div>
      </div>

      <%# List view %>
      <div id="list-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <%= render partial: 'service_card', collection: @services, as: :service %>
      </div>

      <%# Map view %>
      <div id="map-view" class="hidden">
        <div id="services-map" class="w-full h-[600px] rounded-xl border border-slate-200"></div>
      </div>

      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <script>
        var servicesMap = null;
        var servicesData = <%= @services.map { |s|
          next nil unless s.provider.latitude && s.provider.longitude
          {
            id: s.id,
            title: s.title,
            price: s.base_price.to_i,
            provider: s.provider.display_name,
            lat: s.provider.latitude,
            lng: s.provider.longitude,
            url: Rails.application.routes.url_helpers.service_path(s),
            rating: s.provider.average_rating
          }
        }.compact.to_json.html_safe %>;

        function toggleView(view) {
          var list = document.getElementById('list-view');
          var map = document.getElementById('map-view');
          var listBtn = document.getElementById('list-btn');
          var mapBtn = document.getElementById('map-btn');
          if (view === 'map') {
            list.classList.add('hidden');
            map.classList.remove('hidden');
            listBtn.className = 'px-4 py-1.5 rounded-md text-xs font-semibold text-slate-500 hover:text-slate-700 transition-all';
            mapBtn.className = 'px-4 py-1.5 rounded-md text-xs font-semibold bg-white text-slate-900 shadow-sm transition-all';
            if (!servicesMap) initMap();
          } else {
            list.classList.remove('hidden');
            map.classList.add('hidden');
            listBtn.className = 'px-4 py-1.5 rounded-md text-xs font-semibold bg-white text-slate-900 shadow-sm transition-all';
            mapBtn.className = 'px-4 py-1.5 rounded-md text-xs font-semibold text-slate-500 hover:text-slate-700 transition-all';
          }
        }

        function initMap() {
          var center = servicesData.length > 0 ? [servicesData[0].lat, servicesData[0].lng] : [39.8283, -98.5795];
          servicesMap = L.map('services-map').setView(center, servicesData.length > 0 ? 10 : 4);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
          }).addTo(servicesMap);

          servicesData.forEach(function(s) {
            var marker = L.marker([s.lat, s.lng]).addTo(servicesMap);
            marker.bindPopup(
              '<div style="min-width:180px">' +
              '<div style="font-weight:700;color:#0f172a;font-size:13px">' + s.title + '</div>' +
              '<div style="font-size:11px;color:#64748b;margin-top:2px">' + s.provider + ' · ' + s.rating + '★</div>' +
              '<div style="font-size:14px;font-weight:800;color:#0f172a;margin-top:4px">$' + s.price + '</div>' +
              '<a href="' + s.url + '" style="display:inline-block;margin-top:6px;padding:4px 10px;background:#f97316;color:white;border-radius:6px;font-size:11px;font-weight:600;text-decoration:none">View</a>' +
              '</div>'
            );
          });

          if (servicesData.length > 1) {
            var group = L.featureGroup(servicesData.map(function(s){return L.marker([s.lat, s.lng])}));
            servicesMap.fitBounds(group.getBounds().pad(0.2));
          }
        }
      </script>

      <%# Pagination %>
      <% if @services.total_pages > 1 %>
        <div class="mt-12 flex justify-center">
          <nav class="flex items-center gap-1">
            <% if @services.prev_page %>
              <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: @services.prev_page),
                  class: "inline-flex items-center justify-center w-10 h-10 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 transition-colors" do %>
                <i class="fas fa-chevron-left text-xs"></i>
              <% end %>
            <% end %>

            <% (1..@services.total_pages).each do |page_num| %>
              <% if page_num == @services.current_page %>
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-orange-500 text-white text-sm font-medium"><%= page_num %></span>
              <% elsif page_num == 1 || page_num == @services.total_pages || (page_num - @services.current_page).abs <= 2 %>
                <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: page_num),
                    class: "inline-flex items-center justify-center w-10 h-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors text-sm font-medium" do %>
                  <%= page_num %>
                <% end %>
              <% elsif page_num == 2 || page_num == @services.total_pages - 1 %>
                <span class="inline-flex items-center justify-center w-10 h-10 text-slate-400 text-sm">&hellip;</span>
              <% end %>
            <% end %>

            <% if @services.next_page %>
              <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: @services.next_page),
                  class: "inline-flex items-center justify-center w-10 h-10 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 transition-colors" do %>
                <i class="fas fa-chevron-right text-xs"></i>
              <% end %>
            <% end %>
          </nav>
        </div>
      <% end %>

    <% else %>
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 bg-slate-100 rounded-xl flex items-center justify-center">
          <i class="fas fa-search text-slate-400 text-2xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">No services found</h3>
        <p class="text-slate-500 mb-6">Try adjusting your search terms or removing filters.</p>
        <%= link_to "Browse all services", services_path, class: "inline-flex items-center justify-center bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold text-sm transition-colors shadow-sm" %>
      </div>
    <% end %>
  </div>
</section>
