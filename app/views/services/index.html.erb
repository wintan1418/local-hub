<%# ===== HEAD ===== %>
<section class="bg-cream border-b border-line py-10 sm:py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6 sm:mb-8">
      <div class="eyebrow mb-3">discover</div>
      <h1 class="display text-[36px] sm:text-[56px] text-ink leading-[1] tracking-[-0.02em]">Find local pros, <em class="italic-wonk" style="color: #1f4d3a;">actually</em>.</h1>
      <p class="mt-3 text-ink-2 text-[15px] sm:text-[17px] leading-[1.55] max-w-xl">Browse verified professionals ready to help in your area. Filter by category, location, or price.</p>
    </div>

    <%# Pill search bar %>
    <%= form_with url: services_path, method: :get, local: true, class: "block" do |f| %>
      <div class="flex items-stretch gap-1 bg-cream-elevated border border-line-strong rounded-pill p-1.5 shadow-card max-w-3xl">
        <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
          <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">What</label>
          <%= f.text_field :query, value: @query, placeholder: "Cleaning, plumbing, lawn…", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
        </div>
        <span class="w-px self-stretch bg-line"></span>
        <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors flex flex-col justify-center">
          <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">Where</label>
          <%= f.text_field :location, value: @location, placeholder: "Your zip or city", class: "w-full bg-transparent text-sm font-medium text-ink placeholder-ink-4 focus:outline-none mt-1" %>
        </div>
        <span class="w-px self-stretch bg-line hidden sm:block"></span>
        <div class="flex-1 min-w-0 px-4 py-1 hover:bg-cream-sunken rounded-pill transition-colors hidden sm:flex flex-col justify-center">
          <label class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 leading-none">Category</label>
          <%= f.select :category_id,
              options_for_select([ [ "All categories", "" ] ] + @categories.map { |c| [ c.name, c.id ] }, @category_id),
              {}, class: "w-full bg-transparent text-sm font-medium text-ink focus:outline-none mt-1 cursor-pointer" %>
        </div>
        <button type="submit" aria-label="Search" class="flex-shrink-0 w-12 h-12 rounded-full bg-ink hover:bg-ink-2 text-cream flex items-center justify-center transition-colors active:translate-y-px">
          <i class="fas fa-arrow-right text-xs"></i>
        </button>
      </div>
    <% end %>

    <%# Active filter chips %>
    <% if @query.present? || @category_id.present? || @location.present? %>
      <div class="flex flex-wrap items-center gap-2 mt-5">
        <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">filters</span>
        <% if @query.present? %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-pill text-[12px] font-medium bg-cream-elevated border border-line text-ink">
            "<%= @query %>"
            <%= link_to services_path(category_id: @category_id, sort: @sort, location: @location), class: "text-ink-3 hover:text-ink ml-0.5" do %>
              <i class="fas fa-times text-[9px]"></i>
            <% end %>
          </span>
        <% end %>
        <% if @location.present? %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-pill text-[12px] font-medium bg-cream-elevated border border-line text-ink">
            <i class="fas fa-map-marker-alt text-[10px]"></i>
            <%= @location %>
            <%= link_to services_path(query: @query, category_id: @category_id, sort: @sort), class: "text-ink-3 hover:text-ink ml-0.5" do %>
              <i class="fas fa-times text-[9px]"></i>
            <% end %>
          </span>
        <% end %>
        <% if @category_id.present? %>
          <% active_cat = @categories.find { |c| c.id.to_s == @category_id.to_s } %>
          <% if active_cat %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-pill text-[12px] font-medium bg-forest-soft border border-forest/20 text-forest">
              <i class="fas fa-tag text-[10px]"></i>
              <%= active_cat.name %>
              <%= link_to services_path(query: @query, sort: @sort, location: @location), class: "text-forest/60 hover:text-forest ml-0.5" do %>
                <i class="fas fa-times text-[9px]"></i>
              <% end %>
            </span>
          <% end %>
        <% end %>
        <%= link_to "Clear all", services_path, class: "text-[12px] text-ink-3 hover:text-ink underline underline-offset-2" %>
      </div>
    <% end %>
  </div>
</section>

<%# ===== RESULTS ===== %>
<section class="py-10 sm:py-14 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @services.any? %>
      <%# Sort + count + view toggle %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-8">
        <div class="font-mono text-[12px] uppercase tracking-[0.1em] text-ink-3">
          <%= @services.total_count %> service<%= @services.total_count == 1 ? '' : 's' %><% if @query.present? || @category_id.present? %> · matching<% end %>
        </div>
        <div class="flex items-center gap-3 flex-wrap">
          <%# Sort %>
          <div class="flex items-center gap-1 bg-cream-elevated border border-line rounded-pill p-1">
            <% sort_options = [
              [ "Newest", "newest" ],
              [ "Price ↓", "price_low" ],
              [ "Price ↑", "price_high" ],
              [ "Top rated", "top_rated" ]
            ] %>
            <% sort_options.each do |label, value| %>
              <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: value),
                  class: "px-3 py-1.5 rounded-pill text-[12px] font-medium transition-colors #{@sort == value ? 'bg-ink text-cream' : 'text-ink-2 hover:bg-cream-sunken'}" do %>
                <%= label %>
              <% end %>
            <% end %>
          </div>
          <%# View toggle %>
          <div class="flex items-center bg-cream-elevated border border-line rounded-pill p-1">
            <button onclick="toggleView('list')" id="list-btn" class="px-3 py-1.5 rounded-pill text-[12px] font-medium bg-ink text-cream transition-colors">
              <i class="fas fa-grip text-[10px] mr-1"></i>Grid
            </button>
            <button onclick="toggleView('map')" id="map-btn" class="px-3 py-1.5 rounded-pill text-[12px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors">
              <i class="fas fa-map-location-dot text-[10px] mr-1"></i>Map
            </button>
          </div>
        </div>
      </div>

      <%# Grid view %>
      <div id="list-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
        <%= render partial: 'service_card', collection: @services, as: :service %>
      </div>

      <%# Map view %>
      <div id="map-view" class="hidden">
        <div id="services-map" class="w-full h-[600px] rounded-xl border border-line"></div>
      </div>

      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <script>
        var servicesMap = null;
        var servicesData = <%= @services.map { |s|
          next nil unless s.provider.latitude && s.provider.longitude
          {
            id: s.id,
            title: s.title,
            price: s.base_price.to_i,
            provider: s.provider.display_name,
            lat: s.provider.latitude,
            lng: s.provider.longitude,
            url: Rails.application.routes.url_helpers.service_path(s),
            rating: s.provider.average_rating
          }
        }.compact.to_json.html_safe %>;

        function toggleView(view) {
          var list = document.getElementById('list-view');
          var map = document.getElementById('map-view');
          var listBtn = document.getElementById('list-btn');
          var mapBtn = document.getElementById('map-btn');
          var activeCls = 'px-3 py-1.5 rounded-pill text-[12px] font-medium bg-ink text-cream transition-colors';
          var idleCls = 'px-3 py-1.5 rounded-pill text-[12px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors';
          if (view === 'map') {
            list.classList.add('hidden');
            map.classList.remove('hidden');
            listBtn.className = idleCls;
            mapBtn.className = activeCls;
            if (!servicesMap) initMap();
          } else {
            list.classList.remove('hidden');
            map.classList.add('hidden');
            listBtn.className = activeCls;
            mapBtn.className = idleCls;
          }
        }

        function initMap() {
          var center = servicesData.length > 0 ? [servicesData[0].lat, servicesData[0].lng] : [39.8283, -98.5795];
          servicesMap = L.map('services-map').setView(center, servicesData.length > 0 ? 10 : 4);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
          }).addTo(servicesMap);

          servicesData.forEach(function(s) {
            var marker = L.marker([s.lat, s.lng]).addTo(servicesMap);
            marker.bindPopup(
              '<div style="min-width:180px;font-family:Inter">' +
              '<div style="font-family:Fraunces;font-size:15px;color:#1d1813;line-height:1.15">' + s.title + '</div>' +
              '<div style="font-size:11px;color:#766853;margin-top:4px">' + s.provider + ' · ' + s.rating + '★</div>' +
              '<div style="font-family:Fraunces;font-size:18px;color:#1d1813;margin-top:6px">$' + s.price + '</div>' +
              '<a href="' + s.url + '" style="display:inline-block;margin-top:8px;padding:6px 14px;background:#1d1813;color:#fdf8ed;border-radius:999px;font-size:11px;font-weight:600;text-decoration:none">View</a>' +
              '</div>'
            );
          });

          if (servicesData.length > 1) {
            var group = L.featureGroup(servicesData.map(function(s){return L.marker([s.lat, s.lng])}));
            servicesMap.fitBounds(group.getBounds().pad(0.2));
          }
        }
      </script>

      <%# Pagination %>
      <% if @services.total_pages > 1 %>
        <div class="mt-12 flex justify-center">
          <nav class="flex items-center gap-1">
            <% if @services.prev_page %>
              <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: @services.prev_page),
                  class: "inline-flex items-center justify-center w-10 h-10 rounded-pill border border-line text-ink-3 hover:bg-cream-elevated transition-colors" do %>
                <i class="fas fa-chevron-left text-[10px]"></i>
              <% end %>
            <% end %>

            <% (1..@services.total_pages).each do |page_num| %>
              <% if page_num == @services.current_page %>
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-pill bg-ink text-cream text-[13px] font-medium font-mono"><%= page_num %></span>
              <% elsif page_num == 1 || page_num == @services.total_pages || (page_num - @services.current_page).abs <= 2 %>
                <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: page_num),
                    class: "inline-flex items-center justify-center w-10 h-10 rounded-pill border border-line text-ink-2 hover:bg-cream-elevated transition-colors text-[13px] font-medium font-mono" do %>
                  <%= page_num %>
                <% end %>
              <% elsif page_num == 2 || page_num == @services.total_pages - 1 %>
                <span class="inline-flex items-center justify-center w-10 h-10 text-ink-3 text-[13px] font-mono">…</span>
              <% end %>
            <% end %>

            <% if @services.next_page %>
              <%= link_to services_path(query: @query, category_id: @category_id, location: @location, sort: @sort, page: @services.next_page),
                  class: "inline-flex items-center justify-center w-10 h-10 rounded-pill border border-line text-ink-3 hover:bg-cream-elevated transition-colors" do %>
                <i class="fas fa-chevron-right text-[10px]"></i>
              <% end %>
            <% end %>
          </nav>
        </div>
      <% end %>

    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-search",
          title: "No services found",
          message: "Try adjusting your search or removing filters.",
          cta_text: "Browse all services",
          cta_path: services_path %>
    <% end %>
  </div>
</section>
