<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <%# Back link %>
    <div class="mb-6">
      <%= link_to services_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>All services
      <% end %>
    </div>

    <%# ===== GALLERY — 3-col / 2-row, first cell spans both rows ===== %>
    <% imgs = @service.images.attached? ? @service.images.to_a : [] %>
    <div class="grid grid-cols-3 grid-rows-2 gap-2 sm:gap-3 rounded-[20px] overflow-hidden mb-8 sm:mb-10" style="height: 480px;">
      <%# Main — spans 2x2 %>
      <div class="col-span-3 sm:col-span-2 row-span-2 relative bg-cream-sunken">
        <% if imgs.first %>
          <%= image_tag imgs.first, class: "w-full h-full object-cover", alt: @service.title %>
        <% else %>
          <img src="https://images.unsplash.com/photo-<%= ['1581578731548-c64695cc6952','1527515637462-cff94eecc1ac','1572981779307-38b8cabb2407'][@service.id.to_i % 3] %>?w=1200&q=80" class="w-full h-full object-cover" alt="<%= @service.title %>">
        <% end %>
      </div>
      <%# Right top %>
      <div class="hidden sm:block relative bg-cream-sunken">
        <% if imgs[1] %>
          <%= image_tag imgs[1], class: "w-full h-full object-cover" %>
        <% else %>
          <img src="https://i.pravatar.cc/600?u=service<%= @service.id %>a" class="w-full h-full object-cover" alt="">
        <% end %>
      </div>
      <%# Right bottom %>
      <div class="hidden sm:block relative bg-cream-sunken">
        <% if imgs[2] %>
          <%= image_tag imgs[2], class: "w-full h-full object-cover" %>
        <% else %>
          <img src="https://i.pravatar.cc/600?u=service<%= @service.id %>b" class="w-full h-full object-cover" alt="">
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 lg:gap-12">

      <%# ===== MAIN COLUMN ===== %>
      <div class="space-y-10">

        <%# Head — eyebrow → title → stats %>
        <div>
          <div class="eyebrow mb-3"><%= @service.category.name %></div>
          <h1 class="display text-ink leading-[1] tracking-[-0.02em]" style="font-size: clamp(36px, 5vw, 56px);"><%= @service.title %></h1>
          <p class="mt-3 text-[18px] text-ink-2 leading-[1.5]">By <%= @service.provider.display_name %></p>

          <%# Stats row %>
          <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-[14px] text-ink-2">
            <% provider_rating = @service.provider.average_rating %>
            <% if provider_rating > 0 %>
              <div class="flex items-center gap-1.5">
                <i class="fas fa-star text-amber-500 text-[12px]"></i>
                <span class="font-semibold text-ink"><%= provider_rating %></span>
                <span class="text-ink-3">(<%= @service.provider.total_reviews %> reviews)</span>
              </div>
            <% end %>
            <% if @service.provider.verified? %>
              <div class="flex items-center gap-1.5 text-forest"><i class="fas fa-check text-[11px]"></i>Verified</div>
            <% end %>
            <% if @service.provider.total_completed_bookings > 0 %>
              <div class="flex items-center gap-1.5"><i class="far fa-circle-check text-ink-3 text-[11px]"></i><%= @service.provider.total_completed_bookings %> jobs done</div>
            <% end %>
            <div class="flex items-center gap-1.5"><i class="fas fa-clock text-ink-3 text-[11px]"></i>Responds in 12m</div>
          </div>
        </div>

        <%# About section %>
        <div class="border-t border-line pt-8">
          <div class="eyebrow mb-3">about</div>
          <h2 class="display text-[24px] sm:text-[28px] text-ink leading-[1.1]">What's <em class="italic-wonk" style="color: #1f4d3a;">included</em></h2>
          <p class="mt-4 text-[15px] text-ink-2 leading-[1.65] whitespace-pre-line"><%= @service.description %></p>
        </div>

        <%# What I offer — 2-col check list %>
        <div class="border-t border-line pt-8">
          <div class="eyebrow mb-3">guarantees</div>
          <h2 class="display text-[24px] sm:text-[28px] text-ink leading-[1.1]">Always with the work</h2>
          <div class="mt-5 grid sm:grid-cols-2 gap-3">
            <% [
              "Background-checked professional",
              "Money-back guarantee",
              "Same-day availability",
              "Insurance & liability covered",
              "Transparent pricing — no hidden fees",
              "Free reschedule up to 24h"
            ].each do |item| %>
              <div class="flex items-start gap-2.5">
                <i class="fas fa-check text-forest text-[12px] mt-1.5"></i>
                <span class="text-[14px] text-ink-2 leading-[1.5]"><%= item %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# Provider snapshot %>
        <div class="border-t border-line pt-8">
          <div class="eyebrow mb-3">your provider</div>
          <%= link_to provider_path(@service.provider), class: "group flex items-center gap-4 hover:bg-cream-sunken/50 -mx-4 px-4 py-3 rounded-xl transition-colors" do %>
            <% if @service.provider.profile_picture.attached? %>
              <%= image_tag @service.provider.profile_picture, class: "w-14 h-14 rounded-full object-cover border border-line" %>
            <% else %>
              <img src="https://i.pravatar.cc/120?u=provider<%= @service.provider.id %>" class="w-14 h-14 rounded-full object-cover border border-line">
            <% end %>
            <div class="flex-1 min-w-0">
              <div class="display text-[20px] text-ink group-hover:underline underline-offset-2 truncate"><%= @service.provider.business_name.presence || @service.provider.display_name %></div>
              <div class="text-[13px] text-ink-3 mt-0.5">View full profile <i class="fas fa-arrow-right text-[10px] ml-1"></i></div>
            </div>
          <% end %>
        </div>

        <%# Reviews %>
        <% reviews = @service.bookings.includes(:review, :customer).where.not(reviews: { id: nil }).map(&:review).compact %>
        <div class="border-t border-line pt-8">
          <div class="flex items-center justify-between mb-5">
            <div>
              <div class="eyebrow mb-3">reviews</div>
              <h2 class="display text-[24px] sm:text-[28px] text-ink leading-[1.1]">
                <% if reviews.any? %>
                  <span style="color: #1f4d3a;" class="italic-wonk"><%= @service.provider.average_rating %></span> · <%= reviews.size %> review<%= reviews.size == 1 ? '' : 's' %>
                <% else %>
                  No reviews <em class="italic-wonk" style="color: #1f4d3a;">yet</em>
                <% end %>
              </h2>
            </div>
          </div>

          <% if reviews.any? %>
            <div class="space-y-4">
              <% reviews.first(5).each do |review| %>
                <div class="border-t border-line pt-5">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[13px] font-semibold border border-line">
                        <%= review.booking.customer.display_name.first.upcase %>
                      </div>
                      <div>
                        <div class="text-[14px] font-semibold text-ink"><%= review.booking.customer.display_name %></div>
                        <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3"><%= time_ago_in_words(review.created_at) %> ago</div>
                      </div>
                    </div>
                    <div class="flex gap-0.5">
                      <% 5.times do |i| %>
                        <i class="fas fa-star text-[11px] <%= i < review.rating ? 'text-amber-500' : 'text-line' %>"></i>
                      <% end %>
                    </div>
                  </div>
                  <% if review.comment.present? %>
                    <p class="text-[14px] text-ink-2 leading-[1.6] mt-3 max-w-2xl"><%= review.comment %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-[14px] text-ink-3">Be the first to review this service after your booking.</p>
          <% end %>
        </div>
      </div>

      <%# ===== BOOKING SIDEBAR — sticky ===== %>
      <aside>
        <div class="sticky top-24 bg-cream-elevated border border-line rounded-xl p-6">
          <% if user_signed_in? && current_user.customer? %>
            <%# Price + rating %>
            <div class="flex items-end justify-between mb-5">
              <div>
                <div class="display text-[40px] text-ink leading-none">$<%= number_with_precision(@service.base_price, precision: 0) %></div>
                <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= @service.price_type.titleize %></div>
              </div>
              <% if @service.provider.average_rating > 0 %>
                <div class="text-right">
                  <div class="flex items-center gap-1 text-[13px] font-semibold text-ink justify-end">
                    <i class="fas fa-star text-amber-500 text-[10px]"></i>
                    <%= @service.provider.average_rating %>
                  </div>
                  <div class="font-mono text-[10px] text-ink-3"><%= @service.provider.total_reviews %> reviews</div>
                </div>
              <% end %>
            </div>

            <%= form_with url: service_bookings_path(@service), method: :post, local: true, multipart: true, class: "space-y-4" do |f| %>

              <% if flash[:alert] %>
                <div class="bg-rose-50 border border-rose-200 text-rose-700 rounded-lg p-3 text-[13px]">
                  <i class="fas fa-exclamation-triangle mr-1.5"></i><%= flash[:alert] %>
                </div>
              <% end %>

              <%# Packages %>
              <% if @service.packages.any? %>
                <div>
                  <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Package</label>
                  <div class="space-y-2">
                    <% @service.packages.each_with_index do |pkg, i| %>
                      <label class="flex items-start gap-3 p-3 rounded-lg border border-line hover:border-line-strong cursor-pointer has-[:checked]:border-ink has-[:checked]:bg-cream-sunken/40 transition-colors">
                        <input type="radio" name="booking[service_package_id]" value="<%= pkg.id %>" class="mt-0.5 accent-ink" <%= 'checked' if i == 0 %>>
                        <div class="flex-1">
                          <div class="flex items-center justify-between gap-2">
                            <span class="text-[13px] font-semibold text-ink"><%= pkg.name %></span>
                            <span class="display text-[15px] text-ink">$<%= number_with_precision(pkg.price, precision: 0) %></span>
                          </div>
                          <% if pkg.description.present? %>
                            <p class="text-[11px] text-ink-3 mt-0.5"><%= pkg.description %></p>
                          <% end %>
                        </div>
                      </label>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <%# Date + time %>
              <div>
                <label for="booking_scheduled_at" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Date & time</label>
                <input type="datetime-local" name="booking[scheduled_at]" id="booking_scheduled_at"
                       class="w-full px-3 py-2.5 text-sm rounded-lg border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated"
                       required min="<%= Date.current.strftime('%Y-%m-%dT%H:%M') %>">
                <% if @service.availabilities.any? %>
                  <div class="mt-2 flex flex-wrap gap-1">
                    <% days = %w[Sun Mon Tue Wed Thu Fri Sat] %>
                    <% @service.availabilities.order(:day_of_week).each do |a| %>
                      <span class="font-mono text-[10px] text-ink-3 bg-cream-sunken/50 border border-line px-1.5 py-0.5 rounded">
                        <%= days[a.day_of_week] %> <%= a.start_time.strftime("%-I%p") %>–<%= a.end_time.strftime("%-I%p") %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </div>

              <%# Recurrence %>
              <div>
                <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Repeat</label>
                <select name="booking[recurrence]" class="w-full px-3 py-2.5 text-sm rounded-lg border border-line bg-cream-elevated focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink">
                  <option value="one_time">One-time</option>
                  <option value="weekly">Weekly</option>
                  <option value="biweekly">Every 2 weeks</option>
                  <option value="monthly">Monthly</option>
                </select>
              </div>

              <%# Urgent %>
              <label class="flex items-start gap-2.5 p-3 rounded-lg border border-line hover:border-line-strong cursor-pointer has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/[0.08] transition-colors">
                <input type="checkbox" name="booking[urgent]" value="1" class="mt-0.5 accent-terracotta">
                <div>
                  <div class="text-[13px] font-semibold text-ink"><i class="fas fa-bolt text-terracotta mr-1"></i>Urgent</div>
                  <div class="text-[11px] text-ink-3 mt-0.5">Alert provider via SMS immediately.</div>
                </div>
              </label>

              <%# Notes %>
              <div>
                <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Notes (optional)</label>
                <textarea name="booking[notes_from_customer]" rows="2" placeholder="Any special requirements…" class="w-full px-3 py-2 text-sm rounded-lg border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink resize-none"></textarea>
              </div>

              <%# Photos %>
              <div>
                <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">Photos (optional)</label>
                <input type="file" name="booking[photos][]" multiple accept="image/*" class="w-full text-[12px] file:mr-3 file:px-3 file:py-1.5 file:rounded-pill file:border-0 file:bg-cream-sunken file:text-ink-2 file:text-[11px] file:font-semibold hover:file:bg-line">
              </div>

              <%# Total %>
              <div class="border-t border-line pt-4">
                <div class="flex justify-between items-center">
                  <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Total</span>
                  <span class="display text-[28px] text-ink leading-none">$<%= number_with_precision(@service.base_price, precision: 0) %></span>
                </div>
              </div>

              <input type="hidden" name="booking[total_price]" value="<%= @service.base_price %>">

              <button type="submit" class="w-full px-5 py-3 rounded-pill text-sm font-semibold bg-ink hover:bg-ink-2 text-cream transition-colors active:translate-y-px">
                Request to book
              </button>

              <p class="text-[11px] text-ink-3 text-center"><i class="fas fa-shield-alt mr-1"></i>You won't be charged yet · free cancellation 24h before</p>
            <% end %>

            <%# Message provider %>
            <div class="mt-4 pt-4 border-t border-line">
              <%= form_with url: conversations_path, method: :post, local: true do |form| %>
                <%= form.hidden_field :user_id, value: @service.provider.id %>
                <button type="submit" class="w-full px-5 py-2.5 rounded-pill text-sm font-medium bg-cream-sunken hover:bg-line text-ink transition-colors flex items-center justify-center gap-2">
                  <i class="fas fa-comments text-xs"></i>Message <%= @service.provider.display_name.split.first %>
                </button>
              <% end %>
            </div>

          <% elsif !user_signed_in? %>
            <div>
              <div class="display text-[40px] text-ink leading-none">$<%= number_with_precision(@service.base_price, precision: 0) %></div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= @service.price_type.titleize %></div>

              <h2 class="display text-[22px] text-ink mt-6 leading-[1.1]">Sign in to <em class="italic-wonk" style="color: #1f4d3a;">book</em></h2>
              <p class="text-[14px] text-ink-2 mt-2 leading-[1.5]">Create a free account or sign in to book this service.</p>

              <div class="mt-5 space-y-2">
                <%= link_to new_user_session_path, class: "block w-full px-5 py-3 rounded-pill text-sm font-semibold bg-ink hover:bg-ink-2 text-cream text-center transition-colors" do %>
                  Sign in to book
                <% end %>
                <%= link_to new_user_registration_path, class: "block w-full px-5 py-3 rounded-pill text-sm font-medium bg-cream-sunken hover:bg-line text-ink text-center transition-colors" do %>
                  Sign up free
                <% end %>
              </div>
            </div>
          <% else %>
            <div>
              <div class="display text-[40px] text-ink leading-none">$<%= number_with_precision(@service.base_price, precision: 0) %></div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= @service.price_type.titleize %></div>
              <p class="text-[13px] text-ink-3 mt-4">This service is bookable by customers only.</p>
            </div>
          <% end %>
        </div>
      </aside>
    </div>

    <%# ===== RELATED SERVICES ===== %>
    <% related = Service.where(category: @service.category).where.not(id: @service.id).limit(4) %>
    <% if related.any? %>
      <div class="mt-16 sm:mt-20 border-t border-line pt-12">
        <div class="mb-8">
          <div class="eyebrow mb-3">also available</div>
          <h2 class="display text-[28px] sm:text-[32px] text-ink leading-[1.05]">Similar <em class="italic-wonk" style="color: #1f4d3a;">services</em></h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
          <%= render partial: "services/service_card", collection: related, as: :service %>
        </div>
      </div>
    <% end %>
  </div>
</div>
