<div class="min-h-screen bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-slate-700 hover:text-orange-600" do %>
            <i class="fas fa-home mr-2"></i>Home
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-slate-400 mx-2"></i>
            <%= link_to services_path, class: "text-sm font-medium text-slate-700 hover:text-orange-600" do %>
              Services
            <% end %>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-slate-400 mx-2"></i>
            <span class="text-sm font-medium text-slate-500 truncate"><%= @service.title %></span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Service Details -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-slate-100 overflow-hidden">
          <!-- Service Images -->
          <% if @service.images.attached? %>
            <div class="relative h-96 bg-slate-200">
              <% cover = @service.images.first %>
              <% begin %>
                <%= image_tag cover, class: "w-full h-full object-cover", alt: @service.title %>
              <% rescue => e %>
                <!-- Fallback if image processing fails -->
                <div class="w-full h-full bg-gradient-to-br from-slate-300 to-slate-400 flex items-center justify-center">
                  <div class="text-center text-white">
                    <i class="fas fa-image text-4xl mb-2"></i>
                    <p class="text-sm">Image Loading Error</p>
                  </div>
                </div>
              <% end %>
              <% if @service.images.size > 1 %>
                <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
                  <% @service.images.each_with_index do |img, idx| %>
                    <span class="w-3 h-3 rounded-full <%= idx == 0 ? 'bg-white' : 'bg-white bg-opacity-50' %> cursor-pointer"></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <% if @service.images.size > 1 %>
              <div class="p-4 border-b border-slate-200">
                <div class="flex space-x-3 overflow-x-auto">
                  <% @service.images.each_with_index do |img, idx| %>
                    <% begin %>
                      <%= image_tag img, class: "w-20 h-20 object-cover rounded-lg flex-shrink-0 cursor-pointer hover:opacity-75 transition-opacity #{'ring-2 ring-orange-500' if idx == 0}", alt: "#{@service.title} image #{idx + 1}" %>
                    <% rescue => e %>
                      <div class="w-20 h-20 bg-slate-300 rounded-lg flex items-center justify-center">
                        <i class="fas fa-image text-slate-500"></i>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <!-- No images attached - show placeholder -->
            <div class="h-96 bg-gradient-to-br from-blue-100 to-orange-100 flex items-center justify-center">
              <div class="text-center text-slate-600">
                <i class="fas fa-image text-6xl text-slate-400 mb-4"></i>
                <p class="text-lg font-medium">No Images Available</p>
                <p class="text-sm text-slate-500">Service provider hasn't uploaded images yet</p>
              </div>
            </div>
          <% end %>

          <!-- Service Content -->
          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= @service.title %></h1>
                <div class="flex items-center space-x-4 text-sm text-slate-600">
                  <span class="inline-flex items-center">
                    <i class="fas fa-tag mr-1 text-orange-500"></i>
                    <%= @service.category.name %>
                  </span>
                  <span class="inline-flex items-center">
                    <i class="fas fa-user mr-1 text-orange-500"></i>
                    <%= @service.provider.display_name %>
                  </span>
                </div>
              </div>
              <div class="text-right">
                <div class="text-3xl font-bold text-orange-600">
                  $<%= number_with_precision(@service.base_price, precision: 0) %>
                </div>
                <div class="text-sm text-slate-500">
                  <%= @service.price_type.titleize %>
                </div>
              </div>
            </div>

            <div class="prose max-w-none mb-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Description</h3>
              <p class="text-slate-700 leading-relaxed"><%= @service.description %></p>
            </div>

            <!-- Service Features -->
            <div class="border-t border-slate-200 pt-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-4">What's Included</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex items-center">
                  <i class="fas fa-check-circle text-green-500 mr-3"></i>
                  <span class="text-slate-700">Professional Service</span>
                </div>
                <div class="flex items-center">
                  <i class="fas fa-check-circle text-green-500 mr-3"></i>
                  <span class="text-slate-700">Quality Guarantee</span>
                </div>
                <div class="flex items-center">
                  <i class="fas fa-check-circle text-green-500 mr-3"></i>
                  <span class="text-slate-700">Customer Support</span>
                </div>
                <div class="flex items-center">
                  <i class="fas fa-check-circle text-green-500 mr-3"></i>
                  <span class="text-slate-700">Flexible Scheduling</span>
                </div>
              </div>
            </div>

            <!-- Provider Info -->
            <div class="border-t border-slate-200 pt-6 mt-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-4">About the Provider</h3>
              <div class="flex items-center space-x-4">
                <div class="h-12 w-12 rounded-full bg-orange-100 flex items-center justify-center text-lg font-semibold text-orange-600">
                  <%= @service.provider.display_name.first.upcase %>
                </div>
                <% provider_rating = @service.provider.average_rating %>
                <% provider_bookings = @service.provider.total_completed_bookings %>
                <div>
                  <h4 class="font-medium text-slate-900"><%= @service.provider.display_name %></h4>
                  <p class="text-sm text-slate-600">Professional Service Provider</p>
                  <% badge = @service.provider.provider_badge %>
                  <% if badge && badge[:name] != "New" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-<%= badge[:color] %>-50 text-<%= badge[:color] %>-700 mt-1">
                      <i class="<%= badge[:icon] %> mr-1"></i><%= badge[:name] %>
                    </span>
                  <% end %>
                  <div class="flex items-center mt-1">
                    <div class="flex">
                      <% 5.times do |i| %>
                        <i class="fas fa-star <%= i < provider_rating.round ? 'text-yellow-400' : 'text-slate-200' %>"></i>
                      <% end %>
                    </div>
                    <% if provider_rating > 0 %>
                      <span class="ml-2 text-sm text-slate-600">(<%= provider_rating %>) · <%= provider_bookings %> booking<%= provider_bookings == 1 ? '' : 's' %></span>
                    <% else %>
                      <span class="ml-2 text-sm text-slate-500">No reviews yet</span>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Booking Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-slate-100 p-6 sticky top-8">
          <% if user_signed_in? && current_user.customer? %>
            <h2 class="text-xl font-semibold mb-6 text-slate-900">Book This Service</h2>
            
            <form action="<%= service_bookings_path(@service) %>" method="post" class="space-y-6">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <% if flash[:alert] %>
                <div class="bg-red-50 border border-red-300 text-red-700 rounded-lg p-4 mb-4">
                  <div class="flex">
                    <i class="fas fa-exclamation-triangle text-red-400 mr-2 mt-0.5"></i>
                    <span><%= flash[:alert] %></span>
                  </div>
                </div>
              <% end %>

              <!-- Date & Time Selection -->
              <div>
                <label for="booking_scheduled_at" class="block text-sm font-medium text-slate-700 mb-2">Select Date & Time</label>
                <div class="relative">
                  <input type="datetime-local" 
                         name="booking[scheduled_at]" 
                         id="booking_scheduled_at"
                         class="w-full px-3 py-3 pr-10 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent cursor-pointer transition-shadow text-sm"
                         required
                         min="<%= Date.current.strftime("%Y-%m-%dT%H:%M") %>"
                         data-controller="booking-calendar">
                  <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                    <i class="fas fa-calendar-alt text-slate-400"></i>
                  </div>
                </div>
                <% if @service.availabilities.any? %>
                  <div class="mt-2 p-2.5 rounded-lg bg-slate-50 border border-slate-100">
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1.5">Available Hours</p>
                    <% days = %w[Sun Mon Tue Wed Thu Fri Sat] %>
                    <div class="flex flex-wrap gap-1">
                      <% @service.availabilities.order(:day_of_week).each do |a| %>
                        <span class="text-[10px] text-slate-600 bg-white px-1.5 py-0.5 rounded border border-slate-100">
                          <strong><%= days[a.day_of_week] %></strong> <%= a.start_time.strftime("%-I%p") %>-<%= a.end_time.strftime("%-I%p") %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <p class="mt-1 text-xs text-slate-500"><i class="fas fa-info-circle mr-1"></i>Flexible schedule</p>
                <% end %>
              </div>

              <!-- Price Summary -->
              <div class="bg-slate-50 rounded-lg p-4">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm text-slate-600">Base Price</span>
                  <span class="text-sm font-medium text-slate-900">$<%= number_with_precision(@service.base_price, precision: 0) %></span>
                </div>
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm text-slate-600">Service Fee</span>
                  <span class="text-sm font-medium text-slate-900">$0</span>
                </div>
                <hr class="my-2">
                <div class="flex justify-between items-center">
                  <span class="font-medium text-slate-900">Total</span>
                  <span class="font-bold text-lg text-orange-600">$<%= number_with_precision(@service.base_price, precision: 0) %></span>
                </div>
              </div>

              <input type="hidden" name="booking[total_price]" value="<%= @service.base_price %>">

              <!-- Book Button -->
              <button type="submit" class="w-full bg-orange-500 text-white py-3 px-4 rounded-xl hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-colors font-semibold mb-3">
                <i class="fas fa-calendar-check mr-2"></i>Book Now
              </button>
              
              <!-- Additional Info -->
              <div class="text-center">
                <p class="text-xs text-slate-500">
                  <i class="fas fa-shield-alt mr-1"></i>
                  Secure booking • Free cancellation up to 24 hours
                </p>
              </div>
            </form>

            <!-- Chat Button (outside of booking form) -->
            <%= form_with url: conversations_path, method: :post, local: true, class: "w-full mb-3" do |form| %>
              <%= form.hidden_field :user_id, value: @service.provider.id %>
              <button type="submit" class="w-full bg-blue-600 text-white py-3 px-4 rounded-xl hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors font-medium cursor-pointer flex items-center justify-center"
                      data-confirm="Start a conversation with <%= @service.provider.display_name %>?">
                <i class="fas fa-comments mr-2"></i>
                Chat with Provider
              </button>
            <% end %>

          <% elsif !user_signed_in? %>
            <div class="text-center">
              <h2 class="text-xl font-semibold mb-4 text-slate-900">Ready to Book?</h2>
              <p class="text-slate-600 mb-6">Sign in to book this service and manage your appointments.</p>
              
              <%= link_to new_user_session_path, class: "w-full bg-orange-500 text-white py-3 px-4 rounded-xl hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-colors font-medium text-center block" do %>
                <i class="fas fa-sign-in-alt mr-2"></i>Sign In to Book
              <% end %>
              
              <p class="text-sm text-slate-500 mt-4">
                Don't have an account? 
                <%= link_to "Sign up", new_user_registration_path, class: "text-orange-600 hover:text-orange-700 font-medium" %>
              </p>
            </div>

          <% else %>
            <div class="text-center">
              <h2 class="text-xl font-semibold mb-4 text-slate-900">Service Details</h2>
              <p class="text-slate-600 mb-4">This service is available for customers to book.</p>
              
              <div class="bg-slate-50 rounded-xl p-4">
                <div class="text-2xl font-bold text-orange-600 mb-1">
                  $<%= number_with_precision(@service.base_price, precision: 0) %>
                </div>
                <div class="text-sm text-slate-500">
                  <%= @service.price_type.titleize %>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Contact Provider -->
          <div class="mt-6 pt-6 border-t border-slate-200">
            <h3 class="text-sm font-medium text-slate-900 mb-3">Have Questions?</h3>
            <% if user_signed_in? && current_user.customer? %>
              <%= form_with url: conversations_path, method: :post, local: true, class: "w-full" do |form| %>
                <%= form.hidden_field :user_id, value: @service.provider.id %>
                <button type="submit" class="w-full bg-slate-100 text-slate-800 py-2 px-4 rounded-xl hover:bg-slate-200 transition-colors text-sm font-medium cursor-pointer flex items-center justify-center">
                  <i class="fas fa-comments mr-2"></i>
                  Contact Provider
                </button>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path, class: "w-full bg-slate-100 text-slate-800 py-2 px-4 rounded-xl hover:bg-slate-200 transition-colors text-sm font-medium block text-center" do %>
                <i class="fas fa-sign-in-alt mr-2"></i>Sign In to Contact
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Reviews -->
    <% reviews = @service.bookings.includes(:review, :customer).where.not(reviews: { id: nil }).map(&:review).compact %>
    <div class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">Reviews (<%= reviews.size %>)</h2>
        <% if reviews.any? %>
          <div class="flex items-center gap-2">
            <i class="fas fa-star text-amber-400"></i>
            <span class="text-lg font-semibold text-slate-900"><%= @service.provider.average_rating %></span>
            <span class="text-slate-500">average</span>
          </div>
        <% end %>
      </div>

      <% if reviews.any? %>
        <div class="space-y-4">
          <% reviews.each do |review| %>
            <div class="bg-white rounded-xl border border-slate-100 p-6">
              <div class="flex items-start justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-sm font-semibold text-slate-600">
                    <%= review.booking.customer.display_name.first.upcase %>
                  </div>
                  <div>
                    <p class="font-medium text-slate-900"><%= review.booking.customer.display_name %></p>
                    <p class="text-xs text-slate-400"><%= time_ago_in_words(review.created_at) %> ago</p>
                  </div>
                </div>
                <div class="flex gap-0.5">
                  <% 5.times do |i| %>
                    <i class="fas fa-star text-sm <%= i < review.rating ? 'text-amber-400' : 'text-slate-200' %>"></i>
                  <% end %>
                </div>
              </div>
              <% if review.comment.present? %>
                <p class="mt-3 text-sm text-slate-600 leading-relaxed"><%= review.comment %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-xl border border-slate-100 p-8 text-center">
          <i class="fas fa-star text-slate-300 text-3xl mb-3"></i>
          <p class="text-slate-500">No reviews yet. Be the first to review this service!</p>
        </div>
      <% end %>
    </div>

    <!-- Related Services -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Similar Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <% Service.where(category: @service.category).where.not(id: @service.id).limit(4).each do |related| %>
          <%= link_to service_path(related), class: "group block rounded-xl border border-slate-100 bg-white overflow-hidden hover:shadow-lg hover:border-slate-200 transition-all duration-200" do %>
            <% if related.images.any? %>
              <div class="aspect-[16/10] overflow-hidden bg-slate-100">
                <%= image_tag related.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", loading: "lazy" %>
              </div>
            <% else %>
              <div class="aspect-[16/10] bg-slate-100 flex items-center justify-center">
                <i class="fas fa-image text-slate-400 text-2xl"></i>
              </div>
            <% end %>
            <div class="p-4">
              <h3 class="font-semibold text-slate-900 mb-1 truncate group-hover:text-orange-600 transition-colors"><%= related.title %></h3>
              <p class="text-sm text-slate-500 mb-3"><%= related.provider.display_name %></p>
              <span class="font-bold text-slate-900">$<%= number_with_precision(related.base_price, precision: 0) %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>