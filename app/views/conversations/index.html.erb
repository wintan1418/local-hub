<div class="min-h-screen bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Header %>
    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">messages</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">
          Talk to <em class="italic-wonk" style="color: #1f4d3a;"><%= current_user.customer? ? "providers" : "customers" %></em>.
        </h1>
      </div>
      <% if current_user.customer? %>
        <button onclick="openProviderSearch()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px">
          <i class="fas fa-plus text-[10px]"></i>New chat
        </button>
      <% end %>
    </div>

    <% if @conversations.present? %>
      <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
        <div class="divide-y divide-line">
          <% @conversations.each do |conversation| %>
            <% other_user = conversation.other_participant(current_user) %>
            <% unread_count = conversation.unread_count_for(current_user) %>
            <%= link_to conversation_path(conversation), class: "block hover:bg-cream-sunken/40 transition-colors" do %>
              <div class="px-5 sm:px-6 py-4 flex items-start gap-4">
                <% if other_user.profile_picture.attached? %>
                  <%= image_tag other_user.profile_picture, class: "h-12 w-12 rounded-full object-cover border border-line flex-shrink-0" %>
                <% else %>
                  <img src="https://i.pravatar.cc/96?u=user<%= other_user.id %>" class="h-12 w-12 rounded-full object-cover border border-line flex-shrink-0" alt="<%= other_user.display_name %>">
                <% end %>

                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <div class="min-w-0">
                      <div class="display text-[16px] text-ink leading-[1.15] truncate">
                        <%= other_user.display_name %>
                        <% if other_user.provider? && other_user.business_name.present? %>
                          <span class="font-sans text-[13px] text-ink-3 font-normal">· <%= other_user.business_name %></span>
                        <% end %>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                      <% if unread_count > 0 %>
                        <span class="font-mono text-[10px] uppercase tracking-[0.08em] bg-ink text-cream px-2 py-0.5 rounded-pill"><%= unread_count %></span>
                      <% end %>
                      <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 whitespace-nowrap">
                        <%= conversation.last_message_at ? "#{time_ago_in_words(conversation.last_message_at)} ago" : "just now" %>
                      </span>
                    </div>
                  </div>

                  <% if conversation.last_message %>
                    <p class="text-[13px] text-ink-2 truncate mt-1.5">
                      <% if conversation.last_message.sender == current_user %>
                        <span class="text-ink-3">You:</span>
                      <% end %>
                      <%= conversation.last_message.content %>
                    </p>
                  <% else %>
                    <p class="text-[13px] text-ink-3 italic mt-1.5">No messages yet</p>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state",
            icon: "fa-comments",
            title: "No conversations yet",
            message: current_user.customer? ? "Start a conversation with a provider to get help with your needs." : "Customers will message you here when they're interested in your services.",
            cta_text: current_user.customer? ? "Find providers" : nil,
            cta_path: current_user.customer? ? services_path : nil,
            cta_icon: "fa-search" %>
    <% end %>
  </div>
</div>

<%# Provider Search Modal %>
<% if current_user.customer? %>
  <div id="providerSearchModal" class="fixed inset-0 bg-ink/60 hidden z-50 backdrop-blur-sm">
    <div class="flex items-start sm:items-center justify-center min-h-screen p-4 pt-16 sm:pt-4">
      <div class="bg-cream-elevated rounded-xl border border-line max-w-2xl w-full max-h-[80vh] overflow-hidden shadow-card-lg">
        <div class="px-5 sm:px-6 py-4 border-b border-line">
          <div class="flex justify-between items-center">
            <div>
              <div class="eyebrow mb-1">new chat</div>
              <h3 class="display text-[20px] text-ink leading-[1.1]">Start a conversation</h3>
            </div>
            <button onclick="closeProviderSearch()" class="w-9 h-9 rounded-full border border-line text-ink-3 hover:bg-cream-sunken hover:text-ink transition-colors">
              <i class="fas fa-times text-[12px]"></i>
            </button>
          </div>
          <input type="text" id="providerSearch" placeholder="Search providers by name or service…"
                 class="w-full mt-4 px-4 py-2.5 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm"
                 oninput="searchProviders()">
        </div>
        <div class="px-3 sm:px-4 py-3 max-h-96 overflow-y-auto">
          <div id="providerResults">
            <div class="text-center py-10">
              <i class="fas fa-search text-2xl text-ink-3 mb-2"></i>
              <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3">search to start chatting</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
function openProviderSearch() {
  document.getElementById('providerSearchModal').classList.remove('hidden');
  loadAllProviders();
}
function closeProviderSearch() {
  document.getElementById('providerSearchModal').classList.add('hidden');
  document.getElementById('providerSearch').value = '';
}
function loadAllProviders() {
  fetch('/api/providers')
    .then(r => r.json())
    .then(providers => displayProviders(providers))
    .catch(e => console.error('Error:', e));
}
function searchProviders() {
  const query = document.getElementById('providerSearch').value;
  if (query.length < 2) { loadAllProviders(); return; }
  fetch(`/api/providers?search=${encodeURIComponent(query)}`)
    .then(r => r.json())
    .then(providers => displayProviders(providers))
    .catch(e => console.error('Error:', e));
}
function displayProviders(providers) {
  const div = document.getElementById('providerResults');
  if (providers.length === 0) {
    div.innerHTML = `
      <div class="text-center py-10">
        <i class="fas fa-user-slash text-2xl text-ink-3 mb-2"></i>
        <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3">no providers found</p>
      </div>`;
    return;
  }
  div.innerHTML = providers.map(p => `
    <div class="flex items-center gap-3 p-3 hover:bg-cream-sunken/40 rounded-lg cursor-pointer" onclick="startConversation(${p.id})">
      ${p.profile_picture_url
        ? `<img src="${p.profile_picture_url}" class="h-10 w-10 rounded-full object-cover border border-line">`
        : `<div class="h-10 w-10 rounded-full bg-cream-sunken border border-line flex items-center justify-center"><i class="fas fa-user text-ink-3 text-xs"></i></div>`}
      <div class="flex-1 min-w-0">
        <div class="text-[14px] font-semibold text-ink truncate">${p.display_name}</div>
        ${p.business_name ? `<div class="text-[12px] text-ink-3 truncate">${p.business_name}</div>` : ''}
        <div class="flex items-center gap-1 mt-0.5">
          <i class="fas fa-star text-amber-500 text-[9px]"></i>
          <span class="font-mono text-[10px] text-ink-3">${(p.average_rating || 0).toFixed ? (p.average_rating || 0).toFixed(1) : (p.average_rating || 0)} · ${p.total_reviews || 0} reviews</span>
        </div>
      </div>
      <i class="fas fa-arrow-right text-ink-3 text-[10px]"></i>
    </div>`).join('');
}
function startConversation(providerId) {
  fetch('/conversations', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    },
    body: JSON.stringify({ user_id: providerId })
  })
  .then(r => r.ok ? r.json() : Promise.reject('Failed'))
  .then(d => { window.location.href = `/conversations/${d.conversation_id}`; })
  .catch(e => alert('Failed to start conversation'));
}
const __modal = document.getElementById('providerSearchModal');
if (__modal) __modal.addEventListener('click', function(e) { if (e.target === this) closeProviderSearch(); });
</script>
