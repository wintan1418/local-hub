<div class="min-h-screen bg-cream">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to customer_dashboard_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to dashboard
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">leave a review</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">How was <em class="italic-wonk" style="color: #1f4d3a;">it</em>?</h1>
      <p class="mt-2 text-[14px] text-ink-2">Share your experience to help other customers.</p>
    </div>

    <%# Service info card %>
    <div class="bg-cream-elevated border border-line rounded-xl p-5 mb-5 flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
        <i class="fas fa-concierge-bell text-ink-3"></i>
      </div>
      <div class="flex-1 min-w-0">
        <div class="display text-[16px] text-ink leading-[1.15] truncate"><%= @booking.service.title %></div>
        <div class="text-[12px] text-ink-2">by <%= @booking.service.provider.display_name %></div>
        <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-0.5">completed <%= time_ago_in_words(@booking.updated_at) %> ago · $<%= number_with_precision(@booking.total_price, precision: 0) %></div>
      </div>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: @review, url: booking_review_path(@booking), method: :post, class: "space-y-6") do |f| %>
        <% if @review.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <ul class="space-y-0.5 ml-5">
              <% @review.errors.full_messages.each do |msg| %><li class="text-[13px] text-rose-700 list-disc"><%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3 block">Rating</label>
          <div class="flex gap-2" id="star-rating">
            <% (1..5).each do |star| %>
              <label class="cursor-pointer">
                <input type="radio" name="review[rating]" value="<%= star %>" class="hidden peer" <%= 'checked' if @review.rating == star %>>
                <i class="fas fa-star text-[32px] text-line peer-checked:text-amber-500 hover:text-amber-400 transition-colors star-btn" data-star="<%= star %>"></i>
              </label>
            <% end %>
          </div>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-3" id="star-label">select a rating</p>
        </div>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Tell us about it</label>
          <%= f.text_area :comment, rows: 5,
              placeholder: "What went well? Was the provider professional and on time? Would you hire again?",
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
          <p class="text-[11px] text-ink-3 mt-1.5">Minimum 10 characters. Be honest and helpful.</p>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-line">
          <%= link_to "Cancel", customer_dashboard_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <%= f.submit "Submit review", class: "bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm cursor-pointer transition-colors active:translate-y-px" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var labels = ['', 'Poor', 'Fair', 'Good', 'Very good', 'Excellent'];
  var stars = document.querySelectorAll('.star-btn');
  var labelEl = document.getElementById('star-label');

  function highlightStars(upTo) {
    stars.forEach(function(s, i) {
      s.classList.toggle('text-amber-500', i < upTo);
      s.classList.toggle('text-line', i >= upTo);
    });
  }

  stars.forEach(function(star) {
    var val = parseInt(star.dataset.star);
    star.addEventListener('mouseenter', function() {
      highlightStars(val);
      if (labelEl) labelEl.textContent = labels[val];
    });
    star.parentElement.addEventListener('click', function() {
      highlightStars(val);
      if (labelEl) labelEl.textContent = labels[val];
    });
  });

  document.getElementById('star-rating').addEventListener('mouseleave', function() {
    var checked = document.querySelector('input[name="review[rating]"]:checked');
    var val = checked ? parseInt(checked.value) : 0;
    highlightStars(val);
    if (labelEl) labelEl.textContent = val ? labels[val] : 'select a rating';
  });
});
</script>
