<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="mb-8 sm:mb-10">
      <div class="eyebrow mb-3">my pros</div>
      <h1 class="display text-[36px] sm:text-[48px] text-ink leading-[1] tracking-[-0.02em]">Pros you've <em class="italic-wonk" style="color: #1f4d3a;">saved</em>.</h1>
      <p class="mt-3 text-ink-2 text-[15px] sm:text-[17px] leading-[1.55] max-w-xl">Quick rebooking with the providers you trust.</p>
    </div>

    <% if @providers.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
        <% @providers.each do |provider| %>
          <%= link_to provider_path(provider), class: "group block bg-cream-elevated rounded-xl border border-line overflow-hidden hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200" do %>
            <div class="relative aspect-[4/5] bg-cream-sunken">
              <% if provider.profile_picture.attached? %>
                <%= image_tag provider.profile_picture, class: "absolute inset-0 w-full h-full object-cover" %>
              <% else %>
                <img src="https://i.pravatar.cc/400?u=provider<%= provider.id %>" class="absolute inset-0 w-full h-full object-cover" alt="<%= provider.display_name %>">
              <% end %>
              <% if provider.average_rating >= 4.8 %>
                <div class="absolute top-3 left-3 bg-cream-elevated border border-line rounded-pill px-2.5 py-1 flex items-center gap-1.5 shadow-card">
                  <i class="fas fa-star text-amber-500 text-[9px]"></i>
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink">top-rated</span>
                </div>
              <% end %>
              <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-cream-elevated border border-line flex items-center justify-center">
                <i class="fas fa-heart text-rose-500 text-xs"></i>
              </div>
            </div>
            <div class="p-4">
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5"><%= provider.services.first&.category&.name || "pro" %></div>
              <div class="display text-[18px] leading-[1.15] tracking-[-0.01em] text-ink truncate"><%= provider.business_name.presence || provider.display_name %></div>
              <div class="mt-3 flex items-center justify-between">
                <% if provider.average_rating > 0 %>
                  <div class="flex items-center gap-1.5 text-[13px] text-ink-2">
                    <i class="fas fa-star text-amber-500 text-[10px]"></i>
                    <span class="font-medium"><%= provider.average_rating %></span>
                    <span class="text-ink-3">(<%= provider.total_reviews %>)</span>
                  </div>
                <% else %>
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">new pro</span>
                <% end %>
                <span class="font-mono text-[10px] text-ink-3"><%= provider.respond_to?(:total_completed_bookings) ? "#{provider.total_completed_bookings} jobs" : "" %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-heart",
          title: "No favorites yet",
          message: "Tap the heart on any provider to save them here for quick rebooking.",
          cta_text: "Browse pros",
          cta_path: services_path %>
    <% end %>
  </div>
</div>
