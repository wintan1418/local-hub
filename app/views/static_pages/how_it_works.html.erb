<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ===== HERO ===== %>
<section class="bg-cream border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-3xl">
      <div class="eyebrow mb-4">how it works</div>
      <h1 class="display text-ink leading-[0.95] tracking-[-0.035em]" style="font-size: clamp(48px, 8vw, 96px);">
        Three steps to <em class="italic-wonk" style="color: #1f4d3a;">getting</em> it done.
      </h1>
      <p class="mt-6 text-[17px] sm:text-[19px] leading-[1.55] text-ink-2 max-w-2xl">
        Whether you need a plumber at midnight or a painter for next week — Radius gets you matched, booked, and sorted.
      </p>
    </div>
  </div>
</section>

<%# ===== FOR CUSTOMERS — 3 steps ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12 sm:mb-16">
      <div class="eyebrow mb-3">for customers</div>
      <h2 class="display text-[32px] sm:text-[44px] text-ink leading-[1.05] tracking-[-0.02em]">Find, book, pay — in <em class="italic-wonk" style="color: #1f4d3a;">minutes</em>.</h2>
    </div>

    <div class="space-y-16 sm:space-y-20">
      <% [
        {
          num: "1", title: "Search & compare",
          body: "Tell us what you need. Browse verified pros by category, location, price, and rating. Read real reviews from customers who actually booked.",
          bullets: [ "Search by service, city, or ZIP", "Filter by price, rating, availability", "Compare side by side", "Read verified reviews" ],
          img: "https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=800&q=80",
          flip: false
        },
        {
          num: "2", title: "Book & pay securely",
          body: "Found your pro? Pick a time. Pay through Stripe — your money is protected until the job is done. Or request a custom quote first.",
          bullets: [ "Instant booking with date/time", "Secure Stripe checkout", "Custom quotes for complex jobs", "Chat before you commit" ],
          img: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80",
          flip: true
        },
        {
          num: "3", title: "Get it done & review",
          body: "Your pro handles the work. Reminders before, an invoice when it's done, and a chance to leave a review. That's it.",
          bullets: [ "24-hour booking reminders", "Auto-generated invoices", "Verified post-job reviews", "Rebook your favorites" ],
          img: "https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80",
          flip: false
        }
      ].each do |step| %>
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="<%= step[:flip] ? 'lg:order-2' : '' %>">
            <div class="display italic-wonk text-[88px] leading-none" style="color: #1f4d3a; font-style: italic;"><%= step[:num] %></div>
            <h3 class="display text-[28px] sm:text-[36px] text-ink leading-[1.05] tracking-[-0.02em] mt-4"><%= step[:title] %></h3>
            <p class="mt-4 text-[15px] text-ink-2 leading-[1.65]"><%= step[:body] %></p>
            <ul class="mt-6 space-y-2.5">
              <% step[:bullets].each do |b| %>
                <li class="flex items-start gap-2.5 text-[14px] text-ink-2">
                  <i class="fas fa-check text-forest text-[11px] mt-1.5"></i><%= b %>
                </li>
              <% end %>
            </ul>
          </div>
          <div class="hidden lg:block <%= step[:flip] ? 'lg:order-1' : '' %>">
            <div class="aspect-[4/3] rounded-[20px] overflow-hidden border border-line bg-cream-sunken">
              <img src="<%= step[:img] %>" alt="<%= step[:title] %>" class="w-full h-full object-cover" loading="lazy">
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== FOR PROVIDERS — feature grid ===== %>
<section class="py-16 sm:py-20 bg-cream-sunken border-y border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 sm:mb-12">
      <div class="eyebrow mb-3">for providers</div>
      <h2 class="display text-[32px] sm:text-[44px] text-ink leading-[1.05] tracking-[-0.02em]">Run your business, <em class="italic-wonk" style="color: #1f4d3a;">finally</em>.</h2>
      <p class="mt-3 text-[15px] sm:text-[17px] text-ink-2 leading-[1.55] max-w-xl">Radius isn't just a directory. It's a complete business management platform.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      <% [
        [ "Get Discovered", "Customers find you by searching your area. No cold calling. They come to you." ],
        [ "Send Quotes", "Quotes with line items. Customers approve in one click — auto-creates a booking." ],
        [ "Manage Bookings", "Accept, reject, or complete bookings from your dashboard. Customers notified each step." ],
        [ "Visual Calendar", "Your entire month at a glance. Color-coded bookings, drag-and-drop reschedule." ],
        [ "Track Revenue", "Monthly revenue charts, top services, completion rate — all in one analytics view." ],
        [ "Auto Invoicing", "Invoices generated when you mark a job complete. Professional, printable, branded." ],
        [ "Build Reputation", "Every completed booking earns a verified review. Climb the leaderboard." ],
        [ "Chat with Clients", "In-app messaging with files, pinned messages, and reply threads." ],
        [ "Run Campaigns", "SMS and email campaigns to your customer base. Re-engage and promote." ]
      ].each do |title, desc| %>
        <div class="bg-cream-elevated rounded-xl border border-line p-6">
          <h3 class="display text-[20px] text-ink leading-[1.15]"><%= title %></h3>
          <p class="mt-2 text-[13px] text-ink-2 leading-[1.6]"><%= desc %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== TRUST SIGNALS ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 sm:mb-12">
      <div class="eyebrow mb-3">why trust us</div>
      <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">Every move is <em class="italic-wonk" style="color: #1f4d3a;">checked</em>.</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-4 sm:gap-5">
      <% [
        { icon: "fa-shield-alt", title: "Every pro is verified", desc: "Business licenses, insurance certificates, professional credentials, and government ID — checked by hand." },
        { icon: "fa-star", title: "Reviews you can trust", desc: "Only customers who completed and paid for a booking can leave a review. Zero fakes, zero gaming." },
        { icon: "fa-lock", title: "Payments are protected", desc: "All payments via Stripe — same processor as Amazon and Google. Card details never touch our servers." }
      ].each do |item| %>
        <div class="bg-cream-elevated rounded-xl border border-line p-7">
          <div class="w-11 h-11 rounded-full bg-forest-soft flex items-center justify-center mb-5">
            <i class="fas <%= item[:icon] %> text-forest"></i>
          </div>
          <h3 class="display text-[20px] text-ink leading-[1.15]"><%= item[:title] %></h3>
          <p class="mt-2 text-[14px] text-ink-2 leading-[1.6]"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== STATS ===== %>
<section class="py-12 sm:py-16 bg-cream-sunken border-y border-line">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-line">
      <% [
        { value: number_with_delimiter(@total_providers) + "+", label: "Verified Pros" },
        { value: number_with_delimiter(@total_bookings) + "+", label: "Bookings" },
        { value: number_with_delimiter(@total_reviews) + "+", label: "Reviews" },
        { value: "4.9", label: "Avg Rating", suffix: "★" }
      ].each do |stat| %>
        <div class="px-3 py-5 sm:py-2">
          <div class="display text-[28px] sm:text-[36px] text-ink leading-none"><%= stat[:value] %><% if stat[:suffix] %><span class="text-amber-500 text-[20px]"><%= stat[:suffix] %></span><% end %></div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-2"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== FAQ ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 sm:mb-12">
      <div class="eyebrow mb-3">questions</div>
      <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">Common <em class="italic-wonk" style="color: #1f4d3a;">questions</em>.</h2>
    </div>

    <div class="border-t border-line">
      <% [
        { q: "Is Radius free for customers?", a: "Yes, completely free. You only pay for the services you book. No subscription, no hidden fees, no catches." },
        { q: "How are providers verified?", a: "Every provider submits business licenses, insurance certificates, professional credentials, and government ID. Our admin team reviews each application before granting verified status." },
        { q: "How do payments work?", a: "When you book a service, you pay securely through Stripe. Card details never touch our servers. Funds are held until the job is completed." },
        { q: "What if I'm not happy with the service?", a: "Talk to your provider first — most issues resolve directly. You can also contact our support team. We stand behind every booking." },
        { q: "Can I request a quote before booking?", a: "Yes. Providers can send a detailed quote with line items and pricing. You review and approve with one click — it auto-creates a booking." },
        { q: "How much does it cost for providers?", a: "Free plan to start (1 service listing). Professional ($29/mo) and Business ($99/mo) plans unlock more services, analytics, badges, and marketing tools." },
        { q: "Do I get reminders before my appointment?", a: "Yes — email reminders 24 hours before. After completion, we'll also ask you to leave a review." },
        { q: "Can I see invoices for my bookings?", a: "Yes. Invoices are auto-generated when your booking is marked complete. View and print from your dashboard." }
      ].each do |faq| %>
        <details class="group border-b border-line">
          <summary class="flex items-center justify-between cursor-pointer py-5 text-left">
            <span class="display text-[18px] sm:text-[20px] text-ink leading-[1.2] pr-4"><%= faq[:q] %></span>
            <span class="flex-shrink-0 w-7 h-7 rounded-full border border-line flex items-center justify-center transition-colors group-open:bg-ink group-open:border-ink">
              <i class="fas fa-plus text-ink-3 text-[10px] transition-all group-open:rotate-45 group-open:text-cream"></i>
            </span>
          </summary>
          <div class="pb-5 -mt-1">
            <p class="text-[14px] text-ink-2 leading-[1.6] max-w-2xl"><%= faq[:a] %></p>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</section>

<%# ===== FINAL CTA ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="rounded-[20px] p-10 sm:p-14 lg:p-16 grid lg:grid-cols-[1.5fr_1fr] gap-8 items-center" style="background-color: #1d1813;">
      <div>
        <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-4">ready to try</div>
        <h2 class="display text-cream" style="font-size: clamp(36px, 5vw, 56px); line-height: 1; letter-spacing: -0.02em;">
          Get started, <em class="italic-wonk" style="color: #d96a3a;">free</em>.
        </h2>
        <p class="mt-5 text-cream/70 text-[15px] sm:text-[17px] leading-[1.5] max-w-md">Join thousands of customers and providers on Radius.</p>
      </div>
      <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
        <% if user_signed_in? %>
          <%= link_to services_path, class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Browse services <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path(role: 'customer'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Find a pro <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
          <%= link_to new_user_registration_path(role: 'provider'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-medium text-cream/80 hover:text-cream border border-cream/20 hover:border-cream/40 transition-colors" do %>
            Join as a pro
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
