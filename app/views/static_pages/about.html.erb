<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ========== HERO BANNER ========== %>
<section class="relative bg-gray-900 overflow-hidden min-h-[400px] sm:min-h-[450px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1920&q=80"
         alt="Team working together"
         class="w-full h-full object-cover object-center opacity-25">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/80 to-gray-900/40"></div>
  </div>
  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <p class="text-orange-400 font-semibold text-sm tracking-wide uppercase mb-4">About Us</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">
        We're building the future of<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">local services.</span>
      </h1>
      <p class="mt-6 text-lg text-gray-300 max-w-2xl leading-relaxed">
        LocalServiceHub connects homeowners and businesses with trusted, verified professionals in their community. We're making it simpler, safer, and faster to get things done.
      </p>
    </div>
  </div>
</section>

<%# ========== MISSION + STORY (split with image) ========== %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <%# Image %>
      <div class="relative">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1200&q=80"
               alt="Our team collaborating"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
        <%# Floating stat card %>
        <div class="absolute -bottom-6 -right-4 sm:right-8 bg-white rounded-xl shadow-xl p-5 border border-gray-100">
          <div class="text-3xl font-bold text-orange-500"><%= number_with_delimiter(@total_bookings) %>+</div>
          <div class="text-sm text-gray-500 mt-1">Services Completed</div>
        </div>
      </div>

      <%# Content %>
      <div>
        <p class="text-orange-500 font-semibold text-sm tracking-wide uppercase mb-3">Our Mission</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">Making quality services accessible to everyone</h2>
        <p class="mt-6 text-gray-600 leading-relaxed">
          We started LocalServiceHub because finding a reliable service provider shouldn't be stressful. Too often, people settle for whoever's available rather than whoever's best for the job.
        </p>
        <p class="mt-4 text-gray-600 leading-relaxed">
          Our platform changes that. We verify every provider, make pricing transparent, and let real customer reviews guide your decisions. Whether you need an emergency plumber at midnight or a landscaper for your dream garden, we connect you with the right professional, fast.
        </p>

        <div class="mt-8 grid grid-cols-2 gap-6">
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@total_providers) %>+</div>
            <div class="text-sm text-gray-500 mt-1">Verified Providers</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-gray-900"><%= @categories_count %></div>
            <div class="text-sm text-gray-500 mt-1">Service Categories</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== OUR VALUES ========== %>
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-orange-500 font-semibold text-sm tracking-wide uppercase mb-3">Our Values</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">What we stand for</h2>
      <p class="mt-4 text-lg text-gray-500">These principles guide every decision we make.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% [
        {
          icon: "fa-shield-alt", color: "blue",
          title: "Trust & Safety",
          desc: "Every provider on our platform goes through a multi-step verification process. We check documents, licenses, and insurance so you don't have to."
        },
        {
          icon: "fa-eye", color: "green",
          title: "Transparency",
          desc: "No hidden fees, no surprises. See real prices upfront, read genuine reviews from verified customers, and know exactly what you're paying for."
        },
        {
          icon: "fa-handshake", color: "orange",
          title: "Community First",
          desc: "We support local professionals and small businesses. When you book through LocalServiceHub, you're investing in your community."
        },
        {
          icon: "fa-bolt", color: "amber",
          title: "Simplicity",
          desc: "Finding help should be easy. Search, compare, book, done. We've stripped away the complexity so you can focus on what matters."
        },
        {
          icon: "fa-headset", color: "purple",
          title: "Customer Support",
          desc: "Have a question or issue? Our support team is here to help. We stand behind every booking made through our platform."
        },
        {
          icon: "fa-chart-line", color: "indigo",
          title: "Provider Growth",
          desc: "We help providers build their business with tools for managing bookings, marketing campaigns, and building their online reputation."
        }
      ].each do |value| %>
        <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-md transition-shadow duration-200">
          <div class="w-12 h-12 rounded-xl bg-<%= value[:color] %>-50 text-<%= value[:color] %>-600 flex items-center justify-center mb-5">
            <i class="fas <%= value[:icon] %> text-xl"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3"><%= value[:title] %></h3>
          <p class="text-sm text-gray-500 leading-relaxed"><%= value[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== HOW WE'RE DIFFERENT (image + content, reversed) ========== %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <%# Content %>
      <div class="lg:order-1">
        <p class="text-orange-500 font-semibold text-sm tracking-wide uppercase mb-3">How We're Different</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">Built for both sides of the marketplace</h2>
        <p class="mt-6 text-gray-600 leading-relaxed">
          Unlike other platforms, we invest equally in our customers and our providers. We believe a great marketplace works when both sides thrive.
        </p>

        <div class="mt-8 space-y-6">
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center flex-shrink-0 mt-1">
              <i class="fas fa-user text-sm"></i>
            </div>
            <div>
              <h4 class="font-bold text-gray-900 mb-1">For Customers</h4>
              <p class="text-sm text-gray-500 leading-relaxed">Search and compare providers, read verified reviews, book instantly, chat directly, and pay securely through the platform.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center flex-shrink-0 mt-1">
              <i class="fas fa-briefcase text-sm"></i>
            </div>
            <div>
              <h4 class="font-bold text-gray-900 mb-1">For Providers</h4>
              <p class="text-sm text-gray-500 leading-relaxed">Get discovered by new customers, manage your bookings and schedule, run marketing campaigns, and grow your reputation with verified reviews.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-green-50 text-green-500 flex items-center justify-center flex-shrink-0 mt-1">
              <i class="fas fa-cogs text-sm"></i>
            </div>
            <div>
              <h4 class="font-bold text-gray-900 mb-1">For Admins</h4>
              <p class="text-sm text-gray-500 leading-relaxed">Full oversight with provider verification workflows, analytics dashboards, and content management tools to keep the platform running smoothly.</p>
            </div>
          </div>
        </div>
      </div>

      <%# Image %>
      <div class="lg:order-2">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&q=80"
               alt="Professional service provider"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== STATS BANNER ========== %>
<section class="bg-gray-900 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 text-center">
      <% [
        { value: number_with_delimiter(@total_providers), suffix: "+", label: "Providers" },
        { value: number_with_delimiter(@total_customers), suffix: "+", label: "Customers" },
        { value: number_with_delimiter(@total_services), suffix: "+", label: "Services" },
        { value: number_with_delimiter(@total_bookings), suffix: "+", label: "Bookings" },
        { value: number_with_delimiter(@total_reviews), suffix: "+", label: "Reviews" }
      ].each do |stat| %>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-white"><%= stat[:value] %><span class="text-orange-400"><%= stat[:suffix] %></span></div>
          <div class="text-sm text-gray-400 mt-2"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== PLATFORM FEATURES ========== %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-orange-500 font-semibold text-sm tracking-wide uppercase mb-3">Platform Features</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Everything you need, built in</h2>
      <p class="mt-4 text-lg text-gray-500">A complete toolkit for managing local services.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10">
      <% [
        { icon: "fa-search", title: "Smart Search", desc: "Find services by category, location, price, and rating." },
        { icon: "fa-calendar-check", title: "Instant Booking", desc: "Book appointments directly with real-time availability." },
        { icon: "fa-comments", title: "In-App Chat", desc: "Message providers directly with file sharing and typing indicators." },
        { icon: "fa-credit-card", title: "Secure Payments", desc: "Stripe-powered checkout with subscription plans." },
        { icon: "fa-bell", title: "Notifications", desc: "Stay updated on bookings, messages, and reviews." },
        { icon: "fa-star", title: "Reviews & Ratings", desc: "Verified reviews from customers who actually booked." },
        { icon: "fa-id-badge", title: "Provider Verification", desc: "Document verification, licenses, and identity checks." },
        { icon: "fa-bullhorn", title: "CRM & Campaigns", desc: "SMS and email marketing tools for providers." }
      ].each do |feature| %>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center mx-auto mb-4">
            <i class="fas <%= feature[:icon] %> text-lg"></i>
          </div>
          <h3 class="text-sm font-bold text-gray-900 mb-1"><%= feature[:title] %></h3>
          <p class="text-sm text-gray-500"><%= feature[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== TEAM / BUILT BY ========== %>
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1200&q=80"
               alt="Building the platform"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
      </div>

      <div>
        <p class="text-orange-500 font-semibold text-sm tracking-wide uppercase mb-3">Our Story</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">Built by people who understand the problem</h2>
        <p class="mt-6 text-gray-600 leading-relaxed">
          We've been on both sides of the equation. As homeowners frustrated by unreliable contractors, and as freelancers struggling to find consistent work. That's why we built LocalServiceHub.
        </p>
        <p class="mt-4 text-gray-600 leading-relaxed">
          Our platform is built on modern technology: Ruby on Rails, real-time messaging, Stripe payments, and Twilio communications. We're constantly improving and adding features based on feedback from our community.
        </p>
        <p class="mt-4 text-gray-600 leading-relaxed">
          Whether you're a customer looking for help or a provider looking to grow, we're here to make the connection work.
        </p>

        <div class="mt-8">
          <p class="text-sm text-gray-500">
            Powered by
            <a href="mailto:wintan1418@gmail.com" class="text-orange-500 font-semibold hover:text-orange-600 transition-colors">Wintech</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== CTA ========== %>
<section class="py-24 bg-orange-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Ready to get started?</h2>
    <p class="mt-4 text-lg text-gray-500">Join our growing community of customers and service providers.</p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <% if user_signed_in? %>
        <%= link_to services_path, class: "inline-flex items-center justify-center bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-xl font-semibold text-base transition-colors shadow-sm" do %>
          Browse Services
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path(role: 'customer'), class: "inline-flex items-center justify-center bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-xl font-semibold text-base transition-colors shadow-sm" do %>
          Sign Up as Customer
        <% end %>
        <%= link_to new_user_registration_path(role: 'provider'), class: "inline-flex items-center justify-center text-gray-700 hover:text-gray-900 px-8 py-4 rounded-xl font-semibold text-base border border-gray-300 hover:border-gray-400 bg-white transition-colors" do %>
          Join as Provider
        <% end %>
      <% end %>
    </div>
  </div>
</section>
