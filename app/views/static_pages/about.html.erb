<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ========== HERO — Dark, immersive ========== %>
<section class="relative bg-slate-950 overflow-hidden min-h-[500px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1920&q=80"
         alt="Team working together"
         class="w-full h-full object-cover opacity-15">
  </div>
  <div class="absolute inset-0">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-64 h-64 bg-violet-500/8 rounded-full blur-[100px]"></div>
  </div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/[0.06] border border-white/[0.08] text-white/70 text-xs font-bold uppercase tracking-wider mb-6">
        <i class="fas fa-heart text-orange-400 text-[10px]"></i>
        Our Story
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.08] tracking-tight">
        We're making local services<br>
        <span class="hero-gradient-text">actually work.</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Radius connects homeowners and businesses with trusted, verified professionals. Simpler, safer, faster.
      </p>
    </div>
  </div>

  <div class="absolute bottom-0 inset-x-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
</section>

<%# ========== MISSION — Split layout ========== %>
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative" data-aos="fade-right">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10">
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1200&q=80"
               alt="Professional at work"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
        <div class="absolute -bottom-6 -right-4 sm:right-8 bg-white rounded-xl shadow-xl p-5 border border-slate-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center">
              <i class="fas fa-check-double text-emerald-600 text-sm"></i>
            </div>
            <div>
              <div class="text-2xl font-black text-slate-900"><%= number_with_delimiter(@total_bookings) %>+</div>
              <div class="text-xs text-slate-500">Jobs completed</div>
            </div>
          </div>
        </div>
      </div>

      <div data-aos="fade-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange-50 border border-orange-100 text-orange-600 text-xs font-bold uppercase tracking-wider mb-5">
          Our Mission
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight tracking-tight">Quality services should be accessible to everyone</h2>
        <p class="mt-6 text-slate-500 leading-relaxed">
          We started Radius because finding a reliable service provider shouldn't be stressful. Too often, people settle for whoever's available — not whoever's best.
        </p>
        <p class="mt-4 text-slate-500 leading-relaxed">
          We verify every provider, make pricing transparent, and let real reviews guide your decisions. Emergency plumber at midnight? Landscaper for your dream garden? We connect you with the right pro, fast.
        </p>

        <div class="mt-10 grid grid-cols-3 gap-6">
          <div>
            <div class="text-3xl font-black text-slate-900"><%= number_with_delimiter(@total_providers) %>+</div>
            <div class="text-sm text-slate-400 mt-1">Verified Pros</div>
          </div>
          <div>
            <div class="text-3xl font-black text-slate-900"><%= @categories_count %></div>
            <div class="text-sm text-slate-400 mt-1">Categories</div>
          </div>
          <div>
            <div class="text-3xl font-black text-slate-900">4.9</div>
            <div class="text-sm text-slate-400 mt-1">Avg Rating</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== VALUES — Bento grid ========== %>
<section class="py-24 bg-slate-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight">What we stand for</h2>
      <p class="mt-3 text-slate-500 text-lg">These principles guide every decision we make.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-aos="fade-up" data-aos-delay="100">
      <% [
        { icon: "fa-shield-alt", color: "blue", title: "Trust & Safety", desc: "Multi-step verification for every provider. We check documents, licenses, and insurance so you don't have to." },
        { icon: "fa-eye", color: "emerald", title: "Transparency", desc: "No hidden fees. See real prices, read genuine reviews from verified customers, know exactly what you're paying." },
        { icon: "fa-handshake", color: "orange", title: "Community First", desc: "We support local pros and small businesses. When you book through Radius, you invest in your community." },
        { icon: "fa-bolt", color: "amber", title: "Simplicity", desc: "Search, compare, book, done. We stripped away the complexity so you can focus on what matters." },
        { icon: "fa-headset", color: "violet", title: "Always Here", desc: "Have a question? Our support team stands behind every booking made through the platform." },
        { icon: "fa-chart-line", color: "sky", title: "Provider Growth", desc: "Tools for managing bookings, marketing campaigns, and building reputation — we help pros succeed." }
      ].each do |value| %>
        <div class="tilt-card bg-white rounded-xl p-7 border border-slate-100 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-<%= value[:color] %>-50 text-<%= value[:color] %>-500 flex items-center justify-center mb-5">
            <i class="fas <%= value[:icon] %> text-lg"></i>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2"><%= value[:title] %></h3>
          <p class="text-sm text-slate-500 leading-relaxed"><%= value[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== HOW IT WORKS — For both sides ========== %>
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div data-aos="fade-right">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-50 border border-sky-100 text-sky-600 text-xs font-bold uppercase tracking-wider mb-5">
          How It Works
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight tracking-tight">Built for both sides of the marketplace</h2>
        <p class="mt-4 text-slate-500 leading-relaxed">
          A great marketplace works when both sides thrive. That's why we invest equally in our customers and providers.
        </p>

        <div class="mt-10 space-y-6">
          <% [
            { icon: "fa-user", color: "orange", title: "For Customers", desc: "Search verified pros, compare ratings, book instantly, chat directly, and pay securely." },
            { icon: "fa-briefcase", color: "sky", title: "For Providers", desc: "Get discovered, manage bookings, run campaigns, and grow your reputation with reviews." },
            { icon: "fa-cogs", color: "emerald", title: "For Admins", desc: "Provider verification, analytics, content management, and platform health monitoring." }
          ].each do |item| %>
            <div class="flex gap-4 p-5 rounded-xl bg-slate-50 border border-slate-100 hover:border-<%= item[:color] %>-200 transition-colors duration-200">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-<%= item[:color] %>-50 text-<%= item[:color] %>-500 flex items-center justify-center">
                <i class="fas <%= item[:icon] %> text-sm"></i>
              </div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1"><%= item[:title] %></h4>
                <p class="text-sm text-slate-500 leading-relaxed"><%= item[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="hidden lg:block" data-aos="fade-left">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10">
          <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&q=80"
               alt="Professional service provider"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== STATS — Dark section with counters ========== %>
<section class="py-20 bg-slate-900 relative overflow-hidden">
  <div class="absolute top-0 left-1/3 w-96 h-96 bg-orange-500/[0.06] rounded-full blur-[120px]"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-8 text-center">
      <% [
        { value: @total_providers, label: "Providers" },
        { value: @total_customers, label: "Customers" },
        { value: @total_services, label: "Services" },
        { value: @total_bookings, label: "Bookings" },
        { value: @total_reviews, label: "Reviews" }
      ].each do |stat| %>
        <div>
          <div class="text-3xl sm:text-4xl font-black text-white"><%= number_with_delimiter(stat[:value]) %>+</div>
          <div class="text-xs text-slate-500 mt-2 font-medium uppercase tracking-wider"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== PLATFORM FEATURES — Icon grid ========== %>
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight">Everything built in</h2>
      <p class="mt-3 text-slate-500 text-lg">A complete toolkit for local services.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10" data-aos="fade-up" data-aos-delay="100">
      <% [
        { icon: "fa-search", color: "orange", title: "Smart Search", desc: "Find by category, location, price, and rating." },
        { icon: "fa-file-invoice-dollar", color: "sky", title: "Quoting", desc: "Professional quotes with line items and one-click approval." },
        { icon: "fa-credit-card", color: "emerald", title: "Payments", desc: "Stripe-powered checkout. Customers pay when they book." },
        { icon: "fa-file-invoice", color: "violet", title: "Invoicing", desc: "Auto-generated invoices after job completion." },
        { icon: "fa-calendar-alt", color: "amber", title: "Calendar", desc: "Visual month calendar for managing your schedule." },
        { icon: "fa-chart-line", color: "rose", title: "Analytics", desc: "Revenue charts, booking trends, performance data." },
        { icon: "fa-comments", color: "teal", title: "Messaging", desc: "In-app chat with files, pins, and replies." },
        { icon: "fa-bell", color: "blue", title: "Reminders", desc: "Automated booking reminders and review follow-ups." },
        { icon: "fa-star", color: "orange", title: "Reviews", desc: "Verified reviews from real customers who booked." },
        { icon: "fa-shield-alt", color: "emerald", title: "Verification", desc: "Document verification, identity checks, verified badges." },
        { icon: "fa-bullhorn", color: "violet", title: "CRM", desc: "SMS and email marketing campaigns for providers." },
        { icon: "fa-trophy", color: "amber", title: "Leaderboard", desc: "Top-rated providers ranked by performance." }
      ].each do |feature| %>
        <div class="text-center group">
          <div class="w-12 h-12 rounded-xl bg-<%= feature[:color] %>-50 text-<%= feature[:color] %>-500 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-200">
            <i class="fas <%= feature[:icon] %> text-lg"></i>
          </div>
          <h3 class="text-sm font-bold text-slate-900 mb-1"><%= feature[:title] %></h3>
          <p class="text-sm text-slate-500"><%= feature[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ========== OUR STORY ========== %>
<section class="py-24 bg-slate-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="hidden lg:block" data-aos="fade-right">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10">
          <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1200&q=80"
               alt="Building the platform"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
      </div>

      <div data-aos="fade-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-50 border border-violet-100 text-violet-600 text-xs font-bold uppercase tracking-wider mb-5">
          Behind the scenes
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight tracking-tight">Built by people who get it</h2>
        <p class="mt-6 text-slate-500 leading-relaxed">
          We've been on both sides — homeowners frustrated by unreliable contractors, and freelancers struggling to find consistent work. That dual perspective shapes everything we build.
        </p>
        <p class="mt-4 text-slate-500 leading-relaxed">
          Radius runs on modern technology: Ruby on Rails, real-time messaging, Stripe payments, and intelligent matching. We ship weekly, driven by real feedback from our community.
        </p>

        <div class="mt-8 flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-rose-500 flex items-center justify-center shadow-lg shadow-orange-500/20">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="7" opacity="0.6"/><circle cx="12" cy="12" r="11" opacity="0.3"/></svg>
          </div>
          <div>
            <div class="text-sm font-bold text-slate-900">Built by Wintech</div>
            <div class="text-xs text-slate-400">Shipping great products since day one</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== CTA ========== %>
<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-orange-500 via-orange-600 to-rose-600"></div>
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-5xl font-black text-white tracking-tight" data-aos="fade-up">Ready to get started?</h2>
    <p class="mt-4 text-white/80 text-lg" data-aos="fade-up" data-aos-delay="100">Join our growing community of customers and service professionals.</p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center" data-aos="fade-up" data-aos-delay="200">
      <% if user_signed_in? %>
        <%= link_to services_path, class: "group bg-white text-slate-900 px-8 py-4 rounded-xl font-bold text-sm hover:shadow-xl hover:shadow-black/10 hover:scale-[1.02] active:scale-[0.98] transition-all" do %>
          Browse Services <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path(role: 'customer'), class: "group bg-white text-slate-900 px-8 py-4 rounded-xl font-bold text-sm hover:shadow-xl hover:shadow-black/10 hover:scale-[1.02] active:scale-[0.98] transition-all" do %>
          Sign Up Free <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
        <% end %>
        <%= link_to new_user_registration_path(role: 'provider'), class: "text-white/90 hover:text-white px-8 py-4 rounded-xl font-bold text-sm border-2 border-white/30 hover:border-white/60 transition-all" do %>
          Join as Provider
        <% end %>
      <% end %>
    </div>
  </div>
</section>
