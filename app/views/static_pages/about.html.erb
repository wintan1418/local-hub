<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ===== HERO ===== %>
<section class="bg-cream border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-3xl">
      <div class="eyebrow mb-4">our story</div>
      <h1 class="display text-ink leading-[0.95] tracking-[-0.035em]" style="font-size: clamp(48px, 8vw, 96px);">
        We're making local services <em class="italic-wonk" style="color: #1f4d3a;">actually</em> work.
      </h1>
      <p class="mt-6 text-[17px] sm:text-[19px] leading-[1.55] text-ink-2 max-w-2xl">
        Radius connects homeowners and businesses with trusted, verified professionals. Simpler, safer, faster.
      </p>
    </div>
  </div>
</section>

<%# ===== MISSION — split layout ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative">
        <div class="aspect-[4/5] rounded-[20px] overflow-hidden border border-line bg-cream-sunken">
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1200&q=80" alt="Provider at work" class="w-full h-full object-cover" loading="lazy">
        </div>
        <div class="absolute -bottom-5 -right-5 sm:right-8 bg-cream-elevated rounded-pill border border-line py-3 px-5 shadow-card-lg">
          <div class="flex items-center gap-3">
            <i class="fas fa-check-double text-forest text-[12px]"></i>
            <div class="leading-tight">
              <div class="display text-[20px] text-ink leading-none"><%= number_with_delimiter(@total_bookings) %>+</div>
              <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">jobs done</div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="eyebrow mb-3">our mission</div>
        <h2 class="display text-[32px] sm:text-[44px] text-ink leading-[1.05] tracking-[-0.02em]">Quality service should be <em class="italic-wonk" style="color: #1f4d3a;">accessible</em> to everyone.</h2>
        <p class="mt-5 text-[15px] text-ink-2 leading-[1.65]">
          We started Radius because finding a reliable service provider shouldn't be stressful. Too often, people settle for whoever's available — not whoever's best.
        </p>
        <p class="mt-3 text-[15px] text-ink-2 leading-[1.65]">
          We verify every provider, make pricing transparent, and let real reviews guide your decisions. Emergency plumber at midnight? Landscaper for your dream garden? We connect you with the right pro, fast.
        </p>

        <div class="mt-10 grid grid-cols-3 gap-4 pt-6 border-t border-line">
          <% [
            { num: "#{number_with_delimiter(@total_providers)}+", label: "verified pros" },
            { num: @categories_count, label: "categories" },
            { num: "4.9", label: "avg rating" }
          ].each do |s| %>
            <div>
              <div class="display text-[28px] sm:text-[32px] text-ink leading-none"><%= s[:num] %></div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-1.5"><%= s[:label] %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== VALUES ===== %>
<section class="py-16 sm:py-20 bg-cream-sunken border-y border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 sm:mb-12">
      <div class="eyebrow mb-3">principles</div>
      <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">What we stand <em class="italic-wonk" style="color: #1f4d3a;">for</em>.</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      <% [
        { icon: "fa-shield-alt", title: "Trust & Safety", desc: "Multi-step verification for every provider. We check documents, licenses, and insurance so you don't have to." },
        { icon: "fa-eye", title: "Transparency", desc: "No hidden fees. See real prices, read genuine reviews from verified customers." },
        { icon: "fa-handshake", title: "Community First", desc: "We support local pros and small businesses. When you book, you invest in your community." },
        { icon: "fa-bolt", title: "Simplicity", desc: "Search, compare, book, done. We stripped the complexity so you can focus on what matters." },
        { icon: "fa-headset", title: "Always Here", desc: "Have a question? Our support team stands behind every booking on the platform." },
        { icon: "fa-chart-line", title: "Provider Growth", desc: "Tools for managing bookings, marketing, and reputation — we help pros succeed." }
      ].each do |v| %>
        <div class="bg-cream-elevated rounded-xl border border-line p-7">
          <div class="w-9 h-9 rounded-full bg-forest-soft flex items-center justify-center mb-5">
            <i class="fas <%= v[:icon] %> text-forest text-sm"></i>
          </div>
          <h3 class="display text-[20px] text-ink leading-[1.15] mb-2"><%= v[:title] %></h3>
          <p class="text-[14px] text-ink-2 leading-[1.6]"><%= v[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== BUILT FOR BOTH SIDES ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <div class="eyebrow mb-3">how it works</div>
        <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">Built for <em class="italic-wonk" style="color: #1f4d3a;">both</em> sides.</h2>
        <p class="mt-4 text-[15px] text-ink-2 leading-[1.65]">A great marketplace works when both sides thrive. We invest equally in customers and providers.</p>

        <div class="mt-8 space-y-1">
          <% [
            { title: "For Customers", desc: "Search verified pros, compare ratings, book instantly, chat directly, and pay securely." },
            { title: "For Providers", desc: "Get discovered, manage bookings, run campaigns, and grow your reputation." },
            { title: "For Admins", desc: "Provider verification, analytics, content management, and platform health." }
          ].each_with_index do |item, i| %>
            <div class="py-5 <%= 'border-t' if i > 0 %> border-line">
              <h3 class="display text-[20px] text-ink leading-[1.15]"><%= item[:title] %></h3>
              <p class="text-[14px] text-ink-2 leading-[1.6] mt-1.5"><%= item[:desc] %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="hidden lg:block">
        <div class="aspect-[4/5] rounded-[20px] overflow-hidden border border-line bg-cream-sunken">
          <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&q=80" alt="Service provider" class="w-full h-full object-cover" loading="lazy">
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== STATS ROW ===== %>
<section class="py-12 sm:py-16 bg-cream border-y border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-5 divide-y sm:divide-y-0 sm:divide-x divide-line">
      <% [
        { value: @total_providers, label: "Providers" },
        { value: @total_customers, label: "Customers" },
        { value: @total_services, label: "Services" },
        { value: @total_bookings, label: "Bookings" },
        { value: @total_reviews, label: "Reviews" }
      ].each do |stat| %>
        <div class="px-3 py-5 sm:py-2">
          <div class="display text-[28px] sm:text-[36px] text-ink leading-none"><%= number_with_delimiter(stat[:value]) %>+</div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mt-2"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== EVERYTHING BUILT IN ===== %>
<section class="py-16 sm:py-20 bg-cream-sunken border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <div class="eyebrow mb-3">platform</div>
      <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">Everything <em class="italic-wonk" style="color: #1f4d3a;">built in</em>.</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10">
      <% [
        [ "Smart Search", "Find by category, location, price, rating." ],
        [ "Quoting", "Professional quotes with one-click approval." ],
        [ "Payments", "Stripe-powered checkout and payouts." ],
        [ "Invoicing", "Auto-generated after job completion." ],
        [ "Calendar", "Visual month calendar for scheduling." ],
        [ "Analytics", "Revenue charts, booking trends, performance." ],
        [ "Messaging", "In-app chat with files, pins, replies." ],
        [ "Reminders", "Automated booking and review follow-ups." ],
        [ "Reviews", "Verified reviews from real customers." ],
        [ "Verification", "Document, identity, and license checks." ],
        [ "CRM", "SMS and email campaigns for providers." ],
        [ "Leaderboard", "Top-rated pros ranked by performance." ]
      ].each do |title, desc| %>
        <div>
          <h3 class="display text-[18px] text-ink leading-[1.15]"><%= title %></h3>
          <p class="text-[13px] text-ink-2 leading-[1.5] mt-1.5"><%= desc %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== OUR STORY ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="hidden lg:block">
        <div class="aspect-[4/5] rounded-[20px] overflow-hidden border border-line bg-cream-sunken">
          <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1200&q=80" alt="Building the platform" class="w-full h-full object-cover" loading="lazy">
        </div>
      </div>
      <div>
        <div class="eyebrow mb-3">behind the scenes</div>
        <h2 class="display text-[32px] sm:text-[40px] text-ink leading-[1.05] tracking-[-0.02em]">Built by people who <em class="italic-wonk" style="color: #1f4d3a;">get it</em>.</h2>
        <p class="mt-5 text-[15px] text-ink-2 leading-[1.65]">
          We've been on both sides — homeowners frustrated by unreliable contractors, and freelancers struggling to find consistent work. That dual perspective shapes everything we build.
        </p>
        <p class="mt-3 text-[15px] text-ink-2 leading-[1.65]">
          Radius runs on modern technology: Rails, real-time messaging, Stripe payments, intelligent matching. We ship weekly, driven by real community feedback.
        </p>

        <div class="mt-8 flex items-center gap-3 pt-6 border-t border-line">
          <span class="brand-mark"></span>
          <div>
            <div class="text-[14px] font-semibold text-ink">Built by Wintech</div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">shipping great products</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== FINAL CTA ===== %>
<section class="py-16 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="rounded-[20px] p-10 sm:p-14 lg:p-16 grid lg:grid-cols-[1.5fr_1fr] gap-8 items-center" style="background-color: #1d1813;">
      <div>
        <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-4">get started</div>
        <h2 class="display text-cream" style="font-size: clamp(36px, 5vw, 56px); line-height: 1; letter-spacing: -0.02em;">
          Ready when you <em class="italic-wonk" style="color: #d96a3a;">are</em>.
        </h2>
        <p class="mt-5 text-cream/70 text-[15px] sm:text-[17px] leading-[1.5] max-w-md">Join our community of customers and service pros. Free to sign up.</p>
      </div>
      <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
        <% if user_signed_in? %>
          <%= link_to services_path, class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Browse services <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path(role: 'customer'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Sign up free <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
          <%= link_to new_user_registration_path(role: 'provider'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-medium text-cream/80 hover:text-cream border border-cream/20 hover:border-cream/40 transition-colors" do %>
            Join as a pro
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
