<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ========== HERO BANNER ========== %>
<section class="relative bg-gray-900 overflow-hidden min-h-[350px] sm:min-h-[400px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1920&q=80"
         alt="Get in touch"
         class="w-full h-full object-cover object-center opacity-20">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/80 to-gray-900/40"></div>
  </div>
  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
    <div class="max-w-3xl">
      <p class="text-orange-400 font-semibold text-sm tracking-wide uppercase mb-4">Contact Us</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">
        We'd love to<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-400">hear from you.</span>
      </h1>
      <p class="mt-6 text-lg text-gray-300 max-w-2xl leading-relaxed">
        Have a question, feedback, or need help? Reach out and our team will get back to you as soon as possible.
      </p>
    </div>
  </div>
</section>

<%# ========== CONTACT FORM + INFO ========== %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

      <%# Contact Form (3 cols) %>
      <div class="lg:col-span-3">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Send us a message</h2>
        <p class="text-gray-500 mb-8">Fill out the form below and we'll respond within 24 hours.</p>

        <%= form_tag send_contact_path, method: :post, class: "space-y-6" do %>
          <div class="grid sm:grid-cols-2 gap-6">
            <%# Name %>
            <div>
              <label for="contact_name" class="block text-sm font-medium text-gray-700 mb-1.5">Full Name <span class="text-red-500">*</span></label>
              <input type="text" name="name" id="contact_name" required placeholder="John Doe"
                     class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm">
            </div>

            <%# Email %>
            <div>
              <label for="contact_email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
              <input type="email" name="email" id="contact_email" required placeholder="john@example.com"
                     class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm">
            </div>
          </div>

          <%# Subject %>
          <div>
            <label for="contact_subject" class="block text-sm font-medium text-gray-700 mb-1.5">Subject</label>
            <select name="subject" id="contact_subject"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Customer Support">Customer Support</option>
              <option value="Provider Support">Provider Support</option>
              <option value="Billing & Payments">Billing & Payments</option>
              <option value="Report an Issue">Report an Issue</option>
              <option value="Partnership">Partnership</option>
              <option value="Feedback">Feedback</option>
            </select>
          </div>

          <%# Message %>
          <div>
            <label for="contact_message" class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-red-500">*</span></label>
            <textarea name="message" id="contact_message" rows="6" required placeholder="Tell us how we can help..."
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow text-sm resize-none"></textarea>
          </div>

          <button type="submit"
                  class="w-full sm:w-auto bg-orange-500 hover:bg-orange-600 text-white px-8 py-3.5 rounded-xl font-semibold text-sm transition-colors shadow-sm">
            <i class="fas fa-paper-plane mr-2"></i>Send Message
          </button>
        <% end %>
      </div>

      <%# Contact Info (2 cols) %>
      <div class="lg:col-span-2 space-y-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Get in touch</h2>
        <p class="text-gray-500 mb-8">You can also reach us through any of these channels.</p>

        <%# Email Card %>
        <div class="flex items-start gap-4 p-5 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-sm transition-all">
          <div class="w-11 h-11 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-envelope text-lg"></i>
          </div>
          <div>
            <h3 class="text-sm font-bold text-gray-900">Email</h3>
            <a href="mailto:support@localservicehub.com" class="text-sm text-orange-500 hover:text-orange-600 transition-colors">support@localservicehub.com</a>
            <p class="text-xs text-gray-400 mt-1">We'll respond within 24 hours</p>
          </div>
        </div>

        <%# Phone Card %>
        <div class="flex items-start gap-4 p-5 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-sm transition-all">
          <div class="w-11 h-11 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-phone text-lg"></i>
          </div>
          <div>
            <h3 class="text-sm font-bold text-gray-900">Phone</h3>
            <a href="tel:+18001234567" class="text-sm text-gray-700 hover:text-gray-900 transition-colors">+1 (800) 123-4567</a>
            <p class="text-xs text-gray-400 mt-1">Mon - Fri, 9am - 6pm EST</p>
          </div>
        </div>

        <%# Office Hours Card %>
        <div class="flex items-start gap-4 p-5 rounded-2xl border border-gray-100 hover:border-orange-200 hover:shadow-sm transition-all">
          <div class="w-11 h-11 rounded-xl bg-green-50 text-green-500 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-clock text-lg"></i>
          </div>
          <div>
            <h3 class="text-sm font-bold text-gray-900">Office Hours</h3>
            <p class="text-sm text-gray-700">Monday - Friday: 9am - 6pm EST</p>
            <p class="text-sm text-gray-700">Saturday: 10am - 4pm EST</p>
            <p class="text-xs text-gray-400 mt-1">Closed on Sundays & holidays</p>
          </div>
        </div>

        <%# Social Links %>
        <div class="pt-4">
          <h3 class="text-sm font-bold text-gray-900 mb-3">Follow us</h3>
          <div class="flex gap-3">
            <a href="#" class="w-10 h-10 rounded-xl bg-gray-50 hover:bg-orange-50 text-gray-400 hover:text-orange-500 flex items-center justify-center transition-colors">
              <i class="fab fa-facebook-f"></i>
            </a>
            <a href="#" class="w-10 h-10 rounded-xl bg-gray-50 hover:bg-orange-50 text-gray-400 hover:text-orange-500 flex items-center justify-center transition-colors">
              <i class="fab fa-twitter"></i>
            </a>
            <a href="#" class="w-10 h-10 rounded-xl bg-gray-50 hover:bg-orange-50 text-gray-400 hover:text-orange-500 flex items-center justify-center transition-colors">
              <i class="fab fa-instagram"></i>
            </a>
            <a href="#" class="w-10 h-10 rounded-xl bg-gray-50 hover:bg-orange-50 text-gray-400 hover:text-orange-500 flex items-center justify-center transition-colors">
              <i class="fab fa-linkedin-in"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== FAQ SECTION ========== %>
<section class="py-20 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Frequently Asked Questions</h2>
      <p class="mt-4 text-lg text-gray-500">Quick answers to the questions we hear most often.</p>
    </div>

    <div class="space-y-4">
      <% [
        {
          q: "How do I book a service?",
          a: "Simply search for the service you need, browse available providers, and click \"Book Now\" on the provider's service page. Choose your preferred date and time, and you'll receive instant confirmation."
        },
        {
          q: "Are the service providers verified?",
          a: "Yes. Every provider goes through our multi-step verification process, which includes identity verification, document checks (business license, insurance, certifications), and ongoing review monitoring."
        },
        {
          q: "How do payments work?",
          a: "All payments are processed securely through Stripe. You pay through the platform when you book, and the provider receives payment after the service is completed. Your financial information is never shared with providers."
        },
        {
          q: "What if I'm not satisfied with the service?",
          a: "We take quality seriously. If you're not satisfied, contact our support team within 48 hours of the service. We'll work with both you and the provider to find a fair resolution."
        },
        {
          q: "How do I become a service provider?",
          a: "Sign up for a provider account, complete your profile, upload your verification documents, and choose a subscription plan. Once verified, you can start listing your services and accepting bookings."
        },
        {
          q: "Is there a fee to use LocalServiceHub?",
          a: "It's completely free for customers. Service providers can start with our Free plan (1 service listing) or upgrade to Professional or Business plans for more features and listings."
        }
      ].each_with_index do |faq, i| %>
        <details class="group bg-white rounded-2xl border border-gray-100 overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-left">
            <span class="text-base font-semibold text-gray-900 pr-4"><%= faq[:q] %></span>
            <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-gray-50 group-open:bg-orange-50 flex items-center justify-center transition-colors">
              <i class="fas fa-chevron-down text-gray-400 group-open:text-orange-500 text-xs transition-transform group-open:rotate-180"></i>
            </span>
          </summary>
          <div class="px-6 pb-5">
            <p class="text-sm text-gray-500 leading-relaxed"><%= faq[:a] %></p>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</section>

<%# ========== CTA ========== %>
<section class="py-20 bg-gradient-to-r from-orange-500 to-amber-500">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">Ready to get started?</h2>
    <p class="mt-4 text-lg text-orange-100">Join our growing community of customers and service providers.</p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <% if user_signed_in? %>
        <%= link_to services_path, class: "inline-flex items-center justify-center bg-white text-orange-600 px-8 py-4 rounded-xl font-semibold text-base hover:bg-gray-50 transition-colors shadow-lg" do %>
          Browse Services
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path(role: 'customer'), class: "inline-flex items-center justify-center bg-white text-orange-600 px-8 py-4 rounded-xl font-semibold text-base hover:bg-gray-50 transition-colors shadow-lg" do %>
          Sign Up Free
        <% end %>
        <%= link_to new_user_registration_path(role: 'provider'), class: "inline-flex items-center justify-center bg-transparent text-white px-8 py-4 rounded-xl font-semibold text-base border-2 border-white/50 hover:border-white hover:bg-white/10 transition-colors" do %>
          Join as Provider
        <% end %>
      <% end %>
    </div>
  </div>
</section>
