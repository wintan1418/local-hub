<% content_for :page_title, @page_title %>
<% content_for :page_description, @page_description %>

<%# ===== HERO ===== %>
<section class="bg-cream border-b border-line">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="max-w-3xl">
      <div class="eyebrow mb-4">contact</div>
      <h1 class="display text-ink leading-[0.95] tracking-[-0.035em]" style="font-size: clamp(48px, 8vw, 88px);">
        We'd love to <em class="italic-wonk" style="color: #1f4d3a;">hear</em> from you.
      </h1>
      <p class="mt-6 text-[17px] sm:text-[19px] leading-[1.55] text-ink-2 max-w-2xl">
        Question, feedback, or need help? Reach out and we'll get back to you within 24 hours.
      </p>
    </div>
  </div>
</section>

<%# ===== FORM + INFO ===== %>
<section class="py-14 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16">

      <%# Form %>
      <div class="lg:col-span-3">
        <div class="eyebrow mb-3">send a message</div>
        <h2 class="display text-[28px] sm:text-[32px] text-ink leading-[1.05] tracking-[-0.02em]">Tell us <em class="italic-wonk" style="color: #1f4d3a;">what's up</em>.</h2>

        <%= form_tag send_contact_path, method: :post, class: "mt-7 space-y-5" do %>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="contact_name" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Full name <span class="text-rose-600">*</span></label>
              <input type="text" name="name" id="contact_name" required placeholder="John Doe"
                     class="w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm">
            </div>
            <div>
              <label for="contact_email" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Email <span class="text-rose-600">*</span></label>
              <input type="email" name="email" id="contact_email" required placeholder="john@example.com"
                     class="w-full px-4 py-3 rounded-pill border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm">
            </div>
          </div>

          <div>
            <label for="contact_subject" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Subject</label>
            <select name="subject" id="contact_subject" class="w-full px-4 py-3 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm">
              <option value="General Inquiry">General inquiry</option>
              <option value="Customer Support">Customer support</option>
              <option value="Provider Support">Provider support</option>
              <option value="Billing & Payments">Billing &amp; payments</option>
              <option value="Report an Issue">Report an issue</option>
              <option value="Partnership">Partnership</option>
              <option value="Feedback">Feedback</option>
            </select>
          </div>

          <div>
            <label for="contact_message" class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Message <span class="text-rose-600">*</span></label>
            <textarea name="message" id="contact_message" rows="6" required placeholder="Tell us how we can help…"
                      class="w-full px-4 py-3 rounded-2xl border border-line text-ink placeholder-ink-4 focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none"></textarea>
          </div>

          <button type="submit" class="bg-ink hover:bg-ink-2 text-cream px-7 py-3 rounded-pill font-semibold text-sm transition-colors active:translate-y-px inline-flex items-center gap-2">
            Send message <i class="fas fa-arrow-right text-[10px]"></i>
          </button>
        <% end %>
      </div>

      <%# Info %>
      <div class="lg:col-span-2 lg:pl-8 lg:border-l border-line">
        <div class="eyebrow mb-3">other ways</div>
        <h2 class="display text-[24px] sm:text-[28px] text-ink leading-[1.1]">Get in touch</h2>

        <div class="mt-6 space-y-1">
          <% [
            { icon: "fa-envelope", title: "Email", value: "support@radiusapp.com", href: "mailto:support@radiusapp.com", note: "Response within 24h" },
            { icon: "fa-phone", title: "Phone", value: "+1 (800) 123-4567", href: "tel:+18001234567", note: "Mon–Fri, 9am–6pm EST" },
            { icon: "fa-clock", title: "Hours", value: "Mon–Fri 9–6, Sat 10–4", href: nil, note: "Closed Sundays & holidays" }
          ].each_with_index do |item, i| %>
            <div class="flex items-start gap-4 py-5 <%= 'border-t' if i > 0 %> border-line">
              <div class="w-9 h-9 rounded-full bg-forest-soft flex items-center justify-center flex-shrink-0 mt-0.5">
                <i class="fas <%= item[:icon] %> text-forest text-sm"></i>
              </div>
              <div class="min-w-0">
                <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1"><%= item[:title] %></div>
                <% if item[:href] %>
                  <a href="<%= item[:href] %>" class="display text-[18px] text-ink leading-[1.15] hover:underline underline-offset-2"><%= item[:value] %></a>
                <% else %>
                  <div class="display text-[18px] text-ink leading-[1.15]"><%= item[:value] %></div>
                <% end %>
                <p class="text-[12px] text-ink-3 mt-1"><%= item[:note] %></p>
              </div>
            </div>
          <% end %>
        </div>

        <div class="pt-5 border-t border-line mt-1">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">follow</div>
          <div class="flex gap-2">
            <% [ "fa-instagram", "fa-x-twitter", "fa-linkedin-in", "fa-facebook-f" ].each do |icon| %>
              <a href="#" class="w-10 h-10 rounded-pill bg-cream-elevated border border-line text-ink-3 hover:text-ink hover:border-line-strong flex items-center justify-center transition-colors">
                <i class="fab <%= icon %> text-xs"></i>
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== FAQ ===== %>
<section class="py-14 sm:py-20 bg-cream-sunken border-y border-line">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <div class="eyebrow mb-3">questions</div>
      <h2 class="display text-[28px] sm:text-[36px] text-ink leading-[1.05] tracking-[-0.02em]">Frequently <em class="italic-wonk" style="color: #1f4d3a;">asked</em>.</h2>
    </div>

    <div class="border-t border-line">
      <% [
        { q: "How do I book a service?", a: "Search for the service you need, browse providers, and click 'Request to book' on the service page. Pick a date and time and you'll get instant confirmation." },
        { q: "Are the providers verified?", a: "Yes. Every provider goes through multi-step verification: identity, business license, insurance, certifications. We monitor reviews ongoing too." },
        { q: "How do payments work?", a: "All payments processed securely through Stripe. You pay through the platform at booking, the provider gets paid after completion. Your financial info is never shared." },
        { q: "What if I'm not satisfied?", a: "Contact support within 48 hours of the service. We work with you and the provider to find a fair resolution." },
        { q: "How do I become a provider?", a: "Sign up for a provider account, complete your profile, upload verification documents, and choose a subscription plan. Once verified, you can list services." },
        { q: "Is there a fee to use Radius?", a: "Free for customers. Providers start with a Free plan (1 listing) or upgrade to Professional / Business for more features." }
      ].each do |faq| %>
        <details class="group border-b border-line">
          <summary class="flex items-center justify-between cursor-pointer py-5 text-left">
            <span class="display text-[18px] sm:text-[20px] text-ink leading-[1.2] pr-4"><%= faq[:q] %></span>
            <span class="flex-shrink-0 w-7 h-7 rounded-full border border-line flex items-center justify-center transition-colors group-open:bg-ink group-open:border-ink">
              <i class="fas fa-plus text-ink-3 text-[10px] transition-all group-open:rotate-45 group-open:text-cream"></i>
            </span>
          </summary>
          <div class="pb-5 -mt-1">
            <p class="text-[14px] text-ink-2 leading-[1.6] max-w-2xl"><%= faq[:a] %></p>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</section>

<%# ===== FINAL CTA ===== %>
<section class="py-14 sm:py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="rounded-[20px] p-10 sm:p-14 grid lg:grid-cols-[1.5fr_1fr] gap-8 items-center" style="background-color: #1d1813;">
      <div>
        <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-4">get started</div>
        <h2 class="display text-cream" style="font-size: clamp(32px, 4.5vw, 48px); line-height: 1; letter-spacing: -0.02em;">
          Ready to <em class="italic-wonk" style="color: #d96a3a;">try</em> it?
        </h2>
        <p class="mt-4 text-cream/70 text-[15px] leading-[1.5] max-w-md">Join our community of customers and service pros.</p>
      </div>
      <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
        <% if user_signed_in? %>
          <%= link_to services_path, class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Browse services <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path(role: 'customer'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-semibold bg-cream text-ink hover:bg-cream-sunken transition-colors active:translate-y-px" do %>
            Sign up free <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
          <%= link_to new_user_registration_path(role: 'provider'), class: "inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill text-sm font-medium text-cream/80 hover:text-cream border border-cream/20 hover:border-cream/40 transition-colors" do %>
            Join as a pro
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
