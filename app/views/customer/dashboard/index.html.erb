<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

    <%# ===== HEADER ===== %>
    <div class="mb-8 sm:mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <% tier = current_user.loyalty_tier %>
          <div class="eyebrow mb-3 flex items-center gap-2">
            <span>dashboard</span>
            <span class="text-line">·</span>
            <span class="inline-flex items-center gap-1.5 text-forest"><i class="fas <%= tier[:icon] %> text-[9px]"></i><%= tier[:name] %> tier</span>
          </div>
          <h1 class="display text-[36px] sm:text-[48px] text-ink leading-[1] tracking-[-0.02em]">Welcome back, <em class="italic-wonk" style="color: #1f4d3a;"><%= current_user.email.split('@').first.titleize %></em>.</h1>
        </div>
        <div class="flex gap-2">
          <%= link_to favorites_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors" do %>
            <i class="fas fa-heart text-rose-500 text-[12px]"></i><span class="hidden sm:inline">My pros</span>
          <% end %>
          <%= link_to services_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
            Find services <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        </div>
      </div>
    </div>

    <%# ===== STATS — divided 4-up on cream ===== %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-8 sm:mb-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-line">
        <% [
          { label: "Bookings", value: @total_bookings },
          { label: "Total spent", value: "$#{number_with_delimiter(@total_spent)}" },
          { label: "Pending", value: @pending_count },
          { label: "This month", value: @this_month_bookings }
        ].each do |stat| %>
          <div class="p-5 sm:p-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= stat[:label] %></div>
            <div class="display text-[36px] sm:text-[44px] text-ink leading-none mt-2"><%= stat[:value] %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ===== MAIN GRID ===== %>
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-6 lg:gap-8">

      <%# LEFT — upcoming + recommended %>
      <div class="space-y-6">

        <%# Upcoming bookings %>
        <div class="bg-cream-elevated border border-line rounded-xl">
          <div class="px-5 sm:px-6 py-4 border-b border-line flex items-center justify-between">
            <div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">upcoming</div>
              <div class="display text-[20px] text-ink leading-[1.1]"><%= @upcoming_bookings.count %> booking<%= @upcoming_bookings.count == 1 ? '' : 's' %></div>
            </div>
            <%= link_to bookings_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>see all →<% end %>
          </div>

          <div class="p-3 sm:p-4">
            <% if @upcoming_bookings.any? %>
              <div class="space-y-2">
                <% @upcoming_bookings.each do |booking| %>
                  <%= link_to booking_path(booking), class: "block p-4 rounded-lg border border-line hover:bg-cream-sunken/40 transition-colors" do %>
                    <div class="flex items-start gap-3">
                      <div class="h-11 w-11 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-tools text-ink-3 text-sm"></i>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <div class="display text-[16px] text-ink leading-[1.15] truncate"><%= booking.service.title %></div>
                          <% status_colors = {
                            "pending" => [ "bg-amber-100/60", "text-amber-800" ],
                            "confirmed" => [ "bg-forest-soft", "text-forest" ],
                            "completed" => [ "bg-cream-sunken", "text-ink-2" ],
                            "cancelled" => [ "bg-rose-100/60", "text-rose-700" ]
                          } %>
                          <% c = status_colors[booking.status] || [ "bg-cream-sunken", "text-ink-2" ] %>
                          <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %> flex-shrink-0"><%= booking.status %></span>
                        </div>
                        <div class="font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3 mt-1 truncate">
                          <%= booking.service.provider.display_name %> · <%= booking.scheduled_at.strftime("%b %-d · %-I:%M %p") %>
                        </div>
                        <div class="flex items-center justify-between gap-2 mt-2">
                          <span class="display text-[16px] text-ink leading-none">$<%= number_with_precision(booking.total_price, precision: 0) %></span>
                          <% if booking.status == 'pending' %>
                            <div onclick="event.stopPropagation(); event.preventDefault();">
                              <%= button_to booking_path(booking), method: :delete, data: { turbo_confirm: "Cancel this booking?" }, class: "font-mono text-[10px] uppercase tracking-[0.1em] text-rose-700 hover:text-rose-800 cursor-pointer" do %>
                                cancel
                              <% end %>
                            </div>
                          <% elsif booking.status == 'completed' && !booking.review %>
                            <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-forest">leave review →</span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <%= render "shared/empty_state",
                  icon: "fa-calendar-plus",
                  title: "No upcoming bookings",
                  message: "Browse services and book your next appointment.",
                  cta_text: "Find services",
                  cta_path: services_path,
                  cta_icon: "fa-search" %>
            <% end %>
          </div>
        </div>

        <%# Recommended services — using shared service card %>
        <div>
          <div class="flex items-end justify-between mb-4">
            <div>
              <div class="eyebrow mb-2">recommended</div>
              <h2 class="display text-[22px] text-ink leading-[1.1]">Pros you might <em class="italic-wonk" style="color: #1f4d3a;">like</em></h2>
            </div>
            <%= link_to services_path, class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>browse all →<% end %>
          </div>
          <% if @services.any? %>
            <div class="grid sm:grid-cols-2 gap-4">
              <%= render partial: "services/service_card", collection: @services.limit(4), as: :service %>
            </div>
          <% else %>
            <p class="text-[13px] text-ink-3">No services found.</p>
          <% end %>
        </div>
      </div>

      <%# RIGHT — sidebar %>
      <aside class="space-y-4">

        <%# Quick search %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">quick search</div>
          <%= form_with url: customer_dashboard_path, method: :get, local: true, class: "space-y-2" do |form| %>
            <%= form.text_field :query, placeholder: "Search services…", value: @query,
                class: "w-full px-3 py-2.5 text-sm rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated" %>
            <%= form.select :category_id,
                options_for_select([ [ "All categories", "" ] ] + @categories.map { |c| [ c.name, c.id ] }, @category_id),
                {}, class: "w-full px-3 py-2.5 text-sm rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated" %>
            <%= form.submit "Search", class: "w-full bg-ink text-cream py-2.5 px-4 text-sm font-semibold rounded-pill hover:bg-ink-2 transition-colors cursor-pointer" %>
          <% end %>
        </div>

        <%# Quick actions — icon grid mobile / list desktop %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">quick actions</div>
          <div class="grid grid-cols-4 sm:grid-cols-1 gap-2 sm:gap-1.5">
            <% [
              { path: services_path, icon: "fa-search", label: "Browse" },
              { path: conversations_path, icon: "fa-comments", label: "Messages" },
              { path: notifications_path, icon: "fa-bell", label: "Alerts" },
              { path: favorites_path, icon: "fa-heart", label: "My pros" },
              { path: job_requests_path, icon: "fa-briefcase", label: "Jobs" },
              { path: refer_path, icon: "fa-gift", label: "Refer" },
              { path: gift_cards_path, icon: "fa-gift", label: "Gift cards" },
              { path: settings_path, icon: "fa-cog", label: "Settings" }
            ].each do |action| %>
              <%= link_to action[:path], class: "flex sm:flex-row flex-col items-center justify-center sm:justify-start gap-1 sm:gap-3 py-2.5 sm:py-2 px-2 sm:px-3 rounded-lg sm:rounded-pill text-ink-2 hover:bg-cream-sunken transition-colors text-center sm:text-left" do %>
                <i class="fas <%= action[:icon] %> text-[13px] text-ink-3"></i>
                <span class="text-[10px] sm:text-[13px] font-medium leading-tight"><%= action[:label] %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Pending quotes %>
        <% if @quotes.present? && @quotes.any? %>
          <div class="bg-cream-elevated border border-line rounded-xl p-5">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">quotes received</div>
            <div class="space-y-1.5">
              <% @quotes.each do |quote| %>
                <%= link_to quote_path(quote), class: "block p-3 rounded-lg border border-line hover:bg-cream-sunken/40 transition-colors" do %>
                  <div class="flex items-center justify-between gap-2">
                    <div class="min-w-0 flex-1">
                      <div class="text-[13px] font-semibold text-ink truncate"><%= quote.title %></div>
                      <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 truncate mt-0.5"><%= quote.provider.display_name %></div>
                    </div>
                    <div class="text-right flex-shrink-0">
                      <div class="display text-[14px] text-ink leading-none">$<%= number_with_precision(quote.total_price, precision: 0) %></div>
                      <div class="font-mono text-[10px] uppercase tracking-[0.08em] mt-0.5 <%= quote.status == 'approved' ? 'text-forest' : 'text-ink-3' %>"><%= quote.status %></div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Needs review %>
        <% if @needs_review.present? && @needs_review.any? %>
          <div class="bg-forest-soft rounded-xl border border-forest/20 p-5">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-forest mb-2"><i class="fas fa-star mr-1.5"></i>leave a review</div>
            <p class="text-[12px] text-ink-2 mb-3">Help the community by reviewing your completed bookings.</p>
            <div class="space-y-1.5">
              <% @needs_review.each do |booking| %>
                <%= link_to new_booking_review_path(booking), class: "flex items-center justify-between gap-2 p-3 bg-cream-elevated rounded-lg border border-forest/20 hover:border-forest/40 transition-colors" do %>
                  <div class="min-w-0 flex-1">
                    <div class="text-[13px] font-semibold text-ink truncate"><%= booking.service.title %></div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-0.5"><%= time_ago_in_words(booking.updated_at) %> ago</div>
                  </div>
                  <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-forest flex-shrink-0">review →</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Recent history %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">recent history</div>
          <% if @past_bookings.any? %>
            <div class="space-y-1.5">
              <% @past_bookings.limit(3).each do |booking| %>
                <div class="flex items-center gap-3 p-3 rounded-lg border border-line">
                  <div class="h-8 w-8 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-check text-forest text-[11px]"></i>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-[13px] font-semibold text-ink truncate"><%= booking.service.title %></div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-0.5"><%= booking.scheduled_at.strftime("%b %-d, %Y") %></div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="display text-[14px] text-ink leading-none">$<%= number_with_precision(booking.total_price, precision: 0) %></div>
                    <div class="flex items-center gap-2 mt-1 justify-end flex-wrap">
                      <% if booking.status == 'completed' && !booking.review %>
                        <%= link_to new_booking_review_path(booking), class: "font-mono text-[9px] uppercase tracking-[0.1em] text-forest hover:text-forest/80" do %>review<% end %>
                      <% elsif booking.review %>
                        <span class="font-mono text-[9px] uppercase tracking-[0.1em] text-forest"><i class="fas fa-check mr-0.5"></i>reviewed</span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-[13px] text-ink-3 text-center py-3">No booking history yet.</p>
          <% end %>
        </div>
      </aside>
    </div>
  </div>
</div>
