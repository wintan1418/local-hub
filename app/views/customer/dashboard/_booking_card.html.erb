<div class="bg-cream-elevated border border-line rounded-xl p-5">
  <div class="flex items-start justify-between gap-2 mb-2">
    <div class="display text-[16px] text-ink leading-[1.15] truncate"><%= booking.service.title %></div>
    <% sc = { "pending" => [ "bg-amber-100/60", "text-amber-800" ], "confirmed" => [ "bg-forest-soft", "text-forest" ], "completed" => [ "bg-cream-sunken", "text-ink-2" ], "cancelled" => [ "bg-rose-100/60", "text-rose-700" ] } %>
    <% c = sc[booking.status] || [ "bg-cream-sunken", "text-ink-2" ] %>
    <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %> flex-shrink-0"><%= booking.status %></span>
  </div>
  <div class="font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3 mb-3">
    <%= booking.scheduled_at.strftime('%a, %b %-d · %-I:%M %p') %>
  </div>
  <div class="display text-[20px] text-ink leading-none mb-4">$<%= number_with_precision(booking.total_price, precision: 2) %></div>
  <div class="flex items-center gap-2">
    <%= link_to "View service", service_path(booking.service), class: "inline-flex items-center gap-2 px-4 py-2 rounded-pill text-[12px] font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors" %>
    <% if booking.scheduled_at.future? %>
      <%= button_to "Cancel", booking_path(booking), method: :delete, data: { turbo_confirm: "Cancel this booking?" }, class: "inline-flex items-center gap-2 px-4 py-2 rounded-pill text-[12px] font-medium border border-rose-300 text-rose-700 hover:bg-rose-50 cursor-pointer transition-colors" %>
    <% end %>
  </div>
</div>
