<div class="min-h-screen bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Hero card — terracotta on cream %>
    <div class="relative overflow-hidden rounded-[20px] p-8 sm:p-12 mb-10" style="background-color: #d96a3a;">
      <div class="absolute -top-4 -right-4 opacity-15"><i class="fas fa-gift text-cream text-[200px]"></i></div>
      <div class="relative">
        <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/70 mb-3">gift cards</div>
        <h1 class="display text-cream leading-[1] tracking-[-0.02em]" style="font-size: clamp(36px, 5vw, 56px);">
          Give the gift of <em class="italic-wonk" style="color: #fdf8ed;">good</em> service.
        </h1>
        <p class="mt-4 text-cream/85 max-w-md text-[15px] leading-[1.55]">Perfect for birthdays, holidays, or thanking someone. $25 to $500.</p>
        <%= link_to new_gift_card_path, class: "mt-6 inline-flex items-center gap-2 px-6 py-3 bg-cream-elevated text-ink hover:bg-cream-sunken rounded-pill font-semibold text-sm transition-colors active:translate-y-px" do %>
          <i class="fas fa-plus text-[10px]"></i>Buy a gift card
        <% end %>
      </div>
    </div>

    <%# Amount options %>
    <div class="mb-10">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">denominations</div>
      <div class="grid grid-cols-5 gap-3">
        <% @available_amounts.each do |amt| %>
          <%= link_to new_gift_card_path(amount: amt), class: "block p-5 rounded-xl bg-cream-elevated border border-line hover:shadow-card-md hover:-translate-y-0.5 transition-all duration-200 text-center" do %>
            <div class="display text-[28px] sm:text-[32px] text-ink leading-none">$<%= amt %></div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# My gift cards %>
    <% if @my_cards.any? %>
      <div>
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">your gift cards</div>
        <h2 class="display text-[22px] text-ink leading-[1.1] mb-4">Cards you've sent</h2>
        <div class="space-y-2">
          <% @my_cards.each do |card| %>
            <%= link_to gift_card_path(card), class: "block bg-cream-elevated rounded-xl border border-line p-5 hover:shadow-card-md transition-all" do %>
              <div class="flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 mb-1"><%= card.code %></div>
                  <div class="display text-[16px] text-ink leading-[1.15] truncate">To: <%= card.recipient_name.presence || card.recipient_email.presence || "Unassigned" %></div>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="display text-[24px] text-ink leading-none">$<%= number_with_precision(card.balance, precision: 2) %></div>
                  <% sc = { "active" => "text-forest", "redeemed" => "text-ink-3", "expired" => "text-rose-700", "cancelled" => "text-rose-700", "pending" => "text-amber-700" } %>
                  <div class="font-mono text-[10px] uppercase tracking-[0.08em] mt-1 <%= sc[card.status] || 'text-ink-3' %>"><%= card.status %></div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
