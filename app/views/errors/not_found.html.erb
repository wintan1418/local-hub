<div class="min-h-screen flex items-center justify-center bg-cream px-4">
  <div class="text-center max-w-md">
    <div class="display italic-wonk text-[120px] leading-none mb-4" style="color: #1f4d3a; font-style: italic;">404</div>
    <div class="eyebrow mb-2">page not found</div>
    <h1 class="display text-[28px] sm:text-[32px] text-ink leading-[1.1] tracking-[-0.02em]">Nothing <em class="italic-wonk" style="color: #1f4d3a;">here</em>.</h1>
    <p class="mt-3 text-[14px] text-ink-2">The page you're looking for doesn't exist or has been moved.</p>
    <%= link_to root_path, class: "mt-6 inline-flex items-center gap-2 bg-ink hover:bg-ink-2 text-cream px-6 py-3 rounded-pill text-sm font-semibold transition-colors active:translate-y-px" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back home
    <% end %>
  </div>
</div>
