<div class="min-h-screen flex items-center justify-center bg-cream py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-ink">
        Reset your password
      </h2>
      <p class="mt-2 text-center text-sm text-ink-2">
        Enter your email address and we'll send you a link to reset your password.
      </p>
    </div>
    
    <%= form_with url: password_resets_path, method: :post, local: true, class: "mt-8 space-y-4" do |form| %>
      <div>
        <%= form.label :email, "Email address", class: "sr-only" %>
        <%= form.email_field :email,
              autocomplete: "email",
              required: true,
              placeholder: "Email address",
              class: "w-full px-3 py-2.5 text-sm rounded-pill border border-line focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
      </div>

      <div>
        <%= form.submit "Send reset instructions",
              class: "w-full py-2.5 px-4 bg-ink hover:bg-ink-2 text-white rounded-pill text-sm font-semibold cursor-pointer transition-colors" %>
      </div>

      <div class="text-center">
        <%= link_to "Back to sign in", new_user_session_path, class: "text-orange-600 hover:text-orange-500" %>
      </div>
    <% end %>
  </div>
</div>