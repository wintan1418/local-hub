<div class="min-h-screen bg-cream">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to booking_path(@booking), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to booking
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3 text-rose-700"><i class="fas fa-exclamation-triangle mr-1 text-[10px]"></i>dispute</div>
      <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Something <em class="italic-wonk" style="color: #b8551c;">wrong</em>?</h1>
      <p class="mt-2 text-[14px] text-ink-2 leading-[1.55]">Submit a dispute and our team will review within 24 hours.</p>
    </div>

    <%# Booking summary %>
    <div class="bg-cream-sunken/40 border border-line rounded-xl p-4 mb-5 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-cream-elevated border border-line flex items-center justify-center">
        <i class="fas fa-calendar text-ink-3 text-[12px]"></i>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-[14px] font-semibold text-ink truncate"><%= @booking.service.title %></div>
        <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= @booking.scheduled_at.strftime("%b %-d, %Y") %> · $<%= number_with_precision(@booking.total_price, precision: 2) %></div>
      </div>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
      <%= form_with(model: [ @booking, @dispute ], url: booking_dispute_path(@booking), local: true, class: "space-y-6") do |f| %>
        <% if @dispute.errors.any? %>
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-200">
            <ul class="text-[13px] text-rose-700 space-y-0.5 ml-5">
              <% @dispute.errors.full_messages.each do |msg| %><li class="list-disc"><%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2 block">What's the issue?</label>
          <div class="grid sm:grid-cols-2 gap-2">
            <% Dispute::REASONS.each do |reason| %>
              <label class="cursor-pointer">
                <input type="radio" name="dispute[reason]" value="<%= reason %>" class="peer sr-only" required>
                <div class="px-3 py-3 rounded-lg border border-line bg-cream-elevated peer-checked:border-rose-500 peer-checked:bg-rose-50 transition-all">
                  <span class="text-[13px] font-medium text-ink"><%= reason %></span>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Tell us what happened</label>
          <%= f.text_area :description, rows: 6, placeholder: "Please provide as much detail as possible. Include dates, conversations, and any evidence.",
              class: "w-full px-4 py-3 rounded-2xl border border-line text-ink focus:outline-none focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 bg-cream-elevated text-sm resize-none" %>
          <p class="text-[11px] text-ink-3 mt-1.5"><i class="fas fa-info-circle mr-1"></i>The more detail, the faster we can resolve.</p>
        </div>

        <div class="p-4 rounded-xl bg-amber-100/50 border border-amber-200 flex gap-3">
          <i class="fas fa-info-circle text-amber-700 mt-0.5"></i>
          <div class="text-[12px] text-ink-2 leading-[1.55]">
            <strong>Before submitting:</strong> Try to resolve directly with the provider first through chat. Most issues resolve quickly without a formal dispute.
          </div>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-line">
          <%= link_to "Cancel", booking_path(@booking), class: "font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" %>
          <button type="submit" class="bg-rose-700 hover:bg-rose-800 text-cream px-7 py-3 rounded-pill text-sm font-semibold cursor-pointer transition-colors active:translate-y-px">
            Submit dispute
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
