<div class="min-h-screen bg-slate-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%= link_to booking_path(@booking), class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 mb-6 group" do %>
      <i class="fas fa-arrow-left text-xs group-hover:-translate-x-1 transition-transform"></i>
      Back to booking
    <% end %>

    <div class="mb-8">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-50 border border-red-100 text-red-600 text-xs font-bold uppercase tracking-wider mb-4">
        <i class="fas fa-exclamation-triangle text-[10px]"></i>Dispute
      </div>
      <h1 class="text-2xl sm:text-3xl font-black text-slate-900">Open a Dispute</h1>
      <p class="mt-2 text-slate-500">Something went wrong? We're here to help. Submit a dispute and our team will review within 24 hours.</p>
    </div>

    <%# Booking summary %>
    <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 mb-6 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-white border border-slate-200 flex items-center justify-center">
        <i class="fas fa-calendar text-slate-400"></i>
      </div>
      <div class="flex-1">
        <div class="text-sm font-bold text-slate-900"><%= @booking.service.title %></div>
        <div class="text-xs text-slate-400"><%= @booking.scheduled_at.strftime("%B %d, %Y") %> · $<%= number_with_precision(@booking.total_price, precision: 2) %></div>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-lg p-6 sm:p-8">
      <%= form_with(model: [@booking, @dispute], url: booking_dispute_path(@booking), local: true) do |f| %>
        <% if @dispute.errors.any? %>
          <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200">
            <ul class="text-sm text-red-700 space-y-0.5">
              <% @dispute.errors.full_messages.each do |msg| %><li>• <%= msg %></li><% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-6">
          <div>
            <label class="block text-sm font-bold text-slate-900 mb-3">What's the issue? <span class="text-red-500">*</span></label>
            <div class="grid sm:grid-cols-2 gap-2">
              <% Dispute::REASONS.each do |reason| %>
                <label class="relative cursor-pointer">
                  <input type="radio" name="dispute[reason]" value="<%= reason %>" class="peer absolute opacity-0" required>
                  <div class="flex items-center gap-2.5 px-3 py-3 rounded-xl border-2 border-slate-100 hover:border-slate-200 peer-checked:border-red-500 peer-checked:bg-red-50 transition-all">
                    <span class="text-sm font-semibold text-slate-700 peer-checked:text-red-700"><%= reason %></span>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-900 mb-2">Tell us what happened <span class="text-red-500">*</span></label>
            <%= f.text_area :description, rows: 6, placeholder: "Please provide as much detail as possible. Include dates, conversations, and any evidence.",
                class: "w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-red-500/10 focus:border-red-500 transition-all resize-none" %>
            <p class="mt-1.5 text-xs text-slate-400"><i class="fas fa-info-circle mr-1"></i>The more detail you share, the faster we can resolve this.</p>
          </div>

          <div class="p-4 rounded-xl bg-amber-50 border border-amber-100 flex gap-3">
            <i class="fas fa-info-circle text-amber-600 mt-0.5"></i>
            <div class="text-xs text-amber-800">
              <strong>Before submitting:</strong> Try to resolve the issue directly with the provider first through chat. Most issues are resolved quickly without needing a formal dispute.
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
          <%= link_to "Cancel", booking_path(@booking), class: "text-sm font-semibold text-slate-500 hover:text-slate-700" %>
          <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-8 py-3 rounded-xl font-bold text-sm transition-all cursor-pointer">
            Submit Dispute
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
