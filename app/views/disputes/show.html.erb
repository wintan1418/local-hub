<div class="min-h-screen bg-cream">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to booking_path(@booking), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to booking
    <% end %>

    <% sc = {
      "open" => [ "bg-amber-100/60", "text-amber-800" ],
      "under_review" => [ "bg-cream-sunken", "text-ink-2" ],
      "resolved" => [ "bg-forest-soft", "text-forest" ],
      "dismissed" => [ "bg-cream-sunken", "text-ink-3" ],
      "refunded" => [ "bg-terracotta/15", "text-terracotta" ]
    } %>
    <% c = sc[@dispute.status] || [ "bg-cream-sunken", "text-ink-3" ] %>

    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
      <div class="p-6 sm:p-8 border-b border-line">
        <div class="flex items-start justify-between mb-4 flex-wrap gap-2">
          <div>
            <div class="eyebrow mb-2">dispute · #<%= @dispute.id %></div>
            <h1 class="display text-[24px] sm:text-[28px] text-ink leading-[1.1]">Opened <%= time_ago_in_words(@dispute.created_at) %> ago</h1>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-1">by <%= @dispute.raised_by.display_name %></p>
          </div>
          <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-3 py-1.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= @dispute.status %></span>
        </div>

        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-pill bg-cream-sunken/50 border border-line mb-4">
          <i class="fas fa-tag text-ink-3 text-[10px]"></i>
          <span class="text-[13px] font-semibold text-ink"><%= @dispute.reason %></span>
        </div>

        <p class="text-[14px] text-ink-2 leading-[1.65] whitespace-pre-line"><%= @dispute.description %></p>
      </div>

      <% if @dispute.resolution.present? %>
        <div class="p-6 sm:p-8 <%= c[0] %> border-b border-line">
          <div class="flex items-start gap-3">
            <i class="fas fa-gavel <%= c[1] %> mt-1"></i>
            <div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] <%= c[1] %> mb-2">resolution</div>
              <p class="text-[14px] text-ink-2 leading-[1.6]"><%= @dispute.resolution %></p>
              <% if @dispute.refund_amount.present? && @dispute.refund_amount > 0 %>
                <div class="display text-[20px] <%= c[1] %> mt-3">Refund: $<%= number_with_precision(@dispute.refund_amount, precision: 2) %></div>
              <% end %>
              <% if @dispute.resolved_at %>
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-2"><%= time_ago_in_words(@dispute.resolved_at) %> ago</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="p-6 sm:p-8 bg-cream-sunken/40">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">related booking</div>
        <%= link_to booking_path(@booking), class: "flex items-center justify-between p-3 rounded-lg bg-cream-elevated border border-line hover:border-line-strong transition-colors" do %>
          <div>
            <div class="text-[14px] font-semibold text-ink"><%= @booking.service.title %></div>
            <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= @booking.scheduled_at.strftime("%b %-d, %Y") %> · $<%= @booking.total_price %></div>
          </div>
          <i class="fas fa-arrow-right text-ink-3 text-[12px]"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>
