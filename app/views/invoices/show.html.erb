<div class="min-h-screen bg-cream py-10 sm:py-14">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-end mb-4 print:hidden">
      <button onclick="window.print()" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill text-sm font-medium border border-line text-ink-2 hover:bg-cream-sunken transition-colors">
        <i class="fas fa-print text-[10px]"></i>Print / Save PDF
      </button>
    </div>

    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden" id="invoice">
      <%# Header — ink %>
      <div class="px-7 sm:px-8 py-7 flex items-start justify-between" style="background-color: #1d1813;">
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <span class="brand-mark brand-mark--on-dark"></span>
            <span class="font-display text-[20px] font-medium tracking-tight text-cream">radius</span>
          </div>
          <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-cream/55">invoice</p>
        </div>
        <div class="text-right">
          <div class="display text-[20px] text-cream"><%= @invoice.invoice_number %></div>
          <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-cream/55 mt-1">issued <%= @invoice.issued_at&.strftime("%b %-d, %Y") %></div>
          <% sc = { "issued" => "bg-amber-100/20 text-amber-300", "paid" => "bg-forest/30 text-cream", "overdue" => "bg-rose-500/20 text-rose-300", "cancelled" => "bg-cream/10 text-cream/55" } %>
          <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2.5 py-0.5 rounded-pill mt-2 <%= sc[@invoice.status] || 'bg-cream/10 text-cream/55' %>"><%= @invoice.status %></span>
        </div>
      </div>

      <%# Parties %>
      <div class="grid sm:grid-cols-2 gap-6 px-7 sm:px-8 py-6 border-b border-line">
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">from</div>
          <div class="text-[14px] font-semibold text-ink"><%= @booking.service.provider.business_name || @booking.service.provider.display_name %></div>
          <div class="font-mono text-[11px] text-ink-3 mt-0.5"><%= @booking.service.provider.email %></div>
          <% if @booking.service.provider.phone.present? %>
            <div class="font-mono text-[11px] text-ink-3"><%= @booking.service.provider.phone %></div>
          <% end %>
        </div>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">bill to</div>
          <div class="text-[14px] font-semibold text-ink"><%= @booking.customer.display_name %></div>
          <div class="font-mono text-[11px] text-ink-3 mt-0.5"><%= @booking.customer.email %></div>
        </div>
      </div>

      <%# Service line %>
      <div class="px-7 sm:px-8 py-6 border-b border-line">
        <table class="w-full">
          <thead>
            <tr class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">
              <th class="text-left pb-3 font-medium">Service</th>
              <th class="text-left pb-3 font-medium">Date</th>
              <th class="text-right pb-3 font-medium">Amount</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="py-3">
                <div class="text-[14px] font-semibold text-ink"><%= @booking.service.title %></div>
                <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= @booking.service.category.name %></div>
              </td>
              <td class="py-3 text-[13px] text-ink-2"><%= @booking.scheduled_at.strftime("%b %-d, %Y") %></td>
              <td class="py-3 display text-[16px] text-ink leading-none text-right">$<%= number_with_precision(@invoice.amount, precision: 2) %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <%# Total %>
      <div class="px-7 sm:px-8 py-6 bg-cream-sunken/40">
        <div class="flex items-center justify-between">
          <div>
            <div class="text-[14px] text-ink-2">Subtotal</div>
            <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 mt-1">platform fee · $0.00</div>
          </div>
          <div class="text-right">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">total due</div>
            <div class="display text-[36px] sm:text-[40px] text-ink leading-none">$<%= number_with_precision(@invoice.amount, precision: 2) %></div>
          </div>
        </div>

        <% if @invoice.paid? %>
          <div class="mt-4 flex items-center gap-2 text-forest">
            <i class="fas fa-check-circle"></i>
            <span class="text-[14px] font-semibold">Paid<%= @invoice.paid_at.present? ? " on #{@invoice.paid_at.strftime('%b %-d, %Y')}" : "" %></span>
          </div>
        <% end %>
      </div>

      <div class="px-7 sm:px-8 py-4 text-center border-t border-line">
        <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">thank you for using radius · support@radiusapp.com</p>
      </div>
    </div>
  </div>
</div>

<style>
  @media print {
    body * { visibility: hidden; }
    #invoice, #invoice * { visibility: visible; }
    #invoice { position: absolute; left: 0; top: 0; width: 100%; border: none; }
    .print\\:hidden { display: none !important; }
    nav, footer { display: none !important; }
  }
</style>
