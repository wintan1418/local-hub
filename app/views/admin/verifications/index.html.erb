<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">verifications</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">Review &amp; <em class="italic-wonk" style="color: #1f4d3a;">approve</em>.</h1>
      </div>
      <%= link_to admin_dashboard_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>Dashboard
      <% end %>
    </div>

    <%# Stats %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-line">
        <% [
          { label: "Pending review", value: @pending_verifications.count },
          { label: "Recently verified", value: @verified_users.count },
          { label: "Total providers", value: User.provider.count }
        ].each do |s| %>
          <div class="p-5 sm:p-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= s[:label] %></div>
            <div class="display text-[36px] text-ink leading-none mt-2"><%= s[:value] %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Pending list %>
    <div class="bg-cream-elevated border border-line rounded-xl mb-6">
      <div class="px-5 sm:px-6 py-4 border-b border-line">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">pending</div>
        <div class="display text-[18px] text-ink leading-[1.1]">Awaiting review</div>
      </div>

      <% if @pending_verifications.any? %>
        <div class="divide-y divide-line">
          <% @pending_verifications.each do |provider| %>
            <div class="px-5 sm:px-6 py-4 hover:bg-cream-sunken/40 transition-colors">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <% if provider.profile_picture.attached? %>
                    <%= image_tag provider.profile_picture, class: "h-12 w-12 rounded-full object-cover border border-line flex-shrink-0" %>
                  <% else %>
                    <div class="h-12 w-12 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[14px] font-semibold border border-line flex-shrink-0">
                      <%= "#{provider.first_name&.first}#{provider.last_name&.first}" %>
                    </div>
                  <% end %>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                      <div class="text-[14px] font-semibold text-ink"><%= provider.business_name %></div>
                      <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-amber-100/60 text-amber-800">pending</span>
                    </div>
                    <div class="text-[12px] text-ink-2"><%= provider.display_name %> · <span class="font-mono text-[11px]"><%= provider.email %></span></div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 mt-1">uploaded <%= time_ago_in_words(provider.updated_at) %> ago · <%= provider.verification_progress %>% complete</div>
                  </div>
                </div>
                <%= link_to admin_verification_path(provider), class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-pill text-[13px] font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors active:translate-y-px" do %>
                  Review <i class="fas fa-arrow-right text-[10px]"></i>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <i class="fas fa-check-circle text-forest text-2xl mb-3"></i>
          <h3 class="display text-[18px] text-ink leading-[1.1]">All caught up</h3>
          <p class="mt-1 text-[13px] text-ink-3">All submitted verifications have been processed.</p>
        </div>
      <% end %>
    </div>

    <%# Verified list %>
    <div class="bg-cream-elevated border border-line rounded-xl">
      <div class="px-5 sm:px-6 py-4 border-b border-line">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recently verified</div>
        <div class="display text-[18px] text-ink leading-[1.1]">Latest approvals</div>
      </div>

      <% if @verified_users.any? %>
        <div class="divide-y divide-line">
          <% @verified_users.each do |provider| %>
            <div class="px-5 sm:px-6 py-4">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <% if provider.profile_picture.attached? %>
                    <%= image_tag provider.profile_picture, class: "h-10 w-10 rounded-full object-cover border border-line flex-shrink-0" %>
                  <% else %>
                    <div class="h-10 w-10 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[12px] font-semibold border border-line flex-shrink-0">
                      <%= "#{provider.first_name&.first}#{provider.last_name&.first}" %>
                    </div>
                  <% end %>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                      <div class="text-[14px] font-semibold text-ink truncate"><%= provider.business_name %></div>
                      <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-forest-soft text-forest"><i class="fas fa-check text-[8px] mr-0.5"></i>verified</span>
                    </div>
                    <div class="text-[12px] text-ink-3 truncate"><%= provider.display_name %></div>
                  </div>
                </div>
                <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 whitespace-nowrap">
                  <% if provider.verified_at %>verified <%= time_ago_in_words(provider.verified_at) %> ago<% else %>recently<% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-[13px] text-ink-3">No recently verified providers</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
