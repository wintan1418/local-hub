<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%= link_to admin_verifications_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to verifications
    <% end %>

    <div class="mb-8">
      <div class="eyebrow mb-3">review · provider #<%= @provider.id %></div>
      <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]"><%= @provider.business_name %></h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <%# Provider info %>
      <aside class="lg:col-span-1">
        <div class="bg-cream-elevated border border-line rounded-xl p-5 lg:sticky lg:top-24">
          <div class="flex items-center mb-5">
            <% if @provider.profile_picture.attached? %>
              <%= image_tag @provider.profile_picture, class: "h-14 w-14 rounded-full object-cover border border-line" %>
            <% else %>
              <div class="h-14 w-14 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[16px] font-semibold border border-line">
                <%= "#{@provider.first_name&.first}#{@provider.last_name&.first}" %>
              </div>
            <% end %>
            <div class="ml-3 min-w-0">
              <div class="text-[14px] font-semibold text-ink truncate"><%= @provider.display_name %></div>
              <div class="font-mono text-[10px] text-ink-3 truncate"><%= @provider.email %></div>
            </div>
          </div>

          <div class="space-y-3 text-[13px] border-t border-line pt-4">
            <% [
              [ "Business", @provider.business_name ],
              [ "Phone", @provider.phone ],
              [ "Address", @provider.complete_address ],
              [ "Experience", "#{@provider.years_experience} years" ],
              [ "Services", "#{@provider.services.count}" ]
            ].each do |label, value| %>
              <div>
                <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"><%= label %></div>
                <div class="text-ink mt-0.5"><%= value.presence || "—" %></div>
              </div>
            <% end %>
            <div>
              <div class="flex justify-between font-mono text-[10px] uppercase tracking-[0.12em] mb-1.5">
                <span class="text-ink-3">progress</span>
                <span class="text-ink"><%= @provider.verification_progress %>%</span>
              </div>
              <div class="w-full bg-cream-sunken rounded-pill h-1.5 overflow-hidden">
                <div class="h-full rounded-pill" style="width: <%= @provider.verification_progress %>%; background-color: #1f4d3a;"></div>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <%# Documents review %>
      <div class="lg:col-span-2 space-y-3">
        <% [
          { field: :business_license_file, title: "Business license", note: "Valid business registration or license" },
          { field: :insurance_certificate_file, title: "Insurance certificate", note: "Liability insurance coverage" },
          { field: :professional_certifications_file, title: "Professional certifications", note: "Trade licenses and credentials" },
          { field: :government_id_file, title: "Government ID", note: "Valid government-issued photo ID" }
        ].each do |doc| %>
          <% file = @provider.send(doc[:field]) %>
          <% uploaded = file.attached? %>
          <div class="rounded-xl p-5 border <%= uploaded ? 'bg-forest-soft border-forest/20' : 'bg-rose-50 border-rose-200' %>">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <h4 class="display text-[18px] text-ink leading-[1.15]"><%= doc[:title] %></h4>
                  <% if uploaded %>
                    <i class="fas fa-check-circle text-forest text-[12px]"></i>
                  <% else %>
                    <i class="fas fa-times-circle text-rose-700 text-[12px]"></i>
                  <% end %>
                </div>
                <p class="text-[12px] text-ink-3"><%= doc[:note] %></p>
              </div>
            </div>
            <% if uploaded %>
              <div class="bg-cream-elevated border border-line rounded-lg p-3 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <i class="fas fa-file-alt text-ink-3 text-[14px]"></i>
                  <div class="min-w-0">
                    <div class="text-[13px] font-medium text-ink truncate"><%= file.filename %></div>
                    <div class="font-mono text-[10px] text-ink-3"><%= number_to_human_size(file.byte_size) %></div>
                  </div>
                </div>
                <%= link_to "Download", rails_blob_path(file, disposition: "attachment"), target: "_blank",
                    class: "font-mono text-[10px] uppercase tracking-[0.1em] text-ink hover:text-ink-2 whitespace-nowrap" %>
              </div>
            <% else %>
              <p class="text-[13px] text-rose-700 font-medium">Not uploaded</p>
            <% end %>
          </div>
        <% end %>

        <%# Action buttons %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="flex flex-col sm:flex-row sm:justify-end gap-2">
            <%= button_to "Reject verification", reject_admin_verification_path(@provider),
                data: { turbo_method: :patch, turbo_confirm: "Are you sure? This will reset all uploaded documents." },
                params: { reset_documents: true, rejection_reason: "Please re-upload clearer documents" },
                class: "inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold border border-rose-300 text-rose-700 bg-cream-elevated hover:bg-rose-50 transition-colors cursor-pointer" %>

            <% if @provider.verification_documents_uploaded? %>
              <%= button_to "Approve verification", approve_admin_verification_path(@provider),
                  data: { turbo_method: :patch, turbo_confirm: "Approve this provider for verification?" },
                  class: "inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-forest hover:opacity-90 text-cream transition-opacity cursor-pointer active:translate-y-px" %>
            <% else %>
              <button disabled class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-cream-sunken text-ink-3 cursor-not-allowed">
                Approve verification
              </button>
            <% end %>
          </div>

          <% unless @provider.verification_documents_uploaded? %>
            <p class="text-[12px] text-rose-700 mt-3 text-right">All required documents must be uploaded before approval</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
