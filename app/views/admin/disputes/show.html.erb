<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to admin_disputes_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-[10px]"></i>Back to disputes
    <% end %>

    <%# Header %>
    <div class="mb-6">
      <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
        <div>
          <div class="eyebrow mb-2">dispute · #<%= @dispute.id %></div>
          <h1 class="display text-[32px] sm:text-[40px] text-ink leading-[1] tracking-[-0.02em]"><%= @dispute.reason %></h1>
        </div>
        <% sc = {
          "open" => [ "bg-amber-100/60", "text-amber-800" ],
          "under_review" => [ "bg-cream-sunken", "text-ink-2" ],
          "resolved" => [ "bg-forest-soft", "text-forest" ],
          "dismissed" => [ "bg-cream-sunken", "text-ink-3" ],
          "refunded" => [ "bg-terracotta/15", "text-terracotta" ]
        } %>
        <% c = sc[@dispute.status] || [ "bg-cream-sunken", "text-ink-3" ] %>
        <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-3 py-1.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= @dispute.status %></span>
      </div>
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3">Raised by <%= @dispute.raised_by.display_name %> · <%= time_ago_in_words(@dispute.created_at) %> ago</p>
    </div>

    <%# Description card %>
    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden mb-6">
      <div class="p-5 sm:p-6 border-b border-line">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">description</div>
        <p class="text-[14px] text-ink-2 leading-[1.65] whitespace-pre-line"><%= @dispute.description %></p>
      </div>

      <div class="p-5 sm:p-6 bg-cream-sunken/40">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-2">booking</div>
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <div class="text-[14px] font-semibold text-ink truncate"><%= @dispute.booking.service.title %></div>
            <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 truncate"><%= @dispute.booking.customer.display_name %> → <%= @dispute.booking.service.provider.display_name %> · $<%= @dispute.booking.total_price %></div>
          </div>
          <%= link_to "View booking →", booking_path(@dispute.booking), class: "font-mono text-[10px] uppercase tracking-[0.1em] text-ink hover:text-ink-2 whitespace-nowrap" %>
        </div>
      </div>
    </div>

    <%# Action panels %>
    <% unless @dispute.resolved? || @dispute.dismissed? || @dispute.refunded? %>
      <div class="bg-cream-elevated border border-line rounded-xl p-5 sm:p-6">
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">actions</div>
        <h2 class="display text-[18px] text-ink leading-[1.1] mb-4">Take action</h2>

        <%# Resolve %>
        <details class="mb-2 group">
          <summary class="cursor-pointer flex items-center justify-between p-4 rounded-lg border border-forest/30 bg-forest-soft hover:bg-forest/15 transition-colors">
            <span class="text-[13px] font-semibold text-forest"><i class="fas fa-check mr-2 text-[11px]"></i>Resolve (no refund)</span>
            <i class="fas fa-chevron-down text-forest text-[11px] group-open:rotate-180 transition-transform"></i>
          </summary>
          <%= form_with url: resolve_admin_dispute_path(@dispute), method: :patch, local: true, class: "p-4 border border-t-0 border-forest/30 rounded-b-lg -mt-1 bg-forest-soft/50" do |f| %>
            <%= f.text_area :resolution, rows: 3, placeholder: "Resolution notes (visible to customer and provider)…",
                class: "w-full px-3 py-2.5 rounded-lg border border-line text-ink focus:outline-none focus:ring-2 focus:ring-forest/30 focus:border-forest bg-cream-elevated text-sm resize-none" %>
            <button type="submit" class="mt-3 bg-forest hover:opacity-90 text-cream px-5 py-2 rounded-pill text-[13px] font-semibold cursor-pointer transition-opacity">Mark resolved</button>
          <% end %>
        </details>

        <%# Refund %>
        <details class="mb-2 group">
          <summary class="cursor-pointer flex items-center justify-between p-4 rounded-lg border border-terracotta/30 bg-terracotta/10 hover:bg-terracotta/15 transition-colors">
            <span class="text-[13px] font-semibold text-terracotta"><i class="fas fa-undo mr-2 text-[11px]"></i>Refund customer</span>
            <i class="fas fa-chevron-down text-terracotta text-[11px] group-open:rotate-180 transition-transform"></i>
          </summary>
          <%= form_with url: refund_admin_dispute_path(@dispute), method: :patch, local: true, class: "p-4 border border-t-0 border-terracotta/30 rounded-b-lg -mt-1 bg-terracotta/[0.05]" do |f| %>
            <div class="mb-3">
              <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-terracotta mb-1.5 block">Refund amount ($)</label>
              <%= f.number_field :refund_amount, step: 0.01, value: @dispute.booking.total_price,
                  class: "w-full px-3 py-2.5 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta bg-cream-elevated text-sm" %>
              <p class="text-[11px] text-ink-3 mt-1">Max: $<%= @dispute.booking.total_price %> (full booking amount)</p>
            </div>
            <%= f.text_area :resolution, rows: 3, placeholder: "Why are you refunding?",
                class: "w-full px-3 py-2.5 rounded-lg border border-line text-ink focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta bg-cream-elevated text-sm resize-none" %>
            <button type="submit" class="mt-3 bg-terracotta hover:opacity-90 text-cream px-5 py-2 rounded-pill text-[13px] font-semibold cursor-pointer transition-opacity">Process refund</button>
          <% end %>
        </details>

        <%# Dismiss %>
        <details class="group">
          <summary class="cursor-pointer flex items-center justify-between p-4 rounded-lg border border-line bg-cream-sunken/40 hover:bg-cream-sunken transition-colors">
            <span class="text-[13px] font-semibold text-ink-2"><i class="fas fa-times mr-2 text-[11px]"></i>Dismiss (no action)</span>
            <i class="fas fa-chevron-down text-ink-3 text-[11px] group-open:rotate-180 transition-transform"></i>
          </summary>
          <%= form_with url: dismiss_admin_dispute_path(@dispute), method: :patch, local: true, class: "p-4 border border-t-0 border-line rounded-b-lg -mt-1 bg-cream-sunken/30" do |f| %>
            <%= f.text_area :resolution, rows: 3, placeholder: "Why dismiss?",
                class: "w-full px-3 py-2.5 rounded-lg border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm resize-none" %>
            <button type="submit" class="mt-3 bg-ink hover:bg-ink-2 text-cream px-5 py-2 rounded-pill text-[13px] font-semibold cursor-pointer transition-colors">Dismiss</button>
          <% end %>
        </details>
      </div>
    <% else %>
      <% bg_map = { "resolved" => [ "bg-forest-soft", "border-forest/20", "text-forest" ], "dismissed" => [ "bg-cream-sunken", "border-line", "text-ink-2" ], "refunded" => [ "bg-terracotta/10", "border-terracotta/30", "text-terracotta" ] } %>
      <% c = bg_map[@dispute.status] || [ "bg-cream-sunken", "border-line", "text-ink-2" ] %>
      <div class="<%= c[0] %> rounded-xl border <%= c[1] %> p-6">
        <div class="flex items-start gap-3">
          <i class="fas fa-gavel <%= c[2] %> mt-1"></i>
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] <%= c[2] %> mb-1">resolution</div>
            <p class="text-[14px] text-ink-2 leading-[1.55]"><%= @dispute.resolution %></p>
            <% if @dispute.refund_amount.present? && @dispute.refund_amount > 0 %>
              <p class="display text-[18px] <%= c[2] %> mt-3">Refunded: $<%= number_with_precision(@dispute.refund_amount, precision: 2) %></p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
