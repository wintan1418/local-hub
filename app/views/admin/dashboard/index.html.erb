<div class="min-h-screen bg-cream">
  <%# ===== INK HEADER ===== %>
  <div class="border-b border-line" style="background-color: #1d1813;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/55 mb-3">admin · <%= Date.current.strftime("%B %-d, %Y") %></div>
          <h1 class="display text-cream leading-[1] tracking-[-0.02em]" style="font-size: clamp(36px, 5vw, 56px);">Platform <em class="italic-wonk" style="color: #d96a3a;">overview</em>.</h1>
        </div>
        <%= link_to admin_categories_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-medium border border-cream/20 text-cream/85 hover:border-cream/40 hover:text-cream transition-colors" do %>
          <i class="fas fa-plus text-[10px]"></i>Add category
        <% end %>
      </div>

      <%# Stat row inside ink header %>
      <div class="mt-8 grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-cream/10 border border-cream/10 rounded-xl overflow-hidden">
        <% [
          { label: "Total users", value: number_with_delimiter(@total_users), sub: "+#{@new_users_this_month} this month" },
          { label: "Revenue", value: "$#{number_with_delimiter(@total_revenue)}", sub: "$#{number_with_delimiter(@this_month_revenue)} this month" },
          { label: "Bookings", value: number_with_delimiter(@total_bookings), sub: "#{@pending_bookings} pending" },
          { label: "Rating", value: "#{@avg_platform_rating}★", sub: "#{@total_reviews} reviews" }
        ].each do |stat| %>
          <div class="p-5 sm:p-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-cream/55"><%= stat[:label] %></div>
            <div class="display text-[28px] sm:text-[36px] text-cream leading-none mt-2 truncate"><%= stat[:value] %></div>
            <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-cream/55 mt-2 truncate"><%= stat[:sub] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <%# Quick actions %>
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-2 sm:gap-3 mb-8">
      <% [
        { name: "Users", icon: "fa-users", path: admin_users_path },
        { name: "Services", icon: "fa-concierge-bell", path: admin_services_path },
        { name: "Categories", icon: "fa-tags", path: admin_categories_path },
        { name: "Verifications", icon: "fa-shield-alt", path: admin_verifications_path },
        { name: "Disputes", icon: "fa-gavel", path: admin_disputes_path },
        { name: "Providers", icon: "fa-user-tie", path: admin_users_path(role: 'provider') }
      ].each do |action| %>
        <%= link_to action[:path], class: "group flex flex-col items-center p-3 sm:p-4 rounded-xl bg-cream-elevated border border-line hover:shadow-card-md hover:-translate-y-0.5 transition-all" do %>
          <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-cream-sunken border border-line flex items-center justify-center mb-2">
            <i class="fas <%= action[:icon] %> text-ink-2 text-sm"></i>
          </div>
          <span class="text-[11px] sm:text-[12px] font-semibold text-ink text-center"><%= action[:name] %></span>
        <% end %>
      <% end %>
    </div>

    <%# Verification banner %>
    <% if current_user.can_manage_verifications? %>
      <% pending_verifications = User.provider.where(verified: false, business_license_document: true, insurance_certificate_document: true, professional_certifications_document: true, government_id_document: true).count %>
      <% if pending_verifications > 0 %>
        <div class="mb-8 bg-amber-100/60 border border-amber-200 rounded-xl p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div class="flex items-center gap-3">
            <i class="fas fa-clock text-amber-700 text-[18px]"></i>
            <div>
              <div class="display text-[18px] text-ink leading-[1.15]"><%= pending_verifications %> provider<%= pending_verifications == 1 ? '' : 's' %> awaiting verification</div>
              <div class="text-[12px] text-ink-2 mt-0.5">Documents uploaded and ready for review</div>
            </div>
          </div>
          <%= link_to admin_verifications_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-pill text-sm font-semibold bg-ink text-cream hover:bg-ink-2 transition-colors whitespace-nowrap active:translate-y-px" do %>
            Review now <i class="fas fa-arrow-right text-[10px]"></i>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <div class="grid lg:grid-cols-3 gap-6">

      <%# Recent bookings %>
      <div class="lg:col-span-2">
        <div class="bg-cream-elevated border border-line rounded-xl">
          <div class="px-5 sm:px-6 py-4 border-b border-line flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
            <div>
              <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">recent bookings</div>
              <div class="display text-[18px] text-ink leading-[1.1]">Latest activity</div>
            </div>
            <div class="flex gap-1.5 flex-wrap">
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-amber-100/60 text-amber-800"><%= @pending_bookings %> pending</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-forest-soft text-forest"><%= @confirmed_bookings %> confirmed</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill bg-cream-sunken text-ink-2"><%= @completed_bookings %> completed</span>
            </div>
          </div>

          <% if @recent_bookings.any? %>
            <div class="divide-y divide-line">
              <% @recent_bookings.each do |booking| %>
                <div class="px-5 sm:px-6 py-3.5 hover:bg-cream-sunken/40 transition-colors">
                  <div class="flex items-start gap-3">
                    <div class="w-9 h-9 rounded-full bg-cream-sunken border border-line flex items-center justify-center flex-shrink-0">
                      <i class="fas fa-calendar text-ink-3 text-xs"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2">
                        <div class="display text-[15px] text-ink leading-[1.15] truncate"><%= booking.service.title %></div>
                        <div class="display text-[15px] text-ink leading-none flex-shrink-0">$<%= booking.total_price %></div>
                      </div>
                      <div class="flex items-center justify-between gap-2 mt-1">
                        <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 truncate"><%= booking.customer.display_name %> → <%= booking.service.provider.display_name %> · <%= time_ago_in_words(booking.created_at) %> ago</div>
                        <% sc = { "pending" => [ "bg-amber-100/60", "text-amber-800" ], "confirmed" => [ "bg-forest-soft", "text-forest" ], "completed" => [ "bg-cream-sunken", "text-ink-2" ], "cancelled" => [ "bg-rose-100/60", "text-rose-700" ] } %>
                        <% c = sc[booking.status] || [ "bg-cream-sunken", "text-ink-2" ] %>
                        <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %> flex-shrink-0 whitespace-nowrap"><%= booking.status %></span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-8 text-center">
              <i class="fas fa-calendar-alt text-2xl text-ink-3 mb-2"></i>
              <p class="text-[13px] text-ink-3">No bookings yet.</p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Sidebar %>
      <aside class="space-y-4">

        <%# Breakdown %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-3">platform breakdown</div>
          <div class="space-y-2.5">
            <% [
              { label: "Customers", value: @total_customers },
              { label: "Providers", value: @total_providers },
              { label: "Services", value: @total_services },
              { label: "Categories", value: @total_categories },
              { label: "Reviews", value: @total_reviews }
            ].each do |item| %>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-ink-2"><%= item[:label] %></span>
                <span class="display text-[16px] text-ink leading-none"><%= number_with_delimiter(item[:value]) %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# Recent users %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="flex items-end justify-between mb-3">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">new users</div>
            <%= link_to admin_users_path, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>view all →<% end %>
          </div>
          <div class="space-y-1">
            <% @recent_users.each do |user| %>
              <%= link_to admin_user_path(user), class: "flex items-center gap-3 p-2 rounded-lg hover:bg-cream-sunken/40 transition-colors" do %>
                <div class="w-8 h-8 rounded-full bg-cream-sunken border border-line text-ink-2 flex items-center justify-center text-[11px] font-semibold">
                  <%= user.display_name.first.upcase %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] font-semibold text-ink truncate"><%= user.display_name %></div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= user.user_role&.titleize %> · <%= time_ago_in_words(user.created_at) %> ago</div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Recent services %>
        <div class="bg-cream-elevated border border-line rounded-xl p-5">
          <div class="flex items-end justify-between mb-3">
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">new services</div>
            <%= link_to admin_services_path, class: "font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 hover:text-ink" do %>view all →<% end %>
          </div>
          <div class="space-y-1">
            <% @recent_services.limit(5).each do |service| %>
              <div class="flex items-center justify-between gap-2 p-2 rounded-lg hover:bg-cream-sunken/40 transition-colors">
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] font-semibold text-ink truncate"><%= service.title %></div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3 truncate"><%= service.provider.display_name %> · <%= service.category.name %></div>
                </div>
                <span class="display text-[14px] text-ink leading-none">$<%= number_with_precision(service.base_price, precision: 0) %></span>
              </div>
            <% end %>
          </div>
        </div>
      </aside>
    </div>
  </div>
</div>
