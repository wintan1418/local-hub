<div class="min-h-screen bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="flex items-end justify-between gap-3 mb-8">
      <div>
        <div class="eyebrow mb-3">users</div>
        <h1 class="display text-[36px] sm:text-[44px] text-ink leading-[1] tracking-[-0.02em]">All <em class="italic-wonk" style="color: #1f4d3a;">users</em>.</h1>
        <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3"><%= @total_users %> total</p>
      </div>
      <%= link_to admin_dashboard_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-pill text-[13px] font-medium text-ink-2 hover:bg-cream-sunken transition-colors" do %>
        <i class="fas fa-arrow-left text-[10px]"></i>Dashboard
      <% end %>
    </div>

    <%# Role tabs %>
    <div class="flex items-center gap-1.5 mb-5 overflow-x-auto pb-1">
      <% [
        [ "All", nil, @total_users ],
        [ "Customers", "customer", @total_customers ],
        [ "Providers", "provider", @total_providers ],
        [ "Admins", "admin", @total_admins ]
      ].each do |label, role, count| %>
        <%= link_to admin_users_path(role: role, q: params[:q]),
            class: "inline-flex items-center gap-2 px-4 py-2 rounded-pill text-[13px] font-medium whitespace-nowrap transition-colors #{params[:role] == role ? 'bg-ink text-cream' : 'bg-cream-sunken/50 text-ink-2 hover:bg-cream-sunken'}" do %>
          <%= label %> <span class="font-mono text-[10px] opacity-60">(<%= count %>)</span>
        <% end %>
      <% end %>
    </div>

    <%# Search %>
    <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-6" do |f| %>
      <%= f.hidden_field :role, value: params[:role] %>
      <div class="flex gap-2">
        <div class="relative flex-1">
          <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-ink-4 text-xs"></i>
          <%= f.text_field :q, value: params[:q], placeholder: "Search by name or email…",
              class: "w-full pl-10 pr-4 py-2.5 rounded-pill border border-line text-ink focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink bg-cream-elevated text-sm" %>
        </div>
        <button type="submit" class="bg-ink text-cream px-5 py-2.5 rounded-pill text-sm font-semibold hover:bg-ink-2 transition-colors">Search</button>
      </div>
    <% end %>

    <%# Users table %>
    <div class="bg-cream-elevated border border-line rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-cream-sunken/40 border-b border-line">
            <tr>
              <th class="text-left px-5 sm:px-6 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">User</th>
              <th class="text-left px-5 sm:px-6 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Role</th>
              <th class="text-left px-5 sm:px-6 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Joined</th>
              <th class="text-left px-5 sm:px-6 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">Status</th>
              <th class="text-right px-5 sm:px-6 py-3 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            <% @users.each do |user| %>
              <tr class="hover:bg-cream-sunken/40 transition-colors">
                <td class="px-5 sm:px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[12px] font-semibold border border-line">
                      <%= user.display_name.first.upcase %>
                    </div>
                    <div class="min-w-0">
                      <div class="text-[14px] font-semibold text-ink truncate"><%= user.display_name %></div>
                      <div class="font-mono text-[10px] text-ink-3 truncate"><%= user.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-5 sm:px-6 py-4">
                  <% role_colors = { "customer" => [ "bg-cream-sunken", "text-ink-2" ], "provider" => [ "bg-forest-soft", "text-forest" ], "admin" => [ "bg-terracotta/15", "text-terracotta" ] } %>
                  <% c = role_colors[user.user_role] || [ "bg-cream-sunken", "text-ink-2" ] %>
                  <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= user.user_role %></span>
                </td>
                <td class="px-5 sm:px-6 py-4 font-mono text-[11px] text-ink-3"><%= user.created_at.strftime("%b %-d, %Y") %></td>
                <td class="px-5 sm:px-6 py-4">
                  <% if user.provider? && user.verified? %>
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-forest"><i class="fas fa-check-circle mr-0.5"></i>verified</span>
                  <% elsif user.provider? %>
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">unverified</span>
                  <% else %>
                    <span class="text-[12px] text-ink-3">—</span>
                  <% end %>
                </td>
                <td class="px-5 sm:px-6 py-4 text-right whitespace-nowrap">
                  <%= link_to admin_user_path(user), class: "font-mono text-[10px] uppercase tracking-[0.1em] text-ink hover:text-ink-2" do %>view →<% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% if @users.total_pages > 1 %>
      <div class="mt-6 flex justify-center">
        <nav class="flex items-center gap-1">
          <% if @users.prev_page %>
            <%= link_to admin_users_path(role: params[:role], q: params[:q], page: @users.prev_page), class: "w-10 h-10 rounded-pill border border-line flex items-center justify-center text-ink-3 hover:bg-cream-elevated" do %><i class="fas fa-chevron-left text-[10px]"></i><% end %>
          <% end %>
          <% (1..@users.total_pages).each do |p| %>
            <% if p == @users.current_page %>
              <span class="w-10 h-10 rounded-pill bg-ink text-cream flex items-center justify-center font-mono text-[13px]"><%= p %></span>
            <% elsif (p - @users.current_page).abs <= 2 || p == 1 || p == @users.total_pages %>
              <%= link_to admin_users_path(role: params[:role], q: params[:q], page: p), class: "w-10 h-10 rounded-pill border border-line flex items-center justify-center font-mono text-[13px] text-ink-2 hover:bg-cream-elevated" do %><%= p %><% end %>
            <% elsif (p - @users.current_page).abs == 3 %>
              <span class="w-10 h-10 flex items-center justify-center text-ink-3 font-mono">…</span>
            <% end %>
          <% end %>
          <% if @users.next_page %>
            <%= link_to admin_users_path(role: params[:role], q: params[:q], page: @users.next_page), class: "w-10 h-10 rounded-pill border border-line flex items-center justify-center text-ink-3 hover:bg-cream-elevated" do %><i class="fas fa-chevron-right text-[10px]"></i><% end %>
          <% end %>
        </nav>
      </div>
    <% end %>
  </div>
</div>
