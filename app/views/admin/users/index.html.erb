<div class="min-h-screen bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-black text-slate-900">Manage Users</h1>
        <p class="text-sm text-slate-500 mt-1"><%= @total_users %> total users</p>
      </div>
      <%= link_to admin_dashboard_path, class: "text-sm text-slate-500 hover:text-slate-700" do %>
        <i class="fas fa-arrow-left mr-1"></i> Back to Dashboard
      <% end %>
    </div>

    <%# Role filter tabs %>
    <div class="flex items-center gap-2 mb-6">
      <% [
        ["All", nil, @total_users],
        ["Customers", "customer", @total_customers],
        ["Providers", "provider", @total_providers],
        ["Admins", "admin", @total_admins]
      ].each do |label, role, count| %>
        <%= link_to admin_users_path(role: role, q: params[:q]),
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition-colors #{params[:role] == role ? 'bg-slate-900 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50'}" do %>
          <%= label %> <span class="text-xs opacity-60">(<%= count %>)</span>
        <% end %>
      <% end %>
    </div>

    <%# Search %>
    <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-6" do |f| %>
      <%= f.hidden_field :role, value: params[:role] %>
      <div class="flex gap-2">
        <div class="relative flex-1">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <i class="fas fa-search text-slate-400 text-sm"></i>
          </div>
          <%= f.text_field :q, value: params[:q], placeholder: "Search by name or email...",
              class: "w-full pl-11 pr-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
        </div>
        <button type="submit" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-800 transition-colors">Search</button>
      </div>
    <% end %>

    <%# Users table %>
    <div class="bg-white rounded-xl border border-slate-100 overflow-hidden">
      <table class="w-full">
        <thead class="bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="text-left px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">User</th>
            <th class="text-left px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Role</th>
            <th class="text-left px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Joined</th>
            <th class="text-left px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</th>
            <th class="text-right px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% @users.each do |user| %>
            <tr class="hover:bg-slate-50/50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-slate-100 to-slate-50 flex items-center justify-center text-sm font-bold text-slate-400">
                    <%= user.display_name.first.upcase %>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-slate-900"><%= user.display_name %></div>
                    <div class="text-xs text-slate-400"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <% role_colors = { "customer" => "sky", "provider" => "emerald", "admin" => "orange" } %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-<%= role_colors[user.user_role] || 'slate' %>-50 text-<%= role_colors[user.user_role] || 'slate' %>-700">
                  <%= user.user_role&.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4">
                <% if user.provider? && user.verified? %>
                  <span class="text-xs font-semibold text-emerald-600"><i class="fas fa-check-circle mr-1"></i>Verified</span>
                <% elsif user.provider? %>
                  <span class="text-xs text-slate-400">Unverified</span>
                <% else %>
                  <span class="text-xs text-slate-400">—</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to admin_user_path(user), class: "text-xs font-semibold text-orange-600 hover:text-orange-700" do %>
                  View <i class="fas fa-arrow-right ml-1"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Pagination %>
    <% if @users.total_pages > 1 %>
      <div class="mt-6 flex justify-center">
        <nav class="flex items-center gap-1">
          <% if @users.prev_page %>
            <%= link_to admin_users_path(role: params[:role], q: params[:q], page: @users.prev_page), class: "w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-slate-50" do %><i class="fas fa-chevron-left text-xs"></i><% end %>
          <% end %>
          <% (1..@users.total_pages).each do |p| %>
            <% if p == @users.current_page %>
              <span class="w-9 h-9 rounded-lg bg-slate-900 text-white flex items-center justify-center text-sm font-medium"><%= p %></span>
            <% elsif (p - @users.current_page).abs <= 2 || p == 1 || p == @users.total_pages %>
              <%= link_to admin_users_path(role: params[:role], q: params[:q], page: p), class: "w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-700 hover:bg-slate-50 text-sm" do %><%= p %><% end %>
            <% elsif (p - @users.current_page).abs == 3 %>
              <span class="w-9 h-9 flex items-center justify-center text-slate-400 text-sm">&hellip;</span>
            <% end %>
          <% end %>
          <% if @users.next_page %>
            <%= link_to admin_users_path(role: params[:role], q: params[:q], page: @users.next_page), class: "w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-slate-50" do %><i class="fas fa-chevron-right text-xs"></i><% end %>
          <% end %>
        </nav>
      </div>
    <% end %>
  </div>
</div>
