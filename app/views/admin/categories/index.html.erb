<div class="min-h-screen bg-slate-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-black text-slate-900">Manage Categories</h1>
        <p class="text-sm text-slate-500 mt-1"><%= @categories.size %> categories</p>
      </div>
      <%= link_to admin_dashboard_path, class: "text-sm text-slate-500 hover:text-slate-700" do %>
        <i class="fas fa-arrow-left mr-1"></i> Dashboard
      <% end %>
    </div>

    <%# Add category form %>
    <div class="bg-white rounded-xl border border-slate-100 p-6 mb-6">
      <h2 class="text-sm font-bold text-slate-900 mb-4">Add New Category</h2>
      <%= form_with(model: @category, url: admin_categories_path, local: true, class: "flex gap-3") do |f| %>
        <div class="flex-1">
          <%= f.text_field :name, placeholder: "Category name", required: true,
              class: "w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
        </div>
        <div class="w-48">
          <%= f.text_field :icon, placeholder: "Icon class (e.g. fas fa-wrench)",
              class: "w-full px-4 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500" %>
        </div>
        <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors whitespace-nowrap">
          <i class="fas fa-plus mr-1"></i> Add
        </button>
      <% end %>
      <% if @category.errors.any? %>
        <p class="text-sm text-red-500 mt-2"><%= @category.errors.full_messages.join(", ") %></p>
      <% end %>
    </div>

    <%# Categories list %>
    <div class="bg-white rounded-xl border border-slate-100 overflow-hidden">
      <div class="divide-y divide-slate-50">
        <% @categories.each do |category| %>
          <div class="flex items-center justify-between px-6 py-4 hover:bg-slate-50/50 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center">
                <% if category.icon.present? %>
                  <i class="<%= category.icon %> text-slate-500"></i>
                <% else %>
                  <i class="fas fa-tag text-slate-400"></i>
                <% end %>
              </div>
              <div>
                <div class="text-sm font-semibold text-slate-900"><%= category.name %></div>
                <div class="text-xs text-slate-400"><%= category.slug %> &middot; <%= category.services.count %> services</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-slate-400"><%= category.services.count %> services</span>
              <% if category.services.count == 0 %>
                <%= link_to admin_category_path(category), method: :delete, data: { confirm: "Delete #{category.name}?" },
                    class: "text-xs font-semibold text-red-500 hover:text-red-700" do %>
                  <i class="fas fa-trash"></i>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
