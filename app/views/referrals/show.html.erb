<div class="min-h-screen bg-slate-50 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-orange-200/30 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-rose-200/30 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <%# Hero card with credit balance %>
    <div class="relative overflow-hidden bg-gradient-to-br from-orange-500 via-rose-500 to-pink-500 rounded-2xl p-8 sm:p-10 mb-6 text-white shadow-xl shadow-orange-500/20">
      <div class="absolute top-0 right-0 opacity-10"><i class="fas fa-gift text-[200px]"></i></div>
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"></div>

      <div class="relative">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-xs font-bold uppercase tracking-wider mb-6">
          <i class="fas fa-gift text-[10px]"></i>Refer &amp; Earn
        </div>
        <div class="text-xs font-bold uppercase tracking-wider opacity-80 mb-2">Your Balance</div>
        <div class="text-5xl sm:text-6xl font-black tracking-tight">$<%= number_with_precision(@credit, precision: 2) %></div>
        <p class="text-sm opacity-80 mt-2">Earn $<%= Referral::CREDIT_AMOUNT.to_i %> for every friend who signs up and books.</p>
      </div>
    </div>

    <%# Referral code card %>
    <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-8 shadow-sm mb-6">
      <div class="flex items-center gap-2 mb-5">
        <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center">
          <i class="fas fa-code text-violet-500 text-sm"></i>
        </div>
        <h2 class="text-base font-bold text-slate-900">Your Referral Code</h2>
      </div>

      <div class="relative mb-5">
        <div class="flex items-center gap-2 p-2 pr-2 rounded-xl bg-gradient-to-r from-slate-50 to-white border-2 border-dashed border-slate-200">
          <code class="flex-1 pl-4 py-2 font-mono text-lg font-black text-slate-900 tracking-wide"><%= @referral_code %></code>
          <button onclick="copyText(this, '<%= @referral_code %>')" class="px-5 py-2.5 rounded-lg bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition-all flex items-center gap-2">
            <i class="fas fa-copy"></i><span>Copy</span>
          </button>
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Share Link</label>
        <div class="flex items-center gap-2">
          <div class="flex-1 relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <i class="fas fa-link text-slate-300 text-sm"></i>
            </div>
            <input type="text" readonly value="<%= @referral_url %>" onclick="this.select()" class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-slate-50/50 text-sm text-slate-600 cursor-text focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all">
          </div>
          <button onclick="copyText(this, '<%= @referral_url %>')" class="px-5 py-3 rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition-all flex items-center gap-2">
            <i class="fas fa-copy"></i><span>Copy</span>
          </button>
        </div>

        <%# Share buttons %>
        <div class="mt-4 flex flex-wrap gap-2">
          <p class="text-xs text-slate-400 w-full mb-1">Or share on:</p>
          <a href="mailto:?subject=Check out Radius&body=I've been using Radius to find local service pros. Sign up with my code <%= @referral_code %> and we both earn credit! <%= @referral_url %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 hover:bg-slate-100 text-xs font-semibold text-slate-700 transition-colors">
            <i class="fas fa-envelope text-slate-500"></i>Email
          </a>
          <a href="sms:?&body=Check out Radius — I use it to find verified local pros. Sign up with <%= @referral_code %>: <%= @referral_url %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 hover:bg-slate-100 text-xs font-semibold text-slate-700 transition-colors">
            <i class="fas fa-comment-sms text-emerald-500"></i>SMS
          </a>
          <a href="https://wa.me/?text=Check out Radius! Use my code <%= @referral_code %>: <%= CGI.escape(@referral_url) %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 hover:bg-slate-100 text-xs font-semibold text-slate-700 transition-colors">
            <i class="fab fa-whatsapp text-green-500"></i>WhatsApp
          </a>
          <a href="https://twitter.com/intent/tweet?text=Found a great service marketplace — Radius. Use my code <%= @referral_code %>: <%= CGI.escape(@referral_url) %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 hover:bg-slate-100 text-xs font-semibold text-slate-700 transition-colors">
            <i class="fab fa-x-twitter text-slate-900"></i>X
          </a>
        </div>
      </div>
    </div>

    <%# How it works — stepper %>
    <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-8 shadow-sm mb-6">
      <h2 class="text-base font-bold text-slate-900 mb-6">How it works</h2>
      <div class="relative">
        <div class="absolute left-[15px] top-4 bottom-4 w-0.5 bg-gradient-to-b from-orange-200 via-rose-200 to-emerald-200"></div>
        <div class="space-y-6">
          <% [
            { num: 1, icon: "fa-paper-plane", color: "orange", title: "Share your code", desc: "Send your unique code or link to friends via email, text, or social." },
            { num: 2, icon: "fa-user-plus", color: "rose", title: "They sign up", desc: "New users create an account using your link and become part of Radius." },
            { num: 3, icon: "fa-coins", color: "emerald", title: "You both earn", desc: "When they make their first booking, you get $#{Referral::CREDIT_AMOUNT.to_i} credit — automatically applied to your next booking." }
          ].each do |item| %>
            <div class="flex gap-4">
              <div class="relative flex-shrink-0">
                <div class="w-8 h-8 rounded-full bg-<%= item[:color] %>-500 text-white flex items-center justify-center text-xs font-bold shadow-md shadow-<%= item[:color] %>-500/30">
                  <%= item[:num] %>
                </div>
              </div>
              <div class="flex-1 pb-1">
                <div class="flex items-center gap-2 mb-1">
                  <i class="fas <%= item[:icon] %> text-<%= item[:color] %>-500 text-xs"></i>
                  <h3 class="text-sm font-bold text-slate-900"><%= item[:title] %></h3>
                </div>
                <p class="text-sm text-slate-500 leading-relaxed"><%= item[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Referrals list %>
    <% if @referrals_sent.any? %>
      <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-8 shadow-sm">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-base font-bold text-slate-900">Your Referrals</h2>
          <span class="text-xs font-bold text-slate-400"><%= @referrals_sent.count %> total</span>
        </div>
        <div class="space-y-2">
          <% @referrals_sent.each do |ref| %>
            <div class="flex items-center justify-between p-4 rounded-xl bg-slate-50/50 border border-slate-100 hover:border-slate-200 transition-colors">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-xs font-bold text-slate-500">
                  <%= (ref.referee&.display_name || 'P')[0].upcase %>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900"><%= ref.referee&.display_name || 'Pending signup' %></div>
                  <div class="text-xs text-slate-400"><%= time_ago_in_words(ref.created_at) %> ago</div>
                </div>
              </div>
              <% status_colors = { "pending" => { bg: "amber-50", text: "amber-700" }, "completed" => { bg: "sky-50", text: "sky-700" }, "rewarded" => { bg: "emerald-50", text: "emerald-700" } } %>
              <% sc = status_colors[ref.status] || status_colors["pending"] %>
              <div class="flex items-center gap-3">
                <% if ref.rewarded? %>
                  <span class="text-sm font-bold text-emerald-600">+$<%= Referral::CREDIT_AMOUNT.to_i %></span>
                <% end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-<%= sc[:bg] %> text-<%= sc[:text] %>"><%= ref.status.titleize %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl border border-dashed border-slate-200 p-10 text-center">
        <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center mx-auto mb-3">
          <i class="fas fa-user-friends text-slate-300 text-xl"></i>
        </div>
        <h3 class="text-sm font-bold text-slate-900 mb-1">No referrals yet</h3>
        <p class="text-xs text-slate-500">Share your code above to get started.</p>
      </div>
    <% end %>
  </div>
</div>

<script>
function copyText(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    const original = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-check"></i><span>Copied!</span>';
    btn.classList.add('bg-emerald-500');
    btn.classList.remove('bg-slate-900');
    setTimeout(() => {
      btn.innerHTML = original;
      btn.classList.remove('bg-emerald-500');
      btn.classList.add('bg-slate-900');
    }, 2000);
  });
}
</script>
