<div class="min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <%# Hero — terracotta credit card %>
    <div class="relative overflow-hidden rounded-[20px] p-8 sm:p-10 mb-6 text-cream shadow-card-lg" style="background: linear-gradient(135deg, #d96a3a, #b8551c);">
      <div class="absolute -top-4 -right-4 opacity-15"><i class="fas fa-gift text-cream text-[200px]"></i></div>
      <div class="relative">
        <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-cream/85 mb-4">refer & earn</div>
        <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-cream/70 mb-2">your balance</div>
        <div class="display leading-none" style="font-size: clamp(48px, 8vw, 72px);">$<%= number_with_precision(@credit, precision: 2) %></div>
        <p class="mt-4 text-[14px] text-cream/85 leading-[1.55]">Earn $<%= Referral::CREDIT_AMOUNT.to_i %> for every friend who signs up and books.</p>
      </div>
    </div>

    <%# Code card %>
    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8 mb-5">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">your code</div>
      <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">Share to <em class="italic-wonk" style="color: #1f4d3a;">earn</em></h2>

      <div class="mb-5">
        <div class="flex items-center gap-2 p-2 rounded-pill bg-cream-sunken/50 border border-line border-dashed">
          <code class="flex-1 pl-4 font-mono text-[18px] font-bold text-ink tracking-[0.15em]"><%= @referral_code %></code>
          <button onclick="copyText(this, '<%= @referral_code %>')" class="px-5 py-2.5 rounded-pill bg-ink hover:bg-ink-2 text-cream text-[12px] font-bold transition-colors flex items-center gap-2">
            <i class="fas fa-copy text-[10px]"></i><span>Copy</span>
          </button>
        </div>
      </div>

      <div>
        <label class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1.5 block">Share link</label>
        <div class="flex items-center gap-2">
          <div class="flex-1 relative">
            <i class="fas fa-link absolute left-4 top-1/2 -translate-y-1/2 text-ink-3 text-[12px]"></i>
            <input type="text" readonly value="<%= @referral_url %>" onclick="this.select()"
                   class="w-full pl-10 pr-4 py-3 rounded-pill border border-line bg-cream-sunken/30 text-[13px] text-ink-2 font-mono cursor-text focus:outline-none focus:ring-2 focus:ring-ink/20 focus:border-ink">
          </div>
          <button onclick="copyText(this, '<%= @referral_url %>')" class="px-5 py-3 rounded-pill bg-ink hover:bg-ink-2 text-cream text-[12px] font-bold transition-colors flex items-center gap-2">
            <i class="fas fa-copy text-[10px]"></i><span>Copy</span>
          </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-3 w-full mb-1">or share on</p>
          <a href="mailto:?subject=Check out Radius&body=I've been using Radius to find local service pros. Sign up with my code <%= @referral_code %> and we both earn credit! <%= @referral_url %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-cream-sunken text-ink-2 hover:bg-line text-[12px] font-medium transition-colors">
            <i class="fas fa-envelope text-ink-3"></i>Email
          </a>
          <a href="sms:?&body=Check out Radius — I use it to find verified local pros. Sign up with <%= @referral_code %>: <%= @referral_url %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-cream-sunken text-ink-2 hover:bg-line text-[12px] font-medium transition-colors">
            <i class="fas fa-comment text-ink-3"></i>SMS
          </a>
          <a href="https://wa.me/?text=Check out Radius! Use my code <%= @referral_code %>: <%= CGI.escape(@referral_url) %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-cream-sunken text-ink-2 hover:bg-line text-[12px] font-medium transition-colors">
            <i class="fab fa-whatsapp text-ink-3"></i>WhatsApp
          </a>
          <a href="https://twitter.com/intent/tweet?text=Found a great service marketplace — Radius. Use my code <%= @referral_code %>: <%= CGI.escape(@referral_url) %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-cream-sunken text-ink-2 hover:bg-line text-[12px] font-medium transition-colors">
            <i class="fab fa-x-twitter text-ink-3"></i>X
          </a>
        </div>
      </div>
    </div>

    <%# How it works %>
    <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8 mb-5">
      <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3 mb-1">how it works</div>
      <h2 class="display text-[20px] text-ink leading-[1.1] mb-5">Three steps</h2>
      <div class="space-y-4">
        <% [
          { num: 1, title: "Share your code", desc: "Send your unique code or link to friends via email, text, or social." },
          { num: 2, title: "They sign up", desc: "New users create an account using your link." },
          { num: 3, title: "You both earn", desc: "When they make their first booking, you get $#{Referral::CREDIT_AMOUNT.to_i} credit — automatically applied next time." }
        ].each do |item| %>
          <div class="flex gap-4">
            <div class="display italic-wonk text-[36px] leading-none w-10 flex-shrink-0" style="color: #1f4d3a; font-style: italic;"><%= item[:num] %></div>
            <div class="flex-1 pt-1">
              <div class="display text-[16px] text-ink leading-[1.15]"><%= item[:title] %></div>
              <p class="mt-1 text-[13px] text-ink-2 leading-[1.55]"><%= item[:desc] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Referrals list %>
    <% if @referrals_sent.any? %>
      <div class="bg-cream-elevated border border-line rounded-xl p-6 sm:p-8">
        <div class="flex items-end justify-between mb-4">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-3">your referrals</div>
            <div class="display text-[18px] text-ink leading-[1.1]">Sent</div>
          </div>
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3"><%= @referrals_sent.count %> total</span>
        </div>
        <div class="space-y-2">
          <% @referrals_sent.each do |ref| %>
            <div class="flex items-center justify-between gap-2 p-3 rounded-lg border border-line">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 rounded-full bg-cream-sunken text-ink-2 flex items-center justify-center text-[12px] font-semibold border border-line flex-shrink-0">
                  <%= (ref.referee&.display_name || 'P')[0].upcase %>
                </div>
                <div class="min-w-0">
                  <div class="text-[13px] font-semibold text-ink truncate"><%= ref.referee&.display_name || 'Pending signup' %></div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3"><%= time_ago_in_words(ref.created_at) %> ago</div>
                </div>
              </div>
              <% sc = { "pending" => [ "bg-amber-100/60", "text-amber-800" ], "completed" => [ "bg-cream-sunken", "text-ink-2" ], "rewarded" => [ "bg-forest-soft", "text-forest" ] } %>
              <% c = sc[ref.status] || sc["pending"] %>
              <div class="flex items-center gap-2 flex-shrink-0">
                <% if ref.rewarded? %>
                  <span class="display text-[14px] text-forest leading-none">+$<%= Referral::CREDIT_AMOUNT.to_i %></span>
                <% end %>
                <span class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.08em] px-2 py-0.5 rounded-pill <%= c[0] %> <%= c[1] %>"><%= ref.status %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "fa-user-friends",
          title: "No referrals yet",
          message: "Share your code above to get started." %>
    <% end %>
  </div>
</div>

<script>
function copyText(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    const original = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-check text-[10px]"></i><span>Copied!</span>';
    setTimeout(() => { btn.innerHTML = original; }, 2000);
  });
}
</script>
